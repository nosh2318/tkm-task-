const OTA={
  S:{key:"S",name:"スカイチケット",c:"#0ea5e9",bg:"#f0f9ff",det:r=>r.join(",").includes("氏名カナ")&&r.join(",").includes("事業者名"),parse:(r,h)=>{const g=makeG(r,h);const ld=g("出発日"),rd=g("返却日"),cls=g("車両クラス"),opts=g("オプション項目"),seat=g("シート"),allOpts=[opts,seat].filter(Boolean).join(",");const ss=detectSeats(allOpts,r,h,g);const dc=detectDelCol(r,h,g);const _vc=normClass(cls);console.log("[S-CLASS]",g("予約番号"),"raw="+cls,"→"+_vc);return{ota:"S",id:g("予約番号"),name:g("氏名カナ"),lendDate:ld.split(" ")[0]?.replace(/\//g,"-"),lendTime:ld.split(" ")[1]?.substr(0,5),returnDate:rd.split(" ")[0]?.replace(/\//g,"-"),returnTime:rd.split(" ")[1]?.substr(0,5),people:+(g("ご利用人数(大人)")||0)+ +(g("ご利用人数(子供)")||0),vehicle:_vc,insurance:allOpts.includes("NOC")?"NOC":"免責",tel:g("電話番号"),mail:g("メールアドレス"),price:parsePrice(g)("合計金額"),status:isCancel(g("ステータス"),r)?"cancelled":"confirmed",visitType:dc.visitType,returnType:dc.returnType,flight:g("到着便名"),optB:ss.b,optC:ss.c,optJ:ss.j,optUSB:ss.usb};}},
