<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Expires" content="0">
<title>BUDDICA高松店 タスク管理</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.9/babel.min.js"></script>
<!-- encoding-japanese: 遅延ロード（CSVインポート時のみ） -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<!-- xlsx: 遅延ロード（インポート時のみ window.loadXlsx() で取得） -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css" rel="stylesheet">
<!-- Leaflet loaded on demand -->
<style>
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent;-webkit-user-select:text;user-select:text}
details>summary{list-style:none}details>summary::-webkit-details-marker{display:none}details[open]>summary span:first-child{transform:rotate(90deg);display:inline-block}
html,body{height:100%;overflow:hidden}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','Hiragino Kaku Gothic ProN',sans-serif;margin:0;background:#f3f4f6}
::-webkit-scrollbar{height:5px;width:5px}
::-webkit-scrollbar-thumb{background:#cbd5e1;border-radius:3px}
.fade-in{animation:fadeIn .25s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
.tl-bar{position:absolute;top:3px;bottom:3px;border-radius:4px;cursor:pointer;display:flex;align-items:center;padding:0 4px;overflow:hidden;white-space:nowrap;font-size:9px;font-weight:600;transition:opacity .2s;z-index:2}
.tl-bar:hover{opacity:.85;z-index:3}
@keyframes searchPulse{0%,100%{opacity:1}50%{opacity:.5}}
.tl-bar-hit{animation:searchPulse 1s ease-in-out infinite;z-index:15!important;outline:3px solid #facc15!important}
.top-nav{display:none;position:sticky;top:0;left:0;right:0;z-index:100;background:#1e293b;padding:4px 6px env(safe-area-inset-top,4px);box-shadow:0 2px 8px rgba(0,0,0,.12);overflow-x:auto;-webkit-overflow-scrolling:touch}
.top-nav button{flex-shrink:0;display:inline-flex;align-items:center;gap:3px;padding:6px 10px;border:none;background:transparent;cursor:pointer;font-size:11px;color:#94a3b8;transition:all .15s;border-radius:8px;font-weight:600;white-space:nowrap}
.top-nav button.active{background:#2563eb;color:#fff}
.top-nav button .ico{font-size:16px}
.sidebar{width:56px;min-width:56px;background:#1e293b;display:flex;flex-direction:column;align-items:center;padding-top:8px;gap:2px}
.sidebar button{width:44px;height:44px;border-radius:10px;border:none;background:transparent;cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#94a3b8;font-size:9px;gap:1px;transition:all .15s}
.sidebar button:hover{background:#334155;color:#e2e8f0}
.sidebar button.active{background:#2563eb;color:#fff}
.sidebar button .ico{font-size:18px}
@media(max-width:768px){.sidebar{display:none!important}.top-nav{display:flex!important}.top-nav.hide-on-top{display:none!important}.main-area{padding-top:0!important}.sync-desktop{display:none!important}}
@media(min-width:769px){.top-nav{display:none!important}.sidebar{display:flex!important}.sidebar.hide-on-top{display:none!important}}
.op-fullscreen{position:fixed;inset:0;z-index:200;background:#f3f4f6;display:flex;flex-direction:column}
.op-fullscreen .op-header{background:linear-gradient(135deg,#1e40af,#2563eb);padding:8px 12px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.op-fullscreen .op-body{flex:1;overflow:auto;padding:8px}
@media(max-width:768px){.op-fullscreen .op-body{padding:4px}}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.3);display:flex;align-items:center;justify-content:center;z-index:300;padding:12px}
.modal-box{background:#fff;border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,.15);width:100%;overflow-y:auto}
.input-s{border:1px solid #d1d5db;border-radius:8px;padding:5px 8px;font-size:12px;width:100%}
.btn-primary{background:#2563eb;color:#fff;border:none;border-radius:8px;padding:6px 16px;font-size:12px;font-weight:700;cursor:pointer}
.btn-primary:hover{background:#1d4ed8}
.btn-danger{background:#dc2626;color:#fff;border:none;border-radius:8px;padding:6px 16px;font-size:12px;font-weight:700;cursor:pointer}
.btn-ghost{background:none;border:1px solid #d1d5db;border-radius:8px;padding:6px 16px;font-size:12px;cursor:pointer;color:#374151}
.shift-grid{position:relative;overflow:auto;max-height:400px}
.shift-grid table{border-collapse:collapse}
.shift-grid th,.shift-grid td{border:1px solid #d1d5db}
.shift-grid thead th{position:sticky;top:0;z-index:2}
.shift-col{position:sticky;left:0;z-index:3;background:#fff}
.shift-col-header{position:sticky;left:0;z-index:4;background:#D2B48C}
@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
</style>
<link rel="manifest" href="data:application/json;base64,eyJuYW1lIjoiQlVERElDQemrmOadvuW6lyDjgr/jgrnjgq/nrqHnkIYiLCJzaG9ydF9uYW1lIjoiVEtNIiwic3RhcnRfdXJsIjoiLiIsImRpc3BsYXkiOiJzdGFuZGFsb25lIiwiYmFja2dyb3VuZF9jb2xvciI6IiNmM2Y0ZjYiLCJ0aGVtZV9jb2xvciI6IiMyNTYzZWIiLCJpY29ucyI6W119">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#2563eb">
</head>
<body>
<div id="root"></div>
<script>
function showErr(title,detail){
  var d=document.createElement("div");
  d.style.cssText="position:fixed;top:0;left:0;right:0;background:#fee2e2;color:#991b1b;padding:12px;font-size:12px;z-index:99999;white-space:pre-wrap;max-height:300px;overflow:auto";
  d.textContent=title+"\n"+detail;
  document.body.appendChild(d);
}
window.onerror=function(msg,src,line,col,err){
  showErr("[JS Error] "+msg,"Source: "+(src||"unknown")+"\nLine: "+line+" Col: "+col+(err&&err.stack?"\n"+err.stack:""));
};
window.addEventListener("unhandledrejection",function(e){
  var r=e.reason;
  if(r&&r.message&&r.message.indexOf("SyntaxError")>=0){showErr("[Babel Compile Error]",r.message);}
  console.error("Unhandled promise:",r);
});
</script>
<script type="text/babel">
const {useState,useMemo,useCallback,useEffect,useRef}=React;

/* ===== Supabase 設定 (BUDDICA高松店) ===== */
const SUPABASE_URL = "https://iebojjjgabjmiczmtsm.supabase.co";
const SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImllYm9qampnYWJqbWljenptdHNtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY0MTk5MzEsImV4cCI6MjA5MTk5NTkzMX0.4jFXiz0W_rCzLKnBl1u8nHgNG9WSKxSQLUw0ys-fjjg"; // anon key（RLSで保護）
const SB_ENABLED = !!(SUPABASE_URL && SUPABASE_KEY);
let sb = null;
let sbAuthReady = false;
const sbAuthPromise = (async () => {
  if (!SB_ENABLED) { sbAuthReady = true; return; }
  sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
  try {
    const { data: { session } } = await sb.auth.getSession();
    if (!session) {
      await sb.auth.signInAnonymously();
    }
  } catch (e) {
    console.warn("[Auth] Anonymous sign-in failed:", e.message);
  }
  sbAuthReady = true;
})();

/* ===== SHA-256 ハッシュ ===== */
async function sha256(str){
  const buf=await crypto.subtle.digest("SHA-256",new TextEncoder().encode(str));
  return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,"0")).join("");
}


/* ===== Supabase DB ヘルパー ===== */
function dbLog(op,ok,detail){console.log(`[DB ${ok?"✓":"✗"}] ${op}`,detail||"");}
async function fetchAllRows(table,selectCols="*"){if(!sb)return[];const PAGE=1000;let all=[];let from=0;while(true){const{data,error}=await sb.from(table).select(selectCols).range(from,from+PAGE-1);if(error){dbLog("fetchAll:"+table,false,error.message);break;}if(data)all=all.concat(data);if(!data||data.length<PAGE)break;from+=PAGE;}return all;}
const DB = {
  // --- 予約 ---
  async fetchReservations(){if(!sb)return[];const data=await fetchAllRows("tkm_reservations");dbLog("fetchRes",true,data.length+"件");return data.map(DB._fromDbRes);},
  async upsertReservations(arr){if(!sb||!arr.length)return;const rows=arr.map(DB._toDbRes);const{error}=await sb.from("tkm_reservations").upsert(rows,{onConflict:"id"});if(error)dbLog("upsertRes",false,error.message);else dbLog("upsertRes",true,arr.length+"件保存");},
  async deleteReservations(ids){if(!sb||!ids.length)return;const{error}=await sb.from("tkm_reservations").delete().in("id",ids);if(error)dbLog("deleteRes",false,error.message);else dbLog("deleteRes",true,ids.length+"件削除");},
  _toDbRes(r){return{id:r.id,ota:r.ota,name:r.name,start_date:r.lendDate,start_time:r.lendTime,end_date:r.returnDate,end_time:r.returnTime,people:r.people,vehicle_class:r.vehicle,vehicle_name:r.preferVc||"",insurance:r.insurance,tel:r.tel,mail:r.mail,price:r.price,final_price:r.finalPrice||0,status:r.status,visit_type:r.visitType,return_type:r.returnType,del_time:r.delTime||"",del_place:r.delPlace||"",col_time:r.colTime||"",col_place:r.colPlace||"",del_flight:r.flight||"",car_seat:r.optB||0,junior_seat:r.optC||0,usb:r.optUSB||0,prefecture:r.prefecture||""};},
  _fromDbRes(d){return{id:d.id,ota:d.ota,name:d.name,lendDate:norm(d.start_date),lendTime:d.start_time,returnDate:norm(d.end_date),returnTime:d.end_time,people:d.people,vehicle:d.vehicle_class,preferVc:d.vehicle_name||"",insurance:d.insurance,tel:d.tel,mail:d.mail,price:Number(d.price)||0,finalPrice:Number(d.final_price)||0,status:d.status,visitType:d.visit_type,returnType:d.return_type,delTime:d.del_time,delPlace:d.del_place,colTime:d.col_time,colPlace:d.col_place,flight:d.del_flight,optB:+(d.car_seat||0),optC:+(d.junior_seat||0),optJ:0,optUSB:+(d.usb||0),prefecture:d.prefecture||"",createdAt:d.created_at||""};},
  // --- 配車（LS併用で車両変更保護） ---
  _fleetLsKey:"tkm_fleet",
  _fleetLsSave(f){try{const cnt=Object.keys(f).filter(k=>k!=="_unassignedReasons").length;if(cnt>=10){localStorage.setItem("tkm_fleet_backup",JSON.stringify({data:f,ts:Date.now(),count:cnt}));}localStorage.setItem(DB._fleetLsKey,JSON.stringify(f));}catch(e){}},
  _fleetLsLoad(){try{const s=localStorage.getItem(DB._fleetLsKey);return s?JSON.parse(s):{};}catch(e){return{};}},
  _fleetBackupSave(f){try{const backup={data:f,ts:Date.now(),count:Object.keys(f).filter(k=>k!=="_unassignedReasons").length};localStorage.setItem("tkm_fleet_backup",JSON.stringify(backup));}catch(e){}},
  _fleetBackupLoad(){try{const s=localStorage.getItem("tkm_fleet_backup");return s?JSON.parse(s):null;}catch(e){return null;}},
  async fetchFleet(){if(!sb){return DB._fleetLsLoad();}const data=await fetchAllRows("tkm_fleet");if(!data.length){const ls=DB._fleetLsLoad();const lsCount=Object.keys(ls).filter(k=>k!=="_unassignedReasons").length;if(lsCount>0){console.warn("[fetchFleet] DB空だがlocalStorage有り("+lsCount+"件) → LS使用");}if(lsCount===0){const backup=DB._fleetBackupLoad();if(backup&&backup.count>0){console.warn("[fetchFleet] DB空+LS空 → バックアップ復元("+backup.count+"件)");return backup.data;}}return ls;}const f={};data.forEach(r=>f[r.reservation_id]=r.vehicle_code);dbLog("fetchFleet",true,Object.keys(f).length+"件");DB._fleetLsSave(f);return f;},
  async upsertFleet(fleet){DB._fleetLsSave(fleet);if(!sb)return;const rows=Object.entries(fleet).filter(([k,v])=>k!=="_unassignedReasons"&&typeof v==="string").map(([k,v])=>({reservation_id:k,vehicle_code:v}));if(rows.length){for(let i=0;i<rows.length;i+=500){const chunk=rows.slice(i,i+500);const{error}=await sb.from("tkm_fleet").upsert(chunk,{onConflict:"reservation_id"});if(error){dbLog("upsertFleet",false,error.message);return;}}dbLog("upsertFleet",true,rows.length+"件");}},
  async updateFleetOne(resId,code){if(!sb)return;const{error}=await sb.from("tkm_fleet").upsert({reservation_id:resId,vehicle_code:code},{onConflict:"reservation_id"});if(error)dbLog("updateFleet1",false,error.message);},
  async deleteFleetOne(resId){if(!sb)return;const{error}=await sb.from("tkm_fleet").delete().eq("reservation_id",resId);if(error)dbLog("deleteFleet1",false,error.message);},
  // --- Broadcast（CSV取込ロック通知） ---
  _broadcastCh: null,
  _initBroadcast() {
    if (!sb || DB._broadcastCh) return;
    DB._broadcastCh = sb.channel("tkm-broadcast");
    DB._broadcastCh.subscribe();
  },
  broadcastImportLock(locked, user) {
    if (!DB._broadcastCh) DB._initBroadcast();
    if (DB._broadcastCh) {
      DB._broadcastCh.send({ type: "broadcast", event: "import-lock", payload: { locked, user, ts: Date.now() } });
    }
  },
  // --- タスク（localStorage併用で確実に保存） ---
  _lsKey(date){return"tkm_tasks_"+date;},
  _lsSave(tasks,date){try{localStorage.setItem(DB._lsKey(date),JSON.stringify(tasks));}catch(e){}},
  _lsLoad(date){try{const s=localStorage.getItem(DB._lsKey(date));return s?JSON.parse(s):null;}catch(e){return null;}},
  _pendingSave:0,
  _hasChangedCol:null, // null=未チェック, true=あり, false=なし
  async fetchTasks(date){
    if(!sb){return DB._lsLoad(date)||[];}
    const{data,error}=await sb.from("tkm_tasks").select("*").eq("date",date).order("sort_order");
    if(error){dbLog("fetchTasks",false,error.message);return DB._lsLoad(date)||[];}
    const tasks=(data||[]).map(DB._fromDbTask);
    // ★ 保存中の場合はlocalStorageを上書きしない（保存中のデータが消えるのを防ぐ）
    if(tasks.length&&DB._pendingSave<=0)DB._lsSave(tasks,date);
    // ★ changed_jsonカラムの存在を自動検出（初回のみ）
    if(DB._hasChangedCol===null&&data&&data.length>0){
      DB._hasChangedCol="changed_json" in data[0];
      dbLog("changed_col_detect",true,DB._hasChangedCol?"あり":"なし");
    }
    return tasks;
  },
  // 3段階保存: full → mid(changed_json付きmin) → bare(changed_jsonなしmin)
  _toDbTaskBare(t,date,i){return{_id:t._id,date:date,"内容":t.type||"","時間":t.time||"","変更":t.timeChange||"","内案":t.typeChange||"","予約者":t.name||"","担当":t.assignee||"","確認":!!t.done,"メモ":t.memo||"","予約番号":t.reservationId||"","OTA":t.ota||"","TEL":t.tel||"","MAIL":t.mail||"",assigned_vehicle:t.assignedVehicle||"","No":t.plateNo||"","人数":t.people||0,"送迎場所":t.place||"","クラス":t.vehicle||"","確定":t.insurance||"","便名":t.flight||"","返却日":t.returnDate||"","返却":t.returnTime||"","送迎":t.returnType||"","集客":t.colPlace||"","B":t.opts&&t.opts.b||0,"C":t.opts&&t.opts.c||0,"J":t.opts&&t.opts.j||0,"USB":t.opts&&t.opts.usb||0,"約款":!!t.yakkan,"LINE":!!t.line,"決済":!!t.payment,sort_order:i};},
  _toDbTaskMin(t,date,i){const b=DB._toDbTaskBare(t,date,i);b.changed_json=JSON.stringify(t._changed||{});return b;},
  _dbSaveOk:true,
  // ★ 3段階フォールバック保存関数
  async _upsertWithFallback(rows,label){
    if(!sb||!rows.length)return;
    // 1) フル保存
    const{error}=await sb.from("tkm_tasks").upsert(rows,{onConflict:"_id"});
    if(!error){DB._dbSaveOk=true;DB._hasChangedCol=true;return;}
    dbLog(label,false,error.message);
    // 2) changed_jsonなしで再試行
    const bareRows=rows.map(r=>{const b={...r};delete b.changed_json;return b;});
    const{error:e2}=await sb.from("tkm_tasks").upsert(bareRows,{onConflict:"_id"});
    if(!e2){dbLog(label+"-bare",true,"ベア保存成功");DB._dbSaveOk=true;DB._hasChangedCol=false;return;}
    dbLog(label+"-bare",false,e2.message);DB._dbSaveOk=false;
  },
  async upsertTasks(tasks,date){
    DB._lsSave(tasks,date);
    if(!sb||!tasks.length)return;
    DB._pendingSave++;
    try{
      const rows=tasks.map((t,i)=>DB._toDbTask(t,date,i));
      await DB._upsertWithFallback(rows,"upsertTasks");
    }finally{DB._pendingSave--;}
  },
  async updateTask(t,date){
    const ls=DB._lsLoad(date);
    if(ls){const idx=ls.findIndex(x=>x._id===t._id);if(idx>=0){ls[idx]=t;DB._lsSave(ls,date);}else{ls.push(t);DB._lsSave(ls,date);}}
    else{DB._lsSave([t],date);}
    if(!sb)return;
    DB._pendingSave++;
    try{
      const row=DB._toDbTask(t,date,t._sortOrder||0);
      await DB._upsertWithFallback([row],"updateTask");
    }finally{DB._pendingSave--;}
  },
  async updateTaskFields(taskId, date, fieldChanges) {
    const ls = DB._lsLoad(date);
    if (ls) {
      const idx = ls.findIndex(x => x._id === taskId);
      if (idx >= 0) { Object.assign(ls[idx], fieldChanges); DB._lsSave(ls, date); }
    }
    if (!sb) return;
    const colMap = {
      type: "\u5185\u5BB9", time: "\u6642\u9593", timeChange: "\u5909\u66F4", typeChange: "\u5185\u6848",
      name: "\u4E88\u7D04\u8005", assignee: "\u62C5\u5F53", done: "\u78BA\u8A8D", memo: "\u30E1\u30E2",
      reservationId: "\u4E88\u7D04\u756A\u53F7", ota: "OTA", tel: "TEL", mail: "MAIL",
      assignedVehicle: "assigned_vehicle", plateNo: "No", people: "\u4EBA\u6570",
      place: "\u9001\u8FCE\u5834\u6240", vehicle: "\u30AF\u30E9\u30B9", insurance: "\u78BA\u5B9A", flight: "\u4FBF\u540D",
      returnDate: "\u8FD4\u5374\u65E5", returnTime: "\u8FD4\u5374", returnType: "\u9001\u8FCE", colPlace: "\u96C6\u5BA2",
      yakkan: "\u7D04\u6B3E", line: "LINE", payment: "\u6C7A\u6E08"
    };
    const dbChanges = {};
    Object.entries(fieldChanges).forEach(([k, v]) => {
      if (k === 'opts') return;
      if (k === '_changed' || k === '_timeFromSheet' || k === '_timeChangeSource' || k === '_placeSource' || k === '_ssTime' || k === '_ssPlace' || k === '_ssTimeAt' || k === '_ssPlaceAt' || k === '_manualTimeAt' || k === '_manualPlaceAt') return;
      const col = colMap[k];
      if (col) dbChanges[col] = v;
    });
    if (fieldChanges.opts) {
      if ('b' in fieldChanges.opts) dbChanges["B"] = +(fieldChanges.opts.b || 0);
      if ('c' in fieldChanges.opts) dbChanges["C"] = +(fieldChanges.opts.c || 0);
      if ('j' in fieldChanges.opts) dbChanges["J"] = +(fieldChanges.opts.j || 0);
      if ('usb' in fieldChanges.opts) dbChanges["USB"] = +(fieldChanges.opts.usb || 0);
    }
    if (fieldChanges._changed !== undefined || fieldChanges._ssTime !== undefined || fieldChanges._placeSource !== undefined) {
      const lsNow = DB._lsLoad(date);
      const t = lsNow ? lsNow.find(x => x._id === taskId) : null;
      if (t) {
        dbChanges.changed_json = JSON.stringify({
          ...(t._changed || {}),
          _timeFromSheet: !!t._timeFromSheet,
          _timeChangeSource: t._timeChangeSource || "",
          _placeSource: t._placeSource || "",
          _ssTime: t._ssTime || "", _ssPlace: t._ssPlace || "",
          _ssTimeAt: t._ssTimeAt || "", _ssPlaceAt: t._ssPlaceAt || "",
          _manualTimeAt: t._manualTimeAt || "", _manualPlaceAt: t._manualPlaceAt || ""
        });
      }
    }
    if (!Object.keys(dbChanges).length) return;
    const { error } = await sb.from("tkm_tasks").update(dbChanges).eq("_id", taskId);
    if (error) dbLog("updateTaskFields", false, error.message);
    else dbLog("updateTaskFields", true, taskId + " " + Object.keys(dbChanges).join(","));
  },
  async deleteTasks(date){try{localStorage.removeItem(DB._lsKey(date));}catch(e){} if(!sb)return;const{error}=await sb.from("tkm_tasks").delete().eq("date",date);if(error)dbLog("deleteTasks",false,error.message);},
  async deleteTask(id,date){if(!sb)return;const{error}=await sb.from("tkm_tasks").delete().eq("_id",id);if(error)dbLog("deleteTask",false,error.message);else dbLog("deleteTask",true,id);try{const ls=DB._lsLoad(date);if(ls){const next=ls.filter(t=>t._id!==id);localStorage.setItem(DB._lsKey(date),JSON.stringify(next));}}catch(e){}},
  async fetchTasksRange(fromDate,toDate){if(!sb)return[];const{data,error}=await sb.from("tkm_tasks").select("*").gte("date",fromDate).lte("date",toDate).order("date",{ascending:false}).order("sort_order").limit(5000);if(error){dbLog("fetchTasksRange",false,error.message);return[];}return(data||[]).map(r=>({...DB._fromDbTask(r),_date:r.date}));},
  _toDbTask(t,date,i){return{_id:t._id,date:date,"内容":t.type||"","時間":t.time||"","変更":t.timeChange||"","内案":t.typeChange||"","予約者":t.name||"","担当":t.assignee||"","確認":!!t.done,"メモ":t.memo||"","予約番号":t.reservationId||"","OTA":t.ota||"","TEL":t.tel||"","MAIL":t.mail||"",assigned_vehicle:t.assignedVehicle||"","No":t.plateNo||"","人数":t.people||0,"送迎場所":t.place||"","クラス":t.vehicle||"","確定":t.insurance||"","便名":t.flight||"","返却日":t.returnDate||"","返却":t.returnTime||"","送迎":t.returnType||"","集客":t.colPlace||"","B":+(t.opts?.b||0),"C":+(t.opts?.c||0),"J":+(t.opts?.j||0),"USB":+(t.opts?.usb||0),"約款":!!t.yakkan,"LINE":!!t.line,"決済":!!t.payment,sort_order:i,changed_json:JSON.stringify({...(t._changed||{}),_timeFromSheet:!!t._timeFromSheet,_timeChangeSource:t._timeChangeSource||"",_placeSource:t._placeSource||"",_ssTime:t._ssTime||"",_ssPlace:t._ssPlace||"",_ssTimeAt:t._ssTimeAt||"",_ssPlaceAt:t._ssPlaceAt||"",_manualTimeAt:t._manualTimeAt||"",_manualPlaceAt:t._manualPlaceAt||"",_manual:!!t.manual})};},
  _fromDbTask(d){const ch=(()=>{try{const p=JSON.parse(d.changed_json||"{}");return Object.keys(p).length?p:undefined;}catch(e){return undefined;}})();const tfs=ch&&ch._timeFromSheet;const tcs=ch&&ch._timeChangeSource;const ps=ch&&ch._placeSource;const sst=ch&&ch._ssTime;const ssp=ch&&ch._ssPlace;const sstAt=ch&&ch._ssTimeAt;const sspAt=ch&&ch._ssPlaceAt;const mtAt=ch&&ch._manualTimeAt;const mpAt=ch&&ch._manualPlaceAt;const isManual=ch&&ch._manual;if(ch){delete ch._timeFromSheet;delete ch._timeChangeSource;delete ch._placeSource;delete ch._ssTime;delete ch._ssPlace;delete ch._ssTimeAt;delete ch._ssPlaceAt;delete ch._manualTimeAt;delete ch._manualPlaceAt;delete ch._manual;}return{_id:d._id,type:d["内容"],time:d["時間"],name:d["予約者"],assignee:d["担当"],done:d["確認"]===true||d["確認"]==="true",memo:d["メモ"],reservationId:d["予約番号"],ota:d["OTA"],tel:d["TEL"],mail:d["MAIL"],assignedVehicle:d.assigned_vehicle,plateNo:d["No"],people:d["人数"],place:d["送迎場所"],vehicle:d["クラス"],insurance:d["確定"],insuranceChange:"",timeChange:d["変更"]||"",typeChange:d["内案"]||"",flight:d["便名"],returnDate:norm(d["返却日"]),returnTime:d["返却"],returnType:d["送迎"],colPlace:d["集客"],opts:{b:+(d["B"]||0),c:+(d["C"]||0),j:+(d["J"]||0),usb:+(d["USB"]||0)},yakkan:d["約款"]===true||d["約款"]==="true",line:d["LINE"]===true||d["LINE"]==="true",payment:d["決済"]===true||d["決済"]==="true",_sortOrder:d.sort_order,_assigneeCustom:false,_timeChanged:false,_changed:ch,_timeFromSheet:!!tfs,_timeChangeSource:tcs||"",_placeSource:ps||"",_ssTime:sst||"",_ssPlace:ssp||"",_ssTimeAt:sstAt||"",_ssPlaceAt:sspAt||"",_manualTimeAt:mtAt||"",_manualPlaceAt:mpAt||"",manual:!!isManual};},
  // --- 予約変更管理 ---
  async updateReservationField(resId,changes,changeType,source){
    if(!sb||!resId)return;
    try{
      const{data:cur}=await sb.from("tkm_reservations").select("*").eq("id",resId).single();
      const colMap={lendTime:"start_time",returnTime:"end_time",delTime:"del_time",colTime:"col_time",
        delPlace:"del_place",colPlace:"col_place",vehicle:"vehicle_class",insurance:"insurance",
        optB:"car_seat",optC:"junior_seat",optUSB:"usb",visitType:"visit_type",returnType:"return_type",
        lendDate:"start_date",returnDate:"end_date",flight:"del_flight",people:"people",price:"price"};
      const dbChanges={};
      Object.entries(changes).forEach(([k,v])=>{const col=colMap[k]||k;dbChanges[col]=v;});
      const{error}=await sb.from("tkm_reservations").update(dbChanges).eq("id",resId);
      if(error){dbLog("updateResField",false,error.message);return;}
      dbLog("updateResField",true,resId+" "+changeType);
      if(cur){
        const logs=[];
        Object.entries(dbChanges).forEach(([col,newVal])=>{
          const oldVal=cur[col];
          if(String(oldVal||"")!==String(newVal||"")){
            logs.push({reservation_id:resId,change_type:changeType,field_name:col,
              old_value:String(oldVal||""),new_value:String(newVal||""),source:source||"op_sheet"});
          }
        });
        if(logs.length){
          sb.from("tkm_reservation_changes").insert(logs).then(({error:e2})=>{
            if(e2)dbLog("resChanges",false,e2.message);
            else dbLog("resChanges",true,logs.length+"件記録");
          });
        }
      }
    }catch(e){console.error("[updateResField]",e);}
  },
  async fetchReservationChanges(resId){
    if(!sb)return[];
    const{data,error}=await sb.from("tkm_reservation_changes").select("*").eq("reservation_id",resId).order("changed_at",{ascending:false}).limit(50);
    if(error){dbLog("fetchResChanges",false,error.message);return[];}
    return data||[];
  },
  // --- スタッフ ---
  _staffLsKey:"tkm_staff_backup",
  _staffLsSave(arr){try{localStorage.setItem(DB._staffLsKey,JSON.stringify(arr));}catch(e){}},
  _staffLsLoad(){try{const s=localStorage.getItem(DB._staffLsKey);return s?JSON.parse(s):null;}catch(e){return null;}},
  async fetchStaff(){if(!sb)return DB._staffLsLoad();const{data,error}=await sb.from("tkm_staff").select("*").order("sort_order");if(error){dbLog("fetchStaff",false,error.message);return DB._staffLsLoad();}dbLog("fetchStaff",true,data.length+"件");
    // カラム存在チェック
    const hasWageCols=data.length>0&&data[0].hasOwnProperty("hourly_wage");
    DB._staffHasWageCols=hasWageCols;
    if(!hasWageCols&&data.length>0)console.warn("[fetchStaff] ⚠️ staffテーブルにhourly_wageカラムなし");
    const dbStaff=(data||[]).map(s=>({name:s.name,type:s.type,memo:s.memo||"",hourlyWage:s.hourly_wage||0,transportCost:s.transport_cost||0,monthlySalary:s.monthly_salary||0}));
    // DB側にhourly_wage等カラムがない場合、localStorageの値をマージ→差異あればDBに自動プッシュ
    const lsStaff=DB._staffLsLoad();
    let needPush=false;
    if(lsStaff&&lsStaff.length>0){
      const lsMap={};lsStaff.forEach(s=>{lsMap[s.name]=s;});
      dbStaff.forEach(s=>{const ls=lsMap[s.name];if(ls){
        if(!s.hourlyWage&&ls.hourlyWage){s.hourlyWage=ls.hourlyWage;needPush=true;}
        if(!s.transportCost&&ls.transportCost){s.transportCost=ls.transportCost;needPush=true;}
        if(!s.monthlySalary&&ls.monthlySalary){s.monthlySalary=ls.monthlySalary;needPush=true;}
      }});
    }
    DB._staffLsSave(dbStaff);
    // LSから補完したデータがあればDBに自動保存（他デバイスにも反映）
    if(needPush&&hasWageCols){console.log("[staffSync] LS→DB push: wage data merged");DB.saveStaff(dbStaff).catch(e=>console.error("[staffSync]",e));}
    return dbStaff;},
  _staffHasWageCols:null, // null=未確認, true=あり, false=なし
  async saveStaff(arr){DB._staffLsSave(arr);if(!sb)return;
    const rows=arr.map((s,i)=>({name:s.name,type:s.type,memo:s.memo||"",sort_order:i,active:true,hourly_wage:s.hourlyWage||0,transport_cost:s.transportCost||0,monthly_salary:s.monthlySalary||0}));
    const{error}=await sb.from("tkm_staff").upsert(rows,{onConflict:"name"});
    if(error){
      dbLog("saveStaff",false,error.message);
      // カラム不在エラーの場合、給与カラムなしでリトライ
      if(error.message&&(error.message.includes("hourly_wage")||error.message.includes("transport_cost")||error.message.includes("monthly_salary")||error.message.includes("column"))){
        DB._staffHasWageCols=false;
        console.warn("[saveStaff] 給与カラムなし→カラムなしで再保存");
        const rows2=arr.map((s,i)=>({name:s.name,type:s.type,memo:s.memo||"",sort_order:i,active:true}));
        const{error:e2}=await sb.from("tkm_staff").upsert(rows2,{onConflict:"name"});
        if(e2)dbLog("saveStaff(retry)",false,e2.message);
        else dbLog("saveStaff(retry)",true,arr.length+"件(給与カラムなし)");
      }
    }else{DB._staffHasWageCols=true;dbLog("saveStaff",true,arr.length+"件保存");}
  },
  async deleteStaff(name){if(!sb)return;const{error}=await sb.from("tkm_staff").delete().eq("name",name);if(error)dbLog("deleteStaff",false,error.message);else dbLog("deleteStaff",true,name);},
  // --- 時給履歴 ---
  async fetchWageHistory(){if(!sb)return[];const{data,error}=await sb.from("tkm_wage_history").select("*").order("effective_date",{ascending:true});if(error){dbLog("fetchWageHist",false,error.message);return[];}dbLog("fetchWageHist",true,(data||[]).length+"件");return data||[];},
  async saveWageHistory(rec){if(!sb)return;const{error}=await sb.from("tkm_wage_history").upsert(rec,{onConflict:"id"});if(error)dbLog("saveWageHist",false,error.message);else dbLog("saveWageHist",true,rec.staff_name);},
  async deleteWageHistory(id){if(!sb)return;const{error}=await sb.from("tkm_wage_history").delete().eq("id",id);if(error)dbLog("delWageHist",false,error.message);else dbLog("delWageHist",true,id);},
  // 特定日のスタッフ時給を取得（履歴から逆順で最初にマッチするものを返す）
  getWageForDate(wageHistory,staffName,date){
    const entries=(wageHistory||[]).filter(w=>w.staff_name===staffName&&w.effective_date<=date).sort((a,b)=>b.effective_date.localeCompare(a.effective_date));
    return entries.length>0?entries[0].hourly_wage:null;
  },
  // --- 車両 ---
  async fetchVehicles(){if(!sb)return null;const{data,error}=await sb.from("tkm_vehicles").select("*");if(error){dbLog("fetchVehicles",false,error.message);return null;}dbLog("fetchVehicles",true,data.length+"件");return(data||[]).map(v=>({id:v.code,code:v.code,name:v.name,no:v.plate_no,type:v.type,seats:v.seats,active:v.active!==false}));},
  async saveVehicles(arr){if(!sb)return;const rows=arr.map(v=>({code:v.code,name:v.name,plate_no:v.no,type:v.type,seats:v.seats,active:v.active!==false}));const{error}=await sb.from("tkm_vehicles").upsert(rows,{onConflict:"code"});if(error)dbLog("saveVehicles",false,error.message);else dbLog("saveVehicles",true,arr.length+"件保存");},
  async deleteVehicle(code){if(!sb)return;const{error}=await sb.from("tkm_vehicles").delete().eq("code",code);if(error)dbLog("deleteVehicle",false,error.message);else dbLog("deleteVehicle",true,code);},
  // --- シフト ---
  _shiftsLsKey:"tkm_shifts_backup",
  _shiftsLsSave(obj){try{localStorage.setItem(DB._shiftsLsKey,JSON.stringify(obj));}catch(e){}},
  _shiftsLsLoad(){try{const s=localStorage.getItem(DB._shiftsLsKey);return s?JSON.parse(s):null;}catch(e){return null;}},
  async fetchShifts(){if(!sb){return DB._shiftsLsLoad();}const{data}=await sb.from("tkm_shifts").select("*").limit(5000);const s={};(data||[]).forEach(r=>{if(!s[r.date])s[r.date]=[];s[r.date].push({name:r.staff_name,symbol:r.symbol,start:r.start_time,end:r.end_time,memo:r.memo,status:r.status||"確定"});});DB._shiftsLsSave(s);return s;},
  async saveShift(date,staffName,shift){if(!sb)return;await sb.from("tkm_shifts").upsert({date,staff_name:staffName,symbol:shift.symbol||"",start_time:shift.start||"",end_time:shift.end||"",memo:shift.memo||"",status:shift.status||"確定"},{onConflict:"date,staff_name"});},
  async _shiftsLsSaveAll(){},
  async saveShiftsForDate(date,shifts){if(!sb)return;const rows=shifts.map(s=>({date,staff_name:s.name,symbol:s.symbol||"",start_time:s.start||"",end_time:s.end||"",memo:s.memo||"",status:s.status||"確定"}));await sb.from("tkm_shifts").upsert(rows,{onConflict:"date,staff_name"});},
  async deleteShift(date,staffName){if(!sb)return;const{error}=await sb.from("tkm_shifts").delete().eq("date",date).eq("staff_name",staffName);if(error)dbLog("deleteShift",false,error.message);else dbLog("deleteShift",true,date+"/"+staffName);},
  async deleteShiftsMonth(ym){if(!sb)return;const{error}=await sb.from("tkm_shifts").delete().like("date",ym+"-%");if(error)dbLog("deleteShiftsMonth",false,error.message);else dbLog("deleteShiftsMonth",true,ym);},
  // --- 勤怠 ---
  async fetchAttendance(){if(!sb)return{};try{const{data,error}=await sb.from("tkm_attendance").select("*").limit(5000);if(error){console.warn("[attendance] fetch error (テーブル未作成?):",error.message);return{};}const a={};(data||[]).forEach(r=>{const k=r.date+"_"+r.staff_name;a[k]={date:r.date,name:r.staff_name,start:r.start_time||"",end:r.end_time||"",approved:!!r.approved,memo:r.memo||"",absent:!!r.absent};});return a;}catch(e){console.warn("[attendance]",e);return{};}},
  async saveAttendance(rec){if(!sb)return;try{await sb.from("tkm_attendance").upsert({date:rec.date,staff_name:rec.name,start_time:rec.start||"",end_time:rec.end||"",approved:rec.approved||false,memo:rec.memo||"",absent:!!rec.absent},{onConflict:"date,staff_name"});}catch(e){console.warn("[att save]",e);}},
  async saveAttendanceBatch(recs){if(!sb)return;try{const rows=recs.map(r=>({date:r.date,staff_name:r.name,start_time:r.start||"",end_time:r.end||"",approved:r.approved||false,memo:r.memo||"",absent:!!r.absent}));await sb.from("tkm_attendance").upsert(rows,{onConflict:"date,staff_name"});}catch(e){console.warn("[att batch]",e);}},
  // --- 打刻 ---
  SLACK_PUNCH_WEBHOOK:"",
  async sendPunchSlack(store,name,type,req,now){try{if(!DB.SLACK_PUNCH_WEBHOOK)return;await fetch(DB.SLACK_PUNCH_WEBHOOK,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({text:`⚠️ *打刻仮申請*\n店舗:${store} スタッフ:${name}\n種別:${type==="in"?"出勤":"退勤"} 申請時刻:*${req}*（打刻時点:${now}）\n給与計算タブで確認してください`})});}catch(e){}},
  async punchIn(staffName,timeStr,isProvisional){if(!sb)return;try{const today=new Date().toLocaleDateString("sv-SE",{timeZone:"Asia/Tokyo"});const now=timeStr||new Date().toLocaleTimeString("ja-JP",{hour:"2-digit",minute:"2-digit",hour12:false,timeZone:"Asia/Tokyo"});const{data}=await sb.from("tkm_attendance").select("*").eq("date",today).eq("staff_name",staffName).maybeSingle();if(data&&data.start_time&&["打刻中","打刻","仮申請"].includes(data.memo))throw new Error("既に出勤打刻済みです");const memo=isProvisional?"仮申請":"打刻中";await sb.from("tkm_attendance").upsert({date:today,staff_name:staffName,start_time:now,end_time:data?.end_time||"",approved:!isProvisional,memo,absent:false},{onConflict:"date,staff_name"});}catch(e){throw e;}},
  async punchOut(staffName,timeStr,isProvisional){if(!sb)return;try{const today=new Date().toLocaleDateString("sv-SE",{timeZone:"Asia/Tokyo"});const now=timeStr||new Date().toLocaleTimeString("ja-JP",{hour:"2-digit",minute:"2-digit",hour12:false,timeZone:"Asia/Tokyo"});const{data}=await sb.from("tkm_attendance").select("*").eq("date",today).eq("staff_name",staffName).maybeSingle();if(data?.memo==="打刻"&&data?.end_time)throw new Error("既に退勤打刻済みです");await sb.from("tkm_attendance").upsert({date:today,staff_name:staffName,start_time:data?.start_time||"",end_time:now,approved:!isProvisional,memo:isProvisional?"仮申請":"打刻",absent:false},{onConflict:"date,staff_name"});}catch(e){throw e;}},
  async getTodayPunch(staffName){if(!sb)return null;try{const today=new Date().toLocaleDateString("sv-SE",{timeZone:"Asia/Tokyo"});const{data}=await sb.from("tkm_attendance").select("*").eq("date",today).eq("staff_name",staffName).in("memo",["打刻中","打刻","仮申請"]).maybeSingle();if(!data)return null;const isPunchedOut=data.memo==="打刻";return{start:data.start_time||"",end:isPunchedOut?data.end_time||"":"",approved:!!data.approved};}catch(e){return null;}},
  // --- 申し送りBOX ---
  async fetchMemos(fromDate){if(!sb)return[];try{const{data}=await sb.from("tkm_memos").select("*").gte("target_date",fromDate).order("created_at",{ascending:true});return data||[];}catch(e){return[];}},
  async postMemo(content,targetDate,imageUrl){if(!sb||(!(content||"").trim()&&!imageUrl))return;const row={content:(content||"").trim(),target_date:targetDate,done:false};if(imageUrl)row.image_url=imageUrl;await sb.from("tkm_memos").insert(row);},
  async toggleMemoDone(id,done){if(!sb)return;await sb.from("tkm_memos").update({done:!done}).eq("id",id);},
  async deleteMemo(id){if(!sb)return;await sb.from("tkm_memos").delete().eq("id",id);},
  async uploadMemoImage(file){
    if(!sb)throw new Error("no sb");
    const compressed=await new Promise((resolve)=>{
      const reader=new FileReader();
      reader.onload=(e)=>{
        const img=new Image();
        img.onload=()=>{
          const canvas=document.createElement("canvas");
          let w=img.width,h=img.height,max=1200;
          if(w>max){h=Math.round(h*max/w);w=max;}
          canvas.width=w;canvas.height=h;
          canvas.getContext("2d").drawImage(img,0,0,w,h);
          canvas.toBlob(resolve,"image/jpeg",0.75);
        };
        img.src=e.target.result;
      };
      reader.readAsDataURL(file);
    });
    const fname="nha/"+Date.now()+".jpg";
    const{error}=await sb.storage.from("memo-images").upload(fname,compressed,{contentType:"image/jpeg",upsert:false});
    if(error)throw error;
    const{data:{publicUrl}}=sb.storage.from("memo-images").getPublicUrl(fname);
    return publicUrl;
  },
  // --- メンテナンス ---
  _maintLsKey:"tkm_maintenance",
  _maintLsLoad(){try{return JSON.parse(localStorage.getItem(DB._maintLsKey)||"[]")}catch(e){return[];}},
  _maintLsSave(arr){try{localStorage.setItem(DB._maintLsKey,JSON.stringify(arr));}catch(e){}},
  async fetchMaintenance(){
    if(!sb){return DB._maintLsLoad();}
    const{data,error}=await sb.from("tkm_maintenance").select("*");if(error){dbLog("fetchMaint",false,error.message);return DB._maintLsLoad();}
    const result=(data||[]).map(m=>({id:m.id,vehicleCode:m.vehicle_code,startDate:m.start_date,endDate:m.end_date,label:m.label||""}));
    // Supabaseが権威: DBの結果でlocalStorageを上書き（削除済みブロックの復活を防止）
    DB._maintLsSave(result);
    dbLog("fetchMaint",true,result.length+"件");
    return result;
  },
  async saveMaintenance(arr){
    const mapped=arr.map(m=>({id:m.id,vehicleCode:m.vehicleCode,startDate:m.startDate,endDate:m.endDate,label:m.label||""}));
    // localStorage更新（既存+新規をマージ）
    const ls=DB._maintLsLoad();const idSet=new Set(ls.map(m=>m.id));
    mapped.forEach(m=>{if(idSet.has(m.id)){const idx=ls.findIndex(x=>x.id===m.id);if(idx>=0)ls[idx]=m;}else ls.push(m);});
    DB._maintLsSave(ls);
    if(!sb)return;const rows=arr.map(m=>({id:m.id,vehicle_code:m.vehicleCode,start_date:m.startDate,end_date:m.endDate,label:m.label||""}));if(rows.length){const{error}=await sb.from("tkm_maintenance").upsert(rows,{onConflict:"id"});if(error)dbLog("saveMaint",false,error.message);else dbLog("saveMaint",true,rows.length+"件");}
  },
  async deleteMaintenance(id){
    const ls=DB._maintLsLoad().filter(m=>m.id!==id);DB._maintLsSave(ls);
    if(!sb)return;const{error}=await sb.from("tkm_maintenance").delete().eq("id",id);if(error)dbLog("delMaint",false,error.message);else dbLog("delMaint",true,id);
  },
  async clearAllMaintenance(){DB._maintLsSave([]);if(!sb)return;await sb.from("tkm_maintenance").delete().neq("id","__never__");},
  // --- 場所 ---
  async upsertPlaces(places){if(!sb)return;const rows=Object.entries(places).map(([k,v])=>({reservation_id:k,del_place:v.delPlace||"",col_place:v.colPlace||""}));if(rows.length)await sb.from("tkm_places").upsert(rows,{onConflict:"reservation_id"});},
  async fetchPlaces(){if(!sb)return{};const{data}=await sb.from("tkm_places").select("*");const p={};(data||[]).forEach(r=>p[r.reservation_id]={delPlace:r.del_place,colPlace:r.col_place});return p;},
  // --- じゃらん決済 ---
  _jalanPayLS:"tkm_jalan_payment",
  jalanPayLsSave(d){try{localStorage.setItem(DB._jalanPayLS,JSON.stringify(d));}catch(e){}},
  jalanPayLsLoad(){try{const s=localStorage.getItem(DB._jalanPayLS);return s?JSON.parse(s):{};}catch(e){return{};}},
  async fetchJalanPayment(){if(!sb){return DB.jalanPayLsLoad();}
    // テーブル自動作成
    try{await sb.rpc("exec_sql",{query:"CREATE TABLE IF NOT EXISTS tkm_jalan_payment (reservation_id text PRIMARY KEY, category text DEFAULT '売上', pay_status text DEFAULT '未完了', send_date text DEFAULT '', refund_date text DEFAULT '', content text DEFAULT '', link_url text DEFAULT '', adjusted_price text DEFAULT '', created_at timestamptz DEFAULT now())"});}catch(e){}
    try{await sb.rpc("exec_sql",{query:"ALTER TABLE tkm_reservations ADD COLUMN IF NOT EXISTS final_price numeric DEFAULT 0"});}catch(e){}
    try{await sb.rpc("exec_sql",{query:"ALTER TABLE tkm_jalan_payment ENABLE ROW LEVEL SECURITY"});}catch(e){}
    try{await sb.rpc("exec_sql",{query:"DO $$ BEGIN IF NOT EXISTS (SELECT 1 FROM pg_policies WHERE tablename='tkm_jalan_payment') THEN CREATE POLICY tkm_jalan_payment_all ON tkm_jalan_payment FOR ALL USING (true) WITH CHECK (true); END IF; END $$"});}catch(e){}
    // LS→SB同期
    const lsData=DB.jalanPayLsLoad();
    const lsEntries=Object.entries(lsData);
    if(lsEntries.length>0){
      for(const[resId,d] of lsEntries){
        const row={reservation_id:resId,category:d.category||"売上",pay_status:d.payStatus||"未完了",send_date:d.sendDate||"",refund_date:d.refundDate||"",content:d.content||"",link_url:d.linkUrl||"",adjusted_price:d.adjustedPrice||""};
        try{await sb.from("tkm_jalan_payment").upsert(row,{onConflict:"reservation_id"});}catch(e){}
      }
      dbLog("fetchJalanPay",true,"LS→SB同期: "+lsEntries.length+"件");
    }
    const{data,error}=await sb.from("tkm_jalan_payment").select("*");if(error){dbLog("fetchJalanPay",false,error.message);return DB.jalanPayLsLoad();}dbLog("fetchJalanPay",true,(data||[]).length+"件");const m={};(data||[]).forEach(r=>{m[r.reservation_id]={category:r.category||"売上",payStatus:r.pay_status||"未完了",sendDate:r.send_date||"",refundDate:r.refund_date||"",content:r.content||"",linkUrl:r.link_url||"",adjustedPrice:r.adjusted_price||""};});DB.jalanPayLsSave(m);return m;},
  async saveJalanPayment(resId,d){DB.jalanPayLsSave({...DB.jalanPayLsLoad(),[resId]:d});if(!sb)return;const row={reservation_id:resId,category:d.category||"売上",pay_status:d.payStatus||"未完了",send_date:d.sendDate||"",refund_date:d.refundDate||"",content:d.content||"",link_url:d.linkUrl||"",adjusted_price:d.adjustedPrice||""};const{error}=await sb.from("tkm_jalan_payment").upsert(row,{onConflict:"reservation_id"});if(error)dbLog("saveJalanPay",false,error.message);else dbLog("saveJalanPay",true,resId);},
  // --- 会計（現金出納帳＋予約外売上） ---
  _acctLsKey:"tkm_accounting",
  _acctLsLoad(){try{return JSON.parse(localStorage.getItem(DB._acctLsKey)||"[]");}catch(e){return[];}},
  _acctLsSave(arr){try{localStorage.setItem(DB._acctLsKey,JSON.stringify(arr));}catch(e){}},
  _acctMigrated:false,
  async _acctMigrate(){
    if(DB._acctMigrated||!sb)return;DB._acctMigrated=true;
    // テーブルが存在しない場合は作成
    try{await sb.rpc("exec_sql",{query:"CREATE TABLE IF NOT EXISTS tkm_accounting (id text PRIMARY KEY, date text, type text, category text, sub_category text DEFAULT '', description text DEFAULT '', amount integer DEFAULT 0, input_by text DEFAULT '', memo text DEFAULT '', pay_method text DEFAULT '', resv_no text DEFAULT '', url text DEFAULT '', paid boolean DEFAULT false, staff_name text DEFAULT '', user_name text DEFAULT '', payee text DEFAULT '', pay_content text DEFAULT '', created_at timestamptz DEFAULT now())"});}catch(e){dbLog("acctMigrate","createTable",e.message);}
    // RLSポリシー追加（既存なら無視）
    try{await sb.rpc("exec_sql",{query:"ALTER TABLE tkm_accounting ENABLE ROW LEVEL SECURITY"});}catch(e){}
    try{await sb.rpc("exec_sql",{query:"DO $$ BEGIN IF NOT EXISTS (SELECT 1 FROM pg_policies WHERE tablename='tkm_accounting' AND policyname='tkm_accounting_all') THEN CREATE POLICY tkm_accounting_all ON tkm_accounting FOR ALL USING (true) WITH CHECK (true); END IF; END $$"});}catch(e){}
    // 既存テーブルにカラム追加
    const cols=["pay_method text DEFAULT ''","resv_no text DEFAULT ''","url text DEFAULT ''","paid boolean DEFAULT false","staff_name text DEFAULT ''","user_name text DEFAULT ''","payee text DEFAULT ''","pay_content text DEFAULT ''"];
    for(const c of cols){
      try{await sb.rpc("exec_sql",{query:"ALTER TABLE tkm_accounting ADD COLUMN IF NOT EXISTS "+c});}catch(e){}
    }
  },
  async fetchAccounting(){
    if(!sb){return DB._acctLsLoad();}
    await DB._acctMigrate();
    const{data,error}=await sb.from("tkm_accounting").select("*").order("date",{ascending:false}).limit(5000);
    if(error){dbLog("fetchAcct",false,error.message);return DB._acctLsLoad();}
    const result=(data||[]).map(r=>({id:r.id,date:r.date,type:r.type,category:r.category,subCategory:r.sub_category||"",description:r.description||"",amount:r.amount||0,inputBy:r.input_by||"",memo:r.memo||"",payMethod:r.pay_method||"",resvNo:r.resv_no||"",url:r.url||"",paid:!!r.paid,staffName:r.staff_name||"",userName:r.user_name||"",payee:r.payee||"",payContent:r.pay_content||"",createdAt:r.created_at||""}));
    // localStorage→Supabase同期: LSにあってSBにない or 金額が異なるレコードをアップロード
    const lsData=DB._acctLsLoad();
    const sbIds=new Set(result.map(r=>r.id));
    const toSync=lsData.filter(r=>r.id&&(!sbIds.has(r.id)||(()=>{const sbr=result.find(x=>x.id===r.id);return sbr&&sbr.amount!==r.amount;})()));
    if(toSync.length>0){
      dbLog("fetchAcct",true,"LS→SB同期: "+toSync.length+"件");
      for(const rec of toSync){
        const row={id:rec.id,date:rec.date,type:rec.type,category:rec.category,sub_category:rec.subCategory||"",description:rec.description||"",amount:rec.amount||0,input_by:rec.inputBy||"",memo:rec.memo||"",pay_method:rec.payMethod||"",resv_no:rec.resvNo||"",url:rec.url||"",paid:!!rec.paid,staff_name:rec.staffName||"",user_name:rec.userName||"",payee:rec.payee||"",pay_content:rec.payContent||""};
        await sb.from("tkm_accounting").upsert(row,{onConflict:"id"}).then(()=>{}).catch(()=>{});
      }
      // 再取得
      const{data:d2}=await sb.from("tkm_accounting").select("*").order("date",{ascending:false}).limit(5000);
      if(d2){
        const r2=d2.map(r=>({id:r.id,date:r.date,type:r.type,category:r.category,subCategory:r.sub_category||"",description:r.description||"",amount:r.amount||0,inputBy:r.input_by||"",memo:r.memo||"",payMethod:r.pay_method||"",resvNo:r.resv_no||"",url:r.url||"",paid:!!r.paid,staffName:r.staff_name||"",userName:r.user_name||"",payee:r.payee||"",payContent:r.pay_content||"",createdAt:r.created_at||""}));
        DB._acctLsSave(r2);dbLog("fetchAcct",true,"同期後: "+r2.length+"件");return r2;
      }
    }
    DB._acctLsSave(result);dbLog("fetchAcct",true,result.length+"件");return result;
  },
  async saveAccounting(rec){
    const ls=DB._acctLsLoad();const idx=ls.findIndex(r=>r.id===rec.id);
    if(idx>=0)ls[idx]=rec;else ls.unshift(rec);DB._acctLsSave(ls);
    if(!sb)return;
    const row={id:rec.id,date:rec.date,type:rec.type,category:rec.category,sub_category:rec.subCategory||"",description:rec.description||"",amount:rec.amount||0,input_by:rec.inputBy||"",memo:rec.memo||"",pay_method:rec.payMethod||"",resv_no:rec.resvNo||"",url:rec.url||"",paid:!!rec.paid,staff_name:rec.staffName||"",user_name:rec.userName||"",payee:rec.payee||"",pay_content:rec.payContent||""};
    const{error}=await sb.from("tkm_accounting").upsert(row,{onConflict:"id"});
    if(error)dbLog("saveAcct",false,error.message);else dbLog("saveAcct",true,rec.id);
  },
  async deleteAccounting(id){
    const ls=DB._acctLsLoad().filter(r=>r.id!==id);DB._acctLsSave(ls);
    if(!sb)return;const{error}=await sb.from("tkm_accounting").delete().eq("id",id);
    if(error)dbLog("delAcct",false,error.message);else dbLog("delAcct",true,id);
  },
  // --- 認証 ---
  async checkPassword(pw){if(!sb)return true;const{data}=await sb.from("tkm_app_settings").select("value").eq("key","team_password").single();if(!data||!data.value){if(pw==="BD2026"){await sb.from("tkm_app_settings").upsert({key:"team_password",value:pw},{onConflict:"key"});return true;}return false;}const hash=await sha256(pw);if(data.value.length===64)return data.value===hash;return data.value===pw;},
  // --- 編集ログ ---
  async fetchEditLogs(date){
    if(!sb)return[];
    const{data,error}=await sb.from("tkm_edit_log").select("*").eq("date",date).order("created_at",{ascending:false}).limit(500);
    if(error){console.warn("[editLog] fetch:",error.message);return[];}
    return data||[];
  },
  async addEditLog(entry){
    if(!sb)return;
    const row={id:"elog_"+Date.now()+"_"+Math.random().toString(36).slice(2,6),date:entry.date,task_id:entry.taskId,task_name:entry.taskName||"",field:entry.field||"",old_value:entry.oldValue||"",new_value:entry.newValue||"",edited_by:entry.editedBy||"",created_at:new Date().toISOString()};
    const{error}=await sb.from("tkm_edit_log").upsert([row],{onConflict:"id"});
    if(error)console.warn("[editLog] save:",error.message);
    // LSキャッシュにも追加
    try{const k="tkm_editlog_"+entry.date;const ls=JSON.parse(localStorage.getItem(k)||"[]");ls.unshift(row);if(ls.length>200)ls.length=200;localStorage.setItem(k,JSON.stringify(ls));}catch(e){}
  },
  // --- BUDDICA Fleet (store_id=takamatsu) ---
  hm:{
    STORE:'takamatsu',
    _lsKey(k){return"tkm_hm_"+k;},
    _lsLoad(k){try{const s=localStorage.getItem(DB.hm._lsKey(k));return s?JSON.parse(s):null;}catch(e){return null;}},
    _lsSave(k,v){try{localStorage.setItem(DB.hm._lsKey(k),JSON.stringify(v));}catch(e){}},
    _buildCarsFromMaster(vehiclesState){
      // 常にマスター車両＋送迎車から車両リストを生成（Single Source of Truth）
      const src=vehiclesState||INIT_VEHICLES||[];
      const cars=src.map(v=>({id:v.code,store_id:"takamatsu",name:v.name,plate:v.no,class_id:v.type,status:"active",notes:""}));
      // 送迎車を末尾に追加（マスターにない場合）
      const SHUTTLE=[{id:"HIA01",name:"ハイエース①",plate:"7062",class_id:"送迎車"},{id:"HIA02",name:"ハイエース②",plate:"1713",class_id:"送迎車"},{id:"COS01",name:"コースター",plate:"2515",class_id:"送迎車"}];
      SHUTTLE.forEach(s=>{if(!cars.find(c=>c.plate===s.plate))cars.push({...s,store_id:"takamatsu",status:"active",notes:""});});
      // localStorageの状態(status,notes)をマージ
      const ls=DB.hm._lsLoad("cars")||[];
      const lsMap={};ls.forEach(c=>{lsMap[c.id||c.plate]=c;});
      cars.forEach(c=>{const saved=lsMap[c.id]||lsMap[c.plate];if(saved){c.status=saved.status||c.status;c.notes=saved.notes||c.notes;}});
      DB.hm._lsSave("cars",cars);
      return cars;
    },
    async fetchCars(vehiclesState){
      if(!sb){return DB.hm._buildCarsFromMaster(vehiclesState);}
      const{data,error}=await sb.from("tkm_cars").select("*").eq("store_id",DB.hm.STORE);
      if(error){dbLog("hm.cars",false,error.message);return DB.hm._buildCarsFromMaster(vehiclesState);}
      const result=data||[];
      // Supabaseが空 → マスターから生成してアップロード
      if(result.length===0){
        const built=DB.hm._buildCarsFromMaster(vehiclesState);
        if(built.length>0){
          for(const c of built){try{await sb.from("tkm_cars").upsert(c,{onConflict:"id"});}catch(e){}}
          dbLog("hm.cars",true,"マスター→SB同期 "+built.length+"台");
        }
        return built;
      }
      // Supabaseが権威: LSにあってDBにない車両のみ追加（statusはDB優先）
      const ls=DB.hm._lsLoad("cars")||[];
      const dbIds=new Set(result.map(c=>c.id));
      ls.forEach(c=>{if(c&&c.id&&!dbIds.has(c.id)){result.push(c);}});
      // ★ Supabase→localStorage一方向同期（DBが権威）
      DB.hm._lsSave("cars",result);
      dbLog("hm.cars",true,result.length+"台 (SB authority)");
      return result;
    },
    _carsMigrated:false,
    async _carsMigrate(){
      if(DB.hm._carsMigrated||!sb)return;DB.hm._carsMigrated=true;
      try{await sb.rpc("exec_sql",{query:"ALTER TABLE tkm_cars ADD COLUMN IF NOT EXISTS notes text DEFAULT ''"});}catch(e){}
    },
    async saveCar(car){
      // 常にlocalStorageも更新（稼働管理ポーリング連動用）
      const ls=DB.hm._lsLoad("cars")||[];const idx=ls.findIndex(c=>c.id===car.id);if(idx>=0)ls[idx]=car;else ls.push(car);DB.hm._lsSave("cars",ls);
      if(!sb){dbLog("hm.saveCar",false,"sb未接続 - LS保存のみ");return;}
      await DB.hm._carsMigrate();
      // 全カラムを含むrowを構築（upsertで欠落カラムがデフォルト値に戻るのを防ぐ）
      const row={id:car.id,store_id:car.store_id||"takamatsu",name:car.name||"",plate:car.plate||"",class_id:car.class_id||"",status:car.status||"active",memo:car.memo||"",notes:car.notes||""};
      const{error}=await sb.from("tkm_cars").upsert(row,{onConflict:"id"});
      if(error){dbLog("hm.saveCar",false,car.id+" → "+error.message);throw new Error(error.message);}
      dbLog("hm.saveCar",true,car.id+" status="+car.status);
      // 保存後検証: 書き込みが反映されたか確認
      try{const{data:verify}=await sb.from("tkm_cars").select("id,status").eq("id",car.id).single();
        if(verify&&verify.status!==car.status){dbLog("hm.saveCar",false,"検証失敗: DB="+verify.status+" expected="+car.status);
          // リトライ
          await sb.from("tkm_cars").update({status:car.status}).eq("id",car.id);
          dbLog("hm.saveCar",true,"リトライ成功 "+car.id);
        }
      }catch(e){}
    },
    async deleteCar(id){if(!sb){const ls=(DB.hm._lsLoad("cars")||[]).filter(c=>c.id!==id);DB.hm._lsSave("cars",ls);return;}await sb.from("tkm_cars").delete().eq("id",id);},
    async fetchCarData(){
      if(!sb){return DB.hm._lsLoad("carData")||[];}
      const{data,error}=await sb.from("tkm_car_data").select("*").eq("store_id",DB.hm.STORE);if(error){dbLog("hm.carData",false,error.message);return[];}return data||[];
    },
    async saveCarData(rec){
      if(!sb){const ls=DB.hm._lsLoad("carData")||[];const idx=ls.findIndex(d=>d.id===rec.id);if(idx>=0)ls[idx]=rec;else ls.push(rec);DB.hm._lsSave("carData",ls);return;}
      const{error}=await sb.from("tkm_car_data").upsert(rec,{onConflict:"id"});if(error){dbLog("hm.saveCD",false,error.message);throw new Error(error.message);}
    },
    async deleteCarData(id){if(!sb){const ls=(DB.hm._lsLoad("carData")||[]).filter(d=>d.id!==id);DB.hm._lsSave("carData",ls);return;}await sb.from("tkm_car_data").delete().eq("id",id);},
    async fetchLogs(){
      if(!sb){return(DB.hm._lsLoad("logs")||[]).sort((a,b)=>(b.date||"").localeCompare(a.date||""));}
      const{data,error}=await sb.from("tkm_logs").select("*").eq("store_id",DB.hm.STORE).order("date",{ascending:false});if(error){dbLog("hm.logs",false,error.message);return[];}return data||[];
    },
    async saveLog(log){
      if(!sb){const ls=DB.hm._lsLoad("logs")||[];const idx=ls.findIndex(l=>l.id===log.id);if(idx>=0)ls[idx]=log;else ls.push(log);DB.hm._lsSave("logs",ls);return;}
      const{error}=await sb.from("tkm_logs").upsert(log,{onConflict:"id"});if(error){dbLog("hm.saveLog",false,error.message);throw new Error(error.message);}
    },
    async deleteLog(id){if(!sb){const ls=(DB.hm._lsLoad("logs")||[]).filter(l=>l.id!==id);DB.hm._lsSave("logs",ls);return;}await sb.from("tkm_logs").delete().eq("id",id);},
    async fetchClasses(){
      if(!sb){const ls=DB.hm._lsLoad("classes");if(ls&&ls.length)return ls;if(typeof INIT_CLASSES!=="undefined")return INIT_CLASSES.map(c=>({id:c.type,store_id:"takamatsu",name:c.label}));return[];}
      const{data,error}=await sb.from("tkm_classes").select("*").eq("store_id",DB.hm.STORE);if(error){dbLog("hm.classes",false,error.message);return[];}return data||[];
    },
    async saveClass(cls){if(!sb){const ls=DB.hm._lsLoad("classes")||[];const idx=ls.findIndex(c=>c.id===cls.id);if(idx>=0)ls[idx]=cls;else ls.push(cls);DB.hm._lsSave("classes",ls);return;}const{error}=await sb.from("tkm_classes").upsert(cls,{onConflict:"id"});if(error)dbLog("hm.saveCls",false,error.message);},
    async deleteClass(id){if(!sb){const ls=(DB.hm._lsLoad("classes")||[]).filter(c=>c.id!==id);DB.hm._lsSave("classes",ls);return;}await sb.from("tkm_classes").delete().eq("id",id);},
  },
};

/* ===== 認証コンポーネント ===== */
function LoginScreen({onLogin}){
  const[pw,setPw]=useState("");const[err,setErr]=useState("");const[loading,setLoading]=useState(false);
  const[url,setUrl]=useState(SUPABASE_URL);const[key,setKey]=useState(SUPABASE_KEY);
  const[showSetup,setShowSetup]=useState(!SB_ENABLED);
  const doLogin=async()=>{
    if(showSetup){
      if(!url||!key){setErr("URLとKeyを入力してください");return;}
      localStorage.setItem("tkm_sb_url",url);localStorage.setItem("tkm_sb_key",key);
      window.location.reload();return;
    }
    setLoading(true);setErr("");
    try{const ok=await DB.checkPassword(pw);if(ok){localStorage.setItem("tkm_auth","1");onLogin();}else{setErr("パスワードが違います");}}
    catch(e){setErr("接続エラー: "+e.message);}
    setLoading(false);
  };
  return <div style={{minHeight:"100vh",display:"flex",alignItems:"center",justifyContent:"center",background:"linear-gradient(135deg,#1e3a5f,#2563eb)",padding:20}}>
    <div style={{background:"#fff",borderRadius:20,padding:32,width:"100%",maxWidth:380,boxShadow:"0 20px 60px rgba(0,0,0,.2)"}}>
      <div style={{textAlign:"center",marginBottom:24}}>
        <div style={{width:56,height:56,borderRadius:14,background:"linear-gradient(135deg,#3b82f6,#1d4ed8)",display:"inline-flex",alignItems:"center",justifyContent:"center",color:"#fff",fontWeight:900,fontSize:24,marginBottom:12}}>O</div>
        <h1 style={{fontSize:20,fontWeight:800,color:"#1e293b",margin:0}}>BUDDICA高松店 タスク管理</h1>
        <p style={{fontSize:12,color:"#64748b",margin:"4px 0 0"}}>チーム共有ワークスペース</p>
      </div>
      {showSetup?<div>
        <p style={{fontSize:11,color:"#64748b",marginBottom:12,background:"#f1f5f9",padding:8,borderRadius:8}}>初回セットアップ: SupabaseのURLとanon keyを入力</p>
        <input value={url} onChange={e=>setUrl(e.target.value)} placeholder="https://xxxxx.supabase.co" style={{width:"100%",padding:"10px 14px",border:"1.5px solid #d1d5db",borderRadius:10,fontSize:13,marginBottom:8,boxSizing:"border-box"}}/>
        <input value={key} onChange={e=>setKey(e.target.value)} placeholder="eyJhbGciOiJIUzI1NiIs..." style={{width:"100%",padding:"10px 14px",border:"1.5px solid #d1d5db",borderRadius:10,fontSize:13,marginBottom:8,boxSizing:"border-box"}}/>
        <button onClick={doLogin} style={{width:"100%",padding:"12px",background:"linear-gradient(135deg,#1e40af,#2563eb)",color:"#fff",border:"none",borderRadius:10,fontSize:14,fontWeight:700,cursor:"pointer"}}>{loading?"接続中...":"接続して保存"}</button>
        <p style={{fontSize:10,color:"#94a3b8",marginTop:8,textAlign:"center"}}>設定はこのブラウザに保存されます</p>
      </div>:<div>
        <input type="password" value={pw} onChange={e=>setPw(e.target.value)} onKeyDown={e=>e.key==="Enter"&&doLogin()} placeholder="チームパスワード" style={{width:"100%",padding:"12px 14px",border:"1.5px solid #d1d5db",borderRadius:10,fontSize:14,marginBottom:12,boxSizing:"border-box",textAlign:"center",letterSpacing:4}}/>
        <button onClick={doLogin} disabled={loading} style={{width:"100%",padding:"12px",background:"linear-gradient(135deg,#1e40af,#2563eb)",color:"#fff",border:"none",borderRadius:10,fontSize:14,fontWeight:700,cursor:"pointer",opacity:loading?0.6:1}}>{loading?"認証中...":"ログイン"}</button>
        <button onClick={()=>setShowSetup(true)} style={{width:"100%",marginTop:8,padding:8,background:"none",border:"none",color:"#94a3b8",fontSize:11,cursor:"pointer"}}>Supabase設定を変更</button>
      </div>}
      {err&&<div style={{marginTop:12,padding:8,background:"#fef2f2",borderRadius:8,color:"#b91c1c",fontSize:12,textAlign:"center"}}>{err}</div>}
    </div>
  </div>;
}

/* ===== オフラインインジケータ ===== */
function SyncBadge({connected,inline}){
  return <div style={{position:inline?"static":"fixed",top:inline?undefined:8,right:inline?undefined:8,zIndex:inline?undefined:999,padding:"3px 8px",borderRadius:20,fontSize:9,fontWeight:700,background:connected?(inline?"rgba(34,197,94,.15)":"#dcfce7"):(inline?"rgba(245,158,11,.15)":"#fef3c7"),color:connected?"#15803d":"#92400e",boxShadow:inline?"none":"0 1px 4px rgba(0,0,0,.1)",display:"flex",alignItems:"center",gap:3,flexShrink:0,marginLeft:inline?"auto":undefined}}>
    <span style={{width:5,height:5,borderRadius:"50%",background:connected?"#22c55e":"#f59e0b"}}></span>
    {connected?"接続中":"OFF"}
  </div>;
}

/* ===== CSV/TSV Parser ===== */
function parseCSV(text){text=text.replace(/^\uFEFF/,"").replace(/\u200B/g,"");const lines=[];let cur="",inQ=false;for(let i=0;i<text.length;i++){const c=text[i];if(c==='"'){inQ=!inQ;cur+=c;}else if((c==="\n"||c==="\r")&&!inQ){if(cur.trim())lines.push(cur);cur="";if(c==="\r"&&text[i+1]==="\n")i++;}else if((c==="\n"||c==="\r")&&inQ){cur+=" ";if(c==="\r"&&text[i+1]==="\n")i++;}else cur+=c;}if(cur.trim())lines.push(cur);if(!lines.length)return[];const firstLine=lines[0];const tabs=firstLine.split("\t").length;const commas=firstLine.split(",").length;const sep=tabs>commas?"\t":",";return lines.map(l=>{const cells=[];let cell="",q=false;for(let i=0;i<l.length;i++){const c=l[i];if(c==='"')q=!q;else if(c===sep&&!q){cells.push(cell.trim());cell="";}else cell+=c;}cells.push(cell.trim());return cells;});}
function readFile(file,cb){const r=new FileReader();r.onload=async e=>{const a=new Uint8Array(e.target.result);let t;// encoding-japanese遅延ロード
let Enc=window.Encoding;if(!Enc){try{await new Promise((res,rej)=>{const s=document.createElement('script');s.src='https://cdnjs.cloudflare.com/ajax/libs/encoding-japanese/2.1.0/encoding.min.js';s.onload=res;s.onerror=rej;document.head.appendChild(s);});}catch(e){}}Enc=window.Encoding;
if(Enc){const d=Enc.detect(a);const u=Enc.convert(a,{to:"UNICODE",from:d||"AUTO"});t=Enc.codeToString(u);}else{t=new TextDecoder("utf-8").decode(a);if(!t.includes("事業者")&&!t.includes("予約")&&!t.includes("貸出"))try{t=new TextDecoder("shift_jis").decode(a);}catch(e){}}cb(t);};r.readAsArrayBuffer(file);}

// 金額パース（カンマ・￥除去、複数フィールド名対応）
function parsePrice(g){return function(){for(let i=0;i<arguments.length;i++){const v=g(arguments[i]);if(v){const c=v.replace(/[,，¥￥\s円税込抜（）()\u3000]/g,"");const n=+c;if(!isNaN(n)&&n>0)return n;const m=v.match(/[\d,，]+/);if(m){const n2=+(m[0].replace(/[,，]/g,""));if(!isNaN(n2)&&n2>0)return n2;}}}return 0;};}
// キャンセル判定（行全体のテキストからも検出）
function isCancel(st,rowArr){if(st.includes("キャンセル"))return true;if(rowArr){const txt=rowArr.join(",");if(txt.includes("キャンセル"))return true;}return false;}
// シート検出ヘルパー（チャイルド/ジュニア/ベビーを行全体からも検出）
// ★ CSVクラスコード正規化: "_OKI"等の店舗サフィックス除去 + サブクラス(A2→A等)をマスターに合わせる
function normClass(raw){
  if(!raw)return"C";
  const cls1=["A","B","C","D","E","F","H","S"];
  const cls2=["A2","B2","EV"];
  // ★ rawに対して直接パターンマッチ（_OKA等を消す前に）
  // ① アンダースコア区切り: _F_OKA, プラン_F★, XXX_A_YYY（GAS extractVehicleClass互換）
  const p1=raw.match(/[_＿]([A-Z]\d?)[_＿](OKA|OKI|SPK|CTS|NHA|HKD)/i);
  if(p1){const v=p1[1].toUpperCase();if(cls2.includes(v))return v;if(cls1.includes(v.charAt(0)))return v.charAt(0);}
  const p2=raw.match(/[_＿]([A-Z]\d?)[_＿★☆\s]/);
  if(p2){const v=p2[1].toUpperCase();if(cls2.includes(v))return v;if(cls1.includes(v.charAt(0)))return v.charAt(0);}
  const p3=raw.match(/[_＿]([A-Z]\d?)$/);
  if(p3){const v=p3[1].toUpperCase();if(cls2.includes(v))return v;if(cls1.includes(v.charAt(0)))return v.charAt(0);}
  const p4=raw.match(/^([A-Z]\d?)[_＿]/);
  if(p4){const v=p4[1].toUpperCase();if(cls2.includes(v))return v;if(cls1.includes(v.charAt(0)))return v.charAt(0);}
  // ② 店舗コード除去後に完全一致（"A", "B2", "F" 等）
  let c=raw.replace(/_SPK|_HKD|_OKA|_TKM|_OKI|_CTS|^HKD_/g,"").trim();
  if(cls2.includes(c))return c;
  if(c.length<=2&&cls1.includes(c.charAt(0))&&/^[A-Z]\d?$/.test(c))return c.charAt(0);
  // ③ 日本語車名・カテゴリからクラス推定（長いキーから先にマッチ）
  const nameMap={"アルファードHクラス":"A","アルファードH":"A","アルファードM":"B","ヴェルファイア":"B","セレナH":"B","ヴォクシー":"B","ノアH":"B","ヤリスクロス":"C","ライズ":"C","プリウスα":"H","プリウスアルファ":"H","プリウス":"H","ヴィッツ":"F","ノート":"F","アクア":"F","セレナM":"D","ノアM":"D","エスクァイア":"D","ハリアー":"S","コンパクトSUV":"C","コンパクトカー":"F","コンパクト":"F","ミニバン":"B","ワゴン":"B","1BOX":"B","ワンボックス":"B","SUV":"C","ハイブリッド":"H","セダン":"H","エコノミー":"F","軽自動車":"F","プレミアム":"S","アルファード":"A"};
  for(const[k,v]of Object.entries(nameMap)){if(raw.includes(k))return v;}
  // ④ マッチしない場合はログ出力してデフォルト
  console.warn("[normClass] クラス判定失敗:",raw,"→デフォルトC");
  return"C";
}
function detectSeats(opts,rowArr,h,g){
  // ① g()で専用カラムから数を取得（複数のカラム名パターンに対応）
  let b=0,c=0,j=0,usb=0;
  if(g){
    b=+(g("ベビーシート数")||g("ベビーシート")||g("ベビー")||0);
    c=+(g("チャイルドシート数")||g("チャイルドシート")||g("チャイルド")||0);
    j=+(g("ジュニアシート数")||g("ジュニアシート")||g("ジュニア")||0);
    usb=+(g("USBポート数")||g("USBポート")||g("USB充電器")||0);
  }
  // ② ヘッダスキャンで「ベビー/チャイルド/ジュニア/USB」を含むカラムを直接検索
  const parseQty=(v)=>{if(!v)return 0;const s=String(v).trim();if(s==="○"||s==="〇"||s==="あり"||s==="有"||s==="TRUE"||s==="true"||s==="Yes"||s==="yes"||s==="はい")return 1;if(s==="×"||s==="✕"||s==="なし"||s==="無"||s==="FALSE"||s==="false"||s===""||s==="-"||s==="ー"||s==="0")return 0;const nm=s.match(/(\d+)/);return nm?parseInt(nm[1]):0;};
  if(h&&rowArr){
    for(let i=0;i<h.length;i++){
      const hn=(h[i]||"").trim();
      if(!hn||!rowArr[i])continue;
      const val=parseQty(rowArr[i]);
      if(!val)continue;
      if(!b&&/ベビー/.test(hn))b=val;
      if(!c&&/チャイルド/.test(hn))c=val;
      if(!j&&/ジュニア/.test(hn))j=val;
      if(!usb&&/USB/.test(hn))usb=val;
    }
  }
  // ③ オプション文字列からキーワード検索（カラム名が見つからない場合のフォールバック）
  let optText=opts||"";
  if(h&&rowArr){
    for(let i=0;i<h.length;i++){
      const hn=(h[i]||"").trim();
      if(hn&&OPT_HEADER_RE.test(hn)&&rowArr[i])optText+=","+rowArr[i];
    }
    OPT_COL_NAMES.forEach(n=>{const v=g?g(n):"";if(v)optText+=","+v;});
  }else if(rowArr){
    optText+=","+rowArr.join(",");
  }
  const countMatch=(keyword)=>{
    // "ベビーシート×2" "チャイルドシート：1" "ジュニア x1" 等
    const re=new RegExp(keyword+"[^\\d]*?(\\d+)");
    const m=optText.match(re);
    if(m)return parseInt(m[1])||1;
    return optText.includes(keyword)?1:0;
  };
  if(!b)b=countMatch("ベビーシート")||countMatch("ベビー");
  if(!c)c=countMatch("チャイルドシート")||countMatch("チャイルド");
  if(!j)j=countMatch("ジュニアシート")||countMatch("ジュニア");
  if(!usb)usb=countMatch("USBポート")||countMatch("USB充電")||countMatch("USB");
  console.log("[SEATS]",g?g("予約番号"):"?","B="+b,"C="+c,"J="+j,"USB="+usb,"optText="+optText.substring(0,200));
  return{b,c,j,usb};
}
/*
 * ============================================================
 * OTAオプション文字列 → タスク内容(type) 完全マッピング定義
 * ============================================================
 * ■ 判定優先順位:
 *   1. 専用カラム（楽天:貸渡方法, オフィシャル:デリバリー選択有無）
 *   2. オプション列のキーワードマッチ
 *   3. デフォルト = PU/BD（デリバリーオプション未申込）
 *
 * ■ 貸出タスク判定（visitType）:
 *   DEL = 以下のいずれかがオプション列に存在する場合
 *     - "デリバリー"     例: デリバリー（お届け） ※エリア限定×1
 *     - "お届け"         例: お届けサービス, お届け希望
 *     - "配車"           例: 配車サービス, 空港配車
 *     - "配達"           例: 配達サービス
 *   PU = 上記キーワードがオプション列に存在しない場合
 *
 * ■ 返却タスク判定（returnType）:
 *   COL = 以下のいずれかがオプション列に存在する場合
 *     - "回収"           例: 回収サービス, 空港回収, ホテル回収
 *     - "引取"           例: 引取サービス
 *     - "集車"           例: 集車サービス
 *   BD = 上記キーワードがオプション列に存在しない場合
 *
 * ■ OTA別のオプション列名:
 *   S(スカイチケット): "オプション項目", "シート"
 *   J(じゃらん):       "オプション"
 *   R(楽天):           "付帯サービス" + "貸渡方法"(専用カラム)
 *   A(エアトリ):       "オプション"
 *   O(オフィシャル):   専用カラム "デリバリー（お届け）選択有無"
 *   RC(レンタカードットコム): "オプション内容" + "貸出場所"/"返却場所"
 * ============================================================
 */
const DEL_RE=/デリバリー|お届け|配車|配達/;
const COL_RE=/回収|引取|集車/;
// オプション列として安全なヘッダ名パターン（店舗名・住所・氏名列を除外）
const OPT_HEADER_RE=/オプション|付帯|シート|備考|要望|希望|サービス|内容/;
// g()で明示取得するオプション列名リスト
const OPT_COL_NAMES=["オプション","オプション項目","オプション内容","付帯サービス","シート","備考","要望"];

function detectDelCol(r,h,g){
  // ① 専用カラム（楽天の貸渡方法/返却方法）
  const mL=g("貸渡方法")||g("受渡方法")||"";
  const mR=g("返却方法")||"";
  let vt=null,rt=null;
  if(mL)vt=/^(来店|店舗|店頭)$/.test(mL.trim())?"来店":"DEL";
  if(mR)rt=/^(来店|店舗|店頭)$/.test(mR.trim())?"返却":"COL";
  // ② オプション列テキスト収集（ヘッダベース + 名前ベース）
  let optText="";
  // 安全なヘッダ名パターンに該当する列のみ収集
  const UNSAFE_RE=/氏名|名前|住所|店舗|出発|返却|貸出|貸渡|予約番号|ステータス|電話|メール|日時|日付|時間|金額|料金|合計|台数|人数/;
  for(let i=0;i<h.length;i++){
    const hn=(h[i]||"").trim();
    if(!hn||!r[i])continue;
    // ヘッダがオプション系 OR (ヘッダが安全でない列名を含まない場合のみ)
    if(OPT_HEADER_RE.test(hn))optText+=","+r[i];
  }
  OPT_COL_NAMES.forEach(n=>{const v=g(n);if(v)optText+=","+v;});
  // ③ オプション列でヒットしない場合、全列のうち安全な列もスキャン（フォールバック）
  if(!DEL_RE.test(optText)&&!COL_RE.test(optText)){
    for(let i=0;i<h.length;i++){
      const hn=(h[i]||"").trim();
      if(!hn||!r[i])continue;
      if(!UNSAFE_RE.test(hn)&&!OPT_HEADER_RE.test(hn))optText+=","+r[i];
    }
  }
  // ④ 未決定の場合のみキーワード判定
  if(!vt)vt=DEL_RE.test(optText)?"DEL":"来店";
  if(!rt)rt=COL_RE.test(optText)?"COL":"返却";
  return{visitType:vt,returnType:rt};
}
// ロバストなCSV列取得（exact→正規化→部分一致のフォールバック）
function makeG(r,h){
  const hNorm=h.map(s=>(s||"").replace(/[\s\u3000\uFEFF\u200B]/g,""));
  return function(n){
    // 1) exact match
    let i=h.indexOf(n);
    if(i>=0)return r[i]||"";
    // 2) normalized match（空白・全角スペース除去）
    const nn=n.replace(/[\s\u3000\uFEFF\u200B]/g,"");
    i=hNorm.indexOf(nn);
    if(i>=0)return r[i]||"";
    // 3) 部分一致（ヘッダーがnを含む or nがヘッダーを含む）
    for(let j=0;j<hNorm.length;j++){
      if(hNorm[j]&&(hNorm[j].includes(nn)||nn.includes(hNorm[j])))return r[j]||"";
    }
    return"";
  };
}
