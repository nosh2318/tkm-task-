                React.createElement("tbody",null,
                  delRank.map(([p,c],i)=>{const maxC=delRank[0]?delRank[0][1]:1;return React.createElement("tr",{key:p,style:zRow(i,false)},
                    React.createElement("td",{style:{...td2,fontWeight:700,color:"#64748b"}},i+1),React.createElement("td",{style:{...td2,fontWeight:i<3?700:400}},p),React.createElement("td",{style:{...td2,textAlign:"right",fontWeight:600}},c),
                    React.createElement("td",{style:td2},bar(Math.round(c/maxC*100),"#10b981"))
                  );})
                )
              ),"50vh")
            ),
            // COL
            React.createElement("div",{style:{flex:"1 1 320px",...card,padding:16}},
              React.createElement("div",{style:{fontSize:13,fontWeight:900,marginBottom:10,color:"#dc2626"}},"COL場所 Top20"),
              tableWrap(React.createElement("table",{style:{width:"100%",borderCollapse:"collapse"}},
                React.createElement("thead",null,React.createElement("tr",null,
                  React.createElement("th",{style:{...th2,width:28}},"#"),React.createElement("th",{style:th2},"場所"),React.createElement("th",{style:{...th2,textAlign:"right"}},"件数"),React.createElement("th",{style:{...th2,minWidth:100}},"")
                )),
                React.createElement("tbody",null,
                  colRank.map(([p,c],i)=>{const maxC=colRank[0]?colRank[0][1]:1;return React.createElement("tr",{key:p,style:zRow(i,false)},
                    React.createElement("td",{style:{...td2,fontWeight:700,color:"#64748b"}},i+1),React.createElement("td",{style:{...td2,fontWeight:i<3?700:400}},p),React.createElement("td",{style:{...td2,textAlign:"right",fontWeight:600}},c),
                    React.createElement("td",{style:td2},bar(Math.round(c/maxC*100),"#f59e0b"))
                  );})
                )
              ),"50vh")
            )
          ),
          // 利用者エリア
          sectionCard(React.createElement("div",null,
            React.createElement("div",{style:{fontSize:13,fontWeight:900,marginBottom:10,color:"#1e3a5f"}},"利用者エリア Top20（都道府県）"),
            prefRank.length>0?tableWrap(React.createElement("table",{style:{width:"100%",borderCollapse:"collapse"}},
              React.createElement("thead",null,React.createElement("tr",null,
                React.createElement("th",{style:{...th2,width:28}},"#"),React.createElement("th",{style:th2},"都道府県"),React.createElement("th",{style:{...th2,textAlign:"right"}},"件数"),React.createElement("th",{style:{...th2,minWidth:120}},"")
              )),
              React.createElement("tbody",null,
                prefRank.map(([p,c],i)=>{const maxC=prefRank[0]?prefRank[0][1]:1;return React.createElement("tr",{key:p,style:zRow(i,false)},
                  React.createElement("td",{style:{...td2,fontWeight:700,color:"#64748b"}},i+1),React.createElement("td",{style:{...td2,fontWeight:i<3?700:400}},p),React.createElement("td",{style:{...td2,textAlign:"right",fontWeight:600}},c),
                  React.createElement("td",{style:td2},bar(Math.round(c/maxC*100),"#8b5cf6"))
                );})
              )
            ),"40vh"):React.createElement("div",{style:{fontSize:12,color:"#94a3b8",padding:8}},"prefectureデータなし")
          )),
          // タスク時間帯
          sectionCard(React.createElement("div",null,
            React.createElement("div",{style:{fontSize:13,fontWeight:900,marginBottom:10,color:"#1e3a5f"}},"DEL/COL 時間帯分布"),
            React.createElement("div",{style:{display:"flex",gap:16,flexWrap:"wrap"}},
              ["DEL","COL"].map(type=>{
                const buckets=taskTimeBuckets[type];
                const sorted=Object.entries(buckets).sort((a,b)=>a[0].localeCompare(b[0]));
                const maxV=sorted.reduce((a,[,v])=>Math.max(a,v),1);
                return React.createElement("div",{key:type,style:{flex:"1 1 240px"}},
                  React.createElement("div",{style:{fontSize:12,fontWeight:800,marginBottom:6,color:type==="DEL"?"#059669":"#dc2626",padding:"4px 10px",background:type==="DEL"?"#f0fdf4":"#fef2f2",borderRadius:6,display:"inline-block"}},type),
                  sorted.length>0?React.createElement("table",{style:{width:"100%",borderCollapse:"collapse"}},
                    React.createElement("tbody",null,
                      sorted.map(([h,c],i)=>React.createElement("tr",{key:h,style:zRow(i,false)},
                        React.createElement("td",{style:{...td2,fontWeight:700,width:50}},h),
                        React.createElement("td",{style:{...td2,textAlign:"right",width:36,fontWeight:600}},c),
                        React.createElement("td",{style:td2},bar(Math.round(c/maxV*100),type==="DEL"?"#059669":"#dc2626"))
                      ))
                    )
                  ):React.createElement("div",{style:{fontSize:11,color:"#94a3b8",padding:8}},"データなし")
                );
              })
            )
          ))
        )

        ) // end padding div
        ) // end dbLoading2 ternary
      ); // end return
    })()}

    {sub==="cfsim"&&(()=>{
      const isSpk=dbStore==="spk";
      const rdKey=isSpk?"return_date":"end_date";
      const chOrder=["オフィシャル","じゃらん","楽天","エアトリ","スカイチケット","レンタカードットコム","その他売上"];
      const cycles={};(mgSettings.channels||[]).forEach(c=>{cycles[c.name]=c.cycle||0;});
      // 実績売上からチャネル構成比を算出
      const active=dbResvs.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");
      const ymRevByCh={};
      active.forEach(r=>{
        const rd=r[rdKey];if(!rd)return;
        const ym=rd.slice(0,7);
        const ch=DB_OTA_MAP[r.ota]||"その他売上";
        const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
        const rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
        if(!ymRevByCh[ym])ymRevByCh[ym]={total:0};
        ymRevByCh[ym][ch]=(ymRevByCh[ym][ch]||0)+rev;
        ymRevByCh[ym].total+=rev;
      });
      // 各月の入金を計算
      const cashByYm={};
      Object.entries(ymRevByCh).forEach(([ym,data])=>{
        chOrder.forEach(ch=>{
          const rev=data[ch]||0;if(rev===0)return;
          const cycle=cycles[ch]||0;
          const[sy,sm]=ym.split("-").map(Number);
          let ny=sy,nm=sm+cycle;while(nm>12){nm-=12;ny++;}
          const cashYm=ny+"-"+String(nm).padStart(2,"0");
          if(!cashByYm[cashYm])cashByYm[cashYm]={};
          cashByYm[cashYm][ch]=(cashByYm[cashYm][ch]||0)+rev;
        });
      });
      const allYmsAsc=[...new Set([...Object.keys(ymRevByCh),...Object.keys(cashByYm)])].sort();
      // Pre-compute cumCash for each month (ascending order)
      let _cum=mgSettings.initCash||0;
      const cumCashMap={};
      allYmsAsc.forEach(ym=>{const cashData=cashByYm[ym]||{};const cashTotal=Object.values(cashData).reduce((a,b)=>a+b,0);_cum+=cashTotal;cumCashMap[ym]=_cum;});
      const allYms=[...allYmsAsc].reverse();
      return <div>
        <div style={{display:"flex",gap:6,marginBottom:10}}>
          {["tkm","spk"].map(s=><button key={s} onClick={()=>setDbStore(s)} style={{padding:"4px 12px",fontSize:11,fontWeight:700,borderRadius:6,border:"none",cursor:"pointer",background:dbStore===s?"#9333ea":"#e2e8f0",color:dbStore===s?"#fff":"#334155"}}>{s==="tkm"?"高松":"札幌"}</button>)}
        </div>
        <div style={{fontSize:11,color:"#64748b",marginBottom:4}}>実績売上 × 入金サイクル → 月別入金シミュレーション（期初現金: ¥{fmt(mgSettings.initCash||0)}）</div>
        {dbLoading2?<div style={{padding:24,textAlign:"center",color:"#94a3b8"}}>読込中...</div>:
        <div style={{overflow:"auto",maxHeight:"70vh",border:"1px solid #e2e8f0",borderRadius:8}}>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
            <thead><tr>
              <th style={th}>月</th>
              <th style={{...th,textAlign:"right"}}>売上(計上)</th>
              {chOrder.map(ch=><th key={ch} style={{...th,textAlign:"right",fontSize:9}}>{ch.slice(0,3)}</th>)}
              <th style={{...th,textAlign:"right",background:"#dcfce7"}}>入金計</th>
              <th style={{...th,textAlign:"right",background:"#fef3c7"}}>累積CF</th>
            </tr></thead>
            <tbody>
              {allYms.map(ym=>{
                const revData=ymRevByCh[ym]||{};
                const cashData=cashByYm[ym]||{};
                const cashTotal=Object.values(cashData).reduce((a,b)=>a+b,0);
                const cumCashVal=cumCashMap[ym];
                return <tr key={ym}>
                  <td style={{...td,fontWeight:700}}>{ym}</td>
                  <td style={{...td,textAlign:"right"}}>¥{fmt(revData.total||0)}</td>
                  {chOrder.map(ch=>{
                    const v=cashData[ch]||0;
                    return <td key={ch} style={{...td,textAlign:"right",color:v>0?"#0f172a":"#cbd5e1",fontSize:9}}>{v>0?"¥"+fmt(v):"-"}</td>;
                  })}
                  <td style={{...td,textAlign:"right",fontWeight:800,background:"#f0fdf4",color:"#059669"}}>¥{fmt(Math.round(cashTotal))}</td>
                  <td style={{...td,textAlign:"right",fontWeight:800,background:cumCashVal<(mgSettings.minCash||0)?"#fecaca":"#fef9c3",color:cumCashVal>=0?"#92400e":"#dc2626"}}>¥{fmt(Math.round(cumCashVal))}</td>
                </tr>;
              })}
            </tbody>
          </table>
        </div>}
      </div>;
    })()}

  </div>;
}

/* ==========================================
   PASガード（パスコード認証）
   ========================================== */
function PASGuard({children,label}){
  const[unlocked,setUnlocked]=useState(false);
  const[input,setInput]=useState("");
  const[err,setErr]=useState("");
  const code="BD2026";
  const unlock=()=>{
    if(!code)return;
    if(input===code){
      setUnlocked(true);setErr("");
    }else{setErr("パスコードが違います");setInput("");}
  };
  if(unlocked)return children;
  return <div style={{maxWidth:400,margin:"40px auto",textAlign:"center"}}>
    <div style={{background:"#fff",borderRadius:16,padding:32,border:"1px solid #e2e8f0",boxShadow:"0 2px 8px rgba(0,0,0,.06)"}}>
      <div style={{fontSize:32,marginBottom:12}}>🔒</div>
      <div style={{fontSize:16,fontWeight:800,color:"#1e293b",marginBottom:4}}>{label||"この画面はロックされています"}</div>
      <div style={{fontSize:12,color:"#64748b",marginBottom:20}}>閲覧にはパスコードが必要です</div>
      <input type="password" maxLength={6} value={input} onChange={e=>setInput(e.target.value)} onKeyDown={e=>e.key==="Enter"&&unlock()} placeholder="パスコード" style={{width:"100%",padding:"12px",border:"1.5px solid #d1d5db",borderRadius:10,fontSize:20,textAlign:"center",letterSpacing:8,boxSizing:"border-box",marginBottom:8}}/>
      {err&&<div style={{color:"#dc2626",fontSize:12,fontWeight:600,marginBottom:8}}>{err}</div>}
      <button onClick={unlock} disabled={input.length<6} style={{width:"100%",padding:"12px",background:input.length>=6?"linear-gradient(135deg,#1e40af,#2563eb)":"#94a3b8",color:"#fff",border:"none",borderRadius:10,fontSize:14,fontWeight:700,cursor:input.length>=6?"pointer":"not-allowed"}}>認証</button>
    </div>
  </div>;
}

/* ==========================================
   じゃらん決済確認
   ========================================== */
function JalanPayment({data,jalanPay,onJalanPayChange}){
  const[editId,setEditId]=useState(null);
  const[form,setForm]=useState({});
  const[sheetLoading,setSheetLoading]=useState(false);
  const jData=useMemo(()=>data.filter(r=>r.ota==="J"&&r.status!=="cancelled").sort((a,b)=>(b.lendDate||"").localeCompare(a.lendDate||"")),[data]);
  const startEdit=(id)=>{const existing=jalanPay[id]||{};const res=jData.find(r=>r.id===id);setEditId(id);setForm({category:existing.category||"売上",payStatus:existing.payStatus||"未完了",sendDate:existing.sendDate||"",refundDate:existing.refundDate||"",content:existing.content||"",linkUrl:existing.linkUrl||"",adjustedPrice:existing.adjustedPrice||(res?String(res.finalPrice||res.price||""):"")});};
  const saveEdit=()=>{if(!editId)return;onJalanPayChange(editId,form);setEditId(null);};
  const cancelEdit=()=>{setEditId(null);setForm({});};
  const summary=useMemo(()=>{const done=jData.filter(r=>(jalanPay[r.id]?.payStatus)==="完了").length;return{total:jData.length,done,undone:jData.length-done};},[jData,jalanPay]);
  const cardS={background:"#fff",borderRadius:14,border:"1px solid #e2e8f0",boxShadow:"0 1px 3px rgba(0,0,0,.05)"};
  // ★ スプレッドシートから支払データを一括取得
  const fetchFromSheet=async()=>{
    const resIds=jData.map(r=>r.id);
    if(!resIds.length){alert("じゃらん予約がありません");return;}
    setSheetLoading(true);
    try{
      const payMap=await fetchJalanPaySheetData(resIds);
      const matched=Object.keys(payMap).length;
      if(!matched){setSheetLoading(false);alert("該当する予約番号がスプレッドシートに見つかりませんでした");return;}
      let updated=0;
      Object.entries(payMap).forEach(([rid,pd])=>{
        const existing=jalanPay[rid]||{};
        onJalanPayChange(rid,{...existing,adjustedPrice:pd.adjustedPrice,payStatus:pd.payStatus});
        updated++;
      });
      alert(`${matched}件中 ${updated}件の支払データを反映しました`);
    }catch(e){alert("取得エラー: "+e.message);}
    setSheetLoading(false);
  };

  return <div style={{maxWidth:800,margin:"0 auto"}}>
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
      <h3 style={{fontSize:16,fontWeight:800,margin:0}}>じゃらん決済確認</h3>
      <div style={{display:"flex",gap:8,fontSize:11,fontWeight:700,alignItems:"center"}}>
        <button onClick={fetchFromSheet} disabled={sheetLoading} style={{padding:"4px 12px",borderRadius:8,background:sheetLoading?"#94a3b8":"#7c3aed",color:"#fff",border:"none",fontSize:11,fontWeight:700,cursor:sheetLoading?"not-allowed":"pointer"}}>{sheetLoading?"取得中...":"📊 スプレッドシート取得"}</button>
        <span style={{padding:"2px 10px",borderRadius:10,background:"#f0fdf4",color:"#059669"}}>完了 {summary.done}</span>
        <span style={{padding:"2px 10px",borderRadius:10,background:"#fef2f2",color:"#dc2626"}}>未完了 {summary.undone}</span>
      </div>
    </div>
    {jData.length===0&&<div style={{...cardS,padding:24,textAlign:"center",color:"#94a3b8",fontSize:13}}>じゃらんの予約データがありません</div>}
    {jData.length>0&&<div style={{...cardS,overflow:"hidden"}}>
      <div style={{overflowX:"auto"}}><table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
        <thead><tr style={{background:"#fdf2f8"}}>
          {["予約番号","予約者","貸出日","請求金額","差引請求金額","分類","支払確認","送付日","返金日","予約内容","リンク","操作"].map(h=><th key={h} style={{padding:"6px 8px",textAlign:"left",fontWeight:700,fontSize:10,color:"#9d174d",borderBottom:"2px solid #fbcfe8",whiteSpace:"nowrap"}}>{h}</th>)}
        </tr></thead>
        <tbody>{jData.map((r,ri)=>{
          const p=jalanPay[r.id]||{};
          const isDone=p.payStatus==="完了";
          const isEdit=editId===r.id;
          return <tr key={r.id} style={{background:isDone?"#f0fdf4":ri%2===0?"#fff":"#fafbfc",borderBottom:"1px solid #f1f5f9"}}>
            <td style={{padding:"4px 8px",fontFamily:"monospace",fontSize:9,fontWeight:600}}>{r.id}</td>
            <td style={{padding:"4px 8px",fontWeight:600}}>{r.name}</td>
            <td style={{padding:"4px 8px",fontSize:10,color:"#475569"}}>{r.lendDate||"-"}</td>
            <td style={{padding:"4px 8px",fontWeight:700,color:"#1e40af"}}>¥{(r.price||0).toLocaleString()}</td>
            {isEdit?<>
              <td style={{padding:"2px 4px"}}><input type="number" value={form.adjustedPrice||""} onChange={e=>setForm(f=>({...f,adjustedPrice:e.target.value}))} placeholder="金額" style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db",width:80}}/></td>
              <td style={{padding:"2px 4px"}}><select value={form.category||"売上"} onChange={e=>setForm(f=>({...f,category:e.target.value}))} style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db"}}><option>売上</option><option>立替</option></select></td>
              <td style={{padding:"2px 4px"}}><select value={form.payStatus||"未完了"} onChange={e=>setForm(f=>({...f,payStatus:e.target.value}))} style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db"}}><option>完了</option><option>未完了</option></select></td>
              <td style={{padding:"2px 4px"}}><input type="date" value={form.sendDate||""} onChange={e=>setForm(f=>({...f,sendDate:e.target.value}))} style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db",width:110}}/></td>
              <td style={{padding:"2px 4px"}}><input type="date" value={form.refundDate||""} onChange={e=>setForm(f=>({...f,refundDate:e.target.value}))} style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db",width:110}}/></td>
              <td style={{padding:"2px 4px"}}><input value={form.content||""} onChange={e=>setForm(f=>({...f,content:e.target.value}))} placeholder="予約内容" style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db",width:100}}/></td>
              <td style={{padding:"2px 4px"}}><input value={form.linkUrl||""} onChange={e=>setForm(f=>({...f,linkUrl:e.target.value}))} placeholder="URL" style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db",width:80}}/></td>
              <td style={{padding:"2px 4px",whiteSpace:"nowrap"}}><button onClick={saveEdit} style={{fontSize:10,padding:"2px 8px",borderRadius:4,border:"none",background:"#2563eb",color:"#fff",fontWeight:700,cursor:"pointer",marginRight:4}}>保存</button><button onClick={cancelEdit} style={{fontSize:10,padding:"2px 8px",borderRadius:4,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer"}}>取消</button></td>
            </>:<>
              <td style={{padding:"4px 8px",fontWeight:700,color:(p.adjustedPrice||r.finalPrice||r.price)?"#7c3aed":"#94a3b8"}}>{(()=>{const fp=Number(p.adjustedPrice)||r.finalPrice||r.price||0;return fp?("¥"+fp.toLocaleString()):"-";})()}</td>
              <td style={{padding:"4px 8px"}}><span style={{fontSize:10,fontWeight:600,padding:"1px 6px",borderRadius:4,background:p.category==="立替"?"#fef3c7":"#dbeafe",color:p.category==="立替"?"#92400e":"#1d4ed8"}}>{p.category||"売上"}</span></td>
              <td style={{padding:"4px 8px"}}><span style={{fontSize:10,fontWeight:700,padding:"1px 6px",borderRadius:4,background:isDone?"#dcfce7":"#fef2f2",color:isDone?"#166534":"#dc2626"}}>{isDone?"完了":"未完了"}</span></td>
              <td style={{padding:"4px 8px",fontSize:10,color:"#64748b"}}>{p.sendDate||"-"}</td>
              <td style={{padding:"4px 8px",fontSize:10,color:"#64748b"}}>{p.refundDate||"-"}</td>
              <td style={{padding:"4px 8px",fontSize:10,color:"#64748b",maxWidth:100,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{p.content||"-"}</td>
              <td style={{padding:"4px 8px",fontSize:10}}>{p.linkUrl?<a href={p.linkUrl} target="_blank" rel="noreferrer" style={{color:"#2563eb"}}>🔗</a>:"-"}</td>
              <td style={{padding:"4px 8px"}}><button onClick={()=>startEdit(r.id)} style={{fontSize:10,padding:"2px 8px",borderRadius:4,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer",fontWeight:600}}>編集</button></td>
            </>}
          </tr>;
        })}</tbody>
      </table></div>
    </div>}
  </div>;
}

/* ==========================================
   スタッフ管理
   ========================================== */
function StaffManager({staff,onStaffChange,onDeleteStaff}){
  const[editId,setEditId]=useState(null);
  const[form,setForm]=useState({name:"",type:"アルバイト",memo:"",hourlyWage:1100,transportCost:500,monthlySalary:0});
  const[adding,setAdding]=useState(false);
  const[editOrigName,setEditOrigName]=useState("");
  const[wageHistory,setWageHistory]=useState([]);
  const[showWageHistory,setShowWageHistory]=useState(null); // staff name or null
  const[wageForm,setWageForm]=useState({effective_date:"",hourly_wage:""});
  React.useEffect(()=>{DB.fetchWageHistory().then(d=>setWageHistory(d||[]));},[]);
  const addWageEntry=async(staffName)=>{
    if(!wageForm.effective_date||!wageForm.hourly_wage){alert("適用開始日と時給を入力してください");return;}
    const rec={id:"wh_"+Date.now()+"_"+Math.random().toString(36).slice(2,5),staff_name:staffName,effective_date:wageForm.effective_date,hourly_wage:Number(wageForm.hourly_wage)||0};
    await DB.saveWageHistory(rec);
    setWageHistory(prev=>[...prev,rec].sort((a,b)=>a.effective_date.localeCompare(b.effective_date)));
    setWageForm({effective_date:"",hourly_wage:""});
  };
  const deleteWageEntry=async(id)=>{
    if(!confirm("この時給履歴を削除しますか？"))return;
    await DB.deleteWageHistory(id);
    setWageHistory(prev=>prev.filter(w=>w.id!==id));
  };

  const save=()=>{
    if(!form.name.trim())return;
    if(!window.confirm(adding?"新規登録を実行しますか？":"変更を保存しますか？"))return;
    const entry={name:form.name.trim(),type:form.type,memo:form.memo,hourlyWage:Number(form.hourlyWage)||0,transportCost:Number(form.transportCost)||0,monthlySalary:Number(form.monthlySalary)||0};
    if(adding){
      onStaffChange([...staff,entry]);setAdding(false);
    }else if(editId!==null){
      const oldName=editOrigName;
      const updated=[...staff];updated[editId]=entry;
      onStaffChange(updated);
      if(oldName&&oldName!==entry.name&&onDeleteStaff)onDeleteStaff(oldName);
      setEditId(null);setEditOrigName("");
    }
    setForm({name:"",type:"アルバイト",memo:"",hourlyWage:1100,transportCost:500,monthlySalary:0});
  };

  const startEdit=(i)=>{setEditId(i);setEditOrigName(staff[i].name);setForm({...staff[i]});setAdding(false);};
  const startAdd=()=>{setForm({name:"",type:"アルバイト",memo:"",hourlyWage:1100,transportCost:500,monthlySalary:0});setAdding(true);setEditId(null);};
  const remove=(i)=>{if(window.confirm(`${staff[i].name} を削除しますか？`)){const name=staff[i].name;onStaffChange(staff.filter((_,j)=>j!==i));if(onDeleteStaff)onDeleteStaff(name);}};
  const cancel=()=>{setAdding(false);setEditId(null);setForm({name:"",type:"アルバイト",memo:"",hourlyWage:1100,transportCost:500,monthlySalary:0});};

  const showModal=adding||editId!==null;
  const cardS={background:"#fff",borderRadius:14,padding:16,border:"1px solid #e2e8f0",marginBottom:10,boxShadow:"0 1px 3px rgba(0,0,0,.05)"};
  const fmtCur=n=>n?("¥"+Number(n).toLocaleString()):"¥0";

  return <div style={{maxWidth:640,margin:"0 auto"}}>
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14}}>
      <h3 style={{fontSize:16,fontWeight:800,margin:0}}>スタッフ ({staff.length})</h3>
      <button onClick={startAdd} style={{padding:"6px 14px",borderRadius:8,background:"#2563eb",color:"#fff",border:"none",fontSize:12,fontWeight:700,cursor:"pointer"}}>＋ 追加</button>
    </div>

    {staff.map((s,i)=>{
      const isP=s.type==="アルバイト";const isR=s.type==="正社員";
      return <div key={i} style={cardS}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
          <div style={{display:"flex",alignItems:"center",gap:8}}>
            <span style={{fontSize:15,fontWeight:800}}>{s.name}</span>
            <span style={{fontSize:10,fontWeight:700,padding:"2px 10px",borderRadius:12,background:isP?"#fef3c7":"#dbeafe",color:isP?"#92400e":"#1d4ed8"}}>{s.type}</span>
          </div>
          <div style={{display:"flex",gap:8}}>
            <span onClick={()=>startEdit(i)} style={{fontSize:12,color:"#2563eb",fontWeight:600,cursor:"pointer"}}>編集</span>
            <span onClick={()=>remove(i)} style={{fontSize:12,color:"#dc2626",fontWeight:600,cursor:"pointer"}}>削除</span>
          </div>
        </div>
        {isP&&<div style={{fontSize:13,color:"#374151"}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"4px 0",borderBottom:"1px solid #f1f5f9"}}>
            <span style={{color:"#64748b"}}>時給</span>
            <div style={{display:"flex",alignItems:"center",gap:8}}>
              <span style={{fontWeight:700}}>{fmtCur(s.hourlyWage)}</span>
              <button onClick={()=>setShowWageHistory(showWageHistory===s.name?null:s.name)} style={{fontSize:9,padding:"2px 8px",borderRadius:4,border:"1px solid #d1d5db",background:showWageHistory===s.name?"#2563eb":"#fff",color:showWageHistory===s.name?"#fff":"#2563eb",cursor:"pointer",fontWeight:600}}>履歴</button>
            </div>
          </div>
          {showWageHistory===s.name&&<div style={{background:"#f8fafc",borderRadius:8,padding:10,marginTop:6,marginBottom:6}}>
            <div style={{fontSize:11,fontWeight:700,color:"#1e293b",marginBottom:6}}>時給変更履歴</div>
            {wageHistory.filter(w=>w.staff_name===s.name).length===0&&<div style={{fontSize:10,color:"#94a3b8",marginBottom:6}}>履歴なし（デフォルト時給 {fmtCur(s.hourlyWage)} が適用されます）</div>}
            {wageHistory.filter(w=>w.staff_name===s.name).map(w=><div key={w.id} style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"3px 0",borderBottom:"1px solid #e2e8f0"}}>
              <span style={{fontSize:11}}>{w.effective_date}〜</span>
              <div style={{display:"flex",alignItems:"center",gap:6}}>
                <span style={{fontSize:11,fontWeight:700}}>¥{(w.hourly_wage||0).toLocaleString()}</span>
                <button onClick={()=>deleteWageEntry(w.id)} style={{fontSize:8,padding:"1px 4px",borderRadius:3,border:"1px solid #fecaca",background:"#fff",color:"#dc2626",cursor:"pointer"}}>✕</button>
              </div>
            </div>)}
            <div style={{display:"flex",gap:6,marginTop:8,alignItems:"center"}}>
              <input type="date" value={wageForm.effective_date} onChange={e=>setWageForm(p=>({...p,effective_date:e.target.value}))} style={{fontSize:10,padding:"4px 6px",borderRadius:4,border:"1px solid #d1d5db",flex:1}}/>
              <input type="number" value={wageForm.hourly_wage} onChange={e=>setWageForm(p=>({...p,hourly_wage:e.target.value}))} placeholder="時給" style={{fontSize:10,padding:"4px 6px",borderRadius:4,border:"1px solid #d1d5db",width:70}}/>
              <button onClick={()=>addWageEntry(s.name)} style={{fontSize:10,padding:"4px 10px",borderRadius:4,border:"none",background:"#2563eb",color:"#fff",fontWeight:700,cursor:"pointer"}}>追加</button>
            </div>
          </div>}
          <div style={{display:"flex",justifyContent:"space-between",padding:"4px 0"}}>
            <span style={{color:"#64748b"}}>交通費 / 回</span><span style={{fontWeight:700}}>{fmtCur(s.transportCost)}</span>
          </div>
        </div>}
        {isR&&<div style={{fontSize:13,color:"#374151"}}>
          <div style={{display:"flex",justifyContent:"space-between",padding:"4px 0"}}>
            <span style={{color:"#64748b"}}>交通費 / 回</span><span style={{fontWeight:700}}>{fmtCur(s.transportCost)}</span>
          </div>
        </div>}
      </div>;
    })}

    {/* 編集・追加モーダル */}
    {showModal&&<div className="modal-overlay" onClick={cancel}><div className="modal-box" style={{maxWidth:380,padding:24}} onClick={e=>e.stopPropagation()}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
        <h4 style={{fontSize:16,fontWeight:800,margin:0}}>{adding?"スタッフ追加":"スタッフ編集"}</h4>
        <button onClick={cancel} style={{background:"none",border:"none",fontSize:18,color:"#94a3b8",cursor:"pointer"}}>✕</button>
      </div>
      <div style={{marginBottom:12}}>
        <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>氏名</label>
        <input value={form.name} onChange={e=>setForm(p=>({...p,name:e.target.value}))} placeholder="名前を入力" style={{width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}} autoFocus/>
      </div>
      <div style={{marginBottom:12}}>
        <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>雇用形態</label>
        <select value={form.type} onChange={e=>setForm(p=>({...p,type:e.target.value}))} style={{width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,background:"#fff"}}>
          <option>アルバイト</option><option>正社員</option>
        </select>
      </div>
      {form.type==="アルバイト"&&<>
        <div style={{marginBottom:12}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>時給(¥)</label>
          <input type="number" value={form.hourlyWage||""} onChange={e=>setForm(p=>({...p,hourlyWage:e.target.value}))} placeholder="1100" style={{width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}}/>
        </div>
        <div style={{marginBottom:12}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>交通費/回(¥)</label>
          <input type="number" value={form.transportCost||""} onChange={e=>setForm(p=>({...p,transportCost:e.target.value}))} placeholder="500" style={{width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}}/>
        </div>
      </>}
      {form.type==="正社員"&&<>
        <div style={{marginBottom:12}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>交通費/回(¥)</label>
          <input type="number" value={form.transportCost||""} onChange={e=>setForm(p=>({...p,transportCost:e.target.value}))} placeholder="0" style={{width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}}/>
        </div>
      </>}
      {/* 削除ボタン（編集時のみ） */}
      {editId!==null&&<button onClick={()=>{remove(editId);cancel();}} style={{width:"100%",padding:"10px",borderRadius:10,border:"none",background:"#fef2f2",color:"#dc2626",fontSize:13,fontWeight:700,cursor:"pointer",marginBottom:12}}>この登録を削除</button>}
      <div style={{display:"flex",gap:8}}>
        <button onClick={cancel} style={{flex:"0 0 auto",padding:"10px 16px",borderRadius:10,border:"1px solid #e2e8f0",background:"#fff",fontSize:13,fontWeight:600,color:"#64748b",cursor:"pointer"}}>キャンセル</button>
        <button onClick={save} disabled={!form.name.trim()} style={{flex:1,padding:"10px 16px",borderRadius:10,border:"none",background:form.name.trim()?"#2563eb":"#94a3b8",fontSize:13,fontWeight:700,color:"#fff",cursor:form.name.trim()?"pointer":"not-allowed"}}>保存</button>
      </div>
    </div></div>}
  </div>;
}

/* ==========================================
   申し送りBOX
   ========================================== */
function MemoBox({today}){
  const tomorrow=dOff(today,1);
  const[memos,setMemos]=React.useState([]);
  const[text,setText]=React.useState("");
  const[posting,setPosting]=React.useState(false);
  const[open,setOpen]=React.useState(false);
  const[listOpen,setListOpen]=React.useState(false);
  const[editId,setEditId]=React.useState(null);
  const[editText,setEditText]=React.useState("");
  const[imgPreview,setImgPreview]=React.useState("");
  const[imgFile,setImgFile]=React.useState(null);
  const[imgUploading,setImgUploading]=React.useState(false);
  const[lightbox,setLightbox]=React.useState("");
  const fileRef=React.useRef(null);
  const chRef=React.useRef(null);
  const load=()=>DB.fetchMemos(today).then(d=>setMemos(d||[])).catch(()=>{});
  React.useEffect(()=>{
    load();
    if(sb){chRef.current=sb.channel("tkm-memos-top").on("postgres_changes",{event:"*",schema:"public",table:"tkm_memos"},load).subscribe();}
    const iv=setInterval(load,30000);
    return()=>{clearInterval(iv);if(chRef.current)sb.removeChannel(chRef.current);};
  },[today]);
  const selectImg=(e)=>{
    const f=e.target.files[0];if(!f)return;
    setImgFile(f);
    const r=new FileReader();r.onload=(ev)=>setImgPreview(ev.target.result);r.readAsDataURL(f);
    e.target.value="";
  };
  const clearImg=()=>{setImgFile(null);setImgPreview("");};
  const post=async()=>{
    if(!text.trim()&&!imgFile)return;
    setPosting(true);
    let uploadedUrl="";
    if(imgFile){
      setImgUploading(true);
      try{uploadedUrl=await DB.uploadMemoImage(imgFile);}
      catch(e){alert("画像アップロード失敗: "+e.message);setImgUploading(false);setPosting(false);return;}
      setImgUploading(false);
    }
    await DB.postMemo(text.trim(),tomorrow,uploadedUrl).catch(()=>{});
    setText("");clearImg();setPosting(false);load();
  };
  const toggle=(id,done)=>DB.toggleMemoDone(id,done).then(load).catch(()=>{});
  const del=(id)=>{if(!window.confirm("削除しますか？"))return;DB.deleteMemo(id).then(load).catch(()=>{});};
  const startEdit=(m)=>{setEditId(m.id);setEditText(m.content);};
  const saveEdit=async(id)=>{if(!editText.trim())return;await sb.from("tkm_memos").update({content:editText.trim()}).eq("id",id).catch(()=>{});setEditId(null);setEditText("");load();};
  const cancelEdit=()=>{setEditId(null);setEditText("");};
  const todayList=memos.filter(m=>m.target_date===today);
  const tomList=memos.filter(m=>m.target_date===tomorrow);
  const todayUndone=todayList.filter(m=>!m.done);
  const tomUndone=tomList.filter(m=>!m.done);
  const MemoRow=({m,redStyle})=>{
    const isEditing=editId===m.id;
    if(isEditing)return(
      <div style={{marginBottom:4,padding:"7px 10px",borderRadius:8,background:"#fffbeb",border:"2px solid #f59e0b"}}>
        <textarea value={editText} onChange={e=>setEditText(e.target.value)} rows={3}
          style={{width:"100%",border:"1px solid #fde68a",borderRadius:6,padding:"6px 8px",fontSize:12,background:"#fff",outline:"none",resize:"vertical",boxSizing:"border-box"}}/>
        <div style={{display:"flex",gap:6,marginTop:5,justifyContent:"flex-end"}}>
          <button onClick={cancelEdit} style={{fontSize:10,padding:"3px 10px",borderRadius:6,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer",color:"#6b7280"}}>キャンセル</button>
          <button onClick={()=>saveEdit(m.id)} disabled={!editText.trim()} style={{fontSize:10,padding:"3px 10px",borderRadius:6,border:"none",background:"#f59e0b",color:"#fff",fontWeight:700,cursor:"pointer"}}>保存</button>
        </div>
      </div>
    );
    return(
      <div style={{display:"flex",gap:6,alignItems:"flex-start",padding:"6px 10px",borderRadius:8,
        background:m.done?"#f9fafb":redStyle?"#fef2f2":"#fffbeb",
        border:"1px solid "+(m.done?"#e5e7eb":redStyle?"#fecaca":"#fde68a"),
        marginBottom:4,opacity:m.done?0.5:1}}>
        <span style={{fontSize:12,flexShrink:0,marginTop:1}}>{m.done?"✅":redStyle?"🔴":"📌"}</span>
        <div style={{flex:1,minWidth:0}}>
          <div style={{fontSize:12,fontWeight:m.done?400:600,color:m.done?"#9ca3af":redStyle?"#7f1d1d":"#1c1917",
            lineHeight:1.4,wordBreak:"break-all",textDecoration:m.done?"line-through":"none",whiteSpace:"pre-wrap"}}>{m.content}</div>
          {m.image_url&&<img src={m.image_url} onClick={()=>setLightbox(m.image_url)}
            style={{marginTop:5,maxWidth:"100%",maxHeight:120,borderRadius:6,cursor:"pointer",objectFit:"cover",opacity:m.done?0.5:1}}
            alt="添付画像"/>}
        </div>
        <div style={{display:"flex",gap:3,flexShrink:0,alignSelf:"flex-start"}}>
          {!m.done&&<button onClick={()=>startEdit(m)} style={{fontSize:9,padding:"2px 6px",borderRadius:6,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer",color:"#6b7280"}}>✏️</button>}
          <button onClick={()=>toggle(m.id,m.done)} style={{fontSize:9,padding:"2px 7px",borderRadius:6,
            border:"1px solid "+(m.done?"#d1d5db":redStyle?"#fecaca":"#fde68a"),
            background:"#fff",cursor:"pointer",color:m.done?"#6b7280":redStyle?"#dc2626":"#92400e",whiteSpace:"nowrap"}}>
            {m.done?"戻す":"済み"}
          </button>
          <button onClick={()=>del(m.id)} style={{fontSize:9,padding:"2px 5px",borderRadius:6,border:"1px solid #e5e7eb",background:"#f9fafb",cursor:"pointer",color:"#9ca3af"}}>✕</button>
        </div>
      </div>
    );
  };
  return(
    <div style={{marginBottom:16}}>
      {/* ライトボックス */}
      {lightbox&&<div onClick={()=>setLightbox("")} style={{position:"fixed",inset:0,background:"rgba(0,0,0,.85)",zIndex:9999,display:"flex",alignItems:"center",justifyContent:"center",padding:16}}>
        <img src={lightbox} style={{maxWidth:"100%",maxHeight:"90vh",borderRadius:8,objectFit:"contain"}} alt="拡大"/>
        <button onClick={()=>setLightbox("")} style={{position:"absolute",top:16,right:16,background:"rgba(255,255,255,.2)",border:"none",color:"#fff",borderRadius:99,width:32,height:32,fontSize:16,cursor:"pointer"}}>✕</button>
      </div>}
      {todayUndone.length>0&&(
        <div style={{marginBottom:8,padding:"10px 12px",borderRadius:12,background:"#fef2f2",border:"2px solid #fecaca"}}>
          <div style={{fontSize:10,fontWeight:800,color:"#dc2626",marginBottom:6}}>🔴 本日の Handover（未対応）</div>
          {todayUndone.map(m=><MemoRow key={m.id} m={m} redStyle={true}/>)}
        </div>
      )}
      <div style={{marginBottom:8,borderRadius:12,border:"1px solid #e2e8f0",background:"#fff",overflow:"hidden",boxShadow:"0 1px 3px rgba(0,0,0,.05)"}}>
        <div onClick={()=>setOpen(o=>!o)} style={{background:"#f8fafc",padding:"10px 14px",display:"flex",alignItems:"center",gap:8,cursor:"pointer",userSelect:"none"}}>
          <span style={{fontSize:16}}>✏️</span>
          <span style={{fontSize:13,fontWeight:700,color:"#1e293b"}}>Handover を書く</span>
          <span style={{marginLeft:"auto",fontSize:11,color:"#94a3b8",fontWeight:700}}>{open?"▲":"▼"}</span>
        </div>
        {open&&<div style={{padding:"10px 12px",borderTop:"1px solid #e2e8f0"}}>
          <textarea value={text} onChange={e=>setText(e.target.value)} rows={3}
            placeholder={"例：216決済必要\n明日コーナン買い出し\n山田さん10時出勤変更"}
            style={{width:"100%",border:"1px solid #e2e8f0",borderRadius:8,padding:"8px 10px",fontSize:12,background:"#fff",outline:"none",resize:"vertical",boxSizing:"border-box",marginBottom:6}}/>
          {/* 画像プレビュー */}
          {imgPreview&&<div style={{position:"relative",display:"inline-block",marginBottom:8}}>
            <img src={imgPreview} style={{maxHeight:100,maxWidth:"100%",borderRadius:6,objectFit:"cover"}} alt="preview"/>
            <button onClick={clearImg} style={{position:"absolute",top:-6,right:-6,width:18,height:18,borderRadius:99,background:"#ef4444",border:"none",color:"#fff",fontSize:10,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",lineHeight:1}}>✕</button>
          </div>}
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
            <div>
              <input ref={fileRef} type="file" accept="image/*" onChange={selectImg} style={{display:"none"}}/>
              <button onClick={()=>fileRef.current.click()} style={{fontSize:11,padding:"5px 10px",borderRadius:8,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer",color:"#6b7280",display:"flex",alignItems:"center",gap:4}}>
                📷 {imgFile?"変更":"写真を添付"}
              </button>
            </div>
            <button onClick={post} disabled={(!text.trim()&&!imgFile)||posting}
              style={{padding:"7px 18px",borderRadius:8,border:"none",
                background:(text.trim()||imgFile)?"#f59e0b":"#d1d5db",
                color:"#fff",fontWeight:700,fontSize:12,cursor:(text.trim()||imgFile)?"pointer":"default"}}>
              {imgUploading?"アップロード中...":posting?"投稿中...":"投稿"}
            </button>
          </div>
        </div>}
      </div>
      {tomList.length>0&&<div style={{marginBottom:8,borderRadius:12,border:"1px solid #e2e8f0",background:"#fff",overflow:"hidden",boxShadow:"0 1px 3px rgba(0,0,0,.05)"}}>
        <div onClick={()=>setListOpen(o=>!o)} style={{background:"#f8fafc",padding:"10px 14px",display:"flex",alignItems:"center",gap:8,cursor:"pointer",userSelect:"none"}}>
          <span style={{fontSize:14}}>📌</span>
          <span style={{fontSize:13,fontWeight:700,color:"#1e293b"}}>明日の Handover</span>
          <span style={{marginLeft:"auto",display:"flex",alignItems:"center",gap:6}}>
            <span style={{background:"#f59e0b",color:"#fff",borderRadius:99,fontSize:9,fontWeight:700,padding:"2px 8px"}}>{tomList.length}件</span>
            <span style={{fontSize:11,color:"#94a3b8",fontWeight:700}}>{listOpen?"▲":"▼"}</span>
          </span>
        </div>
        {listOpen&&<div style={{padding:"8px 12px",borderTop:"1px solid #e2e8f0"}}>
          {tomList.map(m=><MemoRow key={m.id} m={m} redStyle={false}/>)}
        </div>}
      </div>}
    </div>
  );
}
/* ==========================================
   勤怠管理
   ========================================== */
function AttendanceManager({shifts,staff,today,attendance,onAttendanceChange}){
  const WK=["日","月","火","水","木","金","土"];
  const todayYM=toYM(today);
  const[viewYM,setViewYM]=useState(todayYM);
  const[selStaff,setSelStaff]=useState(staff[0]?.name||"");
  const[subTab,setSubTab]=useState("budget"); // "budget" | "actual" | "detail"
  const[editDay,setEditDay]=useState(null);
  const[staffFilter,setStaffFilter]=useState("all"); // "all"|"part"|"full"
  const dim=daysInMonth(viewYM);
  const[vy,vmo]=viewYM.split("-").map(Number);

  const[syncing,setSyncing]=useState(false);
  const[lastSync,setLastSync]=useState(null);
  const[wageHistory,setWageHistory]=useState([]);

  // マウント時＋手動同期: DBから最新のシフト＋勤怠＋時給履歴を再取得
  const forceSync=React.useCallback(async()=>{
    setSyncing(true);
    try{
      const[shDB,attDB,whDB]=await Promise.all([DB.fetchShifts(),DB.fetchAttendance(),DB.fetchWageHistory()]);
      if(shDB){
        // 親のshiftsを直接更新（setShiftsSync相当）
        window.__spkForceShifts&&window.__spkForceShifts(shDB);
      }
      if(attDB)onAttendanceChange(attDB);
      if(whDB)setWageHistory(whDB);
      setLastSync(new Date());
    }catch(e){console.error("[forceSync]",e);}
    setSyncing(false);
  },[onAttendanceChange]);

  React.useEffect(()=>{forceSync();},[]);

  // 実働時間計算ヘルパー
  const calcHours=(start,end)=>{
    if(!start||!end)return 0;
    const[sh,sm]=start.split(":").map(Number);
    const[eh,em]=end.split(":").map(Number);
    const diff=(eh*60+em)-(sh*60+sm);
    return diff>0?Math.round(diff/60*10)/10:0;
  };

  // 全スタッフの月間データ生成
  const allStaffData=useMemo(()=>{
    const result={};
    staff.forEach(s=>{
      const days=[];
      for(let d=1;d<=dim;d++){
        const ds=viewYM+"-"+String(d).padStart(2,"0");
        const dow=new Date(vy,vmo-1,d).getDay();
        const sh=(shifts[ds]||[]).find(x=>x.name===s.name);
        const attKey=ds+"_"+s.name;
        const att=attendance[attKey]||null;
        days.push({date:ds,day:d,dow,shift:sh,att});
      }
      // 予算（シフトベース）
      let budgetDays=0,budgetHours=0;
      days.forEach(d=>{
        if(d.shift&&d.shift.symbol!=="公"&&d.shift.symbol!=="希"&&d.shift.symbol!=="有"){
          budgetDays++;budgetHours+=calcHours(d.shift.start||"09:00",d.shift.end||"18:00");
        }
      });
      const isP=s.type==="アルバイト";
      // 予算: 日ごとの時給を参照して計算
      let budgetWage=0;
      if(isP){
        days.forEach(d=>{
          if(d.shift&&d.shift.symbol!=="公"&&d.shift.symbol!=="希"&&d.shift.symbol!=="有"){
            const h=calcHours(d.shift.start||"09:00",d.shift.end||"18:00");
            const w=DB.getWageForDate(wageHistory,s.name,d.date)||(s.hourlyWage||0);
            budgetWage+=w*h;
            d._wage=w; // 日ごとの時給を保持
          }
        });
      }else{budgetWage=s.monthlySalary||0;}
      const budgetTransport=(s.transportCost||0)*budgetDays;
      // 実績（勤怠承認ベース）— 欠勤は出勤0扱い
      let actualDays=0,actualHours=0,absentDays=0,actualWage=0;
      days.forEach(d=>{
        if(d.att&&d.att.approved){
          if(d.att.absent){absentDays++;return;}
          if(d.att.memo&&d.att.memo.startsWith("協議中"))return;
          actualDays++;
          const h=calcHours(d.att.start,d.att.end);
          actualHours+=h;
          if(isP){
            const w=DB.getWageForDate(wageHistory,s.name,d.date)||(s.hourlyWage||0);
            actualWage+=w*h;
            d._wage=w;
          }
        }
      });
      if(!isP)actualWage=s.monthlySalary||0;
      const actualTransport=(s.transportCost||0)*actualDays;
      result[s.name]={days,budgetDays,budgetHours,budgetWage:Math.round(budgetWage),budgetTransport,budgetTotal:Math.round(budgetWage)+budgetTransport,
        actualDays,actualHours,actualWage:Math.round(actualWage),actualTransport,actualTotal:Math.round(actualWage)+actualTransport,isP,absentDays};
    });
    return result;
  },[staff,shifts,attendance,viewYM,dim,vy,vmo,wageHistory]);

  // シフトから勤怠レコード自動生成（シフト変更時にも反映）
  // 注意: attendanceをrefで参照し、依存配列に入れないことで無限ループを防止
  const genAttFromShifts=React.useCallback((curAtt)=>{
    const toCreate=[];
    const toUpdate=[];
    staff.forEach(s=>{
      for(let d=1;d<=dim;d++){
        const ds=viewYM+"-"+String(d).padStart(2,"0");
        const sh=(shifts[ds]||[]).find(x=>x.name===s.name);
        const attKey=ds+"_"+s.name;
        const att=curAtt[attKey]||null;
        if(sh&&!att){
          toCreate.push({date:ds,name:s.name,start:sh.start||"09:00",end:sh.end||"18:00",approved:false,memo:""});
        }else if(sh&&att&&!att.approved){
          const newStart=sh.start||"09:00";const newEnd=sh.end||"18:00";
          if(att.start!==newStart||att.end!==newEnd){
            toUpdate.push({...att,start:newStart,end:newEnd});
          }
        }
      }
    });
    if(toCreate.length>0||toUpdate.length>0){
      const next={...curAtt};
      toCreate.forEach(r=>{next[r.date+"_"+r.name]=r;});
      toUpdate.forEach(r=>{next[r.date+"_"+r.name]=r;});
      onAttendanceChange(next);
      if(toCreate.length>0)DB.saveAttendanceBatch(toCreate);
      if(toUpdate.length>0)DB.saveAttendanceBatch(toUpdate);
    }
  },[shifts,staff,viewYM,dim,onAttendanceChange]);
  // shiftsが変わったら最新のattendanceで自動生成を実行
  React.useEffect(()=>{genAttFromShifts(attendance);},[shifts,viewYM]);

  const approve=(date,name)=>{
    if(!window.confirm("承認を実行しますか？"))return;
    const key=date+"_"+name;const cur=attendance[key];if(!cur)return;
    const updated={...cur,approved:true};
    onAttendanceChange({...attendance,[key]:updated});
    DB.saveAttendance(updated);
  };
  const approveAll=(name)=>{
    if(!window.confirm("全承認を実行しますか？"))return;
    const d=allStaffData[name];if(!d)return;
    const next={...attendance};const batch=[];
    d.days.forEach(day=>{
      if(day.att&&!day.att.approved){
        const key=day.date+"_"+name;
        const updated={...day.att,approved:true};
        next[key]=updated;batch.push(updated);
      }
    });
    onAttendanceChange(next);if(batch.length)DB.saveAttendanceBatch(batch);
  };
  const saveEdit=()=>{
    if(!editDay)return;
    if(!window.confirm("保存を実行しますか？"))return;
    const key=editDay.date+"_"+editDay.name;
    const origMemo=attendance[key]?.memo||"";
    const isKyogi=origMemo.startsWith("協議中");
    // 協議中の場合は解決→memo="打刻" approved=true
    const memo=isKyogi?"打刻":(editDay.memo||"");
    const approved=isKyogi?true:(attendance[key]?.approved||false);
    const updated={date:editDay.date,name:editDay.name,start:editDay.start,end:editDay.end,approved,memo,absent:!!editDay.absent};
    onAttendanceChange({...attendance,[key]:updated});
    DB.saveAttendance(updated);setEditDay(null);
  };

  // 予算総額（フィルター連動）
  const filteredStaff=useMemo(()=>staff.filter(s=>staffFilter==="all"?true:staffFilter==="part"?s.type==="アルバイト":s.type==="正社員"),[staff,staffFilter]);
  const budgetGrandTotal=useMemo(()=>{
    let payTotal=0,transTotal=0,actualRef=0;
    filteredStaff.forEach(s=>{const d=allStaffData[s.name];if(d){payTotal+=d.budgetWage;transTotal+=d.budgetTransport;actualRef+=d.actualTotal;}});
    return{payTotal,transTotal,grandTotal:payTotal+transTotal,actualRef};
  },[allStaffData,filteredStaff]);

  const cardS={background:"#fff",borderRadius:14,padding:16,border:"1px solid #e2e8f0",marginBottom:12,boxShadow:"0 1px 3px rgba(0,0,0,.05)"};
  const boxS=(bg)=>({background:bg||"#f0f9ff",borderRadius:10,padding:"10px 14px",textAlign:"center",flex:1});

  // 給与カラム不在チェック
  const wageColsMissing=DB._staffHasWageCols===false;

  return <div style={{maxWidth:640,margin:"0 auto"}}>
    {/* 給与カラム不在の警告 */}
    {wageColsMissing&&<div style={{background:"#fef2f2",border:"2px solid #dc2626",borderRadius:10,padding:12,marginBottom:12}}>
      <div style={{fontSize:13,fontWeight:800,color:"#dc2626",marginBottom:4}}>⚠️ 給与データがDBに未設定</div>
      <div style={{fontSize:11,color:"#991b1b",lineHeight:1.6}}>
        Supabase staffテーブルに給与カラムがありません。<br/>
        Supabase &gt; SQL Editor で以下を実行してください：
      </div>
      <div style={{background:"#1e293b",color:"#22d3ee",padding:8,borderRadius:6,fontSize:10,fontFamily:"monospace",marginTop:6,lineHeight:1.8,overflowX:"auto",whiteSpace:"pre"}}>
{`ALTER TABLE tkm_staff ADD COLUMN IF NOT EXISTS hourly_wage INTEGER DEFAULT 0;
ALTER TABLE tkm_staff ADD COLUMN IF NOT EXISTS transport_cost INTEGER DEFAULT 0;
ALTER TABLE tkm_staff ADD COLUMN IF NOT EXISTS monthly_salary INTEGER DEFAULT 0;`}
      </div>
      <div style={{fontSize:10,color:"#991b1b",marginTop:6}}>実行後にアプリをリロードすると給与データが自動同期されます。</div>
    </div>}
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
      <h3 style={{fontSize:16,fontWeight:800,margin:0}}>給与計算</h3>
      <button onClick={forceSync} disabled={syncing} style={{padding:"4px 12px",borderRadius:8,fontSize:11,fontWeight:700,border:"1px solid #e2e8f0",background:syncing?"#f1f5f9":"#fff",color:syncing?"#94a3b8":"#2563eb",cursor:syncing?"wait":"pointer"}}>
        {syncing?"同期中...":"🔄 同期"}
      </button>
    </div>
    {lastSync&&<div style={{fontSize:9,color:"#94a3b8",textAlign:"right",marginTop:-10,marginBottom:6}}>最終同期: {lastSync.toLocaleTimeString()}</div>}
    {/* 月選択 */}
    <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:12}}>
      <button onClick={()=>setViewYM(ymOff(viewYM,-1))} style={{padding:"4px 10px",fontSize:16,background:"#f1f5f9",border:"1px solid #e2e8f0",borderRadius:6,cursor:"pointer",fontWeight:700,color:"#2563eb"}}>&lt;</button>
      <div style={{fontSize:16,fontWeight:900,color:"#1e293b"}}>{ymLabel(viewYM)}</div>
      <button onClick={()=>setViewYM(ymOff(viewYM,1))} style={{padding:"4px 10px",fontSize:16,background:"#f1f5f9",border:"1px solid #e2e8f0",borderRadius:6,cursor:"pointer",fontWeight:700,color:"#2563eb"}}>&gt;</button>
    </div>
    {/* サブタブ */}
    <div style={{display:"flex",gap:0,marginBottom:14,background:"#f1f5f9",borderRadius:10,padding:3}}>
      {[{id:"budget",l:"予算（シフト）"},{id:"actual",l:"実績（勤怠）"},{id:"detail",l:"給与明細"}].map(t=>
        <button key={t.id} onClick={()=>setSubTab(t.id)} style={{flex:1,padding:"7px 0",borderRadius:8,fontSize:12,fontWeight:700,border:"none",cursor:"pointer",
          background:subTab===t.id?"#fff":"transparent",color:subTab===t.id?"#1e293b":"#94a3b8",
          boxShadow:subTab===t.id?"0 1px 3px rgba(0,0,0,.1)":"none"}}>{t.l}</button>
      )}
    </div>

    {/* スタッフ種別フィルター */}
    <div style={{display:"flex",gap:4,marginBottom:10}}>
      {[{id:"all",l:"全員"},{id:"part",l:"アルバイト"},{id:"full",l:"正社員"}].map(f=>
        <button key={f.id} onClick={()=>setStaffFilter(f.id)} style={{padding:"4px 12px",borderRadius:16,fontSize:11,fontWeight:700,border:"none",cursor:"pointer",
          background:staffFilter===f.id?"#1e293b":"#f1f5f9",color:staffFilter===f.id?"#fff":"#64748b"}}>{f.l}</button>)}
    </div>

    {/* ====== 予算（シフト）タブ ====== */}
    {subTab==="budget"&&<div>
      {staff.filter(s=>staffFilter==="all"?true:staffFilter==="part"?s.type==="アルバイト":s.type==="正社員").map(s=>{
        const d=allStaffData[s.name];if(!d)return null;
        const isP=d.isP;
        return <div key={s.name} style={cardS}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
            <div style={{display:"flex",alignItems:"center",gap:8}}>
              <span style={{fontSize:14,fontWeight:800}}>{s.name}</span>
              <span style={{fontSize:10,fontWeight:700,padding:"2px 10px",borderRadius:12,background:isP?"#fef3c7":"#dbeafe",color:isP?"#92400e":"#1d4ed8"}}>{s.type}</span>
            </div>
            <span style={{fontSize:11,color:"#64748b"}}>{d.budgetDays}日 / {d.budgetHours.toFixed(1)}h</span>
          </div>
          <div style={{display:"flex",gap:8}}>
            <div style={boxS("#f0f9ff")}>
              <div style={{fontSize:18,fontWeight:900,color:"#1e40af"}}>¥{d.budgetWage.toLocaleString()}</div>
              <div style={{fontSize:10,color:"#64748b",fontWeight:600}}>支給</div>
              {isP&&<div style={{fontSize:9,color:"#94a3b8"}}>¥{(s.hourlyWage||0).toLocaleString()}×{d.budgetHours.toFixed(1)}h</div>}
            </div>
            <div style={boxS("#fffbeb")}>
              <div style={{fontSize:18,fontWeight:900,color:"#d97706"}}>¥{d.budgetTransport.toLocaleString()}</div>
              <div style={{fontSize:10,color:"#64748b",fontWeight:600}}>交通費</div>
              <div style={{fontSize:9,color:"#94a3b8"}}>¥{(s.transportCost||0).toLocaleString()}×{d.budgetDays}日</div>
            </div>
            <div style={boxS("#f8fafc")}>
              <div style={{fontSize:18,fontWeight:900,color:"#1e293b"}}>¥{d.budgetTotal.toLocaleString()}</div>
              <div style={{fontSize:10,color:"#64748b",fontWeight:600}}>合計</div>
            </div>
          </div>
        </div>;
      })}
      {/* 予算総額 */}
      <div style={{...cardS,background:"#f0f4ff",border:"2px solid #bfdbfe"}}>
        <div style={{display:"flex",alignItems:"baseline",justifyContent:"space-between",marginBottom:8}}>
          <span style={{fontSize:14,fontWeight:900}}>予算 総額</span>
          <span style={{fontSize:24,fontWeight:900,color:"#dc2626"}}>¥{budgetGrandTotal.grandTotal.toLocaleString()}</span>
        </div>
        <div style={{display:"flex",justifyContent:"space-between",fontSize:12,color:"#475569",marginBottom:2}}>
          <span>支給計</span><span style={{fontWeight:700}}>¥{budgetGrandTotal.payTotal.toLocaleString()}</span>
          <span>交通費計</span><span style={{fontWeight:700,color:"#d97706"}}>¥{budgetGrandTotal.transTotal.toLocaleString()}</span>
        </div>
        <div style={{display:"flex",justifyContent:"space-between",fontSize:12,color:"#475569",borderTop:"1px solid #dbeafe",paddingTop:4,marginTop:4}}>
          <span>実績 参考</span><span style={{fontWeight:700}}>¥{budgetGrandTotal.actualRef.toLocaleString()}</span>
        </div>
        <div style={{display:"flex",justifyContent:"space-between",fontSize:12}}>
          <span style={{color:"#475569"}}>差異</span>
          <span style={{fontWeight:900,color:budgetGrandTotal.grandTotal-budgetGrandTotal.actualRef>=0?"#dc2626":"#059669"}}>¥{(budgetGrandTotal.grandTotal-budgetGrandTotal.actualRef>=0?"-":"")}{Math.abs(budgetGrandTotal.grandTotal-budgetGrandTotal.actualRef).toLocaleString()}</span>
        </div>
      </div>
    </div>}

    {/* ====== 実績（勤怠）タブ ====== */}
    {subTab==="actual"&&<div>
      {/* スタッフ選択 */}
      <div style={{display:"flex",gap:6,flexWrap:"wrap",marginBottom:12}}>
        {staff.filter(s=>staffFilter==="all"?true:staffFilter==="part"?s.type==="アルバイト":s.type==="正社員").map(s=><button key={s.name} onClick={()=>setSelStaff(s.name)} style={{
          padding:"6px 14px",borderRadius:20,fontSize:12,fontWeight:700,border:"none",cursor:"pointer",transition:"all .15s",
          background:selStaff===s.name?"#1e293b":"#f1f5f9",color:selStaff===s.name?"#fff":"#64748b"
        }}>{s.name}</button>)}
      </div>
      {(()=>{
        const sd=allStaffData[selStaff];if(!sd)return null;
        const unapproved=sd.days.filter(d=>d.shift&&d.att&&!d.att.approved).length;
        return <>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
            <div style={{fontSize:13,fontWeight:700}}>{selStaff} ー {ymLabel(viewYM)}</div>
            {unapproved>0?
              <button onClick={()=>approveAll(selStaff)} style={{padding:"5px 14px",borderRadius:8,background:"#059669",color:"#fff",border:"none",fontSize:11,fontWeight:700,cursor:"pointer"}}>全承認 ({sd.days.filter(d=>d.shift).length}件)</button>:
              <span style={{padding:"5px 14px",borderRadius:8,background:"#f0fdf4",color:"#059669",fontSize:11,fontWeight:700}}>全承認済 ✅</span>
            }
          </div>
          {sd.days.map(d=>{
            const isHoliday=d.dow===0;const isSat=d.dow===6;
            const rowBg=isHoliday?"#fef2f2":isSat?"#eff6ff":"#fff";
            const dayColor=isHoliday?"#dc2626":isSat?"#2563eb":"#374151";
            const hasShift=!!d.shift;const att=d.att;const isApproved=att&&att.approved;const isAbsent=att&&att.absent;
            const isKyogi=att&&att.memo&&att.memo.startsWith("協議中");
            const kyogiDetail=isKyogi?att.memo.replace(/^協議中:/,""):"";
            const timeStr=isAbsent?"欠勤":att?(att.start+"〜"+att.end):(hasShift?(d.shift.start+"〜"+d.shift.end):"ー");
            return <div key={d.date} style={{borderBottom:"1px solid #f1f5f9",background:isKyogi?"#fffbeb":isAbsent?"#fef2f2":rowBg}}>
              <div style={{display:"flex",alignItems:"center",padding:"8px 12px",gap:8}}>
                <div style={{width:30,textAlign:"center"}}>
                  <div style={{fontSize:14,fontWeight:800,color:dayColor}}>{d.day}</div>
                  <div style={{fontSize:9,color:dayColor,fontWeight:600}}>{WK[d.dow]}</div>
                </div>
                <div style={{flex:1,fontSize:13,color:isKyogi?"#92400e":isAbsent?"#dc2626":hasShift?"#374151":"#d1d5db",fontWeight:hasShift?600:400}}>{timeStr}</div>
                {hasShift&&<div style={{display:"flex",gap:6}}>
                  {isKyogi&&<span style={{padding:"4px 8px",borderRadius:6,background:"#f59e0b",color:"#fff",fontSize:10,fontWeight:700}}>協議中</span>}
                  {!isKyogi&&isAbsent&&<span style={{padding:"4px 8px",borderRadius:6,background:"#dc2626",color:"#fff",fontSize:10,fontWeight:700}}>欠勤</span>}
                  {!isKyogi&&!isAbsent&&(isApproved?
                    <span style={{padding:"4px 10px",borderRadius:6,background:"#059669",color:"#fff",fontSize:10,fontWeight:700}}>承認</span>:
                    <button onClick={()=>approve(d.date,selStaff)} style={{padding:"4px 10px",borderRadius:6,background:"#dcfce7",color:"#059669",border:"1px solid #bbf7d0",fontSize:10,fontWeight:700,cursor:"pointer"}}>承認</button>
                  )}
                  <button onClick={()=>setEditDay({date:d.date,name:selStaff,start:att?.start||d.shift.start||"09:00",end:att?.end||d.shift.end||"18:00",memo:att?.memo||"",absent:att?.absent||false})} style={{padding:"4px 10px",borderRadius:6,background:isKyogi?"#f59e0b":"#f1f5f9",color:isKyogi?"#fff":"#64748b",border:isKyogi?"none":"1px solid #e2e8f0",fontSize:10,fontWeight:700,cursor:"pointer"}}>{isKyogi?"解決":"編集"}</button>
                </div>}
              </div>
              {isKyogi&&<div style={{padding:"4px 12px 8px 52px",fontSize:11,color:"#92400e",fontWeight:600}}>📝 {kyogiDetail}</div>}
            </div>;
          })}
        </>;
      })()}
    </div>}

    {/* ====== 給与明細タブ ====== */}
    {subTab==="detail"&&<div>
      {staff.filter(s=>staffFilter==="all"?true:staffFilter==="part"?s.type==="アルバイト":s.type==="正社員").map(s=>{
        const d=allStaffData[s.name];if(!d)return null;
        const si=s;const isP=d.isP;
        return <div key={s.name} style={cardS}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
            <div style={{display:"flex",alignItems:"center",gap:8}}>
              <span style={{fontSize:14,fontWeight:800}}>{s.name}</span>
              <span style={{fontSize:10,fontWeight:700,padding:"2px 10px",borderRadius:12,background:isP?"#fef3c7":"#dbeafe",color:isP?"#92400e":"#1d4ed8"}}>{s.type}</span>
            </div>
            <span style={{fontSize:11,color:"#64748b"}}>{d.actualDays}日 / {d.actualHours.toFixed(1)}h{d.absentDays>0?<span style={{color:"#dc2626",fontWeight:700}}> (欠勤{d.absentDays})</span>:""}</span>
          </div>
          <div style={{fontSize:13}}>
            {isP?<>
              {(()=>{
                // 日ごとの時給を集計して表示
                const wageBreakdown={};
                d.days.forEach(dy=>{if(dy.att&&dy.att.approved&&!dy.att.absent&&!(dy.att.memo&&dy.att.memo.startsWith("協議中"))){const w=dy._wage||(si.hourlyWage||0);const h=calcHours(dy.att.start,dy.att.end);if(!wageBreakdown[w])wageBreakdown[w]={hours:0,total:0};wageBreakdown[w].hours+=h;wageBreakdown[w].total+=w*h;}});
                const rates=Object.keys(wageBreakdown).map(Number).sort((a,b)=>a-b);
                if(rates.length<=1){
                  return <div style={{display:"flex",justifyContent:"space-between",padding:"6px 0",borderBottom:"1px solid #f1f5f9"}}>
                    <span style={{color:"#64748b"}}>時給</span><span style={{fontWeight:600}}>¥{(rates[0]||si.hourlyWage||0).toLocaleString()} × {d.actualHours.toFixed(1)}h</span>
                  </div>;
                }
                return rates.map(w=><div key={w} style={{display:"flex",justifyContent:"space-between",padding:"4px 0",borderBottom:"1px solid #f1f5f9"}}>
                  <span style={{color:"#64748b",fontSize:12}}>時給 ¥{w.toLocaleString()}</span>
                  <span style={{fontWeight:600,fontSize:12}}>{wageBreakdown[w].hours.toFixed(1)}h = ¥{Math.round(wageBreakdown[w].total).toLocaleString()}</span>
                </div>);
              })()}
              <div style={{display:"flex",justifyContent:"space-between",padding:"6px 0",borderBottom:"1px solid #f1f5f9"}}>
                <span style={{color:"#64748b"}}>基本給</span><span style={{fontWeight:700}}>¥{d.actualWage.toLocaleString()}</span>
              </div>
            </>:null}
            <div style={{display:"flex",justifyContent:"space-between",padding:"6px 0",borderBottom:"1px solid #f1f5f9"}}>
              <span style={{color:"#64748b"}}>交通費 (¥{(si.transportCost||0).toLocaleString()}×{d.actualDays}日)</span>
              <span style={{fontWeight:600,color:"#d97706"}}>¥{d.actualTransport.toLocaleString()}</span>
            </div>
            <div style={{display:"flex",justifyContent:"space-between",padding:"8px 0",marginTop:4,borderTop:"2px solid #e2e8f0"}}>
              <span style={{fontWeight:900,fontSize:14}}>支給額</span>
              <span style={{fontWeight:900,fontSize:18,color:"#1e40af"}}>¥{d.actualTotal.toLocaleString()}</span>
            </div>
          </div>
        </div>;
      })}
    </div>}

    {/* 編集モーダル */}
    {editDay&&<div className="modal-overlay" onClick={()=>setEditDay(null)}><div className="modal-box" style={{maxWidth:320,padding:20}} onClick={e=>e.stopPropagation()}>
      <h4 style={{fontSize:14,fontWeight:800,margin:"0 0 14px"}}>{editDay.name} — {fmtD(editDay.date)}</h4>
      {editDay.memo&&editDay.memo.startsWith("協議中")&&<div style={{background:"#fffbeb",border:"1px solid #f59e0b",borderRadius:10,padding:"10px 12px",marginBottom:14}}>
        <div style={{fontSize:11,fontWeight:700,color:"#b45309",marginBottom:4}}>📝 スタッフからの修正リクエスト</div>
        <div style={{fontSize:12,color:"#92400e"}}>{editDay.memo.replace(/^協議中:/,"")}</div>
        <div style={{fontSize:10,color:"#b45309",marginTop:6}}>↓ 時間を修正して「解決・保存」すると承認済みになります</div>
      </div>}
      {/* 欠勤チェック */}
      <div style={{marginBottom:14}}>
        <label style={{display:"flex",alignItems:"center",gap:8,cursor:"pointer",padding:"10px 12px",borderRadius:10,border:editDay.absent?"2px solid #dc2626":"1px solid #e2e8f0",background:editDay.absent?"#fef2f2":"#fff"}}>
          <input type="checkbox" checked={!!editDay.absent} onChange={e=>setEditDay(p=>({...p,absent:e.target.checked}))} style={{width:18,height:18,accentColor:"#dc2626"}}/>
          <div>
            <div style={{fontSize:13,fontWeight:700,color:editDay.absent?"#dc2626":"#374151"}}>欠勤</div>
            <div style={{fontSize:10,color:"#94a3b8"}}>出勤カウント0・時間0扱い</div>
          </div>
        </label>
      </div>
      {/* 時間入力（欠勤でない場合のみ） */}
      {!editDay.absent&&<>
        <div style={{marginBottom:10}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>開始時間</label>
          <input type="time" value={editDay.start} onChange={e=>setEditDay(p=>({...p,start:e.target.value}))} style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}}/>
        </div>
        <div style={{marginBottom:10}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>終了時間</label>
          <input type="time" value={editDay.end} onChange={e=>setEditDay(p=>({...p,end:e.target.value}))} style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}}/>
        </div>
      </>}
      <div style={{marginBottom:14}}>
        <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>メモ</label>
        <input value={editDay.memo||""} onChange={e=>setEditDay(p=>({...p,memo:e.target.value}))} placeholder="備考" style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:13,boxSizing:"border-box"}}/>
      </div>
      <div style={{display:"flex",gap:8}}>
        <button onClick={()=>setEditDay(null)} style={{flex:"0 0 auto",padding:"8px 14px",borderRadius:8,border:"1px solid #e2e8f0",background:"#fff",fontSize:12,fontWeight:600,color:"#64748b",cursor:"pointer"}}>キャンセル</button>
        <button onClick={saveEdit} style={{flex:1,padding:"8px 14px",borderRadius:8,border:"none",background:editDay.memo&&editDay.memo.startsWith("協議中")?"#f59e0b":"#2563eb",fontSize:12,fontWeight:700,color:"#fff",cursor:"pointer"}}>{editDay.memo&&editDay.memo.startsWith("協議中")?"✅ 解決・保存":"保存"}</button>
      </div>
    </div></div>}
  </div>;
}

/* ==========================================
   出勤簿（月次カレンダー+ CSV取込）
   ========================================== */
function ShiftCalendar({shifts,onShiftsChange,today,staff,sbSaveShift,reservations,fleet,vehicles}){
  const todayYM=toYM(today);const[viewYM,setViewYM]=useState(todayYM);const WK=["日","月","火","水","木","金","土"];
  const SYMBOLS=["●","希","公","有","出",""];
  const SHIFT_OPTIONS=[
    {s:"●",label:"出勤",color:"#2563eb",bg:"#D4EBFA"},
    {s:"公",label:"公休",color:"#64748b",bg:"#E8E8E8"},
    {s:"希",label:"希望休",color:"#f59e0b",bg:"#FFF3CD"},
    {s:"有",label:"有給",color:"#059669",bg:"#D1FAE5"},
    {s:"出",label:"出張",color:"#7c3aed",bg:"#D4EDDA"},
  ];
  const maxYM=ymOff(todayYM,3);const dim=daysInMonth(viewYM);const[y,mo]=viewYM.split("-").map(Number);
  const getShift=(date)=>shifts[date]||[];
  const regularStaff=staff.filter(s=>s.type==="正社員");const partTimeStaff=staff.filter(s=>s.type==="アルバイト");
  const[cellEdit,setCellEdit]=useState(null); // {dateStr,name,type,symbol,start,end,isNew}

  // 日本の祝日判定（簡易版）
  const jpHolidays=useMemo(()=>{
    const hSet=new Set();
    const addH=(m,d)=>hSet.add(`${viewYM.split("-")[0]}-${String(m).padStart(2,"0")}-${String(d).padStart(2,"0")}`);
    const yr=Number(viewYM.split("-")[0]);
    addH(1,1);addH(1,13);addH(2,11);addH(2,23);addH(3,20);addH(4,29);addH(5,3);addH(5,4);addH(5,5);addH(5,6);
    addH(7,21);addH(8,11);addH(9,15);addH(9,23);addH(10,13);addH(11,3);addH(11,23);
    // 振替休日: 祝日が日曜なら翌月曜
    const all=[...hSet];all.forEach(ds=>{if(new Date(ds).getDay()===0){
      const nd=new Date(ds);nd.setDate(nd.getDate()+1);hSet.add(nd.toISOString().slice(0,10));
    }});
    return hSet;
  },[viewYM]);
  const isHoliday=(ds)=>jpHolidays.has(ds);

  // Supabase同期付きシフト更新
  const updateShifts=(next)=>{onShiftsChange(next);if(sbSaveShift){Object.entries(next).forEach(([date,arr])=>{if(arr!==shifts[date]){
    const newNames=new Set(arr.map(s=>s.name));
    const prev=shifts[date]||[];
    prev.forEach(s=>{if(!newNames.has(s.name))DB.deleteShift(date,s.name);});
    arr.forEach(s=>sbSaveShift(date,s.name,s));
  }});}};
  const _onSC=updateShifts;

  // セルタップ → 編集モーダル表示
  const handleCellClick=(dateStr,name,type)=>{
    const cur=getShift(dateStr);const existing=cur.find(s=>s.name===name);
    if(existing){
      setCellEdit({dateStr,name,type,symbol:existing.symbol||"●",start:existing.start||"09:00",end:existing.end||"18:00",status:existing.status||"確定",isNew:false});
    }else{
      setCellEdit({dateStr,name,type,symbol:type==="正社員"?"●":"",start:"09:00",end:"18:00",status:type==="アルバイト"?"申請":"確定",isNew:true});
    }
  };

  // セル編集保存
  const saveCellEdit=()=>{
    if(!cellEdit)return;
    if(!window.confirm("保存を実行しますか？"))return;
    const{dateStr,name,type,symbol,start,end,status,isNew}=cellEdit;
    const cur=getShift(dateStr);
    const entry={name,type,symbol:type==="正社員"?symbol:"",start,end,status:type==="アルバイト"?(status||"確定"):"確定"};
    if(isNew){
      _onSC({...shifts,[dateStr]:[...cur,entry]});
    }else{
      _onSC({...shifts,[dateStr]:cur.map(s=>s.name===name?entry:s)});
    }
    setCellEdit(null);
  };

  // セル削除
  const deleteCellEdit=()=>{
    if(!cellEdit)return;
    if(!window.confirm("削除を実行しますか？"))return;
    const{dateStr,name}=cellEdit;
    const cur=getShift(dateStr);
    _onSC({...shifts,[dateStr]:cur.filter(s=>s.name!==name)});
    DB.deleteShift(dateStr,name);
    setCellEdit(null);
  };

  const[bulkMode,setBulkMode]=useState(false);
  const[bulkNames,setBulkNames]=useState([]);
  const[bulkDows,setBulkDows]=useState([1,2,3,4,5]);
  const[bulkStart,setBulkStart]=useState("09:00");
  const[bulkEnd,setBulkEnd]=useState("18:00");
  const[bulkOverwrite,setBulkOverwrite]=useState(false);
  const[bulkSymbol,setBulkSymbol]=useState("●");
  const bulkTargetDays=useMemo(()=>{
    let count=0;
    for(let d=1;d<=dim;d++){const dow=new Date(y,mo-1,d).getDay();if(bulkDows.includes(dow))count++;}
    return count;
  },[dim,y,mo,bulkDows]);
  const applyBulk=()=>{
    if(bulkNames.length===0){alert("スタッフを選択してください");return;}
    const dowLabels=bulkDows.map(d=>WK[d]).join("・");
    if(!window.confirm(`${bulkNames.join("・")} の ${dowLabels} に一括登録します。\n時間: ${bulkStart}〜${bulkEnd}\nよろしいですか？`))return;
    const next={...shifts};
    let registered=0,skipped=0;
    bulkNames.forEach(bulkName=>{
      for(let d=1;d<=dim;d++){
        const ds=`${viewYM}-${String(d).padStart(2,"0")}`;
        const dow=new Date(y,mo-1,d).getDay();
        if(bulkDows.includes(dow)){
          const cur=next[ds]||[];
          const existing=cur.find(s=>s.name===bulkName);
          if(existing&&!bulkOverwrite){skipped++;continue;}
          const type=staff.find(s=>s.name===bulkName)?.type||"正社員";
          const entry={name:bulkName,type,symbol:type==="正社員"?bulkSymbol:"",start:bulkStart,end:bulkEnd,status:type==="アルバイト"?"申請":"確定"};
          if(existing&&bulkOverwrite){
            next[ds]=cur.map(s=>s.name===bulkName?entry:s);registered++;
          }else if(!existing){
            next[ds]=[...cur,entry];registered++;
          }
        }
      }
    });
    _onSC(next);setBulkMode(false);
    alert(`✅ 一括登録完了\n登録: ${registered}件${skipped>0?`\nスキップ（既存）: ${skipped}件`:""}`);
  };
  const applyBulkDelete=async()=>{
    if(bulkNames.length===0){alert("スタッフを選択してください");return;}
    const dowLabels=bulkDows.map(d=>WK[d]).join("・");
    if(!window.confirm(`${bulkNames.join("・")} の ${dowLabels} のシフトを削除します。よろしいですか？`))return;
    const next={...shifts};
    let delCount=0;
    const delPromises=[];
    bulkNames.forEach(bulkName=>{
      for(let d=1;d<=dim;d++){
        const ds=`${viewYM}-${String(d).padStart(2,"0")}`;
        const dow=new Date(y,mo-1,d).getDay();
        if(bulkDows.includes(dow)){
          const cur=next[ds]||[];
          const had=cur.some(s=>s.name===bulkName);
          next[ds]=cur.filter(s=>s.name!==bulkName);
          if(had){delPromises.push(DB.deleteShift(ds,bulkName));delCount++;}
        }
      }
    });
    onShiftsChange(next);setBulkMode(false);
    try{await Promise.all(delPromises);}catch(e){console.error("bulkDelete error",e);}
    alert(`✅ 一括削除完了（${delCount}件削除）`);
  };

  // ③ 全スタッフ全シフト一括削除（月単位）
  const clearAllShifts=async()=>{
    if(!window.confirm(`⚠️ ${ymLabel(viewYM)}の全スタッフのシフトを全て削除します。\nこの操作は取り消せません。よろしいですか？`))return;
    if(!window.confirm(`本当に削除しますか？（2回目の確認）`))return;
    // まずローカル状態を即座にクリア
    const next={...shifts};
    let delCount=0;
    for(let d=1;d<=dim;d++){
      const ds=`${viewYM}-${String(d).padStart(2,"0")}`;
      const cur=next[ds]||[];
      delCount+=cur.length;
      next[ds]=[];
    }
    onShiftsChange(next);
    // DBから一括削除（完了を待つ）
    try{
      await DB.deleteShiftsMonth(viewYM);
    }catch(e){console.error("deleteShiftsMonth error",e);}
    alert(`✅ ${ymLabel(viewYM)}の全シフトを削除しました（${delCount}件）`);
  };

  const canPrev=viewYM>todayYM;const canNext=viewYM<maxYM;

  // CSV取込
  const handleCSVUpload=(e)=>{
    const f=e.target.files?.[0];if(!f)return;
    readFile(f,text=>{
      const rows=parseCSV(text);
      if(rows.length<2){alert("CSVフォーマットが無効です");return;}
      const headerRow=rows[0];const dateOffset={};
      for(let i=1;i<headerRow.length;i++){
        const h=headerRow[i];const m=h.match(/(\d+)\/(\d+)/);
        if(m){const ymd=`${y}-${String(m[1]).padStart(2,"0")}-${String(m[2]).padStart(2,"0")}`;dateOffset[i]=ymd;}
      }
      const next={...shifts};
      for(let ri=1;ri<rows.length;ri++){
        const row=rows[ri];
        if(!row[0]||row[0]==="人員")continue;
        const staffName=row[0];const staffItem=staff.find(s=>s.name===staffName);if(!staffItem)continue;
        for(let ci=1;ci<row.length;ci++){
          const val=row[ci]?.trim()||"";if(!val)continue;const dateStr=dateOffset[ci];if(!dateStr)continue;
          const cur=next[dateStr]||[];if(cur.find(s=>s.name===staffName))continue;
          let start="09:00",end="18:00",symbol="";
          const timeMatch=val.match(/(\d{1,2}):(\d{2})-(\d{1,2}):(\d{2})/);
          if(timeMatch){start=`${String(timeMatch[1]).padStart(2,"0")}:${timeMatch[2]}`;end=`${String(timeMatch[3]).padStart(2,"0")}:${timeMatch[4]}`;}
          if(staffItem.type==="正社員"){symbol=val==="●"||val===""?"●":val;}
          next[dateStr]=[...cur,{name:staffName,type:staffItem.type,symbol,start,end,status:staffItem.type==="アルバイト"?"申請":"確定"}];
        }
      }
      _onSC(next);alert("シフトCSVを取込みました");
    });
  };

  const staffTypeMap=useMemo(()=>{const m={};staff.forEach(s=>{m[s.name]=s.type;});return m;},[staff]);
  const calcHeadcount=(dateStr)=>{
    const shfts=getShift(dateStr);
    return shfts.filter(s=>{
      const sType=staffTypeMap[s.name]||"";
      // 正社員: ●（出勤）のみカウント。公/希/有/出はカウントしない
      if(sType==="正社員")return s.symbol==="●";
      // アルバイト: 確定シフトのみカウント
      return!!(s.start&&s.end&&s.status==="確定");
    }).length;
  };

  const dates=[];for(let d=1;d<=dim;d++)dates.push(`${viewYM}-${String(d).padStart(2,"0")}`);

  // タスク数取得（予約データから算出 — 年間通して表示可能）
  const monthTasks=useMemo(()=>{
    if(!reservations||!reservations.length)return{};
    const byDate={};
    const ensure=(d)=>{if(!byDate[d])byDate[d]={洗車:0,PU:0,BD:0,PUB:0,BDB:0,DEL:0,COL:0,来店:0,返却:0,total:0};};
    const NO_BUS=/^(来店|店舗|店頭|ヤード|営業所|ー+|-+|なし|無し|FALSE|false|0)$/;
    reservations.forEach(r=>{
      if(r.status==="cancelled")return;
      // 出発日のタスク
      if(r.lendDate){
        ensure(r.lendDate);
        const dpOk=r.delPlace&&r.delPlace.trim()&&!NO_BUS.test(r.delPlace.trim());
        const lendType=(r.visitType==="DEL"||dpOk)?"DEL":"PU";
        if(lendType==="DEL"){byDate[r.lendDate].DEL++;}
        else{
          // PU → PUB判定（場所が来店系でなければバス）
          const place=(r.delPlace||"").trim();
          const isBus=!place||!NO_BUS.test(place);
          if(isBus){byDate[r.lendDate].PUB++;}else{byDate[r.lendDate].PU++;}
        }
        byDate[r.lendDate].total++;
      }
      // 返却日のタスク
      if(r.returnDate){
        ensure(r.returnDate);
        const cpOk=r.colPlace&&r.colPlace.trim()&&!NO_BUS.test(r.colPlace.trim());
        const retType=(r.returnType==="COL"||cpOk)?"COL":"BD";
        if(retType==="COL"){byDate[r.returnDate].COL++;}
        else{
          const place=(r.colPlace||"").trim();
          const isBus=!place||!NO_BUS.test(place);
          if(isBus){byDate[r.returnDate].BDB++;}else{byDate[r.returnDate].BD++;}
        }
        byDate[r.returnDate].total++;
      }
      // 洗車（出発前日）
      if(r.lendDate){
        const prev=new Date(r.lendDate);prev.setDate(prev.getDate()-1);
        const prevDs=prev.toISOString().slice(0,10);
        ensure(prevDs);byDate[prevDs].洗車++;byDate[prevDs].total++;
      }
    });
    return byDate;
  },[reservations]);

  // セル表示内容を取得
  const SHIFT_STATUS_STYLE={"申請":{color:"#f59e0b",bg:"#fffbeb",border:"#fcd34d",label:"申"},"調整中":{color:"#6366f1",bg:"#eef2ff",border:"#a5b4fc",label:"調"},"確定":{color:"#059669",bg:"#ecfdf5",border:"#6ee7b7",label:"✓"}};
  const getCellDisplay=(shift,type)=>{
    if(!shift)return null;
    if(type==="正社員"){
      return shift.symbol||"";
    }
    // アルバイト: 時間＋ステータスバッジ
    const st=SHIFT_STATUS_STYLE[shift.status]||SHIFT_STATUS_STYLE["確定"];
    if(shift.start&&shift.end){
      const s=shift.start.replace(/^0/,"");const e=shift.end.replace(/^0/,"");
      return <div style={{lineHeight:"1.1",position:"relative"}}>
        <span style={{fontSize:7}}>{s}<br/>{e}</span>
        <div style={{fontSize:7,fontWeight:800,color:st.color,marginTop:1}}>{st.label}</div>
      </div>;
    }
    return "";
  };

  // セル背景色 — 平日:白 土曜:青 日曜:赤 祝日:薄黄
  const getBaseBg=(dow,ds)=>{
    if(isHoliday(ds))return "#FFFDE7"; // 祝日=薄黄
    if(dow===0)return "#FFEBEE"; // 日曜=薄赤
    if(dow===6)return "#E3F2FD"; // 土曜=薄青
    return "#FFFFFF"; // 平日=白
  };
  // 背景色は常に曜日ベース（平日=白、土曜=青、日曜=赤、祝日=薄黄色）
  const getCellBg=(shift,dow,ds)=>getBaseBg(dow,ds);

  return <div className="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div className="px-4 py-3 border-b border-gray-200 flex items-center justify-between flex-wrap gap-2" style={{background:"#D2B48C"}}>
      <div className="flex items-center gap-2">
        <button onClick={()=>canPrev&&setViewYM(ymOff(viewYM,-1))} className="px-2 py-1 bg-white border border-gray-300 rounded text-sm hover:bg-gray-50" style={{opacity:canPrev?1:.4}}>◀</button>
        <h3 className="text-base font-bold" style={{margin:0}}>{ymLabel(viewYM)}</h3>
        <button onClick={()=>canNext&&setViewYM(ymOff(viewYM,1))} className="px-2 py-1 bg-white border border-gray-300 rounded text-sm hover:bg-gray-50" style={{opacity:canNext?1:.4}}>▶</button>
        {viewYM!==todayYM&&<button onClick={()=>setViewYM(todayYM)} className="px-2 py-1 bg-blue-50 border border-blue-200 rounded text-xs font-semibold text-blue-700">今月</button>}
      </div>
      <div className="flex items-center gap-2">
        <button onClick={clearAllShifts} className="px-3 py-1 rounded-lg text-xs font-semibold border" style={{background:"#991b1b",color:"#fff"}}>全削除</button>
        <button onClick={()=>{setBulkNames([]);setBulkDows([1,2,3,4,5]);setBulkMode("delete");}} className="px-3 py-1 rounded-lg text-xs font-semibold border" style={{background:"#dc2626",color:"#fff"}}>一括削除</button>
        <button onClick={()=>{setBulkNames([]);setBulkDows([1,2,3,4,5]);setBulkSymbol("●");setBulkStart("09:00");setBulkEnd("18:00");setBulkOverwrite(false);setBulkMode("set");}} className="px-3 py-1 rounded-lg text-xs font-semibold border" style={{background:"#2563eb",color:"#fff"}}>一括設定</button>
        <label className="px-3 py-1 rounded-lg text-xs font-semibold border border-blue-300 bg-blue-50 text-blue-700 cursor-pointer hover:bg-blue-100"><span>CSV</span><input type="file" accept=".csv,.txt" className="hidden" onChange={handleCSVUpload}/></label>
      </div>
    </div>
    {/* 一括モーダル */}
    {bulkMode&&<div className="modal-overlay" onClick={()=>setBulkMode(false)}><div className="modal-box" style={{maxWidth:380,padding:24}} onClick={e=>e.stopPropagation()}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
        <h4 style={{fontSize:16,fontWeight:800,margin:0}}>{bulkMode==="delete"?"一括削除":"一括設定"}</h4>
        <button onClick={()=>setBulkMode(false)} style={{background:"none",border:"none",fontSize:18,color:"#94a3b8",cursor:"pointer"}}>✕</button>
      </div>
      <div style={{marginBottom:14}}>
        <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:6}}>スタッフ（複数選択可）</label>
        <div style={{display:"flex",gap:4,flexWrap:"wrap",marginBottom:6}}>
          <button onClick={()=>setBulkNames(staff.map(s=>s.name))} style={{padding:"4px 10px",borderRadius:6,fontSize:11,fontWeight:700,border:"1px solid #e2e8f0",background:bulkNames.length===staff.length?"#2563eb":"#f8fafc",color:bulkNames.length===staff.length?"#fff":"#64748b",cursor:"pointer"}}>全員</button>
          <button onClick={()=>setBulkNames(regularStaff.map(s=>s.name))} style={{padding:"4px 10px",borderRadius:6,fontSize:11,fontWeight:600,border:"1px solid #e2e8f0",background:"#f8fafc",color:"#1d4ed8",cursor:"pointer"}}>正社員</button>
          <button onClick={()=>setBulkNames(partTimeStaff.map(s=>s.name))} style={{padding:"4px 10px",borderRadius:6,fontSize:11,fontWeight:600,border:"1px solid #e2e8f0",background:"#f8fafc",color:"#92400e",cursor:"pointer"}}>アルバイト</button>
          <button onClick={()=>setBulkNames([])} style={{padding:"4px 10px",borderRadius:6,fontSize:11,fontWeight:600,border:"1px solid #e2e8f0",background:"#f8fafc",color:"#94a3b8",cursor:"pointer"}}>解除</button>
        </div>
        <div style={{maxHeight:120,overflowY:"auto",border:"1px solid #e2e8f0",borderRadius:8,padding:4}}>
          {staff.map(s=>{const sel=bulkNames.includes(s.name);return <label key={s.name} style={{display:"flex",alignItems:"center",gap:6,padding:"4px 6px",cursor:"pointer",borderRadius:4,background:sel?"#eff6ff":"transparent"}}>
            <input type="checkbox" checked={sel} onChange={()=>setBulkNames(p=>p.includes(s.name)?p.filter(n=>n!==s.name):[...p,s.name])} style={{width:14,height:14}}/>
            <span style={{fontSize:12,fontWeight:sel?700:400}}>{s.name}</span>
            <span style={{fontSize:9,color:s.type==="正社員"?"#1d4ed8":"#92400e",fontWeight:600}}>({s.type})</span>
          </label>;})}
        </div>
        {bulkNames.length>0&&<div style={{fontSize:11,color:"#2563eb",fontWeight:600,marginTop:4}}>{bulkNames.length}名選択中</div>}
      </div>
      <div style={{marginBottom:14}}>
        <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:6}}>曜日</label>
        <div style={{display:"flex",gap:6}}>
          {WK.map((w,i)=>{const isSun=i===0;const isSat=i===6;return <button key={i} onClick={()=>setBulkDows(p=>p.includes(i)?p.filter(x=>x!==i):[...p,i])} style={{
            width:38,height:38,borderRadius:8,fontSize:13,fontWeight:700,border:"none",cursor:"pointer",transition:"all .15s",
            background:bulkDows.includes(i)?"#2563eb":"#f1f5f9",color:bulkDows.includes(i)?"#fff":isSun?"#dc2626":isSat?"#2563eb":"#94a3b8"
          }}>{w}</button>;})}
        </div>
      </div>
      {bulkMode==="set"&&<>
        {bulkNames.length>0&&bulkNames.some(bn=>staff.find(s=>s.name===bn)?.type==="正社員")&&<div style={{marginBottom:14}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:6}}>シフト種別（正社員）</label>
          <div style={{display:"flex",gap:4,flexWrap:"wrap"}}>
            {SHIFT_OPTIONS.map(o=><button key={o.s} onClick={()=>setBulkSymbol(o.s)} style={{
              padding:"6px 10px",borderRadius:8,fontSize:11,fontWeight:700,border:"2px solid",cursor:"pointer",
              background:bulkSymbol===o.s?o.color:"#fff",color:bulkSymbol===o.s?"#fff":o.color,borderColor:bulkSymbol===o.s?o.color:"#e2e8f0"
            }}>{o.s} {o.label}</button>)}
          </div>
        </div>}
        <div style={{display:"flex",gap:12,marginBottom:14}}>
          <div style={{flex:1}}>
            <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>開始</label>
            <input type="time" value={bulkStart} onChange={e=>setBulkStart(e.target.value)} style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14}}/>
          </div>
          <div style={{flex:1}}>
            <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>終了</label>
            <input type="time" value={bulkEnd} onChange={e=>setBulkEnd(e.target.value)} style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14}}/>
          </div>
        </div>
        <label style={{display:"flex",alignItems:"center",gap:8,fontSize:12,color:"#374151",marginBottom:16,cursor:"pointer"}}>
          <input type="checkbox" checked={bulkOverwrite} onChange={e=>setBulkOverwrite(e.target.checked)} style={{width:16,height:16}}/>
          既存シフトを上書き
        </label>
      </>}
      <div style={{textAlign:"center",padding:"8px 0",background:bulkMode==="delete"?"#fef2f2":"#f8fafc",borderRadius:8,marginBottom:14,fontSize:13,color:"#64748b"}}>
        対象: <span style={{fontWeight:900,color:bulkMode==="delete"?"#dc2626":"#1e293b",fontSize:16}}>{bulkNames.length}</span> 名 × <span style={{fontWeight:900,color:bulkMode==="delete"?"#dc2626":"#1e293b",fontSize:16}}>{bulkTargetDays}</span> 日 = <span style={{fontWeight:900,color:bulkMode==="delete"?"#dc2626":"#1e293b",fontSize:16}}>{bulkNames.length*bulkTargetDays}</span> 件
      </div>
      <div style={{display:"flex",gap:8}}>
        <button onClick={()=>setBulkMode(false)} style={{flex:"0 0 auto",padding:"10px 16px",borderRadius:10,border:"1px solid #e2e8f0",background:"#fff",fontSize:13,fontWeight:600,color:"#64748b",cursor:"pointer"}}>キャンセル</button>
        {bulkMode==="delete"?
          <button onClick={applyBulkDelete} disabled={bulkNames.length===0} style={{flex:1,padding:"10px 16px",borderRadius:10,border:"none",background:bulkNames.length>0?"#dc2626":"#94a3b8",fontSize:13,fontWeight:700,color:"#fff",cursor:bulkNames.length>0?"pointer":"not-allowed"}}>一括削除 ({bulkTargetDays}日)</button>:
          <button onClick={applyBulk} disabled={bulkNames.length===0} style={{flex:1,padding:"10px 16px",borderRadius:10,border:"none",background:bulkNames.length>0?"#2563eb":"#94a3b8",fontSize:13,fontWeight:700,color:"#fff",cursor:bulkNames.length>0?"pointer":"not-allowed"}}>一括設定 ({bulkTargetDays}件)</button>
        }
      </div>
    </div></div>}

    {/* シフト表（改良版） */}
    <div style={{maxHeight:600,overflowX:"auto",overflowY:"auto",position:"relative",WebkitOverflowScrolling:"touch"}}>
      <table style={{borderCollapse:"collapse",fontSize:10,minWidth:"100%"}}>
        <thead>
          <tr style={{background:"#D2B48C",position:"sticky",top:0,zIndex:3}}>
            <th style={{position:"sticky",left:0,zIndex:5,width:72,minWidth:72,padding:"6px 4px",textAlign:"center",fontWeight:700,borderRight:"2px solid #b8976a",background:"#D2B48C",fontSize:10}}>名前</th>
            {dates.map(ds=>{const dt=new Date(ds);const dow=dt.getDay();const day=dt.getDate();const isToday=ds===today;const hol=isHoliday(ds);
            const bgc=isToday?"#FFFF99":hol?"#FFFDE7":dow===0?"#FFCDD2":dow===6?"#BBDEFB":"#D2B48C";
            const txtC=hol?"#e65100":dow===0?"#c62828":dow===6?"#1565c0":"#78716c";
            return <th key={ds} style={{minWidth:42,width:42,padding:"4px 1px",textAlign:"center",fontWeight:700,fontSize:9,background:bgc,borderRight:"1px solid #b8976a",borderBottom:"1px solid #b8976a",boxShadow:isToday?"inset 0 0 0 2px #f59e0b":"none"}}>
              <div style={{lineHeight:1.2}}>{day}</div>
              <div style={{fontSize:8,color:txtC}}>{WK[dow]}{hol?"*":""}</div>
            </th>;})}
          </tr>
        </thead>
        <tbody>
          {/* 正社員 */}
          {regularStaff.length>0&&<tr><td colSpan={dates.length+1} style={{background:"#eff6ff",padding:"3px 8px",fontSize:9,fontWeight:700,color:"#1d4ed8",borderBottom:"1px solid #bfdbfe"}}>正社員</td></tr>}
          {regularStaff.map(st=><tr key={st.name}>
            <td style={{position:"sticky",left:0,zIndex:2,width:72,minWidth:72,padding:"4px 6px",fontWeight:600,fontSize:10,background:"#fff",borderRight:"2px solid #e5e7eb",borderBottom:"1px solid #e5e7eb",whiteSpace:"nowrap"}}>
              <span style={{fontSize:8,fontWeight:700,padding:"1px 4px",borderRadius:3,background:"#dbeafe",color:"#1d4ed8",marginRight:2}}>社</span>{st.name}
            </td>
            {dates.map(ds=>{
              const shift=getShift(ds).find(s=>s.name===st.name);const dow=new Date(ds).getDay();
              const bg=getCellBg(shift,dow,ds);const isToday=ds===today;
              return <td key={ds} onClick={()=>handleCellClick(ds,st.name,"正社員")} style={{
                minWidth:42,width:42,padding:"2px",textAlign:"center",fontSize:11,fontWeight:700,background:bg,
                borderRight:"1px solid #e5e7eb",borderBottom:"1px solid #e5e7eb",cursor:"pointer",
                boxShadow:isToday?"inset 0 0 0 2px #f59e0b":"none",
                color:shift?.symbol==="●"?"#1d4ed8":shift?.symbol==="公"?"#64748b":shift?.symbol==="希"?"#d97706":shift?.symbol==="有"?"#059669":shift?.symbol==="出"?"#7c3aed":"#d1d5db",
                height:36,verticalAlign:"middle"
              }}>{shift?shift.symbol:<span style={{color:"#e5e7eb",fontSize:14}}>+</span>}</td>;
            })}
          </tr>)}

          {/* アルバイト */}
          {partTimeStaff.length>0&&<tr><td colSpan={dates.length+1} style={{background:"#fffbeb",padding:"3px 8px",fontSize:9,fontWeight:700,color:"#92400e",borderBottom:"1px solid #fde68a"}}>アルバイト</td></tr>}
          {partTimeStaff.map(st=><tr key={st.name}>
            <td style={{position:"sticky",left:0,zIndex:2,width:72,minWidth:72,padding:"4px 6px",fontWeight:600,fontSize:10,background:"#fff",borderRight:"2px solid #e5e7eb",borderBottom:"1px solid #e5e7eb",whiteSpace:"nowrap"}}>
              <span style={{fontSize:8,fontWeight:700,padding:"1px 4px",borderRadius:3,background:"#fef3c7",color:"#92400e",marginRight:2}}>ア</span>{st.name}
            </td>
            {dates.map(ds=>{
              const shift=getShift(ds).find(s=>s.name===st.name);const dow=new Date(ds).getDay();
              const bg=getCellBg(shift,dow,ds);const isToday=ds===today;
              const stStatus=shift?.status;const stStyle=stStatus?SHIFT_STATUS_STYLE[stStatus]:null;
              const cellBorder=stStyle?`2px solid ${stStyle.border}`:"";
              return <td key={ds} onClick={()=>handleCellClick(ds,st.name,"アルバイト")} style={{
                minWidth:42,width:42,padding:"1px",textAlign:"center",background:bg,
                borderRight:"1px solid #e5e7eb",borderBottom:"1px solid #e5e7eb",cursor:"pointer",
                boxShadow:isToday?"inset 0 0 0 2px #f59e0b":cellBorder?`inset 0 0 0 1px ${stStyle.border}`:"none",
                height:36,verticalAlign:"middle"
              }}>{shift?getCellDisplay(shift,"アルバイト"):<span style={{color:"#e5e7eb",fontSize:14}}>+</span>}</td>;
            })}
          </tr>)}

          {/* 人員合計行 */}
          <tr style={{fontWeight:700,background:"#D2B48C"}}>
            <td style={{position:"sticky",left:0,zIndex:2,width:72,minWidth:72,padding:"4px 6px",fontSize:10,fontWeight:700,background:"#D2B48C",borderRight:"2px solid #b8976a",borderBottom:"1px solid #b8976a"}}>人員</td>
            {dates.map(ds=>{const hc=calcHeadcount(ds);return <td key={ds} style={{minWidth:42,width:42,padding:"3px 1px",textAlign:"center",fontSize:11,fontWeight:800,background:"#D2B48C",borderRight:"1px solid #b8976a",borderBottom:"1px solid #b8976a",color:hc===0?"#b8976a":"#1e293b"}}>{hc}</td>;})}
          </tr>
          {/* タスク数合計行 */}
          <tr style={{fontWeight:700,background:"#f0fdf4"}}>
            <td style={{position:"sticky",left:0,zIndex:2,width:72,minWidth:72,padding:"4px 6px",fontSize:10,fontWeight:700,background:"#f0fdf4",borderRight:"2px solid #d1d5db",borderBottom:"1px solid #d1d5db"}}>タスク</td>
            {dates.map(ds=>{const tc=monthTasks[ds];const total=tc?tc.total:0;const hc=calcHeadcount(ds);
              const ratio=hc>0?total/hc:0;const rBg=total===0?"#f0fdf4":ratio>3?"#fecaca":ratio>2?"#fed7aa":"#f0fdf4";
              return <td key={ds} style={{minWidth:42,width:42,padding:"2px 1px",textAlign:"center",fontSize:10,fontWeight:800,background:rBg,borderRight:"1px solid #d1d5db",borderBottom:"1px solid #d1d5db",color:total===0?"#d1d5db":"#1e293b"}}>{total||""}</td>;})}
          </tr>
          {/* タスク内訳行 */}
          {[{key:"洗車",label:"洗車",color:"#795548",bg:"#FFFDE7"},{key:"PUB",label:"PUB",color:"#7c3aed",bg:"#f5f3ff"},{key:"BDB",label:"BDB",color:"#ea580c",bg:"#fff7ed"},{key:"PU",label:"PU",color:"#2563eb",bg:"#eff6ff"},{key:"BD",label:"BD",color:"#dc2626",bg:"#fef2f2"},{key:"DEL",label:"DEL",color:"#0891b2",bg:"#ecfeff"},{key:"COL",label:"COL",color:"#0d9488",bg:"#f0fdfa"}].map(cat=>
          <tr key={cat.key} style={{background:cat.bg}}>
            <td style={{position:"sticky",left:0,zIndex:2,width:72,minWidth:72,padding:"3px 6px",fontSize:8,fontWeight:700,background:cat.bg,borderRight:"2px solid #d1d5db",borderBottom:"1px solid #e5e7eb",color:cat.color}}>{cat.label}</td>
            {dates.map(ds=>{const tc=monthTasks[ds];const cnt=tc?tc[cat.key]:0;
              return <td key={ds} style={{minWidth:42,width:42,padding:"1px",textAlign:"center",fontSize:9,fontWeight:700,background:cat.bg,borderRight:"1px solid #e5e7eb",borderBottom:"1px solid #e5e7eb",color:cnt?cat.color:"#e5e7eb"}}>{cnt||""}</td>;})}
          </tr>)}
        </tbody>
      </table>
    </div>

    {/* サマリーテーブル */}
    <div className="px-4 py-3 border-t border-gray-200 bg-gray-50 overflow-x-auto">
      <div style={{fontSize:11,fontWeight:700,color:"#374151",marginBottom:6}}>月間サマリー</div>
      <table style={{fontSize:10,borderCollapse:"collapse",width:"100%"}}>
        <thead><tr style={{background:"#e5e7eb"}}>
          <th style={{padding:"5px 8px",textAlign:"left",fontWeight:700,border:"1px solid #d1d5db",minWidth:80}}>名前</th>
          <th style={{padding:"5px 6px",textAlign:"center",fontWeight:700,border:"1px solid #d1d5db",minWidth:40,color:"#2563eb"}}>出勤</th>
          <th style={{padding:"5px 6px",textAlign:"center",fontWeight:700,border:"1px solid #d1d5db",minWidth:40,color:"#64748b"}}>公休</th>
          <th style={{padding:"5px 6px",textAlign:"center",fontWeight:700,border:"1px solid #d1d5db",minWidth:40,color:"#d97706"}}>希望休</th>
          <th style={{padding:"5px 6px",textAlign:"center",fontWeight:700,border:"1px solid #d1d5db",minWidth:40,color:"#059669"}}>有給</th>
          <th style={{padding:"5px 6px",textAlign:"center",fontWeight:700,border:"1px solid #d1d5db",minWidth:40,color:"#7c3aed"}}>出張</th>
          <th style={{padding:"5px 6px",textAlign:"center",fontWeight:700,border:"1px solid #d1d5db",minWidth:40}}>合計</th>
        </tr></thead>
        <tbody>
          {staff.map(s=>{
            const staffSymCounts={};let workDays=0;
            const isP=s.type==="アルバイト";
            dates.forEach(ds=>{
              const sShift=getShift(ds).find(sh=>sh.name===s.name);
              if(!sShift)return;
              if(sShift.symbol){
                staffSymCounts[sShift.symbol]=(staffSymCounts[sShift.symbol]||0)+1;
              }else if(isP&&sShift.start&&sShift.end){
                workDays++;
              }
            });
            const symWork=staffSymCounts["●"]||0;
            const totalWork=symWork+workDays;
            const total=totalWork+(staffSymCounts["公"]||0)+(staffSymCounts["希"]||0)+(staffSymCounts["有"]||0)+(staffSymCounts["出"]||0);
            return <tr key={s.name} style={{background:isP?"#fffbeb":"#fff",borderBottom:"1px solid #d1d5db"}}>
              <td style={{padding:"4px 8px",border:"1px solid #d1d5db",fontWeight:600,fontSize:10}}>
                <span style={{fontSize:8,fontWeight:700,padding:"1px 4px",borderRadius:3,background:isP?"#fef3c7":"#dbeafe",color:isP?"#92400e":"#1d4ed8",marginRight:4}}>{isP?"ア":"社"}</span>{s.name}
              </td>
              <td style={{padding:"4px 6px",border:"1px solid #d1d5db",textAlign:"center",fontWeight:totalWork>0?700:400,color:totalWork>0?"#1d4ed8":"#d1d5db"}}>{totalWork}</td>
              <td style={{padding:"4px 6px",border:"1px solid #d1d5db",textAlign:"center",color:(staffSymCounts["公"]||0)>0?"#64748b":"#d1d5db"}}>{staffSymCounts["公"]||0}</td>
              <td style={{padding:"4px 6px",border:"1px solid #d1d5db",textAlign:"center",color:(staffSymCounts["希"]||0)>0?"#d97706":"#d1d5db"}}>{staffSymCounts["希"]||0}</td>
              <td style={{padding:"4px 6px",border:"1px solid #d1d5db",textAlign:"center",color:(staffSymCounts["有"]||0)>0?"#059669":"#d1d5db"}}>{staffSymCounts["有"]||0}</td>
              <td style={{padding:"4px 6px",border:"1px solid #d1d5db",textAlign:"center",color:(staffSymCounts["出"]||0)>0?"#7c3aed":"#d1d5db"}}>{staffSymCounts["出"]||0}</td>
              <td style={{padding:"4px 6px",border:"1px solid #d1d5db",textAlign:"center",fontWeight:700}}>{total}</td>
            </tr>;
          })}
        </tbody>
      </table>
    </div>

    {/* セル編集モーダル（日毎のシフト内容設定） */}
    {cellEdit&&<div className="modal-overlay" onClick={()=>setCellEdit(null)}><div className="modal-box" style={{maxWidth:340,padding:0,borderRadius:16,overflow:"hidden"}} onClick={e=>e.stopPropagation()}>
      {/* ヘッダー */}
      <div style={{background:"#D2B48C",padding:"14px 20px",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
        <div>
          <div style={{fontSize:14,fontWeight:800,color:"#1e293b"}}>{cellEdit.name}</div>
          <div style={{fontSize:12,color:"#78716c"}}>{fmtD(cellEdit.dateStr)} ({WK[new Date(cellEdit.dateStr).getDay()]})</div>
        </div>
        <button onClick={()=>setCellEdit(null)} style={{background:"none",border:"none",fontSize:18,color:"#78716c",cursor:"pointer",padding:4}}>✕</button>
      </div>
      <div style={{padding:"16px 20px"}}>
        {/* シフト種別選択（正社員のみ） */}
        {cellEdit.type==="正社員"&&<div style={{marginBottom:16}}>
          <label style={{fontSize:11,color:"#64748b",fontWeight:700,display:"block",marginBottom:8}}>出勤内容</label>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:6}}>
            {SHIFT_OPTIONS.map(o=>{
              const sel=cellEdit.symbol===o.s;
              return <button key={o.s} onClick={()=>setCellEdit({...cellEdit,symbol:o.s})} style={{
                padding:"10px 8px",borderRadius:10,fontSize:12,fontWeight:700,border:"2px solid",cursor:"pointer",transition:"all .15s",
                background:sel?o.color:"#fff",color:sel?"#fff":o.color,borderColor:sel?o.color:"#e2e8f0",
                display:"flex",alignItems:"center",justifyContent:"center",gap:6
              }}><span style={{fontSize:16}}>{o.s}</span> {o.label}</button>;
            })}
          </div>
        </div>}
        {/* ステータス選択（アルバイトのみ） */}
        {cellEdit.type==="アルバイト"&&<div style={{marginBottom:16}}>
          <label style={{fontSize:11,color:"#64748b",fontWeight:700,display:"block",marginBottom:8}}>ステータス</label>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:6}}>
            {[{s:"申請",c:"#f59e0b",bg:"#fffbeb"},{s:"調整中",c:"#6366f1",bg:"#eef2ff"},{s:"確定",c:"#059669",bg:"#ecfdf5"}].map(o=>{
              const sel=cellEdit.status===o.s;
              return <button key={o.s} onClick={()=>setCellEdit({...cellEdit,status:o.s})} style={{
                padding:"10px 6px",borderRadius:10,fontSize:12,fontWeight:700,border:"2px solid",cursor:"pointer",transition:"all .15s",
                background:sel?o.c:"#fff",color:sel?"#fff":o.c,borderColor:sel?o.c:"#e2e8f0",
                textAlign:"center"
              }}>{o.s}</button>;
            })}
          </div>
        </div>}
        {/* 時間設定（出勤・出張の場合、またはアルバイト） */}
        {(cellEdit.type==="アルバイト"||cellEdit.symbol==="●"||cellEdit.symbol==="出")&&<div style={{marginBottom:16}}>
          <label style={{fontSize:11,color:"#64748b",fontWeight:700,display:"block",marginBottom:8}}>勤務時間</label>
          <div style={{display:"flex",gap:10,alignItems:"center"}}>
            <input type="time" value={cellEdit.start} onChange={e=>setCellEdit({...cellEdit,start:e.target.value})} style={{flex:1,padding:"10px 10px",borderRadius:10,border:"1px solid #e2e8f0",fontSize:15,textAlign:"center"}}/>
            <span style={{color:"#94a3b8",fontWeight:700,fontSize:14}}>〜</span>
            <input type="time" value={cellEdit.end} onChange={e=>setCellEdit({...cellEdit,end:e.target.value})} style={{flex:1,padding:"10px 10px",borderRadius:10,border:"1px solid #e2e8f0",fontSize:15,textAlign:"center"}}/>
          </div>
        </div>}
        {/* ボタン */}
        <div style={{display:"flex",gap:8,marginTop:8}}>
          <button onClick={saveCellEdit} style={{flex:1,padding:"12px 16px",borderRadius:12,border:"none",background:"#2563eb",fontSize:13,fontWeight:700,color:"#fff",cursor:"pointer"}}>
            {cellEdit.isNew?"登録":"保存"}
          </button>
          {!cellEdit.isNew&&<button onClick={deleteCellEdit} style={{padding:"12px 16px",borderRadius:12,border:"1px solid #fecaca",background:"#fef2f2",fontSize:13,fontWeight:700,color:"#dc2626",cursor:"pointer"}}>削除</button>}
          <button onClick={()=>setCellEdit(null)} style={{padding:"12px 16px",borderRadius:12,border:"1px solid #e2e8f0",background:"#fff",fontSize:13,fontWeight:600,color:"#64748b",cursor:"pointer"}}>戻る</button>
        </div>
      </div>
    </div></div>}
  </div>;
}

/* ==========================================
   新規予約登録フォーム（手動 + CSV自動配車）
   ========================================== */
function ReservationForm({onAdd,onBulkAdd,vehicles,vehicleClasses,onClose,prefill,data,fleet,maintenance}){
  const init=prefill||{name:"",people:1,delPlace:"",colPlace:"",vehicle:"A",vehicleCode:"",insurance:"免責",lendDate:"",returnDate:"",lendTime:"09:00",returnTime:"18:00",id:"M"+Date.now(),ota:"HP",flight:""};
  const[f,setF]=useState(init);
  const[mode,setMode]=useState("manual"); // manual / csv
  const[csvResult,setCsvResult]=useState(null);
  const[csvLogs,setCsvLogs]=useState([]);

  const upF=(k,v)=>setF(p=>({...p,[k]:v}));

  // CSV取込（配車は手動）
  const handleCSV=(e)=>{
    const file=e.target.files?.[0];if(!file)return;
    readFile(file,text=>{
      const rows=parseCSV(text);
      const res=detectParse(rows);
      if(!res){setCsvLogs([{t:"err",m:"CSV形式を検出できません"}]);return;}
      const skipMsg=res.skippedOther>0?` (他店舗${res.skippedOther}件除外)`:"";
      setCsvLogs([{t:"ok",m:`${OTA[res.ota].name} 高松${res.data.length}件${skipMsg}`}]);
      setCsvResult({data:res.data,fleet:{},ota:res.ota});
    });
  };
  const commitCSV=()=>{if(csvResult)onBulkAdd(csvResult.data,csvResult.fleet);};

  const submit=()=>{
    if(f.vehicleCode&&f.lendDate&&f.returnDate){
      const tmpRes={id:f.id||"_tmp",lendDate:f.lendDate,returnDate:f.returnDate,status:"confirmed"};
      const conflict=data.find(r=>r.id!==tmpRes.id&&r.status!=="cancelled"&&fleet[r.id]===f.vehicleCode&&norm(r.lendDate)<=norm(tmpRes.returnDate)&&norm(r.returnDate)>=norm(tmpRes.lendDate));
      if(conflict){const cv=vehicles.find(x=>x.code===f.vehicleCode);alert((cv?cv.name:f.vehicleCode)+" は "+fmtD(conflict.lendDate)+"〜"+fmtD(conflict.returnDate)+" に「"+conflict.name+"」様の予約が入っているため配車できません。\n配車表で手動配車してください。");return;}
    }
    const r={...f,id:f.id||"M"+Date.now(),ota:f.ota||"HP",status:"confirmed",visitType:"DEL",returnType:"COL",delTime:f.lendTime,colTime:f.returnTime,delPlace:f.delPlace||"",colPlace:f.colPlace||""};
    onAdd(r,f.vehicleCode);
  };

  return <div className="modal-overlay" onClick={onClose}><div className="modal-box" style={{maxWidth:560,maxHeight:"90vh"}} onClick={e=>e.stopPropagation()}>
    <div style={{padding:"16px 20px",borderBottom:"1px solid #e5e7eb"}}>
      <div className="flex items-center justify-between">
        <h3 className="font-bold text-base">新規予約登録</h3>
        <button onClick={onClose} className="text-gray-400 hover:text-gray-600 text-lg">✕</button>
      </div>
      <div className="flex gap-2 mt-2">
        <button onClick={()=>setMode("manual")} className="px-3 py-1 rounded-lg text-xs font-bold" style={{background:mode==="manual"?"#2563eb":"#f1f5f9",color:mode==="manual"?"#fff":"#374151"}}>手動入力</button>
        <button onClick={()=>setMode("csv")} className="px-3 py-1 rounded-lg text-xs font-bold" style={{background:mode==="csv"?"#2563eb":"#f1f5f9",color:mode==="csv"?"#fff":"#374151"}}>CSV一括取込</button>
      </div>
    </div>

    <div style={{padding:"12px 20px",overflowY:"auto",maxHeight:"calc(90vh - 120px)"}}>
      {mode==="csv"?<div>
        <p className="text-xs text-gray-500 mb-2">CSVをアップロードして予約を一括登録します（配車は配車表から手動で行います）</p>
        <label className="flex flex-col items-center p-6 rounded-xl border-2 border-dashed border-blue-300 bg-blue-50 cursor-pointer hover:bg-blue-100 transition mb-3">
          <span style={{fontSize:28}}>📄</span>
          <span className="text-sm font-semibold text-blue-700 mt-1">CSVファイルを選択</span>
          <input type="file" accept=".csv,.txt" className="hidden" onChange={handleCSV}/>
        </label>
        {csvLogs.map((l,i)=><div key={i} className="text-xs px-2 py-1 rounded mb-1" style={{background:l.t==="err"?"#fef2f2":"#f0fdf4",color:l.t==="err"?"#b91c1c":"#15803d"}}>{l.t==="err"?"✗":"✓"} {l.m}</div>)}
        {csvResult&&<div className="mt-3">
          <div className="text-sm font-bold mb-2">配車プレビュー（{csvResult.data.length}件）</div>
          <div style={{maxHeight:300,overflowY:"auto"}} className="border rounded-lg">
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}><thead><tr style={{background:"#f1f5f9"}}>
              <th className="px-2 py-1 text-left border-b">予約者</th><th className="px-2 py-1 text-left border-b">クラス</th><th className="px-2 py-1 text-left border-b">貸出</th><th className="px-2 py-1 text-left border-b">返却</th><th className="px-2 py-1 text-left border-b">状態</th>
            </tr></thead><tbody>
              {csvResult.data.map((r,i)=><tr key={i} className="border-b border-gray-100">
                <td className="px-2 py-1 font-semibold">{r.name}</td>
                <td className="px-2 py-1">{r.vehicle}</td>
                <td className="px-2 py-1">{fmtD(r.lendDate)} {r.lendTime}</td>
                <td className="px-2 py-1">{fmtD(r.returnDate)} {r.returnTime}</td>
                <td className="px-2 py-1"><span style={{color:"#f59e0b",fontWeight:700}}>未配車</span></td>
              </tr>)}
            </tbody></table>
          </div>
          <button onClick={commitCSV} className="btn-primary mt-3 w-full" style={{padding:10}}>この内容で一括登録（配車は配車表で手動）</button>
        </div>}
      </div>:
      <div className="space-y-3">
        <div style={{display:"grid",gridTemplateColumns:"1fr 80px",gap:8}}>
          <div><label className="text-xs text-gray-500">予約者名</label><input value={f.name} onChange={e=>upF("name",e.target.value)} className="input-s" placeholder="タケモト ショウタ"/></div>
          <div><label className="text-xs text-gray-500">人数</label><input type="number" value={f.people} onChange={e=>upF("people",+e.target.value)} className="input-s"/></div>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
          <div><label className="text-xs text-gray-500">貸出日</label><input type="date" value={f.lendDate} onChange={e=>upF("lendDate",e.target.value)} className="input-s"/></div>
          <div><label className="text-xs text-gray-500">貸出時間</label><input value={f.lendTime} onChange={e=>upF("lendTime",e.target.value)} className="input-s" placeholder="09:00"/></div>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
          <div><label className="text-xs text-gray-500">返却日</label><input type="date" value={f.returnDate} onChange={e=>upF("returnDate",e.target.value)} className="input-s"/></div>
          <div><label className="text-xs text-gray-500">返却時間</label><input value={f.returnTime} onChange={e=>upF("returnTime",e.target.value)} className="input-s" placeholder="18:00"/></div>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
          <div><label className="text-xs text-gray-500">予約車種（クラス）</label><select value={f.vehicle} onChange={e=>upF("vehicle",e.target.value)} className="input-s">{vehicleClasses.map(c=><option key={c.type} value={c.type}>{c.type}クラス — {c.label}</option>)}</select></div>
          <div><label className="text-xs text-gray-500">車両（ナンバー）</label><select value={f.vehicleCode} onChange={e=>upF("vehicleCode",e.target.value)} className="input-s"><option value="">未定（配車表で手動）</option>{vehicles.filter(v=>v.type===f.vehicle).map(v=><option key={v.id} value={v.code}>{v.name} ({v.no}) {v.seats}名</option>)}</select></div>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
          <div><label className="text-xs text-gray-500">補償プラン</label><select value={f.insurance} onChange={e=>upF("insurance",e.target.value)} className="input-s"><option>免責</option><option>NOC</option></select></div>
          <div><label className="text-xs text-gray-500">OTA（予約先）</label><select value={f.ota} onChange={e=>upF("ota",e.target.value)} className="input-s">{Object.entries(OTA).map(([k,o])=><option key={k} value={k}>{o.name}</option>)}<option value="direct">直接予約</option></select></div>
        </div>
        <div><label className="text-xs text-gray-500">予約番号</label><input value={f.id} onChange={e=>upF("id",e.target.value)} className="input-s"/></div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
          <div><label className="text-xs text-gray-500">お届け場所</label><input value={f.delPlace} onChange={e=>upF("delPlace",e.target.value)} className="input-s" placeholder="新千歳空港 etc."/></div>
          <div><label className="text-xs text-gray-500">回収場所</label><input value={f.colPlace} onChange={e=>upF("colPlace",e.target.value)} className="input-s" placeholder="新千歳空港 etc."/></div>
        </div>
        <div><label className="text-xs text-gray-500">到着便名</label><input value={f.flight||""} onChange={e=>upF("flight",e.target.value)} className="input-s" placeholder="ANA123"/></div>
        <button onClick={submit} className="btn-primary w-full" style={{padding:10,marginTop:8}}>予約を登録</button>
      </div>}
    </div>
  </div></div>;
}

/* ==========================================
   タイムテーブル
   ========================================== */
function TimeTable({tasks,staffCount}){
  const lend=tasks.filter(t=>["DEL","PU","PUB","来店"].includes(t.type));const ret=tasks.filter(t=>["COL","BD","BDB","返却"].includes(t.type));
  const rows=[{l:"人員",bg:"#e0e7ff",fg:"#4338ca",b:true,data:SLOTS.map(()=>staffCount),total:staffCount},{l:"貸出計",bg:"#dbeafe",fg:"#1e40af",b:true,w:true,data:SLOTS.map(s=>lend.filter(t=>t.time===s).length),total:lend.length},{l:"┗DEL",bg:"#eff6ff",fg:"#2563eb",data:SLOTS.map(s=>tasks.filter(t=>t.type==="DEL"&&t.time===s).length),total:tasks.filter(t=>t.type==="DEL").length},{l:"┗PUB/PU/来店",bg:"#f5f3ff",fg:"#6d28d9",data:SLOTS.map(s=>tasks.filter(t=>(t.type==="PU"||t.type==="PUB"||t.type==="来店")&&t.time===s).length),total:tasks.filter(t=>t.type==="PU"||t.type==="PUB"||t.type==="来店").length},{l:"返却計",bg:"#ffedd5",fg:"#c2410c",b:true,w:true,data:SLOTS.map(s=>ret.filter(t=>t.time===s).length),total:ret.length},{l:"┗COL",bg:"#fff7ed",fg:"#ea580c",data:SLOTS.map(s=>tasks.filter(t=>t.type==="COL"&&t.time===s).length),total:tasks.filter(t=>t.type==="COL").length},{l:"┗返却/BDB/BD",bg:"#fffbeb",fg:"#b45309",data:SLOTS.map(s=>tasks.filter(t=>(t.type==="返却"||t.type==="BD"||t.type==="BDB")&&t.time===s).length),total:tasks.filter(t=>t.type==="返却"||t.type==="BD"||t.type==="BDB").length},{l:"洗車/他",bg:"#f8fafc",fg:"#64748b",data:SLOTS.map(s=>tasks.filter(t=>!["DEL","PU","PUB","来店","COL","BD","BDB","返却"].includes(t.type)&&t.time===s).length),total:tasks.filter(t=>!["DEL","PU","PUB","来店","COL","BD","BDB","返却"].includes(t.type)).length}];
  return <div className="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden"><div style={{overflowX:"auto"}}><table style={{width:"100%",borderCollapse:"collapse",fontSize:10,whiteSpace:"nowrap"}}><thead><tr style={{background:"#f1f5f9"}}><th style={{position:"sticky",left:0,zIndex:2,background:"#f1f5f9",padding:"4px 5px",textAlign:"left",fontWeight:600,minWidth:60,borderBottom:"1px solid #e2e8f0",fontSize:9}}>TT</th><th style={{padding:"4px 2px",textAlign:"center",fontWeight:600,borderBottom:"1px solid #e2e8f0",fontSize:9}}>計</th>{SLOTS.map(s=><th key={s} style={{padding:"4px 2px",textAlign:"center",fontWeight:500,color:"#64748b",borderBottom:"1px solid #e2e8f0",minWidth:26,fontSize:8}}>{s}</th>)}</tr></thead><tbody>{rows.map((r,i)=><tr key={i}><td style={{position:"sticky",left:0,zIndex:2,background:r.bg,color:r.fg,padding:"2px 5px",fontWeight:r.b?700:500,fontSize:9}}>{r.l}</td><td style={{background:r.bg,color:r.fg,padding:"2px 2px",textAlign:"center",fontWeight:700,fontSize:9}}>{r.total||""}</td>{r.data.map((v,ci)=>{const over=r.w&&v>staffCount;return <td key={ci} style={{background:over?"#fecaca":r.bg,color:over?"#dc2626":v>0?r.fg:"#e2e8f0",padding:"2px",textAlign:"center",fontWeight:over||v>0?700:400,fontSize:9}}>{v||""}</td>;})}</tr>)}</tbody></table></div></div>;
}

/* ==========================================
   配車管理タイムライン（ガントチャート）
   ========================================== */
function FleetTimeline({data,fleet,onFleetChange,today,maintenance,onMaintenanceChange,vehicles,vehicleClasses,onAddReservation,onBulkAddReservation,onCancelReservation,onReassignVehicle,unassignedReasons,hmReload}){
  const scrollRef=useRef(null);const[tooltip,setTooltip]=useState(null);const[viewMode,setViewMode]=useState("month");const[baseDate,setBaseDate]=useState(today);const[collapsed,setCollapsed]=useState(()=>window.innerWidth<=768?{unassignedAlert:true}:{});const[showMaintForm,setShowMaintForm]=useState(null);const[showResForm,setShowResForm]=useState(null);
  const[dragInfo,setDragInfo]=useState(null);const[dropTarget,setDropTarget]=useState(null);const dropTargetRef=useRef(null);
  // ★ 月別稼働フラグ
  const[kpiFlags,setKpiFlags]=useState({});
  const kpiYM=useMemo(()=>{const d=new Date(baseDate+"T00:00:00");return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0");},[baseDate]);
  useEffect(()=>{
    if(!sb)return;
    (async()=>{
      const{data:rows}=await sb.from("tkm_vehicle_monthly_kpi").select("*").eq("year_month",kpiYM);
      const f={};(rows||[]).forEach(r=>f[r.vehicle_code]=r.active);
      setKpiFlags(f);
    })();
  },[kpiYM]);
  const toggleKpi=(code)=>{
    const cur=kpiFlags[code]!==undefined?kpiFlags[code]:(vehicles.find(v=>v.code===code)?.active!==false);
    const next=!cur;
    setKpiFlags(prev=>({...prev,[code]:next}));
    if(sb)sb.from("tkm_vehicle_monthly_kpi").upsert({vehicle_code:code,year_month:kpiYM,active:next},{onConflict:"vehicle_code,year_month"}).then(({error})=>{if(error)console.error("[KPI]",error.message);});
  };
  const isKpiActive=(code)=>kpiFlags[code]!==undefined?kpiFlags[code]:(vehicles.find(v=>v.code===code)?.active!==false);
  const kpiCount=vehicles.filter(v=>isKpiActive(v.code)).length;
  const[searchQuery,setSearchQuery]=useState("");const[searchResult,setSearchResult]=useState(null);const searchInputRef=useRef(null);const vehicleRowRefs=useRef({});
  // 検索実行: 予約番号(部分一致) or 予約者名で検索
  const doSearch=(q)=>{if(!q.trim()){setSearchResult(null);return;}const ql=q.trim().toLowerCase();const hits=data.filter(r=>r.status!=="cancelled"&&((r.id&&r.id.toLowerCase().includes(ql))||(r.name&&r.name.toLowerCase().includes(ql))));if(hits.length===0){setSearchResult({found:false,hitSet:null,info:""});return;}const firstHit=hits[0];const vc=fleet[firstHit.id];const vn=vc?vehicles.find(x=>x.code===vc):null;const info=firstHit.name+" / "+(vn?vn.name+"("+vn.no+")":"未配車")+" / "+firstHit.lendDate+"〜"+firstHit.returnDate;const hitSet=new Set(hits.map(r=>r.id));setSearchResult({found:true,hitSet,info,vc});if(firstHit.lendDate){const dt=new Date(firstHit.lendDate+"T00:00:00");const newBase=toLD(new Date(dt.getFullYear(),dt.getMonth(),1));if(newBase!==baseDate){setBaseDate(newBase);setTimeout(()=>{scrollToVehicle_(vc);},300);return;}}scrollToVehicle_(vc);};
  const scrollToVehicle_=(vc)=>{if(!vc||!vehicleRowRefs.current[vc]||!scrollRef.current)return;const el=vehicleRowRefs.current[vc];const container=scrollRef.current;const elTop=el.offsetTop;container.scrollTop=Math.max(0,elTop-80);};
  const clearSearch=()=>{setSearchQuery("");setSearchResult(null);if(searchInputRef.current)searchInputRef.current.value="";};
  useEffect(()=>{const handler=(e)=>{if(e.key==="Escape"&&searchResult)clearSearch();};window.addEventListener("keydown",handler);return()=>window.removeEventListener("keydown",handler);},[searchResult]);
  const WK=["日","月","火","水","木","金","土"];

  const dates=useMemo(()=>{const dt=new Date(baseDate+"T00:00:00");if(viewMode==="month"){const y=dt.getFullYear(),m=dt.getMonth();const days=new Date(y,m+1,0).getDate();return Array.from({length:days},(_,i)=>toLD(new Date(y,m,i+1)));}else if(viewMode==="week"){const d=new Date(baseDate+"T00:00:00");d.setDate(d.getDate()-d.getDay());return Array.from({length:7},(_,i)=>dOff(toLD(d),i));}else return[baseDate];},[baseDate,viewMode]);

  const[isMobile,setIsMobile]=useState(window.innerWidth<=768);
  useEffect(()=>{const h=()=>setIsMobile(window.innerWidth<=768);window.addEventListener("resize",h);return()=>window.removeEventListener("resize",h);},[]);
  const COL_W=viewMode==="month"?(isMobile?60:80):viewMode==="week"?(isMobile?100:140):600;const LEFT_W=isMobile?100:260;const ROW_H=30;const CLASS_H=28;
  const monthLabel=useMemo(()=>{const dt=new Date(baseDate+"T00:00:00");return`${dt.getFullYear()}年${dt.getMonth()+1}月`;},[baseDate]);
  const monthStats=useMemo(()=>{const dt=new Date(baseDate+"T00:00:00");const y=dt.getFullYear(),m=dt.getMonth();const mStart=`${y}-${String(m+1).padStart(2,"0")}-01`;const mEnd=`${y}-${String(m+1).padStart(2,"0")}-${new Date(y,m+1,0).getDate()}`;const active=data.filter(r=>r.status!=="cancelled");const dep=active.filter(r=>r.lendDate>=mStart&&r.lendDate<=mEnd).length;const ret=active.filter(r=>r.returnDate>=mStart&&r.returnDate<=mEnd).length;return{dep,ret};},[data,baseDate]);

  useEffect(()=>{if(scrollRef.current){const ti=dates.indexOf(today);if(ti>=0)scrollRef.current.scrollLeft=Math.max(0,(ti-2)*COL_W);}},[dates,today]);
  const goToday=()=>setBaseDate(today);
  const goPrev=()=>{const dt=new Date(baseDate+"T00:00:00");if(viewMode==="month")dt.setMonth(dt.getMonth()-1);else if(viewMode==="week")dt.setDate(dt.getDate()-7);else dt.setDate(dt.getDate()-1);setBaseDate(toLD(dt));};
  const goNext=()=>{const dt=new Date(baseDate+"T00:00:00");if(viewMode==="month")dt.setMonth(dt.getMonth()+1);else if(viewMode==="week")dt.setDate(dt.getDate()+7);else dt.setDate(dt.getDate()+1);setBaseDate(toLD(dt));};
  const toggleClass=(t)=>setCollapsed(p=>({...p,[t]:!p[t]}));

  const vehicleBars=useMemo(()=>{
    const bars={};vehicles.forEach(v=>{bars[v.code]=[];});
    const dFirst=dates[0],dLast=dates[dates.length-1];data.forEach(r=>{if(r.status==="cancelled")return;const vc=fleet[r.id];if(!vc||!bars[vc])return;const ld=norm(r.lendDate),rd=norm(r.returnDate);if(rd<dFirst||ld>dLast)return;const si=dates.indexOf(ld),ei=dates.indexOf(rd);const s=si>=0?si:0;const e=ei>=0?ei:dates.length-1;bars[vc].push({type:"reservation",r,startI:s,endI:e,left:s*COL_W,width:(e-s+1)*COL_W-2});});
    (maintenance||[]).forEach(m=>{if(!bars[m.vehicleCode])return;const dFirst=dates[0],dLast=dates[dates.length-1];if(m.endDate<dFirst||m.startDate>dLast)return;const si=dates.indexOf(m.startDate),ei=dates.indexOf(m.endDate);const s=si>=0?si:0;const e=ei>=0?ei:dates.length-1;bars[m.vehicleCode].push({type:"maintenance",m,startI:s,endI:e,left:s*COL_W,width:(e-s+1)*COL_W-2});});
    return bars;
  },[data,fleet,dates,maintenance,vehicles]);

  // 車両ごとの月別稼働率（表示期間の月の1日〜末日で計算）
  const utilRates=useMemo(()=>{
    const bd=new Date(baseDate+"T00:00:00");const y=bd.getFullYear(),m=bd.getMonth();
    const dim=new Date(y,m+1,0).getDate();
    const rates={};
    vehicles.forEach(v=>{
      // ★ 日単位のSetで重複カウントを防止
      const rentalDays=new Set();
      const maintDays=new Set();
      const ms=new Date(y,m,1),me=new Date(y,m,dim);
      // 予約による稼働日
      data.forEach(r=>{if(r.status==="cancelled")return;if(fleet[r.id]!==v.code)return;
        const ld=new Date(norm(r.lendDate)+"T00:00:00"),rd=new Date(norm(r.returnDate)+"T00:00:00");
        const s=ld>ms?ld:ms;const e=rd<me?rd:me;
        for(let d=new Date(s);d<=e;d.setDate(d.getDate()+1)){rentalDays.add(toLD(d));}
      });
      // メンテナンス日数 → 最大稼働日数から減算
      (maintenance||[]).forEach(mt=>{if(mt.vehicleCode!==v.code)return;
        const ld=new Date(norm(mt.startDate)+"T00:00:00"),rd=new Date(norm(mt.endDate)+"T00:00:00");
        const s=ld>ms?ld:ms;const e=rd<me?rd:me;
        for(let d=new Date(s);d<=e;d.setDate(d.getDate()+1)){maintDays.add(toLD(d));}
      });
      const days=rentalDays.size;
      rates[v.code]={days,total:dim,maintDays:maintDays.size,pct:dim>0?Math.min(Math.round(days/dim*100),100):0};
    });
    return rates;
  },[data,fleet,vehicles,maintenance,baseDate]);

  // ★ 稼働フラグON車両の合算稼働率
  const totalUtil=useMemo(()=>{
    const bd=new Date(baseDate+"T00:00:00");const dim=new Date(bd.getFullYear(),bd.getMonth()+1,0).getDate();
    let totalDays=0,activeCount=0;
    vehicles.forEach(v=>{
      if(!isKpiActive(v.code))return;
      activeCount++;
      const u=utilRates[v.code];
      if(u)totalDays+=u.days;
    });
    const maxDays=activeCount*dim;
    return{totalDays,activeCount,maxDays,pct:maxDays>0?Math.round(totalDays/maxDays*100):0};
  },[utilRates,vehicles,kpiFlags,baseDate]);

  // セルクリック → アクション選択
  const[cellAction,setCellAction]=useState(null);
  const handleCellClick=(vehicleCode,dateStr)=>{
    const existing=data.find(r=>fleet[r.id]===vehicleCode&&norm(r.lendDate)<=dateStr&&norm(r.returnDate)>=dateStr);
    if(existing){setTooltip({type:"reservation",...existing,vc:vehicleCode});return;}
    setCellAction({vehicleCode,date:dateStr});
  };
  const handleBarClick=(e,b)=>{e.stopPropagation();if(b.type==="reservation")setTooltip({type:"reservation",...b.r,vc:fleet[b.r.id]});else setTooltip({type:"maintenance",...b.m});};

  const addMaint=(vc,start,end,label)=>{const m={id:"m"+Date.now(),vehicleCode:vc,startDate:start,endDate:end,label};const next=[...(maintenance||[]),m];onMaintenanceChange(next);DB._maintLsSave(next);DB.saveMaintenance([m]);setShowMaintForm(null);
    // ★ 双方向連動: メンテナンスブロック追加 → HM車両ステータスも更新（未来のメンテも含む）
    try{var today2=new Date().toISOString().slice(0,10);if(end>=today2){
      var cars=JSON.parse(localStorage.getItem("tkm_hm_cars")||"[]");
      var car=cars.find(function(c){return c.id===vc});
      if(car&&car.status==="active"){car.status="repair";localStorage.setItem("tkm_hm_cars",JSON.stringify(cars));
        DB.hm.saveCar(car).then(function(){if(hmReload)return hmReload();}).catch(function(){});
      }
    }}catch(e){}
  };
  const removeMaint=(id)=>{const removed=(maintenance||[]).find(m=>m.id===id);const next=(maintenance||[]).filter(m=>m.id!==id);onMaintenanceChange(next);DB._maintLsSave(next);DB.deleteMaintenance(id);setTooltip(null);
    // ★ 双方向連動: メンテナンス削除 → 他にメンテが無ければHMステータスを稼働に戻す
    if(removed){try{var vc=removed.vehicleCode;var today=new Date().toISOString().slice(0,10);
      var hasOther=next.some(function(m){return m.vehicleCode===vc&&m.startDate<=today&&m.endDate>=today});
      if(!hasOther){var cars=JSON.parse(localStorage.getItem("tkm_hm_cars")||"[]");
        var car=cars.find(function(c){return c.id===vc});
        if(car&&car.status!=="active"){car.status="active";localStorage.setItem("tkm_hm_cars",JSON.stringify(cars));
          DB.hm.saveCar(car).then(function(){if(hmReload)return hmReload();}).catch(function(){});
        }
        // HM連動メンテも削除
        var ls=JSON.parse(localStorage.getItem("tkm_maintenance")||"[]");
        ls=ls.filter(function(m){return m.id!=="hm_"+vc});
        localStorage.setItem("tkm_maintenance",JSON.stringify(ls));
      }
    }catch(e){}}
  };

  // ドラッグ&ドロップで車両変更（スロットル付き）
  const handleDragStart=(e,resId)=>{e.dataTransfer.setData("text/plain",resId);e.dataTransfer.effectAllowed="move";setDragInfo(resId);};
  const handleDragEnd=()=>{setDragInfo(null);setDropTarget(null);dropTargetRef.current=null;lastDragOverRef.current={vc:"",t:0};};
  const lastDragOverRef=useRef({vc:"",t:0});
  const handleDragOver=(e,vehicleCode)=>{
    if(!dragInfo)return;e.preventDefault();e.dataTransfer.dropEffect="move";
    // ★ 同じ車両なら完全スキップ（state更新なし=再レンダリングなし）
    if(lastDragOverRef.current.vc===vehicleCode)return;
    lastDragOverRef.current={vc:vehicleCode,t:Date.now()};
    const curVc=fleet[dragInfo];if(curVc===vehicleCode){if(dropTargetRef.current){dropTargetRef.current=null;setDropTarget(null);}return;}
    const conflict=checkVehicleConflict(vehicleCode,dragInfo,data,fleet,maintenance);
    const dt={vc:vehicleCode,ok:!conflict,conflict};
    dropTargetRef.current=dt;
    setDropTarget(dt);
  };
  const handleDrop=(e,vehicleCode)=>{
    e.preventDefault();const resId=e.dataTransfer.getData("text/plain");if(!resId)return;
    setDragInfo(null);setDropTarget(null);
    const res=data.find(r=>r.id===resId);if(!res)return;
    const curVc=fleet[resId];if(curVc===vehicleCode)return;
    const curV=vehicles.find(v=>v.code===curVc);const targetV=vehicles.find(v=>v.code===vehicleCode);
    const conflict=checkVehicleConflict(vehicleCode,resId,data,fleet,maintenance);
    if(conflict){alert((targetV?targetV.name:vehicleCode)+" は "+fmtD(conflict.lendDate)+"〜"+fmtD(conflict.returnDate)+" に「"+conflict.name+"」様の予約が入っているため変更できません。");return;}
    if(!window.confirm(res.name+" 様の配車を\n「"+(curV?curV.name:"未割当")+"」→「"+(targetV?targetV.name:vehicleCode)+"」\nに変更しますか？\n\n※OPシートの車両情報も同時に更新されます"))return;
    if(onReassignVehicle)onReassignVehicle(resId,vehicleCode);
    else onFleetChange({...fleet,[resId]:vehicleCode});
  };

  const groups=useMemo(()=>vehicleClasses.map(vc=>({...vc,items:vehicles.filter(v=>v.type===vc.type)})).filter(g=>g.items.length>0),[vehicles,vehicleClasses]);

  return <div style={{display:"flex",flexDirection:"column",background:"#fff",borderRadius:12,boxShadow:"0 1px 3px rgba(0,0,0,.06)",border:"1px solid #e5e7eb",overflow:"hidden",height:"100%",minHeight:0}}>
    <div style={{padding:isMobile?"4px 6px":"8px 12px",background:"#f8fafc",borderBottom:"1px solid #e5e7eb",display:"flex",alignItems:"center",justifyContent:"space-between",flexWrap:"wrap",gap:isMobile?4:8,flexShrink:0,position:"sticky",top:0,zIndex:20}}>
      <div style={{display:"flex",alignItems:"center",gap:isMobile?2:8}}>
        <button onClick={goToday} style={{padding:isMobile?"2px 4px":"4px 8px",background:"#fff",border:"1px solid #d1d5db",borderRadius:4,fontSize:isMobile?9:12,fontWeight:600,cursor:"pointer"}}>今日</button>
        <button onClick={goPrev} style={{padding:isMobile?"2px 4px":"4px 8px",background:"#fff",border:"1px solid #d1d5db",borderRadius:4,fontSize:isMobile?10:14,cursor:"pointer"}}>◀</button>
        <button onClick={goNext} style={{padding:isMobile?"2px 4px":"4px 8px",background:"#fff",border:"1px solid #d1d5db",borderRadius:4,fontSize:isMobile?10:14,cursor:"pointer"}}>▶</button>
        <span style={{fontSize:isMobile?11:14,fontWeight:700,color:"#1e293b",marginLeft:2}}>{monthLabel}</span>
        {viewMode==="month"&&<span style={{display:"inline-flex",gap:isMobile?4:8,marginLeft:isMobile?4:12,fontSize:isMobile?8:11,fontWeight:600}}>
          <span style={{background:"#dbeafe",color:"#1e40af",padding:"2px 6px",borderRadius:4}}>出発 {monthStats.dep}</span>
          <span style={{background:"#fef3c7",color:"#92400e",padding:"2px 6px",borderRadius:4}}>返却 {monthStats.ret}</span>
          <span style={{background:"#dcfce7",color:"#166534",padding:"2px 6px",borderRadius:4}}>洗車 {monthStats.dep}</span>
          <span style={{background:"#f0fdf4",color:"#059669",padding:"2px 6px",borderRadius:4,border:"1px solid #86efac"}}>📊稼働 {kpiCount}台 {totalUtil.pct}%（{totalUtil.totalDays}/{totalUtil.maxDays}日）</span>
        </span>}
      </div>
      <div style={{display:"flex",alignItems:"center",gap:isMobile?2:8}}>
        <div style={{position:"relative",display:"flex",alignItems:"center"}}>
          <input ref={searchInputRef} type="text" placeholder="予約番号/名前" value={searchQuery} onChange={e=>setSearchQuery(e.target.value)} onKeyDown={e=>{if(e.key==="Enter")doSearch(searchQuery);if(e.key==="Escape")clearSearch();}} style={{width:isMobile?90:130,padding:isMobile?"2px 20px 2px 4px":"3px 24px 3px 6px",fontSize:isMobile?9:11,border:"1px solid #d1d5db",borderRadius:4,background:"#fff",outline:"none"}}/>
          {searchQuery&&<button onClick={clearSearch} style={{position:"absolute",right:isMobile?2:4,top:"50%",transform:"translateY(-50%)",background:"none",border:"none",cursor:"pointer",color:"#94a3b8",fontSize:isMobile?10:12,lineHeight:1,padding:0}}>✕</button>}
          {searchResult&&!searchResult.found&&<span style={{fontSize:9,color:"#dc2626",fontWeight:600,whiteSpace:"nowrap",marginLeft:4}}>✕</span>}
        </div>
        <button onClick={()=>doSearch(searchQuery)} style={{padding:isMobile?"2px 4px":"3px 6px",background:"#e2e8f0",border:"1px solid #d1d5db",borderRadius:4,fontSize:isMobile?9:11,fontWeight:600,cursor:"pointer",color:"#475569"}}>検索</button>
        {searchResult&&searchResult.found&&<span style={{fontSize:isMobile?8:10,color:"#1e40af",fontWeight:700,whiteSpace:"nowrap",background:"#dbeafe",padding:"2px 6px",borderRadius:4}}>📍{searchResult.info}</span>}
        <button onClick={()=>setShowResForm({})} style={{padding:isMobile?"2px 6px":"4px 8px",background:"#16a34a",color:"#fff",border:"none",borderRadius:4,fontSize:isMobile?9:12,fontWeight:700,cursor:"pointer"}}>＋予約</button>
        <div style={{display:"flex",border:"1px solid #d1d5db",borderRadius:4,overflow:"hidden"}}>{["day","week","month"].map(m=><button key={m} onClick={()=>setViewMode(m)} style={{padding:isMobile?"2px 4px":"4px 8px",fontSize:isMobile?9:12,fontWeight:600,background:viewMode===m?"#1e40af":"#fff",color:viewMode===m?"#fff":"#374151",border:"none",cursor:"pointer"}}>{m}</button>)}</div>
      </div>
    </div>

    {((unassigned)=>{const allUa=data.filter(r=>r.status!=="cancelled"&&!fleet[r.id]&&r.returnDate&&r.returnDate>=today);
      const[hiddenIds,setHiddenIds]=React.useState(()=>{try{return JSON.parse(localStorage.getItem("tkm_hidden_unassigned")||"[]");}catch(e){return[];}});
      const hideId=(id)=>{const next=[...hiddenIds,id];setHiddenIds(next);try{localStorage.setItem("tkm_hidden_unassigned",JSON.stringify(next));}catch(e){}};
      const showAll=()=>{setHiddenIds([]);try{localStorage.removeItem("tkm_hidden_unassigned");}catch(e){}};
      const ua=allUa.filter(r=>!hiddenIds.includes(r.id));
      const hiddenCount=allUa.length-ua.length;
      return allUa.length>0?<div style={{borderBottom:"1px solid #fca5a5",background:"#fef2f2",padding:isMobile?"4px 8px":"12px 16px",flexShrink:0,maxHeight:collapsed.unassignedAlert?36:isMobile?"30vh":"25vh",overflow:collapsed.unassignedAlert?"hidden":"auto"}}>
      <div style={{display:"flex",alignItems:"center",gap:6,fontSize:isMobile?10:12,fontWeight:700,color:"#dc2626"}}>
        <span>⚠</span>
        <span>未配車 {ua.length}件</span>
        <button onClick={()=>setCollapsed(p=>({...p,unassignedAlert:!p.unassignedAlert}))} style={{marginLeft:"auto",background:"none",border:"none",cursor:"pointer",color:"#dc2626",fontSize:12,fontWeight:600}}>{collapsed.unassignedAlert?"▶":"▼"}</button>
      </div>
      {!collapsed.unassignedAlert&&<div style={{overflowX:"auto",marginTop:4}}>
        <table style={{fontSize:10,borderCollapse:"collapse",width:"100%"}}>
          <thead><tr style={{background:"#fee2e2"}}>
            <th style={{padding:"4px 6px",textAlign:"left",fontWeight:700,border:"1px solid #fca5a5"}}>OTA</th>
            <th style={{padding:"4px 6px",textAlign:"left",fontWeight:700,border:"1px solid #fca5a5"}}>予約番号</th>
            <th style={{padding:"4px 6px",textAlign:"left",fontWeight:700,border:"1px solid #fca5a5"}}>予約者名</th>
            <th style={{padding:"4px 6px",textAlign:"center",fontWeight:700,border:"1px solid #fca5a5"}}>クラス</th>
            <th style={{padding:"4px 6px",textAlign:"center",fontWeight:700,border:"1px solid #fca5a5"}}>貸出日</th>
            <th style={{padding:"4px 6px",textAlign:"center",fontWeight:700,border:"1px solid #fca5a5"}}>返却日</th>
            <th style={{padding:"4px 6px",textAlign:"left",fontWeight:700,border:"1px solid #fca5a5"}}>未配車理由</th>
            <th style={{padding:"4px 6px",textAlign:"center",fontWeight:700,border:"1px solid #fca5a5"}}>手動配車</th>
            <th style={{padding:"4px 6px",textAlign:"center",fontWeight:700,border:"1px solid #fca5a5",width:36}}></th>
          </tr></thead>
          <tbody>
            {ua.map(r=>{
              const reason=(unassignedReasons||{})[r.id]||"";
              const rL=norm(r.lendDate),rR=norm(r.returnDate);
              // ★ 空き車両を先頭に表示（同クラス優先 + 期間重複チェック）
              const sameClass=vehicles.filter(v=>v.type===r.vehicle);
              const otherClass=vehicles.filter(v=>v.type!==r.vehicle);
              const checkAvail=(v)=>{
                const conflict=data.find(o=>o.id!==r.id&&o.status!=="cancelled"&&fleet[o.id]===v.code&&norm(o.lendDate)<=rR&&norm(o.returnDate)>=rL);
                const inMaint=(maintenance||[]).some(m=>m.vehicleCode===v.code&&norm(m.startDate)<=rR&&norm(m.endDate)>=rL);
                return !conflict&&!inMaint;
              };
              const availSame=sameClass.filter(checkAvail);
              const availOther=otherClass.filter(checkAvail);
              return <tr key={r.id} style={{background:"#fff5f5",borderBottom:"1px solid #fca5a5"}}>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5"}}><OBadge ota={r.ota}/></td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",fontFamily:"monospace",fontSize:9}}>{r.id}</td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5"}}>{r.name}</td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",textAlign:"center"}}>{r.vehicle}</td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",textAlign:"center",fontSize:9}}>{fmtD(r.lendDate)}<br/>{r.lendTime}</td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",textAlign:"center",fontSize:9}}>{fmtD(r.returnDate)}<br/>{r.returnTime}</td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",fontSize:8,color:"#b91c1c",maxWidth:180}}>{reason||"不明"}</td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",textAlign:"center",whiteSpace:"nowrap"}}>
                {(()=>{const selId="ua_sel_"+r.id;return <><select id={selId} style={{fontSize:9,border:"1px solid #d1d5db",borderRadius:4,padding:"2px 4px",background:availSame.length>0?"#dcfce7":"#fff"}}>
                  <option value="">車両選択{availSame.length>0?" (空き"+availSame.length+"台)":""}</option>
                  {availSame.length>0&&<optgroup label={"★ "+r.vehicle+"クラス 空き ("+availSame.length+"台)"}>
                    {availSame.map(v=><option key={v.code} value={v.code}>✅ {v.name} ({v.no})</option>)}
                  </optgroup>}
                  {availOther.length>0&&<optgroup label="他クラス 空き">
                    {availOther.map(v=><option key={v.code} value={v.code}>{v.name} ({v.no}) [{v.type}]</option>)}
                  </optgroup>}
                  <optgroup label="全車両">
                    {vehicles.map(v=><option key={v.code} value={v.code}>{v.name} ({v.no}) [{v.type}]</option>)}
                  </optgroup>
                </select>{" "}<button onClick={()=>{const sel=document.getElementById(selId);const vc=sel?sel.value:"";if(!vc){alert("車両を選択してください");return;}const conflict=checkVehicleConflict(vc,r.id,data,fleet,maintenance);if(conflict){const cv=vehicles.find(x=>x.code===vc);alert((cv?cv.name:vc)+" は "+fmtD(conflict.lendDate)+"〜"+fmtD(conflict.returnDate)+" に「"+conflict.name+"」様の"+(conflict._isMaint?"メンテナンス":"予約")+"が入っているため配車できません。");return;}const targetV=vehicles.find(x=>x.code===vc);if(!window.confirm(r.name+" 様を「"+(targetV?targetV.name:vc)+"」に配車しますか？"))return;if(onReassignVehicle)onReassignVehicle(r.id,vc);else onFleetChange({...fleet,[r.id]:vc});}} style={{fontSize:9,fontWeight:700,background:"#2563eb",color:"#fff",border:"none",borderRadius:4,padding:"3px 10px",cursor:"pointer"}}>配車</button></>})()}
              </td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",textAlign:"center"}}>
                <button onClick={()=>{if(window.confirm(r.name+" 様を未配車リストから非表示にしますか？\n\n※データは変更しません\n※「全て再表示」で戻せます"))hideId(r.id);}} title="リストから非表示（データは変更しません）" style={{background:"#f1f5f9",color:"#64748b",border:"1px solid #d1d5db",borderRadius:4,fontSize:9,fontWeight:700,padding:"2px 5px",cursor:"pointer",lineHeight:1}}>✕</button>
              </td>
            </tr>;})}
          </tbody>
        </table>
        {/* ★ 非表示にした予約BOX */}
        {hiddenCount>0&&<details style={{marginTop:6,background:"#f8fafc",borderRadius:6,border:"1px solid #e2e8f0"}}>
          <summary style={{padding:"6px 10px",cursor:"pointer",fontSize:10,fontWeight:700,color:"#64748b",userSelect:"none",listStyle:"none",display:"flex",alignItems:"center",gap:6}}>
            <span style={{fontSize:9,color:"#94a3b8"}}>▶</span>
            <span>非表示 {hiddenCount}件</span>
            <button onClick={e=>{e.stopPropagation();e.preventDefault();if(window.confirm("非表示を全てリストに戻しますか？"))showAll();}} style={{marginLeft:"auto",background:"#fbbf24",color:"#78350f",border:"none",borderRadius:4,fontSize:8,fontWeight:700,padding:"2px 8px",cursor:"pointer"}}>全て再表示</button>
          </summary>
          <div style={{padding:"4px 8px 8px",overflowX:"auto"}}>
            <table style={{fontSize:9,borderCollapse:"collapse",width:"100%"}}>
              <tbody>
                {allUa.filter(r=>hiddenIds.includes(r.id)).map(r=>
                  <tr key={r.id} style={{background:"#f1f5f9",borderBottom:"1px solid #e2e8f0",opacity:0.6}}>
                    <td style={{padding:"3px 6px"}}><OBadge ota={r.ota}/></td>
                    <td style={{padding:"3px 6px"}}>{r.name}</td>
                    <td style={{padding:"3px 6px",textAlign:"center"}}>{r.vehicle}</td>
                    <td style={{padding:"3px 6px",fontSize:8}}>{fmtD(r.lendDate)}〜{fmtD(r.returnDate)}</td>
                    <td style={{padding:"3px 6px",textAlign:"center"}}>
                      <button onClick={()=>{const next=hiddenIds.filter(x=>x!==r.id);setHiddenIds(next);try{localStorage.setItem("tkm_hidden_unassigned",JSON.stringify(next));}catch(e){}}} style={{background:"#dbeafe",color:"#1d4ed8",border:"none",borderRadius:4,fontSize:8,fontWeight:700,padding:"2px 6px",cursor:"pointer"}}>戻す</button>
                    </td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </details>}
      </div>}
    </div>:null;})()}

    <div ref={scrollRef} style={{flex:1,overflow:"auto",position:"relative"}}>
      <table style={{borderCollapse:"collapse",minWidth:LEFT_W+dates.length*COL_W}}>
        <thead><tr style={{position:"sticky",top:0,zIndex:10}}>
          <th style={{position:"sticky",left:0,zIndex:11,width:LEFT_W,minWidth:LEFT_W,height:44,background:"#f1f5f9",borderBottom:"2px solid #94a3b8",borderRight:"2px solid #94a3b8",padding:"0 8px",textAlign:"left",fontSize:11,fontWeight:700,color:"#1e293b"}}>車両</th>
          {dates.map(d=>{const dt=new Date(d);const dow=dt.getDay();const isToday=d===today;return <th key={d} style={{width:COL_W,minWidth:COL_W,height:44,textAlign:"center",borderRight:"1px solid #cbd5e1",background:isToday?"#dbeafe":"#f1f5f9",borderBottom:"2px solid #94a3b8",padding:0}}><div style={{fontSize:isMobile?9:11,fontWeight:600,color:isToday?"#1d4ed8":"#334155"}}>{dt.getDate()}<span style={{fontSize:isMobile?8:9,fontWeight:dow===0||dow===6?700:400,color:dow===0?"#dc2626":dow===6?"#2563eb":"#64748b",marginLeft:1}}>{WK[dow]}</span></div></th>;})}
        </tr></thead>
        <tbody>
          {groups.map(g=><React.Fragment key={g.type}>
            <tr onClick={()=>toggleClass(g.type)} style={{cursor:"pointer",userSelect:"none"}}>
              <td style={{position:"sticky",left:0,zIndex:5,height:CLASS_H,background:"#f8fafc",borderBottom:"1px solid #e2e8f0",borderRight:"2px solid #94a3b8",padding:"0 6px"}}><span style={{fontSize:10,color:"#64748b",marginRight:3}}>{collapsed[g.type]?"▶":"▼"}</span><span style={{fontSize:isMobile?9:10,fontWeight:700,color:"#334155"}}>{isMobile?g.type:g.type+"クラス（"+g.label+"）"}</span>{!isMobile&&<span style={{fontSize:8,color:"#64748b",marginLeft:4}}>稼働{g.items.filter(v=>isKpiActive(v.code)).length}/{g.items.length}台</span>}</td>
              {dates.map(d=><td key={d} style={{height:CLASS_H,borderBottom:"1px solid #e2e8f0",background:"#f8fafc",borderRight:"1px solid #e2e8f0"}}/>)}
            </tr>
            {!collapsed[g.type]&&g.items.map(v=>{const bars=vehicleBars[v.code]||[];const isDT=dropTarget&&dropTarget.vc===v.code;const rowHL=isDT?(dropTarget.ok?"rgba(34,197,94,.15)":"rgba(239,68,68,.1)"):"transparent";const hasSearchHit=searchResult&&searchResult.found&&bars.some(b=>b.type==="reservation"&&searchResult.hitSet.has(b.r.id));return <tr key={v.id} ref={el=>{vehicleRowRefs.current[v.code]=el;}} onDragOver={e=>handleDragOver(e,v.code)} onDragLeave={()=>{if(dropTargetRef.current){dropTargetRef.current=null;setDropTarget(null);}}} onDrop={e=>handleDrop(e,v.code)} style={{outline:isDT?(dropTarget.ok?"2px solid #22c55e":"2px dashed #ef4444"):"none",background:hasSearchHit?"#fefce8":"transparent"}}>
              <td style={{position:"sticky",left:0,zIndex:5,height:ROW_H,background:hasSearchHit?"#fef08a":(isDT?(dropTarget.ok?"#dcfce7":"#fef2f2"):"#fff"),borderBottom:"1px solid #f1f5f9",borderRight:hasSearchHit?"3px solid #f59e0b":"2px solid #94a3b8",padding:isMobile?"0 4px":"0 10px",overflow:"hidden",whiteSpace:"nowrap",transition:"background .15s"}}>
                {hasSearchHit&&<span style={{fontSize:9,marginRight:3}}>📍</span>}
                <span style={{fontSize:isMobile?9:10,fontWeight:700,color:hasSearchHit?"#b45309":"#2563eb"}}>{v.no}<span style={{fontSize:8,color:hasSearchHit?"#92400e":"#94a3b8",fontWeight:500}}>({v.seats})</span></span>
                {!isMobile&&<span style={{fontSize:9,color:"#64748b",marginLeft:4}}>{v.name}</span>}
                <span onClick={e=>{e.stopPropagation();toggleKpi(v.code);}} style={{fontSize:8,fontWeight:700,marginLeft:3,padding:"0 3px",borderRadius:3,cursor:"pointer",background:isKpiActive(v.code)?"#dcfce7":"#fee2e2",color:isKpiActive(v.code)?"#059669":"#dc2626",border:"1px solid "+(isKpiActive(v.code)?"#86efac":"#fca5a5")}} title={isKpiActive(v.code)?"稼働中（クリックで除外）":"除外中（クリックで稼働に変更）"}>{isKpiActive(v.code)?"稼働":"除外"}</span>
                {(()=>{const u=utilRates[v.code];if(!u)return null;const pc=u.pct;const cl=pc>=80?"#dc2626":pc>=50?"#f59e0b":"#22c55e";return <span style={{fontSize:8,fontWeight:700,color:cl,marginLeft:4,background:pc>=80?"#fef2f2":pc>=50?"#fffbeb":"#f0fdf4",padding:"0 3px",borderRadius:3}}>{u.days}日{!isMobile&&" "+pc+"%"}</span>;})()}
              </td>
              {dates.map((d,di)=>{const isToday=d===today;return <td key={d} style={{position:"relative",height:ROW_H,borderBottom:"1px solid #f1f5f9",borderRight:"1px solid #e2e8f0",cursor:dragInfo?"copy":"pointer",background:isDT?rowHL:(isToday?"#eff6ff":"transparent"),padding:0,transition:"background .15s"}} onClick={()=>{if(!dragInfo)handleCellClick(v.code,d);}}>
                {di===0&&bars.map((b,bi)=>{const isRes=b.type==="reservation";const isMaint=b.type==="maintenance";const isDragging=dragInfo===b.r?.id;const isSearchHit=isRes&&searchResult&&searchResult.found&&searchResult.hitSet.has(b.r.id);return <div key={bi} className={isMaint?"":(isSearchHit?"tl-bar tl-bar-hit":"tl-bar")} draggable={isRes} onDragStart={isRes?e=>handleDragStart(e,b.r.id):undefined} onDragEnd={handleDragEnd} onClick={e=>handleBarClick(e,b)} style={{left:b.left,width:Math.max(b.width,20),background:isMaint?"repeating-linear-gradient(135deg,#2563eb,#2563eb 3px,#3b82f6 3px,#3b82f6 6px)":(isRes?(isDragging?"#f87171":(b.r.ota==="O"?"#fef9c3":(b.r.ota==="HP"?"#dbeafe":"#dc2626"))):"#2563eb"),color:isRes&&!isDragging&&(b.r.ota==="O"||b.r.ota==="HP")?(b.r.ota==="HP"?"#1e40af":"#92400e"):"#fff",fontSize:isMaint?8:9,fontWeight:600,boxShadow:isSearchHit?"0 0 8px 3px rgba(250,204,21,.8),0 0 16px 6px rgba(250,204,21,.4)":(isDragging?"0 4px 12px rgba(0,0,0,.3)":(isMaint?"none":"0 1px 3px rgba(0,0,0,.2)")),outline:isSearchHit?"3px solid #facc15":"none",position:"absolute",top:isMaint?0:3,height:isMaint?8:undefined,bottom:isMaint?undefined:3,zIndex:isMaint?3:(isSearchHit?15:(isDragging?10:2)),opacity:isDragging?0.7:(isMaint?0.9:1),cursor:isRes?"grab":"pointer",transition:"opacity .15s, box-shadow .15s",borderRadius:isMaint?0:4,display:"flex",alignItems:"center",padding:"0 4px",overflow:"hidden",whiteSpace:"nowrap"}}><span style={{overflow:"hidden",textOverflow:"ellipsis"}}>{isRes?`${b.r.lendTime}-${b.r.returnTime} ${b.r.name} 様`:("🔧"+b.m.label)}</span></div>;})}
              </td>;})}
            </tr>;})}
          </React.Fragment>)}
        </tbody>
      </table>
    </div>

    {cellAction&&<div className="modal-overlay" onClick={()=>setCellAction(null)}><div className="modal-box" style={{maxWidth:280,padding:20}} onClick={e=>e.stopPropagation()}>
      <h4 className="font-bold text-sm mb-3">{cellAction.vehicleCode} — {fmtD(cellAction.date)}</h4>
      <div className="space-y-2">
        <button onClick={()=>{const v=vehicles.find(x=>x.code===cellAction.vehicleCode);setShowResForm({vehicleCode:cellAction.vehicleCode,lendDate:cellAction.date,vehicle:v?.type||"A"});setCellAction(null);}} className="w-full py-2 bg-green-600 text-white rounded-lg text-sm font-bold hover:bg-green-700">新規予約を登録</button>
        <button onClick={()=>{setShowMaintForm(cellAction);setCellAction(null);}} className="w-full py-2 bg-blue-600 text-white rounded-lg text-sm font-bold hover:bg-blue-700">メンテナンス登録</button>
        <button onClick={()=>setCellAction(null)} className="w-full py-2 bg-gray-100 text-gray-600 rounded-lg text-sm font-semibold">キャンセル</button>
      </div>
    </div></div>}

    {tooltip&&<div className="modal-overlay" style={{background:"rgba(0,0,0,.15)"}} onClick={()=>setTooltip(null)}><div className="modal-box" style={{maxWidth:340,padding:20}} onClick={e=>e.stopPropagation()}>
      <div className="flex items-center justify-between mb-2"><span className="font-bold text-sm">{tooltip.type==="reservation"?tooltip.name:tooltip.label}</span><button onClick={()=>setTooltip(null)} className="text-gray-400 hover:text-gray-600">✕</button></div>
      {tooltip.type==="reservation"?<div className="text-xs space-y-1 text-gray-600">
        <div><OBadge ota={tooltip.ota}/> <span className="font-mono">{tooltip.id}</span></div>
        <div>貸出: {fmtD(tooltip.lendDate)} {tooltip.lendTime} / 返却: {fmtD(tooltip.returnDate)} {tooltip.returnTime}</div>
        <div>クラス: {tooltip.vehicle} / 補償: {tooltip.insurance}</div>
        <div style={{display:"flex",alignItems:"center",gap:6,marginTop:4}}>
          <span style={{fontWeight:700,color:"#1e293b"}}>配車:</span>
          <select value={tooltip.vc||""} onChange={e=>{const newVc=e.target.value;if(!newVc){if(!window.confirm("配車を解除しますか？"))return;const nf={...fleet};delete nf[tooltip.id];onFleetChange(nf);DB.deleteFleetOne(tooltip.id);setTooltip({...tooltip,vc:""});/* 配車解除→OPシートタスクもクリア */try{const r=data.find(x=>x.id===tooltip.id);if(r){const _clr=async(d)=>{if(!d)return;const tks=await DB.fetchTasks(d);if(!tks)return;const upd=tks.map(tk=>tk.reservationId===tooltip.id?{...tk,assignedVehicle:"",plateNo:""}:tk);if(JSON.stringify(upd)!==JSON.stringify(tks))DB.upsertTasks(upd,d);};const ld=norm(r.lendDate),rd=norm(r.returnDate);_clr(ld);if(rd!==ld)_clr(rd);_clr(dOff(ld,-1));}}catch(e){console.error("[fleet clear tasks]",e);}return;}const conflict=checkVehicleConflict(newVc,tooltip.id,data,fleet,maintenance);if(conflict){const cv=vehicles.find(x=>x.code===newVc);alert((cv?cv.name:newVc)+" は "+fmtD(conflict.lendDate)+"〜"+fmtD(conflict.returnDate)+" に「"+conflict.name+"」様の"+(conflict._isMaint?"メンテナンス":"予約")+"が入っているため変更できません。");return;}const targetV=vehicles.find(x=>x.code===newVc);if(!window.confirm("配車を「"+(targetV?targetV.name:newVc)+"」に変更しますか？"))return;if(onReassignVehicle){onReassignVehicle(tooltip.id,newVc);}else{onFleetChange({...fleet,[tooltip.id]:newVc});}setTooltip({...tooltip,vc:newVc});}} style={{border:"1px solid #d1d5db",borderRadius:6,padding:"3px 6px",fontSize:11,fontWeight:600,color:"#1d4ed8",flex:1}}>
            <option value="">— 未割当 —</option>
            {vehicleClasses.map(cls=><optgroup key={cls.type} label={cls.type+"クラス"}>{vehicles.filter(v=>v.type===cls.type).map(v=><option key={v.code} value={v.code}>{v.name} ({v.no}) {v.seats}名</option>)}</optgroup>)}
          </select>
        </div>
        <div style={{marginTop:6,fontSize:8,color:"#94a3b8",textAlign:"center"}}>※キャンセル処理はデータタブから行えます</div>
      </div>:<div className="text-xs space-y-1 text-gray-600">
        <div>車両: {tooltip.vehicleCode}</div><div>期間: {fmtD(tooltip.startDate)} 〜 {fmtD(tooltip.endDate)}</div>
        <button onClick={()=>removeMaint(tooltip.id)} className="mt-2 w-full py-1.5 bg-red-50 text-red-600 rounded-lg text-xs font-bold hover:bg-red-100">メンテナンスを削除</button>
      </div>}
    </div></div>}

    {showMaintForm&&<div className="modal-overlay" onClick={()=>setShowMaintForm(null)}><div className="modal-box" style={{maxWidth:320,padding:20}} onClick={e=>e.stopPropagation()}><h4 className="font-bold text-sm mb-3">メンテナンス登録</h4><MaintForm vehicleCode={showMaintForm.vehicleCode} startDate={showMaintForm.date} onAdd={addMaint} onClose={()=>setShowMaintForm(null)} vehicles={vehicles}/></div></div>}

    {showResForm&&<ReservationForm prefill={showResForm} onAdd={(r,vc)=>{onAddReservation(r,vc);setShowResForm(null);}} onBulkAdd={(rArr,fl)=>{onBulkAddReservation(rArr,fl);setShowResForm(null);}} vehicles={vehicles} vehicleClasses={vehicleClasses} onClose={()=>setShowResForm(null)} data={data} fleet={fleet} maintenance={maintenance}/>}
  </div>;
}

function MaintForm({vehicleCode,startDate,onAdd,onClose,vehicles}){
  const[start,setStart]=useState(startDate);const[end,setEnd]=useState(startDate);const[label,setLabel]=useState("メンテナンス");const v=vehicles.find(x=>x.code===vehicleCode);
  return <div className="space-y-3">
    <div className="text-xs text-gray-500">車両: <strong>{v?v.name:vehicleCode}</strong> ({v?v.no:""}) {v?v.seats+"名":""}</div>
    <div><label className="text-xs text-gray-500">ラベル</label><select value={label} onChange={e=>setLabel(e.target.value)} className="input-s"><option>メンテナンス</option><option>車検</option><option>修理</option><option>清掃</option><option>その他</option></select></div>
    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
      <div><label className="text-xs text-gray-500">開始日</label><input type="date" value={start} onChange={e=>setStart(e.target.value)} className="input-s"/></div>
      <div><label className="text-xs text-gray-500">終了日</label><input type="date" value={end} onChange={e=>setEnd(e.target.value)} className="input-s"/></div>
    </div>
    <div className="flex justify-end gap-2"><button onClick={onClose} className="btn-ghost">キャンセル</button><button onClick={()=>onAdd(vehicleCode,start,end,label)} className="btn-primary">登録</button></div>
  </div>;
}

/* ==========================================
   OPシート（独立フルスクリーン）
   ========================================== */
function OPScreen({reservations,today,shifts,fleet,onFleetChange,onClose,onGoFleet,vehicles,staff,resOpts,sheetPlaces,onUpdateSheetPlaces,repeaterMap,jalanPay,onReservationUpdate,maintenance}){
  const[dayOff,setDayOff]=useState(0);const selDate=dOff(today,dayOff);const[tasks,setTasks]=useState([]);
  const[opView,setOpView]=useState("summary"); // ★ 表示切替: "summary" | "bus" | "hia" | "tasks" | "wash" | "master"
  const[washAddCat,setWashAddCat]=useState("");const[washAddVc,setWashAddVc]=useState("");const[washAddTime,setWashAddTime]=useState("");const[washAddMemo,setWashAddMemo]=useState("");
  const[editResId,setEditResId]=useState(null); // ★ 編集対象の予約ID（マスターからの遷移用）
  const[editBlock,setEditBlock]=useState(null); // ★ 編集ブロック: null(入口選択) | "dep"(出発) | "ret"(返却) | "common"(共通)
  // ★ 日付変更時に編集状態をリセット
  useEffect(()=>{setEditResId(null);setEditBlock(null);},[dayOff]);
  const[analysisPeriod,setAnalysisPeriod]=useState("day"); // ★ 分析期間: "day" | "month" | "year"
  const[analysisData,setAnalysisData]=useState(null); // ★ 月間/年間分析データ
  const[resDetailPopup,setResDetailPopup]=useState(null); // ★ 予約詳細ポップアップ {task}
  const[chipMenu,setChipMenu]=useState(null); // ★ バス便チップ操作メニュー {taskId, x, y}
  const[busTimeMenu,setBusTimeMenu]=useState(null); // ★ バス便時間変更メニュー {taskId, type, currentHour}
  const[busDrivers,setBusDrivers]=useState(()=>{try{return JSON.parse(localStorage.getItem("tkm_bus_drivers_"+selDate)||"{}");} catch(e){return{};}}); // ★ バス便ごとの運転手・補助 {hourKey: {driver:"", assistant:""}}
  useEffect(()=>{try{localStorage.setItem("tkm_bus_drivers_"+selDate,JSON.stringify(busDrivers));}catch(e){}},[busDrivers,selDate]);
  useEffect(()=>{try{setBusDrivers(JSON.parse(localStorage.getItem("tkm_bus_drivers_"+selDate)||"{}"));}catch(e){setBusDrivers({});}},[selDate]);
  const[busVehicles,setBusVehicles]=useState({}); // ★ バス便ごとの車両ナンバー {hourKey: plateNo}
  const[busTab,setBusTab]=useState("all"); // ★ バスタブ内切替: "all" | "pu" | "bd"
  const[chipAction,setChipAction]=useState(null); // ★ チップ操作メニュー
  const[dragTask,setDragTask]=useState(null); // ★ ドラッグ中のタスク {taskId, fromSlot, fromLeg}
  const[editLogs,setEditLogs]=useState([]); // ★ 編集ログ
  const[showLogTaskId,setShowLogTaskId]=useState(null); // ★ ログ表示対象タスクID
  const[showAllLogs,setShowAllLogs]=useState(false); // ★ 全ログ表示
  const[editorName,setEditorName]=useState(()=>localStorage.getItem("tkm_editor_name")||""); // ★ 操作者名
  // ★ 編集ログ取得
  useEffect(()=>{DB.fetchEditLogs(selDate).then(l=>setEditLogs(l||[]));},[selDate]);
  // ★ 編集ログ記録ヘルパー
  const logEdit=useCallback((t,field,oldVal,newVal)=>{
    const by=editorName||"不明";
    const entry={date:selDate,taskId:t._id,taskName:t.name||"",field,oldValue:String(oldVal||""),newValue:String(newVal||""),editedBy:by};
    DB.addEditLog(entry);
    setEditLogs(prev=>[{...entry,id:"tmp_"+Date.now(),created_at:new Date().toISOString(),task_id:t._id,task_name:t.name,old_value:entry.oldValue,new_value:entry.newValue,edited_by:by},...prev]);
  },[selDate,editorName]);
  // ★ 出勤メンバー: シフト登録者のうち公休・希望休・有休以外の全員
  const staffTypeMapOP=useMemo(()=>{const m={};staff.forEach(s=>{m[s.name]=s.type;});return m;},[staff]);
  const activeMembers=useMemo(()=>{
    const dayShifts=shifts[selDate]||[];
    const offSymbols=new Set(["公","希","有","出"]);
    return dayShifts.filter(s=>{
      const sType=staffTypeMapOP[s.name]||"";
      if(sType==="正社員")return s.symbol==="●";
      return!offSymbols.has(s.symbol)&&!!(s.start&&s.end);
    }).map(s=>s.name);
  },[shifts,selDate,staffTypeMapOP]);
  const fleetRef=React.useRef(fleet);fleetRef.current=fleet;
  // fleet変更時にタスクの車種情報を同期 + LS/DB永続化
  useEffect(()=>{
    setTasks(prev=>{
      let changed=false;
      const next=prev.map(t=>{
        if(!t.reservationId)return t;
        const vc=fleet[t.reservationId];
        const vn=vc?vehicles.find(v=>v.code===vc):null;
        const updates={};
        // fleet変更（配車/解除）
        if(vc&&vc!==t.assignedVehicle){updates.assignedVehicle=vc;updates.plateNo=vn?vn.no:"";updates.vehicleNo=vn?vn.no:"";updates.vehicleName=vn?vn.name:"";}
        if(!vc&&t.assignedVehicle){updates.assignedVehicle="";updates.plateNo="";updates.vehicleNo="";updates.vehicleName="";}
        // 車両マスター変更（type/no/name変更を検出）
        if(vn&&vc===t.assignedVehicle){
          if(vn.type!==t.vehicle)updates.vehicle=vn.type;
          if(vn.no!==t.plateNo){updates.plateNo=vn.no;updates.vehicleNo=vn.no;}
          if(vn.name!==t.vehicleName)updates.vehicleName=vn.name;
        }
        if(vn&&updates.assignedVehicle)updates.vehicle=vn.type;
        if(!Object.keys(updates).length)return t;
        changed=true;
        return{...t,...updates};
      });
      // ★ 変更があればLS/DBに即時保存（タブ移動で元に戻る問題を防止）
      if(changed&&next.length){
        DB._lsSave(next,selDate);
        DB.upsertTasks(next,selDate);
        next.forEach(t=>selfUpdatedIds.current.set(t._id,Date.now()));
      }
      return changed?next:prev;
    });
  },[fleet,vehicles]);
  // ★ 月間/年間分析データロード
  const loadAnalysisData=React.useCallback(async(period)=>{
    if(period==="day"){setAnalysisData(null);return;}
    try{
      let startDate,endDate;
      const d=new Date(selDate);
      if(period==="month"){
        startDate=new Date(d.getFullYear(),d.getMonth(),1).toISOString().slice(0,10);
        endDate=new Date(d.getFullYear(),d.getMonth()+1,0).toISOString().slice(0,10);
      }else{
        startDate=d.getFullYear()+"-01-01";
        endDate=d.getFullYear()+"-12-31";
      }
      if(!sb)return;const{data,error}=await sb.from("tkm_tasks").select("type,time,people,date,flight,done").gte("date",startDate).lte("date",endDate);
      if(error)throw error;
      setAnalysisData({tasks:data||[],period,startDate,endDate});
    }catch(e){console.error("Analysis load error:",e);setAnalysisData(null);}
  },[selDate]);

  // タスクロード
  const selfUpdatedIds=React.useRef(new Map()); // _id -> timestamp
  const loadTasks=React.useCallback(async(date,force)=>{
    // 自分の変更直後（3秒以内）はDBリロードをスキップ（自分の変更を上書きしない）
    if(!force&&selfUpdatedIds.current.size>0&&Date.now()-Math.max(...selfUpdatedIds.current.values())<3000){
      console.log("[loadTasks] 自分の変更直後のためスキップ");return;
    }
    // ★ DB取得前にlocalStorageを読む（fetchTasksがLSを上書きする前に保持）
    const lsData=DB._lsLoad(date);
    const lsMap={};
    if(lsData)lsData.forEach(x=>{lsMap[x._id]=x;});
    // 1. DB(+localStorage)から取得
    const saved=await DB.fetchTasks(date);
    if(saved&&saved.length>0){
      // 日付ズレ修正: DELタスクの予約lendDateがこの日と合わないものを除去
      const removed=[];
      let fixed=saved.filter(t=>{
        if(!t.reservationId||t.manual)return true;
        const r=reservations.find(x=>x.id===t.reservationId);
        // ★ 予約がCSV入替等で消えた場合、対応タスクも除去（幽霊タスク防止）
        if(!r){removed.push(t._id);console.log("[loadTasks] orphan task removed:",t._id,t.reservationId,t.type);return false;}
        if((t.type==="DEL"||t.type==="PU"||t.type==="PUB")&&!sD(r.lendDate,date)){removed.push(t._id);return false;}
        if((t.type==="COL"||t.type==="BD"||t.type==="BDB")&&!sD(r.returnDate,date)){removed.push(t._id);return false;}
        return true;
      });
      // ★ 日付不整合タスクをDBからも削除（幽霊タスク防止）
      if(removed.length&&sb){
        sb.from("tkm_tasks").delete().in("_id",removed).then(()=>dbLog("cleanStale",true,removed.length+"件削除")).catch(e=>dbLog("cleanStale",false,e.message));
      }
      // 不足予約を追加
      const gen=generateTasks(reservations,date,fleetRef.current,vehicles);
      const existIds=new Set(fixed.filter(t=>t.reservationId).map(t=>t.reservationId+":"+t.type));
      // ★ 新規生成タスクにsheetPlacesの場所情報を補完
      gen.forEach(g=>{
        if(g.reservationId&&!existIds.has(g.reservationId+":"+g.type)){
          const sp=sheetPlaces[g.reservationId];
          if(sp&&!g.place){if((g.type==="DEL"||g.type==="PU"||g.type==="PUB")&&sp.delPlace)g.place=sp.delPlace;if((g.type==="COL"||g.type==="BD"||g.type==="BDB")&&sp.colPlace)g.place=sp.colPlace;}
          if(sp&&(g.type==="DEL"||g.type==="PU"||g.type==="PUB")&&!g.colPlace&&sp.colPlace)g.colPlace=sp.colPlace;
          fixed.push(g);
        }
      });
      // ★ 洗車タスクの整合性管理（車両コード単位で重複排除 + 孤児削除 + 未配車分追加）
      const tomorrowDate=dOff(date,1);
      const tomorrowResMap=new Map(); // 翌日DEL: 車両コード→予約 / 未配車: "unassigned:"+resId→予約
      reservations.forEach(r=>{
        if(r.status==="cancelled")return;
        if(!sD(r.lendDate,tomorrowDate))return;
        const vc=fleetRef.current[r.id];
        if(vc){if(!tomorrowResMap.has(vc))tomorrowResMap.set(vc,r);}
        else{tomorrowResMap.set("unassigned:"+r.id,r);}
      });
      // 既存の洗車タスクを車両コード単位で重複排除
      const washByVehicle=new Map();const washDupIds=[];
      fixed.forEach(t=>{
        if(t.type!=="洗車")return;
        const key=t.assignedVehicle||("unassigned:"+t.reservationId);
        if(washByVehicle.has(key)){washDupIds.push(t._id);}
        else{washByVehicle.set(key,t);}
      });
      // 翌日DELがない車両の孤児洗車を検出
      washByVehicle.forEach((wt,key)=>{
        if(!tomorrowResMap.has(key)){washDupIds.push(wt._id);washByVehicle.delete(key);}
      });
      if(washDupIds.length){
        fixed=fixed.filter(t=>!washDupIds.includes(t._id));
        if(sb)sb.from("tkm_tasks").delete().in("_id",washDupIds).then(()=>dbLog("washClean",true,washDupIds.length+"件")).catch(e=>dbLog("washClean",false,e.message));
        console.log("[loadTasks] wash cleanup:",washDupIds.length,"removed");
      }
      // 不足洗車タスクを追加（翌日DEL予約があるのに洗車がない場合）
      tomorrowResMap.forEach((tRes,key)=>{
        if(washByVehicle.has(key))return;
        const vc=key.startsWith("unassigned:")?"":(key);
        const veh=vc?vehicles.find(v=>v.code===vc):null;
        fixed.push({_id:uid(),type:"洗車",time:"",name:`翌日出発: ${tRes.name||""}`,people:0,place:"",vehicle:veh?veh.type:tRes.vehicle,insurance:"",flight:"",reservationId:tRes.id,ota:tRes.ota,tel:"",mail:"",done:false,assignee:"",memo:`${fmtD(tomorrowDate)} DEL ${tRes.lendTime||""} ${tRes.name||""}`,assignedVehicle:vc,plateNo:veh?veh.no:"",insuranceChange:"",opts:{b:+(tRes.optB||0),c:+(tRes.optC||0),j:+(tRes.optJ||0),usb:+(tRes.optUSB||0)},yakkan:false,line:false,payment:false,returnDate:"",returnTime:"",returnType:"",colPlace:""});
        washByVehicle.set(key,true);
      });
      // ★ STEP0: 重複排除（同じ予約ID+同系統タイプの重複を除去）
      const seenResType=new Set();
      const dupIds=[];
      fixed.forEach(t=>{
        if(!t.reservationId||t.manual)return;
        // PU/PUBは同系統、BD/BDBも同系統として重複判定
        const baseType=(t.type==="PUB"||t.type==="PU")?"PU_GROUP":(t.type==="BDB"||t.type==="BD")?"BD_GROUP":t.type;
        const key=t.reservationId+":"+baseType;
        if(seenResType.has(key)){dupIds.push(t._id);}
        else{seenResType.add(key);}
      });
      if(dupIds.length>0){
        console.log("[loadTasks] dedup:",dupIds.length,"件の重複タスクを除去");
        fixed=fixed.filter(t=>!dupIds.includes(t._id));
        if(sb)sb.from("tkm_tasks").delete().in("_id",dupIds).then(()=>dbLog("dedup",true,dupIds.length)).catch(e=>dbLog("dedup",false,e.message));
      }
      // ★ STEP1: 既存PU/BD→PUB/BDB自動昇格（まず全員バスに乗せる）
      // ただし手動でPU/BDに変更されたタスク(_changed.type=true)はスキップ
      let autoUpgraded=0;
      fixed=fixed.map(t=>{
        if(t._changed&&t._changed.type)return t; // 手動変更済み→スキップ
        if(t.type==="PU"&&isBusRequired(t)){autoUpgraded++;return{...t,type:"PUB",place:"高松",_placeSource:"manual"};}
        if(t.type==="BD"&&isBusRequired(t)){autoUpgraded++;return{...t,type:"BDB",place:"高松",_placeSource:"manual"};}
        return t;
      });
      // ★ STEP2: バス便に振り分けて定員超過分をPU/BDに自動降格
      const _puSlots={};BUS_PU_HOURS.forEach(h=>{_puSlots[h]={ids:[],count:0,overIds:[]};});
      const _bdSlots={};BUS_BD_HOURS.forEach(h=>{_bdSlots[h]={ids:[],count:0,overIds:[]};});
      fixed.forEach(t=>{
        if(t.type==="PUB"){
          const time=t.timeChange||t.time||"";if(!time)return;
          const[hh,mm]=time.split(":").map(Number);
          let th=Math.ceil((hh*60+mm+30)/60);
          if(th<BUS_PU_HOURS[0])th=BUS_PU_HOURS[0];
          if(th>BUS_PU_HOURS[BUS_PU_HOURS.length-1])th=BUS_PU_HOURS[BUS_PU_HOURS.length-1];
          const ppl=parseInt(t.people)||1;
          if(_puSlots[th].count+ppl<=BUS_CAPACITY){_puSlots[th].ids.push(t._id);_puSlots[th].count+=ppl;}
          else{_puSlots[th].overIds.push(t._id);}
        }
        if(t.type==="BDB"){
          const time=t.timeChange||t.time||"";if(!time)return;
          const[hh,mm]=time.split(":").map(Number);
          let th=hh;if(mm>30)th=hh+1;
          if(th<BUS_BD_HOURS[0])th=BUS_BD_HOURS[0];
          if(th>BUS_BD_HOURS[BUS_BD_HOURS.length-1])th=BUS_BD_HOURS[BUS_BD_HOURS.length-1];
          const ppl=parseInt(t.people)||1;
          if(_bdSlots[th].count+ppl<=BUS_CAPACITY){_bdSlots[th].ids.push(t._id);_bdSlots[th].count+=ppl;}
          else{_bdSlots[th].overIds.push(t._id);}
        }
      });
      const overflowIds=new Set();
      Object.values(_puSlots).forEach(s=>s.overIds.forEach(id=>overflowIds.add(id)));
      Object.values(_bdSlots).forEach(s=>s.overIds.forEach(id=>overflowIds.add(id)));
      let autoDemoted=0;
      if(overflowIds.size>0){
        fixed=fixed.map(t=>{
          if(overflowIds.has(t._id)){
            autoDemoted++;
            if(t.type==="PUB")return{...t,type:"PU",place:"",_placeSource:"",_changed:{...(t._changed||{}),type:true,place:true}};
            if(t.type==="BDB")return{...t,type:"BD",place:"",_placeSource:"",_changed:{...(t._changed||{}),type:true,place:true}};
          }
          return t;
        });
      }
      if(autoUpgraded>0||autoDemoted>0){
        console.log("[loadTasks] auto-upgrade:",autoUpgraded,"件, auto-demote(overflow):",autoDemoted,"件");
        // 各便の人数を検証ログ出力
        Object.entries(_puSlots).forEach(([h,s])=>{if(s.count>0)console.log(`[BUS] PUB ${h}:00 → ${s.count}/${BUS_CAPACITY}名 (溢れ:${s.overIds.length}件)`);});
        Object.entries(_bdSlots).forEach(([h,s])=>{if(s.count>0)console.log(`[BUS] BDB ${h}:30 → ${s.count}/${BUS_CAPACITY}名 (溢れ:${s.overIds.length}件)`);});
        DB.upsertTasks(fixed,date);
      }
      // ★ LSにあるmanualタスクがDB結果に欠けていれば復元
      const fixedIds=new Set(fixed.map(t=>t._id));
      Object.values(lsMap).forEach(lst=>{
        if(lst.manual&&!fixedIds.has(lst._id)){
          console.log("[loadTasks] manual task restored from LS:",lst._id,lst.name);
          fixed.push(lst);
        }
      });
      // fleet情報をタスクに反映（DBが古い場合の対策）
      const fl=fleetRef.current;let fleetApplied=false;
      const fixedWithFleet=fixed.map(t=>{
        if(!t.reservationId)return t;
        const vc=fl[t.reservationId];
        if(!vc&&!t.assignedVehicle)return t;
        if(vc===t.assignedVehicle)return t;
        fleetApplied=true;
        if(!vc)return{...t,assignedVehicle:"",plateNo:""};
        const vn=vehicles.find(v=>v.code===vc);
        return{...t,assignedVehicle:vc,plateNo:vn?vn.no:"",vehicle:vn?vn.type:t.vehicle};
      });
      // ★ 手動変更を保護: DB _changedがある場合はDB値が権威（他端末の変更を尊重）
      fixedWithFleet.forEach(t=>{
        const ls=lsMap[t._id];
        const dbChanged=t._changed||{};
        const lsChanged=(ls&&ls._changed)||{};
        // DB _changedを基本とし、DBにないLS独自の変更のみ追加
        const merged={...lsChanged,...dbChanged};
        if(Object.keys(merged).length){
          t._changed=merged;
          // LSにのみ存在する_changedフィールドはLS値を適用（DBに未到達のローカル変更）
          Object.keys(lsChanged).forEach(f=>{
            if(lsChanged[f]&&!dbChanged[f]&&ls[f]!==undefined&&ls[f]!==null&&f!=='_changed'&&f!=='opts'&&typeof ls[f]!=='object'){t[f]=ls[f];}
          });
        }
        if(ls){
          if(ls.place&&!t.place)t.place=ls.place;
          if(ls.colPlace&&!t.colPlace)t.colPlace=ls.colPlace;
        }
      });
      if(fixedWithFleet.length!==saved.length||fixedWithFleet.some((t,i)=>t._id!==saved[i]?._id)||fleetApplied||removed.length){
        DB.upsertTasks(fixedWithFleet,date);
      } else {
        // ★ upsertTasksを呼ばない場合でも、マージ結果（_changed/place等）をLSに確実に保存
        DB._lsSave(fixedWithFleet,date);
      }
      setTasks(fixedWithFleet);return;
    }
    // 2. DBにタスクなし→自動生成
    const gen=generateTasks(reservations,date,fleetRef.current,vehicles);
    // ★ sheetPlacesから場所情報を補完
    gen.forEach(g=>{
      if(!g.reservationId)return;
      const sp=sheetPlaces[g.reservationId];
      if(sp&&!g.place){if(g.type==="DEL"&&sp.delPlace)g.place=sp.delPlace;if(g.type==="COL"&&sp.colPlace)g.place=sp.colPlace;}
      if(sp&&g.type==="DEL"&&!g.colPlace&&sp.colPlace)g.colPlace=sp.colPlace;
    });
    setTasks(gen);
    if(gen.length)DB.upsertTasks(gen,date);
  },[reservations,vehicles]);
  useEffect(()=>{loadTasks(selDate,true);},[selDate]);
  // ★ 予約データ変更時（CSV入替等）にも現在日のタスクをリロード（キャンセル済みタスク除去等）
  // loadTasksはreservationsに依存するuseCallbackなので、reservations変更で自動的に再構築される
  // ただしselDateが変わらないとuseEffect[selDate]はトリガーしないため、別途トリガーが必要
  const prevResCountRef=React.useRef(-1);
  useEffect(()=>{
    const cnt=reservations.length;
    if(prevResCountRef.current>=0&&prevResCountRef.current!==cnt){
      console.log("[OPSheet] reservations changed:",prevResCountRef.current,"→",cnt,"reloading tasks");
      loadTasks(selDate,true);
    }
    prevResCountRef.current=cnt;
  },[reservations.length]);
  // Realtimeでタスク更新を受信（他端末の変更を反映）
  useEffect(()=>{
    if(!sb)return;
    let debounce=null;
    const ch=sb.channel("tasks-"+selDate)
      .on("postgres_changes",{event:"*",schema:"public",table:"tkm_tasks",filter:"date=eq."+selDate},(payload)=>{
        const evtId=payload.new&&payload.new._id;
        if(evtId&&selfUpdatedIds.current.has(evtId)&&Date.now()-selfUpdatedIds.current.get(evtId)<3000){return;}
        selfUpdatedIds.current.forEach((ts,k)=>{if(Date.now()-ts>10000)selfUpdatedIds.current.delete(k);});
        clearTimeout(debounce);
        debounce=setTimeout(async()=>{
          // ★ DB取得前にLS読み取り（fetchTasksがLSを上書きする前に保持）
          const lsD=DB._lsLoad(selDate);
          const lm={};if(lsD)lsD.forEach(x=>{lm[x._id]=x;});
          const fresh=await DB.fetchTasks(selDate);
          if(fresh&&fresh.length){
            // ★ 手動変更保護: DB _changedが権威（他端末の変更を尊重）
            fresh.forEach(t=>{
              const ls=lm[t._id];
              const dbChanged=t._changed||{};
              const lsChanged=(ls&&ls._changed)||{};
              // DB優先でマージ（DBにある変更は上書きしない）
              const merged={...lsChanged,...dbChanged};
              if(Object.keys(merged).length){
                t._changed=merged;
                // LSにのみ存在する変更はLS値を適用（DBに未反映のローカル変更）
                Object.keys(lsChanged).forEach(f=>{
                  if(lsChanged[f]&&!dbChanged[f]&&ls[f]!==undefined&&ls[f]!==null&&f!=='_changed'&&f!=='opts'&&typeof ls[f]!=='object'){t[f]=ls[f];}
                });
              }
              if(ls){
                if(ls.place&&!t.place)t.place=ls.place;
                if(ls.colPlace&&!t.colPlace)t.colPlace=ls.colPlace;
              }
            });
            setTasks(fresh);
            DB._lsSave(fresh,selDate);
          }
        },500);
      }).subscribe();
    return()=>{clearTimeout(debounce);sb.removeChannel(ch);};
  },[selDate]);
  // タブ復帰・画面復帰時+30秒ポーリングでDBから最新データ再取得
  useEffect(()=>{
    const onVis=()=>{if(document.visibilityState==="visible")loadTasks(selDate);};
    document.addEventListener("visibilitychange",onVis);
    const timer=setInterval(()=>{if(document.visibilityState==="visible")loadTasks(selDate);},30000);
    return()=>{document.removeEventListener("visibilitychange",onVis);clearInterval(timer);};
  },[selDate,loadTasks]);
  const[saveStatus,setSaveStatus]=useState("ok"); // "ok"|"saving"|"error"
  const pendingSaves=React.useRef(0);
  const upd=async(id,t,resFieldChanges)=>{
    selfUpdatedIds.current.set(id,Date.now());
    let changedFields={};
    setTasks(ts=>{
      const prev=ts.find(x=>x._id===id);
      if(prev){
        Object.keys(t).forEach(k=>{
          if(k.startsWith("_")&&k!=='_changed'&&k!=='_timeFromSheet'&&k!=='_timeChangeSource'&&k!=='_placeSource'&&k!=='_ssTime'&&k!=='_ssPlace'&&k!=='_ssTimeAt'&&k!=='_ssPlaceAt'&&k!=='_manualTimeAt'&&k!=='_manualPlaceAt')return;
          if(k==='opts'){if(JSON.stringify(t.opts)!==JSON.stringify(prev.opts))changedFields.opts=t.opts;return;}
          if(t[k]!==prev[k])changedFields[k]=t[k];
        });
      }else{changedFields=t;}
      const next=ts.map(x=>x._id===id?t:x);DB._lsSave(next,selDate);return next;
    });
    pendingSaves.current++;setSaveStatus("saving");
    if(Object.keys(changedFields).length>0&&Object.keys(changedFields).length<=10){
      await DB.updateTaskFields(id,selDate,changedFields);
    }else{
      await DB.updateTask(t,selDate);
    }
    pendingSaves.current--;
    setSaveStatus(DB._dbSaveOk?(pendingSaves.current>0?"saving":"ok"):"error");
    if(resFieldChanges&&t.reservationId){
      await DB.updateReservationField(t.reservationId,resFieldChanges.fields,resFieldChanges.type,resFieldChanges.source||"op_sheet");
      if(onReservationUpdate)onReservationUpdate(t.reservationId,resFieldChanges.fields);
    }
  };
  const mark=(t,field)=>({...t,_changed:{...t._changed,[field]:true}});
  const confirmUpd=(id,t,label,resFieldChanges)=>{if(!window.confirm(`${label}\n本当に変更しますか？`))return;upd(id,t,resFieldChanges);};
  const add=async(t)=>{
    selfUpdatedIds.current.set(t._id,Date.now());
    let allTasks;
    setTasks(ts=>{const next=[...ts,t].sort((a,b)=>(a.time||"").localeCompare(b.time||""));allTasks=next;DB._lsSave(next,selDate);return next;});
    pendingSaves.current++;setSaveStatus("saving");
    await DB.upsertTasks(allTasks||[t],selDate);
    pendingSaves.current--;
    setSaveStatus(DB._dbSaveOk?(pendingSaves.current>0?"saving":"ok"):"error");
  };
  const TIME_OPTS=useMemo(()=>{const opts=[""];for(let h=6;h<=22;h++)for(let m=0;m<60;m+=5){if(h===22&&m>0)break;opts.push(`${String(h).padStart(2,"0")}:${String(m).padStart(2,"0")}`);}return opts;},[]);
  const assignVehicle=(taskId,vehicleCode)=>{selfUpdatedIds.current.set(taskId,Date.now());const task=tasks.find(t=>t._id===taskId);if(!task)return;const v=vehicles.find(x=>x.code===vehicleCode);const updated={...task,assignedVehicle:vehicleCode,plateNo:v?v.no:""};setTasks(ts=>ts.map(x=>x._id===taskId?updated:x));DB.updateTask(updated,selDate);if(task.reservationId){onFleetChange(prev=>{const nf={...(typeof prev==="object"?prev:fleetRef.current)};if(vehicleCode)nf[task.reservationId]=vehicleCode;else delete nf[task.reservationId];return nf;});}if(v&&task.reservationId){DB.updateReservationField(task.reservationId,{vehicle:v.type},"配車変更→クラス同期","op_sheet");if(onReservationUpdate)onReservationUpdate(task.reservationId,{vehicle:v.type});}};
  const done=tasks.filter(t=>t.done).length;const staffCount=activeMembers.length;
  const WK=["日","月","火","水","木","金","土"];
  const dayButtons=useMemo(()=>{
    const arr=[];
    const active=reservations.filter(r=>r.status!=="cancelled");
    // 日付別 lend/return インデックス
    const lendByDate={};const retByDate={};
    active.forEach(r=>{
      if(r.lendDate){const k=norm(r.lendDate);(lendByDate[k]=lendByDate[k]||[]).push(r);}
      if(r.returnDate){const k=norm(r.returnDate);(retByDate[k]=retByDate[k]||[]).push(r);}
    });
    const fleetNow=fleetRef.current||{};
    for(let i=0;i<=60;i++){
      const d=dOff(today,i);
      const ds=shifts[d]||[];
      const dk=norm(d);
      const lendList=lendByDate[dk]||[];
      const retList=retByDate[dk]||[];
      // 予約タスク数 = lend(PU/DEL) + return(BD/COL)。同日貸出返却は2件扱い（generateTasksと一致）
      let tc=lendList.length+retList.length;
      // 洗車タスク = 翌日lendDate予約から生成（loadTasksと同じロジック）
      // 配車済み: 車両コード単位でユニーク / 未配車: 予約ID単位
      const tmr=dOff(d,1);
      const tmrList=lendByDate[norm(tmr)]||[];
      const washKeys=new Set();
      tmrList.forEach(r=>{
        const vc=fleetNow[r.id];
        washKeys.add(vc?("v:"+vc):("u:"+r.id));
      });
      tc+=washKeys.size;
      if(ds.length>0||tc>0||i<=2)arr.push({i,d,staff:ds.length,tc});
    }
    return arr;
  },[today,shifts,reservations,fleet]);
  const CONTENT_OPTIONS=["PUB","BDB","PU","BD","来店","洗車","DEL","COL","送り","迎え","回収","点検","入庫","その他","マニュアル入力"];
  const[timeLoading,setTimeLoading]=useState(false);
  const updateTimes=async()=>{
    const resIds=[...new Set(tasks.filter(t=>t.reservationId).map(t=>t.reservationId))];
    if(!resIds.length){alert("予約がありません");return;}
    setTimeLoading(true);
    try{
      const timeMap=await fetchTimeData(resIds);
      const matched=Object.keys(timeMap).length;
      if(!matched){setTimeLoading(false);alert("該当する予約番号がスプレッドシートに見つかりませんでした");return;}
      tasks.forEach(t=>{if(t.reservationId&&timeMap[t.reservationId])selfUpdatedIds.current.set(t._id,Date.now());});
      let updatedTasks;let updCount=0;let skipCount=0;
      setTasks(prev=>{
        updatedTasks=prev.map(t=>{
          if(!t.reservationId||!timeMap[t.reservationId])return t;
          const tm=timeMap[t.reservationId];
          let newTime=null;
          if((t.type==="DEL"||t.type==="PU"||t.type==="PUB")&&tm.delTime)newTime=tm.delTime;
          if((t.type==="COL"||t.type==="BD"||t.type==="BDB")&&tm.colTime)newTime=tm.colTime;
          if(!newTime)return t;
          const normalized=newTime.replace(/^(\d):/, "0$1:").replace(/\uff1a/g,":").slice(0,5);
          // ★ SS値は常に _ssTime に保存
          const updates={_ssTime:normalized,_timeFromSheet:true,_ssTimeAt:new Date().toISOString()};
          // ★ 手動変更済み(timeChange)がある場合はtimeを上書きしない
          if(t._timeChangeSource==="manual"&&t.timeChange){
            skipCount++;
            // SS値だけ更新して返す
            return{...t,...updates};
          }
          if(normalized===t.time)return{...t,...updates};
          updCount++;
          const cf={...(t._changed||{}),time:true};
          return{...t,...updates,time:normalized,_changed:cf,_timeChangeSource:"spreadsheet"};
        });
        DB._lsSave(updatedTasks,selDate);
        return updatedTasks;
      });
      pendingSaves.current++;setSaveStatus("saving");
      await DB.upsertTasks(updatedTasks,selDate);
      pendingSaves.current--;
      setSaveStatus(DB._dbSaveOk?(pendingSaves.current>0?"saving":"ok"):"error");
      // ★ reservationsマスターにも書き戻し
      Object.entries(timeMap).forEach(([resId,tm])=>{
        const resFields={};
        if(tm.delTime){const n=tm.delTime.replace(/^(\d):/,"0$1:").replace(/\uff1a/g,":").slice(0,5);resFields.delTime=n;}
        if(tm.colTime){const n=tm.colTime.replace(/^(\d):/,"0$1:").replace(/\uff1a/g,":").slice(0,5);resFields.colTime=n;}
        if(Object.keys(resFields).length){
          DB.updateReservationField(resId,resFields,"\u2464\u6642\u9593:\u30b9\u30d7\u30ec\u30c3\u30c9\u30b7\u30fc\u30c8\u53d6\u5f97","spreadsheet");
          if(onReservationUpdate)onReservationUpdate(resId,resFields);
        }
      });
      alert(`${matched}件中 ${updCount}件の時間を更新しました`+(skipCount>0?`\n（手動変更済み${skipCount}件はスキップ）`:""));
    }catch(e){alert("時間データ取得エラー: "+e.message);}
    setTimeLoading(false);
  };
  const[placeLoading,setPlaceLoading]=useState(false);
  const[lineModal,setLineModal]=useState(null);
  const updatePlaces=async()=>{
    const resIds=[...new Set(tasks.filter(t=>t.reservationId).map(t=>t.reservationId))];
    if(!resIds.length){alert("予約がありません");return;}
    setPlaceLoading(true);
    try{
      const placeMap=await fetchPlaceData(resIds);
      const matched=Object.keys(placeMap).length;
      if(!matched){setPlaceLoading(false);alert("該当する予約番号がスプレッドシートに見つかりませんでした");return;}
      tasks.forEach(t=>{if(t.reservationId&&placeMap[t.reservationId])selfUpdatedIds.current.set(t._id,Date.now());});
      // ★ setState内ではLS保存のみ、DB保存は外で行う
      let updatedTasks;let placeSkip=0;
      setTasks(prev=>{
        updatedTasks=prev.map(t=>{
          if(!t.reservationId||!placeMap[t.reservationId])return t;
          const p=placeMap[t.reservationId];
          const isDel=t.type==="DEL"||t.type==="PU"||t.type==="PUB";
          const isCol=t.type==="COL"||t.type==="BD"||t.type==="BDB";
          // ★ SS値は常に _ssPlace に保存
          const ssPlace=isDel?p.delPlace:isCol?p.colPlace:"";
          const ssUpdates=ssPlace?{_ssPlace:ssPlace,_ssPlaceAt:new Date().toISOString()}:{};
          // ★ 手動変更済みの場合はplaceを上書きしない
          if(t._placeSource==="manual"){placeSkip++;return{...t,...ssUpdates};}
          const updates={};const cf={...(t._changed||{})};
          if(isDel&&p.delPlace){updates.place=p.delPlace;cf.place=true;}
          if(isCol&&p.colPlace){updates.place=p.colPlace;cf.place=true;}
          if(isDel&&p.colPlace){updates.colPlace=p.colPlace;cf.colPlace=true;}
          if(Object.keys(updates).length===0)return{...t,...ssUpdates};
          return{...t,...updates,...ssUpdates,_changed:cf,_placeSource:"spreadsheet"};
        });
        DB._lsSave(updatedTasks,selDate);
        return updatedTasks;
      });
      // ★ DB保存をsetState外で実行（確実にawait）
      pendingSaves.current++;setSaveStatus("saving");
      await DB.upsertTasks(updatedTasks,selDate);
      pendingSaves.current--;
      setSaveStatus(DB._dbSaveOk?(pendingSaves.current>0?"saving":"ok"):"error");
      if(onUpdateSheetPlaces)onUpdateSheetPlaces({...sheetPlaces,...placeMap});
      // ★ placesテーブルにも保存（他端末・リロード時にも場所情報を復元可能にする）
      DB.upsertPlaces(placeMap);
      // ★ reservationsマスターにも書き戻し
      Object.entries(placeMap).forEach(([resId,p])=>{
        const resFields={};
        if(p.delPlace)resFields.delPlace=p.delPlace;
        if(p.colPlace)resFields.colPlace=p.colPlace;
        if(Object.keys(resFields).length){
          DB.updateReservationField(resId,resFields,"\u2466\u5834\u6240:\u30b9\u30d7\u30ec\u30c3\u30c9\u30b7\u30fc\u30c8\u53d6\u5f97","spreadsheet");
          if(onReservationUpdate)onReservationUpdate(resId,resFields);
        }
      });
      alert(`${matched}件の予約の場所情報を更新しました`+(placeSkip>0?`\n（手動変更済み${placeSkip}件はスキップ）`:""));
    }catch(e){alert("場所データ取得エラー: "+e.message);}
    setPlaceLoading(false);
  };
  // ★ 時間・場所を日付切替時＋5分間隔で自動取得（SPKと同仕様）
  useEffect(()=>{
    if(!PLACE_SHEET_CSV)return; // URL未設定なら何もしない
    const doAutoFetch=async()=>{
      const resIds=[...new Set(tasks.filter(t=>t.reservationId).map(t=>t.reservationId))];
      if(!resIds.length)return;
      try{
        const[timeMap,placeMap]=await Promise.all([fetchTimeData(resIds),fetchPlaceData(resIds)]);
        if(Object.keys(timeMap).length||Object.keys(placeMap).length){
          tasks.forEach(t=>{if(t.reservationId&&(timeMap[t.reservationId]||placeMap[t.reservationId]))selfUpdatedIds.current.set(t._id,Date.now());});
          let updatedTasks;
          setTasks(prev=>{
            updatedTasks=prev.map(t=>{
              if(!t.reservationId)return t;
              let changed=false;const next={...t};
              // 時間更新 → _ssTimeに保存
              const tm=timeMap[t.reservationId];
              if(tm){
                let nw=null;
                if((t.type==="DEL"||t.type==="PU"||t.type==="PUB")&&tm.delTime)nw=tm.delTime;
                if((t.type==="COL"||t.type==="BD"||t.type==="BDB")&&tm.colTime)nw=tm.colTime;
                if(nw){
                  const norm=nw.replace(/^(\d):/,"0$1:").replace(/\uff1a/g,":").slice(0,5);
                  if(norm!==t._ssTime){next._ssTime=norm;next._ssTimeAt=new Date().toISOString();changed=true;}
                  // 手動変更なしの場合はtimeも更新
                  if(!(t._timeChangeSource==="manual"&&t.timeChange)&&norm!==t.time){
                    next.time=norm;next._changed={...(t._changed||{}),time:true};next._timeChangeSource="spreadsheet";changed=true;
                  }
                }
              }
              // 場所更新 → _ssPlaceに保存
              const p=placeMap[t.reservationId];
              if(p&&t._placeSource!=="manual"){
                const isDel=t.type==="DEL"||t.type==="PU"||t.type==="PUB";
                const isCol=t.type==="COL"||t.type==="BD"||t.type==="BDB";
                let newPlace=isDel?p.delPlace:isCol?p.colPlace:"";
                if(newPlace){
                  if(newPlace!==t._ssPlace){next._ssPlace=newPlace;next._ssPlaceAt=new Date().toISOString();changed=true;}
                  if(newPlace!==t.place){next.place=newPlace;next._changed={...(next._changed||{}),place:true};next._placeSource="spreadsheet";changed=true;}
                }
                if(isDel&&p.colPlace&&!t._manualColPlace&&p.colPlace!==t.colPlace){
                  next.colPlace=p.colPlace;next._changed={...(next._changed||{}),colPlace:true};changed=true;
                }
              }
              return changed?next:t;
            });
            DB._lsSave(updatedTasks,selDate);
            return updatedTasks;
          });
          // DB保存（変更されたタスクのみ）
          if(updatedTasks){
            const origTasks=tasks;
            updatedTasks.forEach((t,i)=>{if(t!==origTasks[i]){DB.updateTask(t,selDate);}});
          }
          // 場所をplacesテーブルにも保存
          if(Object.keys(placeMap).length){
            if(onUpdateSheetPlaces)onUpdateSheetPlaces({...sheetPlaces,...placeMap});
            DB.upsertPlaces(placeMap);
          }
          // reservationsマスターにも書き戻し
          Object.entries(timeMap).forEach(([resId,tm])=>{
            const resFields={};
            if(tm.delTime){const n=tm.delTime.replace(/^(\d):/,"0$1:").replace(/\uff1a/g,":").slice(0,5);resFields.delTime=n;}
            if(tm.colTime){const n=tm.colTime.replace(/^(\d):/,"0$1:").replace(/\uff1a/g,":").slice(0,5);resFields.colTime=n;}
            if(Object.keys(resFields).length){
              DB.updateReservationField(resId,resFields,"⑤時間:自動取得","spreadsheet");
              if(onReservationUpdate)onReservationUpdate(resId,resFields);
            }
          });
          Object.entries(placeMap).forEach(([resId,p])=>{
            const resFields={};
            if(p.delPlace)resFields.delPlace=p.delPlace;
            if(p.colPlace)resFields.colPlace=p.colPlace;
            if(Object.keys(resFields).length){
              DB.updateReservationField(resId,resFields,"⑦場所:自動取得","spreadsheet");
              if(onReservationUpdate)onReservationUpdate(resId,resFields);
            }
          });
        }
      }catch(e){console.log("[autoFetch]",e.message);}
    };
    const t0=setTimeout(doAutoFetch,3000);
    const iv=setInterval(doAutoFetch,5*60*1000);
    return()=>{clearTimeout(t0);clearInterval(iv);};
  },[selDate,tasks.length]);
  // ソート
  const[sortKey,setSortKey]=useState(null);const[sortAsc,setSortAsc]=useState(true);
  const doSort=(arr,key,asc)=>{const dir=asc?1:-1;return[...arr].sort((a,b)=>{let va,vb;switch(key){case"time":va=a.time||"99:99";vb=b.time||"99:99";break;case"type":va=a.type||"";vb=b.type||"";break;case"assignee":va=a.assignee||"zzz";vb=b.assignee||"zzz";break;case"name":va=a.name||"";vb=b.name||"";break;case"vehicle":va=a.assignedVehicle||"";vb=b.assignedVehicle||"";break;case"done":va=a.done?1:0;vb=b.done?1:0;break;default:va="";vb="";}if(typeof va==="number")return(va-vb)*dir;return va.localeCompare(vb,"ja")*dir;});};
  const handleSort=(key)=>{
    let newKey,newAsc;
    if(sortKey===key){if(sortAsc){newKey=key;newAsc=false;}else{newKey=null;newAsc=true;}}
    else{newKey=key;newAsc=true;}
    setSortKey(newKey);setSortAsc(newAsc);
    // ★ ソート結果をtasks配列に反映してDB保存（並び順の永続化）
    if(newKey){
      tasks.forEach(t=>selfUpdatedIds.current.set(t._id,Date.now()));
      const sorted=doSort(tasks,newKey,newAsc);
      setTasks(sorted);
      DB.upsertTasks(sorted,selDate);
    }
  };
  const sortedTasks=useMemo(()=>{if(!sortKey)return tasks;return doSort(tasks,sortKey,sortAsc);},[tasks,sortKey,sortAsc]);
  const sortIcon=(key)=>sortKey===key?(sortAsc?"▲":"▼"):"";
  // 行移動
  const moveRow=(id,dir)=>{selfUpdatedIds.current.set(id,Date.now());const base=sortKey?sortedTasks:tasks;const idx=base.findIndex(t=>t._id===id);const ni=idx+dir;if(ni<0||ni>=base.length)return;const arr=[...base];[arr[idx],arr[ni]]=[arr[ni],arr[idx]];setTasks(arr);setSortKey(null);DB.upsertTasks(arr,selDate);};

  return <div className="op-fullscreen">
    <div className="op-header" style={{flexWrap:"wrap",gap:4,padding:"6px 10px"}}>
      <div style={{display:"flex",alignItems:"center",gap:6,minWidth:0,flex:"0 0 auto"}}>
        <button onClick={onClose} className="text-white text-lg font-bold hover:bg-white hover:bg-opacity-20 rounded" style={{padding:"0 4px",lineHeight:1}}>←</button>
        <span className="font-bold text-white" style={{fontSize:13,whiteSpace:"nowrap"}}>TOPへ戻る</span>
        <span className="text-blue-200" style={{fontSize:10,whiteSpace:"nowrap"}}>{fmtFull(selDate)} / 出勤{staffCount}名</span>
        {saveStatus==="saving"&&<span style={{fontSize:9,color:"#fbbf24",fontWeight:700}}>💾</span>}
        {saveStatus==="error"&&<span style={{fontSize:9,color:"#ef4444",fontWeight:700,cursor:"pointer"}} onClick={()=>{alert("⚠️ DB保存エラーが発生しています。\n\n変更はこの端末のローカルに保存済みですが、\n他の端末には反映されない可能性があります。\n\nページをリロードせず、しばらく待ってから再度変更してください。")}}>⚠️保存エラー</span>}
        {saveStatus==="ok"&&SB_ENABLED&&<span style={{fontSize:9,color:"#86efac"}}>✓</span>}
      </div>
      <div style={{display:"flex",alignItems:"center",gap:4,marginLeft:"auto",flex:"0 0 auto"}}>
        <span className="text-blue-200" style={{fontSize:10}}>{done}/{tasks.length}</span>
        <div style={{width:40,height:5,background:"#1e3a8a",borderRadius:4,overflow:"hidden"}}><div style={{height:"100%",background:"#4ade80",borderRadius:4,width:`${tasks.length?done/tasks.length*100:0}%`}}/></div>
        <button onClick={()=>{const newTask={_id:uid(),type:"その他",time:"",name:"",people:0,place:"",vehicle:"",insurance:"",flight:"",reservationId:"",ota:"",tel:"",mail:"",done:false,assignee:"",memo:"",assignedVehicle:"",plateNo:"",insuranceChange:"",opts:{b:0,c:0,j:0,usb:0},yakkan:false,line:false,payment:false,returnDate:"",returnTime:"",returnType:"",colPlace:"",manual:true};add(newTask);}} className="px-2 py-1 bg-white text-blue-700 rounded text-xs font-bold shadow-sm">＋</button>
        <button onClick={updateTimes} disabled={timeLoading} className="px-2 py-1 rounded text-xs font-bold shadow-sm" style={{background:timeLoading?"#94a3b8":"#f0abfc",color:"#701a75",whiteSpace:"nowrap",fontSize:10}}>{timeLoading?"...":"⏰時間"}</button>
        <button onClick={updatePlaces} disabled={placeLoading} className="px-2 py-1 rounded text-xs font-bold shadow-sm" style={{background:placeLoading?"#94a3b8":"#fbbf24",color:"#78350f",whiteSpace:"nowrap",fontSize:10}}>{placeLoading?"...":"📍場所"}</button>
        <button id="op-reload-btn" onClick={async e=>{const btn=e.currentTarget;btn.disabled=true;btn.textContent="⏳";selfUpdatedIds.current.clear();try{localStorage.removeItem(DB._lsKey(selDate));await loadTasks(selDate,true);}catch(ex){}btn.textContent="✅";btn.style.background="#d1fae5";setTimeout(()=>{btn.textContent="🔄";btn.style.background="#e0f2fe";btn.disabled=false;},1200);}} className="px-2 py-1 rounded text-xs font-bold shadow-sm" style={{background:"#e0f2fe",color:"#0369a1",whiteSpace:"nowrap",fontSize:10}}>🔄</button>
        <button onClick={()=>{if(onGoFleet)onGoFleet();}} style={{background:"linear-gradient(135deg,#059669,#10b981)",color:"#fff",border:"2px solid #34d399",borderRadius:8,padding:"4px 12px",fontSize:12,fontWeight:800,cursor:"pointer",whiteSpace:"nowrap",boxShadow:"0 2px 6px rgba(5,150,105,.4)"}}>🚗 配車表</button>
      </div>
    </div>
    <div style={{padding:"4px 6px",background:"#fff",borderBottom:"1px solid #e5e7eb",overflowX:"auto",display:"flex",gap:3,flexShrink:0}}>
      {dayButtons.map(db=>{const sel=dayOff===db.i;const dt=new Date(db.d);return <button key={db.i} onClick={()=>setDayOff(db.i)} style={{flexShrink:0,padding:"3px 8px",borderRadius:6,fontSize:10,fontWeight:sel?700:500,background:sel?"#2563eb":"#f1f5f9",color:sel?"#fff":"#374151",border:"none",cursor:"pointer",minWidth:48,textAlign:"center"}}><div style={{fontWeight:700}}>{db.i===0?"今日":db.i===1?"明日":`${dt.getMonth()+1}/${dt.getDate()}`}</div><div style={{fontSize:8,opacity:.7}}>{WK[dt.getDay()]}</div>{db.tc>0&&<div style={{fontSize:7,background:sel?"rgba(255,255,255,.25)":"#dbeafe",color:sel?"#fff":"#1d4ed8",borderRadius:6,padding:"0 3px"}}>{db.tc}件</div>}</button>;})}
    </div>
    {activeMembers.length>0&&<div style={{padding:"3px 6px",background:"#f8fafc",borderBottom:"1px solid #e5e7eb",display:"flex",gap:3,flexWrap:"wrap",flexShrink:0}}><span style={{fontSize:9,color:"#64748b",fontWeight:600}}>出勤:</span>{activeMembers.map(name=>{const isReg=staff.find(x=>x.name===name)?.type==="正社員";return <span key={name} style={{fontSize:9,fontWeight:700,padding:"1px 5px",borderRadius:3,background:isReg?"#dbeafe":"#fef3c7",color:isReg?"#1d4ed8":"#92400e"}}>{name}</span>;})}</div>}
    {/* ★ 表示切替タブ */}
    <div style={{padding:"4px 8px",background:"#fff",borderBottom:"1px solid #e5e7eb",display:"flex",gap:4,flexShrink:0,overflowX:"auto",WebkitOverflowScrolling:"touch"}}>
      {[
        {k:"summary",l:"📊サマリー",cnt:sortedTasks.filter(t=>["PUB","BDB","PU","BD","DEL","COL","洗車"].includes(t.type)).length,ac:"#0f172a"},
        {k:"bus",l:"🚌バス",cnt:sortedTasks.filter(t=>t.type==="PUB"||t.type==="BDB").length,ac:"#1e40af"},
        {k:"hia",l:"🚐ハイエース",cnt:sortedTasks.filter(t=>(t.type==="PU"||t.type==="BD")&&isBusRequired(t)).length,ac:"#546e7a"},
        {k:"tasks",l:"🚗DEL/COL",cnt:sortedTasks.filter(t=>t.type==="DEL"||t.type==="COL").length,ac:"#2563eb"},
        {k:"wash",l:"🧽洗車",cnt:sortedTasks.filter(t=>t.type==="洗車").length,ac:"#64748b"},
        {k:"raiten",l:"🏪来店",cnt:sortedTasks.filter(t=>t.type==="来店"||t.type==="返却"||(t.type!=="PU"&&t.type!=="PUB"&&t.type!=="BD"&&t.type!=="BDB"&&t.type!=="DEL"&&t.type!=="COL"&&t.type!=="洗車"&&/^(来店|店舗|店頭|ヤード|営業所)$/.test((t.place||"").trim()))).length,ac:"#6d4c41"},
        {k:"master",l:"📋マスター",cnt:0,ac:"#7c3aed"},
        {k:"edit",l:"✏️編集",cnt:0,ac:"#dc2626"}
      ].map(v=>{
        const sel=opView===v.k;
        return <button key={v.k} onClick={()=>setOpView(v.k)} style={{padding:"3px 8px",borderRadius:6,fontSize:9,fontWeight:sel?800:500,background:sel?v.ac:"#f1f5f9",color:sel?"#fff":"#374151",border:"none",cursor:"pointer",position:"relative",whiteSpace:"nowrap",flexShrink:0}}>
          {v.l}{v.cnt>0&&<span style={{marginLeft:2,fontSize:7,fontWeight:800,padding:"0 3px",borderRadius:6,background:sel?"rgba(255,255,255,.3)":"#e2e8f0",color:sel?"#fff":"#475569"}}>{v.cnt}</span>}
        </button>;
      })}
    </div>
    <div className="op-body">
      {/* ★ 予約詳細ポップアップ */}
      {resDetailPopup&&(()=>{
        const t=resDetailPopup;
        const srcRes=t.reservationId?reservations.find(r=>r.id===t.reservationId):null;
        return <div style={{position:"fixed",inset:0,zIndex:9999,background:"rgba(0,0,0,.5)",display:"flex",alignItems:"center",justifyContent:"center"}} onClick={()=>setResDetailPopup(null)}>
          <div onClick={e=>e.stopPropagation()} style={{background:"#fff",borderRadius:16,padding:16,width:"90%",maxWidth:400,maxHeight:"80vh",overflowY:"auto",boxShadow:"0 8px 32px rgba(0,0,0,.3)"}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
              <span style={{fontWeight:900,fontSize:16,color:"#1e293b"}}>予約詳細</span>
              <button onClick={()=>setResDetailPopup(null)} style={{background:"none",border:"none",fontSize:18,cursor:"pointer",color:"#94a3b8"}}>✕</button>
            </div>
            <div style={{display:"grid",gridTemplateColumns:"80px 1fr",gap:"6px 8px",fontSize:12}}>
              <span style={{fontWeight:700,color:"#64748b"}}>予約番号</span><span style={{fontWeight:700}}>{t.reservationId||"-"}</span>
              <span style={{fontWeight:700,color:"#64748b"}}>氏名</span><span style={{fontWeight:700}}>{t.name||"-"}</span>
              <span style={{fontWeight:700,color:"#64748b"}}>人数</span><span>{t.people||"-"}名</span>
              <span style={{fontWeight:700,color:"#64748b"}}>種別</span><span>{t.typeChange?<><span style={{textDecoration:"line-through",color:"#aaa"}}>{t.type}</span><span style={{color:"#dc2626",fontWeight:800}}> → {t.typeChange}</span></>:(t.type||"-")}</span>
              <span style={{fontWeight:700,color:"#64748b"}}>時間</span><span>{t.timeChange?<><span style={{textDecoration:"line-through",color:"#aaa"}}>{t.time}</span><span style={{color:"#dc2626",fontWeight:800}}> → {t.timeChange}</span></>:(t.time||"-")}</span>
              <span style={{fontWeight:700,color:"#64748b"}}>便名</span><span>{t.flight||"-"}</span>
              <span style={{fontWeight:700,color:"#64748b"}}>車種</span><span>{t.vehicle||"-"}</span>
              <span style={{fontWeight:700,color:"#64748b"}}>車両No.</span><span>{t.plateNo||"-"}</span>
              <span style={{fontWeight:700,color:"#64748b"}}>場所</span><span>{t.place||"-"}</span>
              <span style={{fontWeight:700,color:"#64748b"}}>担当</span><span>{t.assignee||"-"}</span>
              {srcRes&&<>
                <span style={{fontWeight:700,color:"#64748b"}}>OTA</span><span>{srcRes.ota||"-"}</span>
                <span style={{fontWeight:700,color:"#64748b"}}>補償</span><span>{srcRes.insurance||"-"}</span>
                <span style={{fontWeight:700,color:"#64748b"}}>TEL</span><span>{srcRes.tel||srcRes.phone||"-"}</span>
                <span style={{fontWeight:700,color:"#64748b"}}>MAIL</span><span style={{fontSize:10,wordBreak:"break-all"}}>{srcRes.email||"-"}</span>
                <span style={{fontWeight:700,color:"#64748b"}}>貸出日</span><span>{srcRes.lendDate||"-"}</span>
                <span style={{fontWeight:700,color:"#64748b"}}>返却日</span><span>{srcRes.returnDate||"-"}</span>
              </>}
              {t.opts&&<>
                <span style={{fontWeight:700,color:"#64748b"}}>オプション</span>
                <span style={{display:"flex",gap:4,flexWrap:"wrap"}}>
                  {t.opts.b>0&&<span style={{background:"#fef3c7",color:"#92400e",padding:"1px 4px",borderRadius:3,fontWeight:700,fontSize:10}}>👶B×{t.opts.b}</span>}
                  {t.opts.c>0&&<span style={{background:"#dbeafe",color:"#1e40af",padding:"1px 4px",borderRadius:3,fontWeight:700,fontSize:10}}>🧒C×{t.opts.c}</span>}
                  {t.opts.j>0&&<span style={{background:"#e0e7ff",color:"#4338ca",padding:"1px 4px",borderRadius:3,fontWeight:700,fontSize:10}}>J×{t.opts.j}</span>}
                  {t.opts.usb>0&&<span style={{background:"#dcfce7",color:"#166534",padding:"1px 4px",borderRadius:3,fontWeight:700,fontSize:10}}>🔌×{t.opts.usb}</span>}
                  {!t.opts.b&&!t.opts.c&&!t.opts.j&&!t.opts.usb&&<span>-</span>}
                </span>
              </>}
            </div>
          </div>
        </div>;
      })()}
      {/* ★★★ サマリー（俯瞰ダッシュボード） ★★★ */}
      {opView==="summary"&&(()=>{
        const isMob=window.innerWidth<=768;
        const pubTasks=sortedTasks.filter(t=>t.type==="PUB");
        const bdbTasks=sortedTasks.filter(t=>t.type==="BDB");
        const puTasks=sortedTasks.filter(t=>t.type==="PU"&&isBusRequired(t));
        const bdTasks=sortedTasks.filter(t=>t.type==="BD"&&isBusRequired(t));
        const delTasks=sortedTasks.filter(t=>t.type==="DEL");
        const colTasks=sortedTasks.filter(t=>t.type==="COL");
        const washTasks=sortedTasks.filter(t=>t.type==="洗車");
        const raitenTasks=sortedTasks.filter(t=>t.type==="来店"||t.type==="返却"||(t.type!=="PU"&&t.type!=="PUB"&&t.type!=="BD"&&t.type!=="BDB"&&t.type!=="DEL"&&t.type!=="COL"&&t.type!=="洗車"&&t.place&&/^(来店|店舗|店頭)$/.test(t.place.trim())));
        const pplSum=(arr)=>arr.reduce((s,t)=>s+(parseInt(t.people)||1),0);
        const doneSum=(arr)=>arr.filter(t=>t.done).length;
        // バス便別集計
        const busByHour={};
        BUS_PU_HOURS.forEach(h=>{busByHour[h]={pub:0,bdb:0};});
        pubTasks.forEach(t=>{
          const time=t.timeChange||t.time||"";if(!time)return;
          const[hh,mm]=time.split(":").map(Number);
          let th=Math.ceil((hh*60+mm+30)/60);
          if(th<BUS_PU_HOURS[0])th=BUS_PU_HOURS[0];
          if(th>BUS_PU_HOURS[BUS_PU_HOURS.length-1])th=BUS_PU_HOURS[BUS_PU_HOURS.length-1];
          busByHour[th].pub+=parseInt(t.people)||1;
        });
        bdbTasks.forEach(t=>{
          const time=t.timeChange||t.time||"";if(!time)return;
          const[hh,mm]=time.split(":").map(Number);
          let th=hh;if(mm>30)th=hh+1;
          if(th<BUS_BD_HOURS[0])th=BUS_BD_HOURS[0];
          if(th>BUS_BD_HOURS[BUS_BD_HOURS.length-1])th=BUS_BD_HOURS[BUS_BD_HOURS.length-1];
          if(busByHour[th])busByHour[th].bdb+=parseInt(t.people)||1;
        });
        const noFlightPub=pubTasks.filter(t=>!t.flight);
        const categories=[
          {key:"pub",label:"PUB",sub:"バス空港発",icon:"🚌✈",tasks:pubTasks,color:"#2d6a4f",bg:"#e8f5e9",people:pplSum(pubTasks)},
          {key:"bdb",label:"BDB",sub:"バスヤード発",icon:"🚌🏢",tasks:bdbTasks,color:"#8b3a3a",bg:"#fce4ec",people:pplSum(bdbTasks)},
          {key:"pu",label:"PU",sub:"ハイエース空港",icon:"🚐✈",tasks:puTasks,color:"#37474f",bg:"#eceff1",people:pplSum(puTasks)},
          {key:"bd",label:"BD",sub:"ハイエースヤード",icon:"🚐🏢",tasks:bdTasks,color:"#37474f",bg:"#eceff1",people:pplSum(bdTasks)},
          {key:"del",label:"DEL",sub:"配送",icon:"🚗",tasks:delTasks,color:"#1565c0",bg:"#e3f2fd",people:pplSum(delTasks)},
          {key:"col",label:"COL",sub:"回収",icon:"🚛",tasks:colTasks,color:"#e65100",bg:"#fff3e0",people:pplSum(colTasks)},
          {key:"raiten",label:"来店",sub:"来店貸出/返却",icon:"🏪",tasks:raitenTasks,color:"#7c3aed",bg:"#f5f3ff",people:pplSum(raitenTasks)},
          {key:"wash",label:"洗車",sub:"事前洗車",icon:"🧽",tasks:washTasks,color:"#546e7a",bg:"#f5f5f5",people:0},
        ];
        return <div style={{padding:isMob?4:8}}>
          {/* ヘッダー */}
          <div style={{background:"#0f172a",borderRadius:10,padding:isMob?"10px 12px":"12px 16px",marginBottom:8,color:"#e2e8f0"}}>
            <div style={{fontWeight:900,fontSize:isMob?16:18,marginBottom:2}}>📊 本日のサマリー</div>
            <div style={{fontSize:isMob?10:11,opacity:.7}}>{fmtFull(selDate)} ・ 出勤{staffCount}名 ・ 全{sortedTasks.length}タスク</div>
          </div>
          {/* カテゴリカード */}
          <div style={{display:"grid",gridTemplateColumns:isMob?"repeat(2,1fr)":"repeat(4,1fr)",gap:isMob?6:8,marginBottom:8}}>
            {categories.filter(c=>c.tasks.length>0).map(c=>{
              const done=doneSum(c.tasks);
              return <div key={c.key} onClick={()=>setOpView(c.key==="pub"||c.key==="bdb"?"bus":c.key==="pu"||c.key==="bd"?"hia":c.key==="del"||c.key==="col"?"tasks":"wash")} style={{background:"#fff",borderRadius:8,border:"1px solid #e2e8f0",padding:isMob?"10px":"12px",cursor:"pointer",transition:"all .15s",boxShadow:"0 1px 3px rgba(0,0,0,.06)"}}>
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:4}}>
                  <span style={{fontSize:isMob?18:22}}>{c.icon}</span>
                  <span style={{fontSize:isMob?22:28,fontWeight:900,color:c.color}}>{c.tasks.length}</span>
                </div>
                <div style={{fontWeight:800,fontSize:isMob?13:14,color:c.color}}>{c.label}</div>
                <div style={{fontSize:isMob?9:10,color:"#78909c"}}>{c.sub}</div>
                {c.people>0&&<div style={{fontSize:isMob?10:11,fontWeight:700,color:"#5e35b1",marginTop:2}}>{c.people}名</div>}
                <div style={{display:"flex",alignItems:"center",gap:4,marginTop:4}}>
                  <div style={{flex:1,height:4,background:"#f1f5f9",borderRadius:2,overflow:"hidden"}}>
                    <div style={{height:"100%",background:done===c.tasks.length?"#4caf50":"#90a4ae",width:`${c.tasks.length?done/c.tasks.length*100:0}%`,borderRadius:2}}/>
                  </div>
                  <span style={{fontSize:8,color:"#90a4ae",fontWeight:600}}>{done}/{c.tasks.length}</span>
                </div>
              </div>;
            })}
          </div>
          {/* バス便別乗車人数 */}
          {(pubTasks.length>0||bdbTasks.length>0)&&<div style={{background:"#fff",borderRadius:8,border:"1px solid #e2e8f0",marginBottom:8,overflow:"hidden"}}>
            <div style={{background:"#334155",padding:"6px 12px",color:"#e2e8f0",fontWeight:800,fontSize:isMob?12:11}}>🚌 バス便別乗車人数</div>
            <div style={{overflowX:"auto"}}>
              <table style={{width:"100%",borderCollapse:"collapse",fontSize:isMob?10:9,whiteSpace:"nowrap"}}>
                <thead><tr style={{background:"#f8fafc"}}>
                  <th style={{padding:"4px 8px",textAlign:"left",fontWeight:700,color:"#475569",borderBottom:"1px solid #e2e8f0",position:"sticky",left:0,background:"#f8fafc",zIndex:1}}>便</th>
                  {BUS_PU_HOURS.map(h=>{const k=String(h).padStart(2,"0");return <th key={h} style={{padding:"4px 6px",textAlign:"center",fontWeight:600,color:"#475569",borderBottom:"1px solid #e2e8f0",minWidth:44}}>{k}:00</th>;})}
                  <th style={{padding:"4px 8px",textAlign:"center",fontWeight:800,color:"#1e293b",borderBottom:"1px solid #e2e8f0",background:"#f1f5f9"}}>計</th>
                </tr></thead>
                <tbody>
                  <tr style={{borderBottom:"1px solid #f1f5f9"}}>
                    <td style={{padding:"4px 8px",fontWeight:700,color:"#2d6a4f",position:"sticky",left:0,background:"#fff",zIndex:1}}>✈PUB</td>
                    {BUS_PU_HOURS.map(h=>{const v=busByHour[h].pub;return <td key={h} style={{padding:"4px 6px",textAlign:"center",fontWeight:v?700:400,color:v>BUS_CAPACITY?"#c0392b":v?"#2d6a4f":"#d0d0d0",background:v>BUS_CAPACITY?"#fdecea":v?"#f0faf4":"transparent"}}>{v||"-"}</td>;})}
                    <td style={{padding:"4px 8px",textAlign:"center",fontWeight:800,color:"#2d6a4f",background:"#e8f5e9"}}>{pplSum(pubTasks)}</td>
                  </tr>
                  <tr style={{borderBottom:"1px solid #f1f5f9"}}>
                    <td style={{padding:"4px 8px",fontWeight:700,color:"#8b3a3a",position:"sticky",left:0,background:"#fff",zIndex:1}}>🏢BDB</td>
                    {BUS_PU_HOURS.map(h=>{const v=busByHour[h].bdb;return <td key={h} style={{padding:"4px 6px",textAlign:"center",fontWeight:v?700:400,color:v>BUS_CAPACITY?"#c0392b":v?"#8b3a3a":"#d0d0d0",background:v>BUS_CAPACITY?"#fdecea":v?"#fdf0f0":"transparent"}}>{v||"-"}</td>;})}
                    <td style={{padding:"4px 8px",textAlign:"center",fontWeight:800,color:"#8b3a3a",background:"#fce4ec"}}>{pplSum(bdbTasks)}</td>
                  </tr>
                  <tr>
                    <td style={{padding:"4px 8px",fontWeight:700,color:"#37474f",position:"sticky",left:0,background:"#f8fafc",zIndex:1}}>合計</td>
                    {BUS_PU_HOURS.map(h=>{const v=busByHour[h].pub+busByHour[h].bdb;return <td key={h} style={{padding:"4px 6px",textAlign:"center",fontWeight:v?800:400,color:v>BUS_CAPACITY?"#c0392b":v?"#1e293b":"#d0d0d0",background:v>BUS_CAPACITY?"#fdecea":"#f8fafc"}}>{v||"-"}</td>;})}
                    <td style={{padding:"4px 8px",textAlign:"center",fontWeight:900,color:"#1e293b",background:"#e2e8f0"}}>{pplSum(pubTasks)+pplSum(bdbTasks)}</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>}
          {/* アラート */}
          {noFlightPub.length>0&&<div style={{background:"#fffdf5",borderRadius:8,border:"1px solid #e0c068",padding:isMob?"8px 10px":"8px 12px",marginBottom:8}}>
            <div style={{fontWeight:700,fontSize:isMob?11:10,color:"#8b6914",marginBottom:4}}>⚠ 便名未登録 {noFlightPub.length}件（暫定振分中）</div>
            <div style={{display:"flex",flexWrap:"wrap",gap:4}}>
              {noFlightPub.map(t=><span key={t._id} onClick={()=>setResDetailPopup(t)} style={{fontSize:isMob?10:9,background:"#fff",border:"1px solid #e0c068",padding:"2px 6px",borderRadius:4,cursor:"pointer",fontWeight:600}}>{t.name} {parseInt(t.people)||1}名</span>)}
            </div>
          </div>}
          {/* 時系列スケジュール */}
          {(()=>{
            const timedWash=sortedTasks.filter(t=>t.type==="洗車"&&t.time);
            const untimedWash=sortedTasks.filter(t=>t.type==="洗車"&&!t.time);
            const allSchedule=[...sortedTasks.filter(t=>t.type!=="洗車"&&t.type!=="CXL"),...timedWash].sort((a,b)=>{const ta=a.timeChange||a._ssTime||a.time||"99:99";const tb=b.timeChange||b._ssTime||b.time||"99:99";return ta.localeCompare(tb);});
            const washList=untimedWash;
            const timeGroups={};
            allSchedule.forEach(t=>{const tm=t.timeChange||t._ssTime||t.time||"--:--";const hh=tm.substring(0,2)||"--";if(!timeGroups[hh])timeGroups[hh]=[];timeGroups[hh].push(t);});
            const hours=Object.keys(timeGroups).sort();
            const TM=TASK_META||{};
            const typeStyle=(tp)=>({PUB:{bg:"#dcfce7",c:"#166534",border:"#86efac"},PU:{bg:"#dbeafe",c:"#1e40af",border:"#93c5fd"},DEL:{bg:"#dbeafe",c:"#1d4ed8",border:"#60a5fa"},BDB:{bg:"#fce4ec",c:"#881337",border:"#fda4af"},BD:{bg:"#fee2e2",c:"#991b1b",border:"#fca5a5"},COL:{bg:"#ffedd5",c:"#9a3412",border:"#fdba74"},"来店":{bg:"#f3e8ff",c:"#6b21a8",border:"#c4b5fd"},"返却":{bg:"#f3e8ff",c:"#6b21a8",border:"#c4b5fd"},"洗車":{bg:"#FFFDE7",c:"#795548",border:"#FFD54F"}})[tp]||{bg:"#f1f5f9",c:"#475569",border:"#cbd5e1"};
            return <div style={{background:"#fff",borderRadius:8,border:"1px solid #e2e8f0",overflow:"hidden"}}>
              <div style={{background:"linear-gradient(135deg,#0f172a,#1e293b)",padding:"8px 12px",color:"#e2e8f0",fontWeight:800,fontSize:isMob?13:12,display:"flex",alignItems:"center",gap:8}}>
                <span>🗓 スケジュール</span>
                <span style={{fontSize:10,fontWeight:600,opacity:.7}}>{allSchedule.length}件{washList.length>0?" + 時間未定洗車"+washList.length+"件":""}</span>
              </div>
              {allSchedule.map(t=>{
                  const ppl=parseInt(t.people)||1;
                  const resolvedT=t.timeChange||t._ssTime||t.time||"--:--";
                  const resolvedP=(t._placeSource==="manual"?t.place:(t._ssPlace||t.place))||"";
                  const ts=typeStyle(t.type);
                  const vn=t.assignedVehicle?vehicles.find(v=>v.code===t.assignedVehicle):null;
                  return <div key={t._id} onClick={()=>{if(t.reservationId){setEditResId(t.reservationId);setEditBlock(null);setOpView("edit");}else{setResDetailPopup(t);}}} style={{display:"flex",alignItems:"stretch",gap:0,borderBottom:"1px solid #e2e8f0",cursor:"pointer",opacity:t.done?.5:1,background:t.done?"#fafafa":"#fff"}}>
                    <div style={{width:isMob?56:52,flexShrink:0,display:"flex",alignItems:"center",justifyContent:"center",fontWeight:800,fontSize:isMob?13:12,color:"#334155",fontFamily:"monospace",background:"#f8fafc",borderRight:"1px solid #e2e8f0"}}>{resolvedT}</div>
                    <div style={{width:isMob?48:44,flexShrink:0,display:"flex",alignItems:"center",justifyContent:"center",background:ts.bg,borderRight:"2px solid "+ts.border}}>
                      <span style={{fontSize:isMob?11:10,fontWeight:800,color:ts.c}}>{t.type}</span>
                    </div>
                    <div style={{flex:1,padding:isMob?"6px 10px":"5px 10px",minWidth:0}}>
                      <div style={{display:"flex",alignItems:"center",gap:6}}>
                        <span style={{fontWeight:700,fontSize:isMob?13:12,color:"#0f172a",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{t.type==="洗車"?(t.name||"洗車"):(t.name||"名前なし")}</span>
                        {t.type==="洗車"&&t.memo&&<span style={{fontSize:isMob?10:9,color:"#795548",fontWeight:600,flexShrink:0}}>{t.memo}</span>}
                        {t.type!=="洗車"&&<span style={{fontSize:isMob?11:10,fontWeight:700,color:"#7c3aed",flexShrink:0}}>{ppl}名</span>}
                        {t.done&&<span style={{flexShrink:0}}>✅</span>}
                      </div>
                      <div style={{display:"flex",alignItems:"center",gap:6,marginTop:2,flexWrap:"wrap"}}>
                        {resolvedP&&<span style={{fontSize:isMob?10:9,color:"#475569",fontWeight:600}}>📍{resolvedP}</span>}
                        {t.flight&&<span style={{fontSize:isMob?10:9,color:"#1565c0",fontWeight:600}}>✈{t.flight}</span>}
                        {vn&&<span style={{fontSize:isMob?10:9,color:"#059669",fontWeight:600}}>🚗{vn.name}({vn.no})</span>}
                        {!vn&&t.plateNo&&<span style={{fontSize:isMob?10:9,color:"#64748b",fontWeight:600}}>{t.plateNo}</span>}
                        {!vn&&!t.plateNo&&t.assignedVehicle===""&&t.type!=="来店"&&t.type!=="返却"&&t.type!=="洗車"&&<span style={{fontSize:isMob?9:8,color:"#dc2626",fontWeight:700}}>未配車</span>}
                        {t.assignee&&<span style={{fontSize:isMob?10:9,background:"#ede9fe",color:"#6d28d9",fontWeight:700,padding:"1px 6px",borderRadius:4}}>👤{t.assignee}</span>}
                        {!t.assignee&&t.type!=="来店"&&t.type!=="返却"&&<span style={{fontSize:isMob?9:8,color:"#f59e0b",fontWeight:700}}>担当未定</span>}
                      </div>
                    </div>
                  </div>;
              })}
              {washList.length>0&&<div>
                <div style={{background:"#f8fafc",padding:"4px 12px",borderBottom:"1px solid #e2e8f0",display:"flex",alignItems:"center",gap:6}}>
                  <span style={{fontSize:isMob?14:13,fontWeight:900,color:"#64748b"}}>🧽 洗車（時間未定）</span>
                  <span style={{fontSize:9,color:"#94a3b8",fontWeight:600}}>{washList.length}件</span>
                  <div style={{flex:1,height:1,background:"#e2e8f0"}}/>
                </div>
                {washList.map(t=>{
                  const vn=t.assignedVehicle?vehicles.find(v=>v.code===t.assignedVehicle):null;
                  return <div key={t._id} onClick={()=>setResDetailPopup(t)} style={{display:"flex",alignItems:"center",gap:8,padding:isMob?"6px 12px":"4px 12px",borderBottom:"1px solid #f5f5f5",cursor:"pointer",opacity:t.done?.5:1,fontSize:isMob?11:10}}>
                    <span style={{fontWeight:600,color:"#64748b",flex:1}}>{t.memo||t.name||""}</span>
                    {vn&&<span style={{color:"#059669",fontWeight:600,fontSize:isMob?10:9}}>🚗{vn.name}({vn.no})</span>}
                    {t.assignee&&<span style={{color:"#6d28d9",fontWeight:600,fontSize:isMob?10:9}}>👤{t.assignee}</span>}
                    {t.done&&<span>✅</span>}
                  </div>;
                })}
              </div>}
            </div>;
          })()}
        </div>;
      })()}
      {opView==="bus"&&(()=>{
        const HIA_CAPACITY=8;
        const isMob=window.innerWidth<=768;
        // busTab, setBusTab, chipAction, setChipAction はコンポーネントレベルで宣言済み
        // ★ PUB/BDB振り分けロジック（既存）
        const puBusTasks=sortedTasks.filter(t=>t.type==="PUB");
        const noFlightPU=[];const tentativePUIds=new Set();
        const puSlots={};BUS_PU_HOURS.forEach(h=>{puSlots[h]={tasks:[],count:0,overflow:[]};});
        const puWithFlight=[];const puNoFlight=[];
        puBusTasks.forEach(t=>{const time=t.timeChange||t.time||"";if(!time){noFlightPU.push(t);return;}if(t.flight){puWithFlight.push(t);}else{tentativePUIds.add(t._id);puNoFlight.push(t);}});
        const assignPU=(t)=>{const time=t.timeChange||t.time||"";const[hh,mm]=time.split(":").map(Number);let th=Math.ceil((hh*60+mm+30)/60);if(th<BUS_PU_HOURS[0])th=BUS_PU_HOURS[0];if(th>BUS_PU_HOURS[BUS_PU_HOURS.length-1])th=BUS_PU_HOURS[BUS_PU_HOURS.length-1];const ppl=parseInt(t.people)||1;if(puSlots[th].count+ppl<=BUS_CAPACITY){puSlots[th].tasks.push(t);puSlots[th].count+=ppl;}else{puSlots[th].overflow.push(t);}};
        puWithFlight.forEach(assignPU);puNoFlight.forEach(assignPU);
        const bdBusTasks=sortedTasks.filter(t=>t.type==="BDB");const noTimeBD=[];
        const bdSlots={};BUS_BD_HOURS.forEach(h=>{bdSlots[h]={tasks:[],count:0,overflow:[]};});
        const bdWithTime=[];
        bdBusTasks.forEach(t=>{const time=t.timeChange||t.time||"";if(!time){noTimeBD.push(t);return;}bdWithTime.push(t);});
        const assignBD=(t)=>{const time=t.timeChange||t.time||"";const[hh,mm]=time.split(":").map(Number);let th=hh;if(mm>30)th=hh+1;if(th<BUS_BD_HOURS[0])th=BUS_BD_HOURS[0];if(th>BUS_BD_HOURS[BUS_BD_HOURS.length-1])th=BUS_BD_HOURS[BUS_BD_HOURS.length-1];const ppl=parseInt(t.people)||1;if(bdSlots[th].count+ppl<=BUS_CAPACITY){bdSlots[th].tasks.push(t);bdSlots[th].count+=ppl;}else{bdSlots[th].overflow.push(t);}};
        bdWithTime.forEach(assignBD);
        const totalPU=Object.values(puSlots).reduce((s,v)=>s+v.count,0);
        const totalBD=Object.values(bdSlots).reduce((s,v)=>s+v.count,0);
        const totalOverPU=Object.values(puSlots).reduce((s,v)=>s+v.overflow.length,0);
        const totalOverBD=Object.values(bdSlots).reduce((s,v)=>s+v.overflow.length,0);
        // ★ タブ状態
        const isAll=busTab==="all";const isPU=busTab==="pu";const isBD=busTab==="bd";
        // chipAction はコンポーネントレベルで宣言済み
        // ★ 操作ボタン関数
        const moveToNext=(t,slotHour)=>{
          if(!window.confirm(`${t.name}を次の便に繰り越しますか？`))return;
          const taskIsPU=t.type==="PUB";
          const taskHours=taskIsPU?BUS_PU_HOURS:BUS_BD_HOURS;
          const idx=taskHours.indexOf(slotHour);
          if(idx<0||idx>=taskHours.length-1){alert("最終便のため繰越できません");return;}
          const nextHour=taskHours[idx+1];
          const nextTime=taskIsPU?`${String(nextHour).padStart(2,"0")}:00`:`${String(nextHour).padStart(2,"0")}:30`;
          const u={...t,timeChange:nextTime,_changed:{...(t._changed||{}),timeChange:true}};upd(t._id,u,t.reservationId?{fields:{[taskIsPU?"delTime":"colTime"]:nextTime},type:"便繰越",source:"op_sheet"}:undefined);setChipAction(null);
        };
        const cancelTask=(t)=>{if(!window.confirm(`${t.name}をキャンセルしますか？`))return;const u={...t,type:"CXL",_changed:{...(t._changed||{}),type:true}};upd(t._id,u,t.reservationId?{fields:{status:"cancelled"},type:"OPシートCXL",source:"op_sheet"}:undefined);if(t.reservationId&&fleet[t.reservationId]){DB.deleteFleetOne(t.reservationId);onFleetChange(prev=>{const nf={...(typeof prev==="object"?prev:fleetRef.current)};delete nf[t.reservationId];return nf;});}setChipAction(null);};
        const toRaiten=(t)=>{if(!window.confirm(`${t.name}を来店に変更しますか？`))return;const isPU=t.type==="PU"||t.type==="PUB";const u={...t,place:"来店",type:"来店",_changed:{...(t._changed||{}),place:true,type:true}};upd(t._id,u,t.reservationId?{fields:{[isPU?"visitType":"returnType"]:"来店",[isPU?"delPlace":"colPlace"]:"来店"},type:"来店変更",source:"op_sheet"}:undefined);setChipAction(null);};
        const toPUBD=(t)=>{if(!window.confirm(`${t.name}をPU/BD(ハイエース)に変更しますか？\n場所を再選択してください`))return;const newType=t.type==="PUB"?"PU":"BD";const u={...t,type:newType,place:"",_placeSource:"",_changed:{...(t._changed||{}),type:true,place:true}};upd(t._id,u,t.reservationId?{fields:{[t.type==="PUB"?"delPlace":"colPlace"]:""},type:"PUB/BDB→PU/BD:場所リセット",source:"manual"}:undefined);setChipAction(null);};
        // ★ チップ描画
        const renderChip=(t,slotHour)=>{
          const ppl=parseInt(t.people)||1;
          const isTentative=tentativePUIds.has(t._id);
          const isOpen=chipAction===t._id;
          return <div key={t._id} style={{position:"relative",display:"inline-block",margin:isMob?"3px":"2px"}}>
            <div onClick={()=>setChipAction(isOpen?null:t._id)} style={{display:"inline-flex",alignItems:"center",gap:isMob?4:3,padding:isMob?"6px 12px":"4px 10px",borderRadius:10,background:isTentative?"#fff8e1":"#fff",border:"2px solid "+(isTentative?"#ffb74d":"#e0e0e0"),fontSize:isMob?13:11,cursor:"pointer",boxShadow:"0 1px 4px rgba(0,0,0,.08)",transition:"all .15s"}}>
              {isTentative&&<span style={{background:"#ff9800",color:"#fff",fontSize:isMob?8:7,fontWeight:800,padding:"1px 4px",borderRadius:3}}>暫定</span>}
              <span style={{fontWeight:800,color:"#212121"}}>{t.name}</span>
              <span style={{color:"#7b1fa2",fontWeight:800}}>{ppl}名</span>
              {t.flight?<span style={{color:"#1565c0",fontSize:isMob?10:8,fontWeight:600}}>✈{t.flight}</span>:<span style={{color:"#bdbdbd",fontSize:isMob?9:7}}>✈?</span>}
            </div>
            {isOpen&&<div style={{position:"absolute",top:"100%",left:0,zIndex:50,background:"#fff",borderRadius:8,boxShadow:"0 4px 16px rgba(0,0,0,.2)",border:"1px solid #e0e0e0",padding:4,marginTop:4,minWidth:isMob?160:140,whiteSpace:"nowrap"}}>
              <div onClick={e=>{e.stopPropagation();setResDetailPopup(t);setChipAction(null);}} style={{padding:"6px 10px",fontSize:isMob?12:10,cursor:"pointer",borderRadius:4,fontWeight:600,color:"#1565c0"}}>📋 詳細を見る</div>
              <div onClick={e=>{e.stopPropagation();moveToNext(t,slotHour);}} style={{padding:"6px 10px",fontSize:isMob?12:10,cursor:"pointer",borderRadius:4,fontWeight:600,color:"#2e7d32"}}>⏭ 次の便に繰越</div>
              <div onClick={e=>{e.stopPropagation();toPUBD(t);}} style={{padding:"6px 10px",fontSize:isMob?12:10,cursor:"pointer",borderRadius:4,fontWeight:600,color:"#e65100"}}>🚐 PU/BD(HIA)に変更</div>
              <div onClick={e=>{e.stopPropagation();toRaiten(t);}} style={{padding:"6px 10px",fontSize:isMob?12:10,cursor:"pointer",borderRadius:4,fontWeight:600,color:"#546e7a"}}>🏪 来店に変更</div>
              <div onClick={e=>{e.stopPropagation();cancelTask(t);}} style={{padding:"6px 10px",fontSize:isMob?12:10,cursor:"pointer",borderRadius:4,fontWeight:600,color:"#c62828"}}>❌ キャンセル</div>
            </div>}
          </div>;
        };
        // ★ 統合運行表: 09:00→09:30→10:00→10:30... 交互表示
        const allSlots=[];
        BUS_PU_HOURS.forEach(h=>{
          allSlots.push({hour:h,type:"PUB",slot:puSlots[h],timeStr:`${String(h).padStart(2,"0")}:00`});
          if(BUS_BD_HOURS.includes(h))allSlots.push({hour:h,type:"BDB",slot:bdSlots[h],timeStr:`${String(h).padStart(2,"0")}:30`});
        });
        // ★ フィルター用（isAll/isPU/isBDは上で宣言済み）
        const filteredSlots=isAll?allSlots.filter(s=>s.slot.tasks.length>0||s.slot.overflow.length>0):isPU?allSlots.filter(s=>s.type==="PUB"):allSlots.filter(s=>s.type==="BDB");
        // ★ カード描画関数
        const renderSlotCard=(s,idx)=>{
          const isPUSlot=s.type==="PUB";
          const slot=s.slot;
          const remain=BUS_CAPACITY-slot.count;
          const pct=slot.count/BUS_CAPACITY*100;
          const isFull=remain<=0;const isFew=remain>0&&remain<=5;
          const cardBorder=isFull?"#ef9a9a":isFew?"#ffcc80":isPUSlot?"#a5d6a7":"#ffcc80";
          const barColor=isFull?"#ef5350":isFew?"#ffa726":isPUSlot?"#66bb6a":"#ff8a65";
          const seatsColor=isFull?"#c62828":isFew?"#e65100":isPUSlot?"#2e7d32":"#bf360c";
          const statusBg=isFull?"#ffebee":isFew?"#fff3e0":isPUSlot?"#e8f5e9":"#fff3e0";
          const statusColor=isFull?"#c62828":isFew?"#e65100":isPUSlot?"#2e7d32":"#bf360c";
          const statusText=isFull?"満席":isFew?"残りわずか":"空席あり";
          const routeText=isPUSlot?"BUDDICA高松店 → お届け先":"お届け先 → BUDDICA高松店";
          const key=String(s.hour).padStart(2,"0");
          return <div key={s.type+s.hour} style={{background:"#fff",borderRadius:14,marginBottom:10,overflow:"visible",border:"2px solid "+cardBorder,boxShadow:"0 1px 4px rgba(0,0,0,.05)",borderLeft:"5px solid "+(isPUSlot?"#43a047":"#e65100"),position:"relative"}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",padding:"12px 16px 4px"}}>
              <div>
                <div style={{fontSize:isMob?24:22,fontWeight:900,letterSpacing:1,color:isPUSlot?"#2e7d32":"#bf360c"}}>{s.timeStr}</div>
                <div style={{fontSize:isMob?10:9,color:"#90a4ae",fontWeight:600}}>{isPUSlot?"✈ 空港出発":"🏢 ヤード出発"}</div>
              </div>
              <div style={{textAlign:"right"}}>
                <div style={{fontSize:isMob?30:28,fontWeight:900,lineHeight:1,color:seatsColor}}>{remain>0?remain:0}<span style={{fontSize:isMob?12:11}}>席</span></div>
                <div style={{fontSize:isMob?10:9,fontWeight:600,color:seatsColor}}>{isFull?"満席":remain>=BUS_CAPACITY?"全席空き":"空き"}</div>
              </div>
            </div>
            <div style={{padding:"0 16px 6px",fontSize:isMob?9:8,color:"#78909c",fontWeight:600}}>🚌 {routeText}</div>
            <div style={{height:8,background:"#f1f5f9",margin:"0 16px 6px",borderRadius:4,overflow:"hidden"}}>
              <div style={{height:"100%",borderRadius:4,width:`${Math.min(pct,100)}%`,background:`linear-gradient(90deg,${barColor},${barColor})`,transition:"width .4s"}}/>
            </div>
            {slot.tasks.length>0&&<div style={{padding:"0 12px 6px",display:"flex",flexWrap:"wrap"}}>{slot.tasks.map(t=>renderChip(t,s.hour))}</div>}
            {slot.overflow&&slot.overflow.length>0&&<div style={{padding:"0 12px 6px"}}><span style={{fontSize:isMob?10:8,fontWeight:800,color:"#dc2626"}}>⚠溢れ→HIA: </span><div style={{display:"flex",flexWrap:"wrap"}}>{slot.overflow.map(t=>renderChip(t,s.hour))}</div></div>}
            <div style={{display:"flex",justifyContent:"space-between",padding:"0 16px 10px",fontSize:isMob?11:10,color:"#90a4ae",fontWeight:600,alignItems:"center"}}>
              <span>乗車 {slot.count}名 / 定員{BUS_CAPACITY}名</span>
              <span style={{display:"inline-block",fontSize:isMob?11:10,fontWeight:800,padding:"4px 12px",borderRadius:20,background:statusBg,color:statusColor}}>{statusText}</span>
            </div>
            {slot.tasks.length>0&&<div style={{background:"#f8fafc",padding:"4px 16px 6px",borderTop:"1px solid #f1f5f9",display:"flex",gap:8,alignItems:"center"}}>
              <select value={(busDrivers[key]||{}).driver||""} onChange={e=>setBusDrivers(p=>({...p,[key]:{...(p[key]||{}),driver:e.target.value}}))} style={{border:"1px solid #e2e8f0",borderRadius:6,background:"#fff",fontSize:isMob?11:10,padding:"3px 6px",fontWeight:600}}>
                <option value="">🚌 運転手</option>
                {activeMembers.map(m=><option key={m}>{m}</option>)}
              </select>
              <select value={(busDrivers[key]||{}).assistant||""} onChange={e=>setBusDrivers(p=>({...p,[key]:{...(p[key]||{}),assistant:e.target.value}}))} style={{border:"1px solid #e2e8f0",borderRadius:6,background:"#fff",fontSize:isMob?11:10,padding:"3px 6px",fontWeight:600}}>
                <option value="">👤 補助</option>
                {activeMembers.map(m=><option key={m}>{m}</option>)}
              </select>
            </div>}
          </div>;
        };
        return <div style={{maxWidth:500,margin:"0 auto",background:"#f0f2f5",minHeight:"60vh"}} onClick={()=>chipAction&&setChipAction(null)}>
          {/* ★ ヘッダー */}
          <div style={{background:"linear-gradient(135deg,#1e3a5f,#2d5a87)",padding:"14px 16px",textAlign:"center",color:"#fff",borderRadius:"0 0 12px 12px"}}>
            <div style={{fontWeight:900,fontSize:isMob?18:20,marginBottom:2}}>🚌 バス運行表</div>
            <div style={{fontSize:isMob?10:11,opacity:.7}}>コースター(2515) ・ 定員{BUS_CAPACITY}名 ・ 空港⇔ヤード往復</div>
          </div>
          {/* ★ 3タブ切替: 運行表 / 空港出発便 / ヤード出発便 */}
          <div style={{display:"flex",background:"#fff",borderBottom:"2px solid #e2e8f0"}}>
            {[{k:"all",l:"🚌 運行予定表",c:"#1e3a5f",cnt:puBusTasks.length+bdBusTasks.length},{k:"pu",l:"✈ 空港出発便",c:"#2e7d32",cnt:puBusTasks.length},{k:"bd",l:"🏢 ヤード出発便",c:"#bf360c",cnt:bdBusTasks.length}].map(tab=>{
              const sel=busTab===tab.k;
              return <button key={tab.k} onClick={()=>setBusTab(tab.k)} style={{flex:1,padding:isMob?"10px 0":"12px 0",textAlign:"center",fontSize:isMob?12:13,fontWeight:sel?800:600,cursor:"pointer",border:"none",background:sel?"#f8fafc":"transparent",color:sel?tab.c:"#94a3b8",borderBottom:sel?`3px solid ${tab.c}`:"3px solid transparent"}}>{tab.l} <span style={{fontSize:isMob?11:12,fontWeight:800}}>{tab.cnt}組</span></button>;
            })}
          </div>
          {/* ★ アラート */}
          {(tentativePUIds.size>0||noFlightPU.length>0||noTimeBD.length>0)&&<div style={{background:"#fef3c7",padding:"8px 12px",margin:"8px 12px 0",borderRadius:10,border:"1px solid #f59e0b",fontSize:isMob?11:10}}>
            <div style={{fontWeight:800,color:"#92400e",marginBottom:3}}>⚠ 要確認</div>
            {tentativePUIds.size>0&&<div style={{marginBottom:4}}>
              <div style={{color:"#b45309",fontWeight:600}}>暫定仮組み {tentativePUIds.size}件（便名未登録）</div>
              <div style={{display:"flex",flexWrap:"wrap",gap:4,marginTop:3}}>
                {sortedTasks.filter(t=>tentativePUIds.has(t._id)).map(t=><span key={t._id} style={{display:"inline-flex",alignItems:"center",gap:3,background:"#fff",border:"1px solid #f59e0b",padding:"2px 8px",borderRadius:6,fontSize:isMob?10:9,fontWeight:700}}>
                  <span style={{color:"#212121"}}>{t.name}</span>
                  <span style={{color:"#7b1fa2"}}>{parseInt(t.people)||1}名</span>
                  <span style={{color:"#78909c"}}>{t.time||"--:--"}</span>
                </span>)}
              </div>
            </div>}
            {noFlightPU.length>0&&<div style={{marginBottom:4}}>
              <div style={{color:"#dc2626",fontWeight:600}}>振分不可 {noFlightPU.length}件（情報なし）</div>
              <div style={{display:"flex",flexWrap:"wrap",gap:4,marginTop:3}}>
                {noFlightPU.map(t=><span key={t._id} style={{display:"inline-flex",alignItems:"center",gap:3,background:"#fff",border:"1px solid #ef4444",padding:"2px 8px",borderRadius:6,fontSize:isMob?10:9,fontWeight:700}}>
                  <span style={{color:"#212121"}}>{t.name}</span>
                  <span style={{color:"#7b1fa2"}}>{parseInt(t.people)||1}名</span>
                </span>)}
              </div>
            </div>}
            {noTimeBD.length>0&&<div style={{color:"#dc2626",fontWeight:600}}>BDB時間未登録 {noTimeBD.length}件</div>}
          </div>}
          {/* ★ 便カード */}
          <div style={{padding:"8px 12px 80px"}}>
            {filteredSlots.map((s,i)=>renderSlotCard(s,i))}
          </div>
          {/* 溢れ変換ボタン */}
          {(totalOverPU+totalOverBD)>0&&<div style={{position:"fixed",bottom:16,left:"50%",transform:"translateX(-50%)",zIndex:99}}>
            <button onClick={()=>{if(!window.confirm(`溢れ ${totalOverPU+totalOverBD}件 をHIA(PU/BD)に変換？`))return;const overIds=new Set();Object.values(puSlots).forEach(s=>s.overflow.forEach(t=>overIds.add(t._id)));Object.values(bdSlots).forEach(s=>s.overflow.forEach(t=>overIds.add(t._id)));let cnt=0;tasks.forEach(t=>{if(overIds.has(t._id)){const nt=t.type==="PUB"?"PU":"BD";const u={...t,type:nt,_changed:{...(t._changed||{}),type:true}};upd(t._id,u,t.reservationId?{fields:{[t.type==="PUB"?"visitType":"returnType"]:nt},type:"溢れHIA変換",source:"bus_view"}:undefined);cnt++;}});alert(`✅ ${cnt}件変換`);}} style={{background:"#c62828",color:"#fff",border:"none",borderRadius:24,padding:"10px 20px",fontSize:isMob?14:13,fontWeight:800,cursor:"pointer",boxShadow:"0 4px 12px rgba(0,0,0,.3)"}}>🚐 溢れ{totalOverPU+totalOverBD}件→HIA変換</button>
          </div>}
        </div>;
      })()}
      {/* ★★★ ハイエース運行表タブ ★★★ */}
      {opView==="hia"&&(()=>{
        const HIA_CAPACITY=8;
        const HIA_VEHICLES=2;
        const HIA_TOTAL=HIA_CAPACITY*HIA_VEHICLES;
        const isMob=window.innerWidth<=768;
        // ★ マスターのPU/BD = ハイエース運行表（来店/店舗等は除く）
        const isHiaTarget=(t)=>(t.type==="PU"||t.type==="BD")&&isBusRequired(t);
        const puTasks=sortedTasks.filter(t=>t.type==="PU"&&isBusRequired(t)).sort((a,b)=>(a.time||"99:99").localeCompare(b.time||"99:99"));
        const bdTasks=sortedTasks.filter(t=>t.type==="BD"&&isBusRequired(t)).sort((a,b)=>(a.time||"99:99").localeCompare(b.time||"99:99"));
        const totalPU_hia=puTasks.reduce((s,t)=>s+(parseInt(t.people)||1),0);
        const totalBD_hia=bdTasks.reduce((s,t)=>s+(parseInt(t.people)||1),0);
        // Build hourly slots same as bus
        const hiaPuSlots={};
        BUS_PU_HOURS.forEach(h=>{hiaPuSlots[h]={tasks:[],count:0};});
        puTasks.forEach(t=>{
          const time=t.timeChange||t.time||"";
          if(!time)return;
          const[hh,mm]=time.split(":").map(Number);
          let targetHour=Math.ceil((hh*60+mm+30)/60);
          if(targetHour<BUS_PU_HOURS[0])targetHour=BUS_PU_HOURS[0];
          if(targetHour>BUS_PU_HOURS[BUS_PU_HOURS.length-1])targetHour=BUS_PU_HOURS[BUS_PU_HOURS.length-1];
          hiaPuSlots[targetHour].tasks.push(t);
          hiaPuSlots[targetHour].count+=parseInt(t.people)||1;
        });
        const hiaBdSlots={};
        BUS_BD_HOURS.forEach(h=>{hiaBdSlots[h]={tasks:[],count:0};});
        bdTasks.forEach(t=>{
          const time=t.timeChange||t.time||"";
          if(!time)return;
          const[hh,mm]=time.split(":").map(Number);
          let targetHour=hh;
          if(mm>30)targetHour=hh+1;
          if(targetHour<BUS_BD_HOURS[0])targetHour=BUS_BD_HOURS[0];
          if(targetHour>BUS_BD_HOURS[BUS_BD_HOURS.length-1])targetHour=BUS_BD_HOURS[BUS_BD_HOURS.length-1];
          hiaBdSlots[targetHour].tasks.push(t);
          hiaBdSlots[targetHour].count+=parseInt(t.people)||1;
        });
        const noTimePU=puTasks.filter(t=>!t.time);
        const noTimeBD_hia=bdTasks.filter(t=>!t.time);
        const wasConverted=(t)=>!!(t._changed&&t._changed.type);
        const renderHiaChip=(t,color)=>{
          const ppl=parseInt(t.people)||1;
          const converted=wasConverted(t);
          return <div key={t._id} onClick={()=>setResDetailPopup(t)} style={{display:"inline-flex",alignItems:"center",gap:isMob?3:2,padding:isMob?"4px 8px":"2px 6px",margin:"2px 2px",borderRadius:6,background:converted?"#fffdf5":"#f8fafc",border:"1px solid "+(converted?"#e0c068":"#d1d5db"),fontSize:isMob?11:9,cursor:"pointer",boxShadow:"0 1px 2px rgba(0,0,0,.04)"}}>
            {converted&&<span style={{background:"#d4a017",color:"#fff",fontSize:isMob?7:6,fontWeight:700,padding:"0 3px",borderRadius:3}}>元バス</span>}
            <span style={{color:"#78909c",fontSize:isMob?8:7,fontWeight:600}}>{t.reservationId||""}</span>
            <span style={{fontWeight:700,color:"#37474f"}}>{t.name}</span>
            <span style={{color:"#5e35b1",fontWeight:700,fontSize:isMob?10:8}}>{ppl}</span>
            {t.flight?<span style={{color:"#1565c0",fontSize:isMob?9:7}}>✈{t.flight}</span>:<span style={{color:"#d4a017",fontSize:isMob?8:6,fontWeight:600}}>✈?</span>}
          </div>;
        };
        const hiaTrips=BUS_PU_HOURS.map((h,i)=>{
          const puSlot=hiaPuSlots[h];
          const bdSlot=BUS_BD_HOURS.includes(h)?hiaBdSlots[h]:null;
          return {hour:h,puSlot,bdSlot,tripNum:i+1};
        });
        return <div style={{padding:isMob?4:8}}>
          <div style={{background:"#1e293b",borderRadius:10,padding:isMob?"10px 12px":"12px 16px",marginBottom:8,color:"#f1f5f9"}}>
            <div style={{fontWeight:900,fontSize:isMob?16:18,marginBottom:4}}>🚐 ハイエース運行表</div>
            <div style={{fontSize:isMob?10:11,opacity:.7}}>ハイエース①(7062) + ②(1713) ・ 各{HIA_CAPACITY}名 ・ 合計{HIA_TOTAL}名/便</div>
            <div style={{display:"flex",gap:6,marginTop:6,fontSize:isMob?10:11,fontWeight:700,flexWrap:"wrap"}}>
              <span style={{background:"rgba(255,255,255,.2)",padding:"2px 8px",borderRadius:6}}>✈PU {totalPU_hia}名</span>
              <span style={{background:"rgba(255,255,255,.2)",padding:"2px 8px",borderRadius:6}}>🏢BD {totalBD_hia}名</span>
              <span style={{background:"rgba(255,255,255,.2)",padding:"2px 8px",borderRadius:6}}>定員{HIA_TOTAL}名/便(×2台)</span>
            </div>
          </div>
          {(puTasks.length===0&&bdTasks.length===0)&&<div style={{textAlign:"center",padding:20,color:"#94a3b8",fontSize:13}}>ハイエース運行タスクなし（バス定員超過で溢れた予約がここに表示されます）</div>}
          {(noTimePU.length>0||noTimeBD_hia.length>0)&&<div style={{background:"#fef3c7",borderRadius:10,padding:isMob?"8px 10px":"6px 10px",marginBottom:8,border:"2px solid #f59e0b"}}>
            <div style={{fontWeight:800,fontSize:isMob?12:10,color:"#92400e",marginBottom:4}}>⚠ 時間未設定タスク</div>
            {noTimePU.length>0&&<div style={{marginBottom:4}}>
              <span style={{fontSize:isMob?10:9,fontWeight:700,color:"#059669"}}>PU ({noTimePU.length}件):</span>
              <div style={{display:"flex",flexWrap:"wrap",gap:3,marginTop:2}}>{noTimePU.map(t=>renderHiaChip(t,"#059669"))}</div>
            </div>}
            {noTimeBD_hia.length>0&&<div>
              <span style={{fontSize:isMob?10:9,fontWeight:700,color:"#e11d48"}}>BD ({noTimeBD_hia.length}件):</span>
              <div style={{display:"flex",flexWrap:"wrap",gap:3,marginTop:2}}>{noTimeBD_hia.map(t=>renderHiaChip(t,"#e11d48"))}</div>
            </div>}
          </div>}
          {hiaTrips.map(trip=>{
            const key=String(trip.hour).padStart(2,"0");
            const pu=trip.puSlot;
            const bd=trip.bdSlot;
            const puEmpty=pu.tasks.length===0;
            const bdEmpty=!bd||bd.tasks.length===0;
            const bothEmpty=puEmpty&&bdEmpty;
            const puOver=pu.count>HIA_TOTAL;
            const bdOver=bd&&bd.count>HIA_TOTAL;
            if(bothEmpty)return null;
            return <div key={trip.hour} style={{background:"#fff",borderRadius:8,border:"1px solid #cbd5e1",marginBottom:isMob?6:5,overflow:"hidden"}}>
              <div style={{background:"#455a64",padding:isMob?"7px 10px":"5px 10px",color:"#f1f5f9",display:"flex",justifyContent:"space-between",alignItems:"center",flexWrap:"wrap",gap:4}}>
                <span style={{fontWeight:800,fontSize:isMob?14:12}}>第{trip.tripNum}便 🚐 HIA①②</span>
              </div>
              {!puEmpty&&<div style={{padding:isMob?"6px 10px":"4px 10px",background:puOver?"#fef2f2":"#f8fdfb",borderBottom:"1px solid #f1f5f9"}}>
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:3}}>
                  <span style={{fontWeight:800,fontSize:isMob?12:10,color:"#2d6a4f"}}>✈️ PU 空港発 {key}:00</span>
                  <span style={{fontSize:isMob?10:9,fontWeight:700,color:puOver?"#c0392b":"#2d6a4f",background:puOver?"#fdecea":"#e8f5e9",padding:"1px 6px",borderRadius:4}}>{pu.count}/{HIA_TOTAL}名</span>
                </div>
                <div style={{display:"flex",flexWrap:"wrap"}}>{pu.tasks.map(t=>renderHiaChip(t,"#059669"))}</div>
              </div>}
              {bd&&!bdEmpty&&<div style={{padding:isMob?"6px 10px":"4px 10px",background:bdOver?"#fef2f2":"#fdf8f8",borderBottom:"1px solid #f1f5f9"}}>
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:3}}>
                  <span style={{fontWeight:800,fontSize:isMob?12:10,color:"#8b3a3a"}}>🏢 BD ヤード発 {key}:30</span>
                  <span style={{fontSize:isMob?10:9,fontWeight:700,color:bdOver?"#c0392b":"#8b3a3a",background:bdOver?"#fdecea":"#fce4ec",padding:"1px 6px",borderRadius:4}}>{bd.count}/{HIA_TOTAL}名</span>
                </div>
                <div style={{display:"flex",flexWrap:"wrap"}}>{bd.tasks.map(t=>renderHiaChip(t,"#e11d48"))}</div>
              </div>}
            </div>;
          })}
          <div style={{background:"#f1f5f9",borderRadius:8,padding:"8px 12px",textAlign:"center",fontWeight:700,fontSize:isMob?12:11,color:"#546e7a"}}>
            合計: ✈PU {totalPU_hia}名 + 🏢BD {totalBD_hia}名 = {totalPU_hia+totalBD_hia}名
          </div>
        </div>;
      })()}
      {/* ★★★ DEL/COLタスクタブ（読取専用） ★★★ */}
      {opView==="tasks"&&(()=>{
        const isMob=window.innerWidth<=768;
        const dcTasks=sortedTasks.filter(t=>t.type==="DEL"||t.type==="COL");
        const delList=dcTasks.filter(t=>t.type==="DEL").sort((a,b)=>(a.time||"99:99").localeCompare(b.time||"99:99"));
        const colList=dcTasks.filter(t=>t.type==="COL").sort((a,b)=>(a.time||"99:99").localeCompare(b.time||"99:99"));
        const doneC=dcTasks.filter(t=>t.done).length;
        const renderRow=(t)=>{
          const tm2=TASK_META[t.type]||TASK_META["その他"];
          const pl=(t.type==="DEL"&&t.place&&t.place!=="DEL")?t.place:(t.type==="COL"&&t.colPlace)?t.colPlace:(t.type==="COL"&&t.place&&t.place!=="COL")?t.place:"";
          const hasOpts=!!(t.opts&&(t.opts.b||t.opts.c||t.opts.j||t.opts.usb));
          return <div key={t._id} onClick={()=>setResDetailPopup(t)} style={{padding:isMob?"8px 10px":"4px 8px",borderBottom:"1px solid #f1f5f9",opacity:t.done?.5:1,cursor:"pointer"}}>
            {/* 1行目: 時間 + 名前 + 人数 + 担当 */}
            <div style={{display:"flex",alignItems:"center",gap:6,fontSize:isMob?13:11}}>
              <span style={{fontWeight:700,fontSize:isMob?10:8,background:tm2.bg,color:tm2.c,padding:"1px 5px",borderRadius:3,flexShrink:0}}>{t.type}</span>
              <span style={{fontWeight:800,flexShrink:0}}>{t.time||"--:--"}</span>
              <span style={{fontWeight:700,flex:1,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{t.name||""}</span>
              <span style={{color:"#7c3aed",fontWeight:800,fontSize:isMob?11:9,flexShrink:0}}>{t.people||""}名</span>
              <span style={{color:t.assignee?"#7c3aed":"#d4d4d4",fontWeight:t.assignee?700:400,fontSize:isMob?11:9,flexShrink:0}}>{t.assignee||"未割当"}</span>
            </div>
            {/* 2行目: 予約番号 + 車両 + 場所 + オプション */}
            <div style={{display:"flex",alignItems:"center",gap:4,marginTop:2,fontSize:isMob?10:8,flexWrap:"wrap"}}>
              <span style={{color:"#94a3b8",fontWeight:600}}>{t.reservationId||""}</span>
              {t.plateNo&&<span style={{background:"#eff6ff",color:"#1e40af",padding:"1px 4px",borderRadius:3,fontWeight:700}}>{t.plateNo}</span>}
              {t.vehicle&&<span style={{color:"#64748b"}}>{t.vehicle}</span>}
              {pl&&<span style={{color:"#ea580c",fontWeight:600}}>📍{pl}</span>}
              {hasOpts&&<span style={{display:"inline-flex",gap:2}}>
                {t.opts.b>0&&<span style={{background:"#fef3c7",color:"#92400e",padding:"1px 3px",borderRadius:3,fontWeight:700}}>👶{t.opts.b}</span>}
                {t.opts.c>0&&<span style={{background:"#dbeafe",color:"#1e40af",padding:"1px 3px",borderRadius:3,fontWeight:700}}>🧒{t.opts.c}</span>}
                {t.opts.j>0&&<span style={{background:"#e0e7ff",color:"#4338ca",padding:"1px 3px",borderRadius:3,fontWeight:700}}>J{t.opts.j}</span>}
                {t.opts.usb>0&&<span style={{background:"#dcfce7",color:"#166534",padding:"1px 3px",borderRadius:3,fontWeight:700}}>🔌{t.opts.usb}</span>}
              </span>}
            </div>
          </div>;
        };
        return <div style={{padding:isMob?4:8}}>
          <div style={{background:"linear-gradient(135deg,#2563eb,#3b82f6)",borderRadius:10,padding:isMob?"8px 12px":"10px 16px",marginBottom:8,color:"#fff",display:"flex",justifyContent:"space-between",alignItems:"center",flexWrap:"wrap",gap:4}}>
            <span style={{fontWeight:900,fontSize:isMob?14:16}}>🚗 DEL/COL（読取専用）</span>
            <div style={{display:"flex",gap:6,fontSize:isMob?10:11,fontWeight:700,flexWrap:"wrap"}}>
              <span style={{background:"rgba(255,255,255,.2)",padding:"2px 8px",borderRadius:6}}>DEL {delList.length}</span>
              <span style={{background:"rgba(255,255,255,.2)",padding:"2px 8px",borderRadius:6}}>COL {colList.length}</span>
              <span style={{background:"rgba(255,255,255,.25)",padding:"2px 8px",borderRadius:6}}>✅{doneC}/{dcTasks.length}</span>
            </div>
          </div>
          {delList.length>0&&<div style={{background:"#fff",borderRadius:10,border:"1px solid #bfdbfe",marginBottom:8,overflow:"hidden"}}>
            <div style={{background:"#eff6ff",padding:"6px 12px",borderBottom:"1px solid #bfdbfe",fontWeight:800,fontSize:isMob?12:11,color:"#2563eb"}}>🚗 DEL 配送 ({delList.length}件)</div>
            {delList.map(renderRow)}
          </div>}
          {colList.length>0&&<div style={{background:"#fff",borderRadius:10,border:"1px solid #fed7aa",marginBottom:8,overflow:"hidden"}}>
            <div style={{background:"#fff7ed",padding:"6px 12px",borderBottom:"1px solid #fed7aa",fontWeight:800,fontSize:isMob?12:11,color:"#ea580c"}}>🚛 COL 回収 ({colList.length}件)</div>
            {colList.map(renderRow)}
          </div>}
          {dcTasks.length===0&&<div style={{textAlign:"center",padding:20,color:"#94a3b8",fontSize:13}}>DEL/COLタスクなし</div>}
        </div>;
      })()}
      {/* ★★★ (削除済み: ヤード出発タブ → バス運行表に統合) ★★★ */}
      {opView==="__removed_yard__"&&(()=>{
        const BUS_VEHICLES=[{no:"7062",name:"ハイエース①"},{no:"1713",name:"ハイエース②"},{no:"2515",name:"コースター"}];
        const HIA_CAPACITY=8;
        const isMob=window.innerWidth<=768;
        // ★ BDB自動振り分け: 便名＋30分バッファ→ヤード出発便
        const bdBusTasks=sortedTasks.filter(t=>t.type==="BDB");
        const bdSlots={};
        const noFlightTasksBD=[]; // ★ 便名なし→要確認
        BUS_BD_HOURS.forEach(h=>{bdSlots[h]={pub:[],pubCount:0,pubOverflow:[],hia:[],hiaCount:0};});
        bdBusTasks.forEach(t=>{
          // ★ BD(ヤード出発)は返却なので便名は必須ではないが、時間で振り分け
          const time=t.timeChange||t.time||"";
          if(!time){noFlightTasksBD.push(t);return;}
          const[hh,mm]=time.split(":").map(Number);
          // ★ BD:ヤード出発なので時間から最寄りの:30発を計算
          let targetHour=hh;
          if(mm>30)targetHour=hh+1;
          if(targetHour<BUS_BD_HOURS[0])targetHour=BUS_BD_HOURS[0];
          if(targetHour>BUS_BD_HOURS[BUS_BD_HOURS.length-1])targetHour=BUS_BD_HOURS[BUS_BD_HOURS.length-1];
          const ppl=parseInt(t.people)||1;
          if(bdSlots[targetHour].pubCount+ppl<=BUS_CAPACITY){
            bdSlots[targetHour].pub.push(t);
            bdSlots[targetHour].pubCount+=ppl;
          }else{
            bdSlots[targetHour].pubOverflow.push(t);
          }
        });
        const totalBD=Object.values(bdSlots).reduce((s,v)=>s+v.pubCount,0);
        const totalOverflow=Object.values(bdSlots).reduce((s,v)=>s+v.pubOverflow.length,0);
        const renderDriverSel=(hk,role)=>{
          const val=(busDrivers[hk]||{})[role]||"";
          return <select value={val} onChange={e=>setBusDrivers(p=>({...p,[hk]:{...(p[hk]||{}),[role]:e.target.value}}))} style={{border:"1px solid #e2e8f0",borderRadius:4,background:"#fff",fontSize:isMob?11:9,padding:isMob?"4px 6px":"1px 3px",color:val?"#1e293b":"#94a3b8",fontWeight:val?700:400,minWidth:isMob?80:50}}>
            <option value="">{role==="driver"?"🚌運転手":"👤補助"}</option>
            {activeMembers.map(m=><option key={m}>{m}</option>)}
          </select>;
        };
        const renderTaskChip=(t)=>{
          const ppl=parseInt(t.people)||1;
          return <div key={t._id} onClick={()=>setResDetailPopup(t)} style={{display:"inline-flex",alignItems:"center",gap:isMob?4:2,padding:isMob?"4px 8px":"2px 6px",margin:isMob?"2px 0":"1px 2px",borderRadius:6,background:t.done?"#f1f5f9":"#fff",border:"1px solid "+(t.done?"#e2e8f0":"#cbd5e1"),opacity:t.done?0.5:1,fontSize:isMob?11:9,cursor:"pointer"}}>
            <span style={{color:"#dc2626",fontSize:isMob?9:7,fontWeight:600}}>{t.reservationId||""}</span>
            <span style={{fontWeight:700,color:"#1e293b"}}>{t.name}</span>
            <span style={{color:"#7c3aed",fontWeight:800,fontSize:isMob?10:8}}>{ppl}</span>
            {t.flight&&<span style={{color:"#2563eb",fontSize:isMob?9:7}}>✈{t.flight}</span>}
          </div>;
        };
        return <div style={{padding:isMob?4:8}}>
          <div style={{borderRadius:10,overflow:"hidden",border:"2px solid #dc2626"}}>
            <div style={{background:"linear-gradient(135deg,#dc2626,#ef4444)",padding:isMob?"10px 12px":"12px 16px",color:"#fff"}}>
              <div style={{fontWeight:900,fontSize:isMob?15:17,marginBottom:2}}>🏢 ヤード出発便 (BDB)</div>
              <div style={{fontSize:isMob?10:11,opacity:.85}}>始発 9:30 ／ 1時間おき ／ 最終 18:30 ・ 返却時間→最寄りのバス便に自動振分</div>
              <div style={{fontSize:isMob?9:10,opacity:.75,marginTop:2}}>※ バスは空港⇔ヤードを往復運行（空港出発タブと車両共有）</div>
              <div style={{display:"flex",gap:8,marginTop:4,fontSize:isMob?10:11,fontWeight:700,flexWrap:"wrap"}}>
                <span style={{background:"rgba(255,255,255,.2)",padding:"2px 8px",borderRadius:6}}>BDB合計 {totalBD}名</span>
                <span style={{background:"rgba(255,255,255,.2)",padding:"2px 8px",borderRadius:6}}>BDB定員{BUS_CAPACITY}名/便</span>
                <span style={{background:"rgba(255,255,255,.2)",padding:"2px 8px",borderRadius:6}}>HIA定員{HIA_CAPACITY}名/便</span>
                {totalOverflow>0&&<span style={{background:"rgba(255,100,100,.3)",padding:"2px 8px",borderRadius:6}}>⚠溢れ{totalOverflow}件</span>}
                {noFlightTasksBD.length>0&&<span style={{background:"rgba(255,200,0,.4)",padding:"2px 8px",borderRadius:6}}>⚠時間なし{noFlightTasksBD.length}件</span>}
              </div>
            </div>
            {/* ★ 時間なし要確認アラート */}
            {noFlightTasksBD.length>0&&<div style={{background:"#fef3c7",padding:isMob?"8px 10px":"6px 10px",borderBottom:"2px solid #f59e0b"}}>
              <div style={{fontWeight:800,fontSize:isMob?12:10,color:"#92400e",marginBottom:4}}>⚠ 要確認: 時間未登録 ({noFlightTasksBD.length}件) — マスターで時間を入力してください</div>
              <div style={{display:"flex",flexWrap:"wrap",gap:4}}>
                {noFlightTasksBD.map(t=><div key={t._id} onClick={()=>setResDetailPopup(t)} style={{display:"inline-flex",alignItems:"center",gap:3,padding:"2px 6px",borderRadius:4,background:"#fff",border:"1px solid #f59e0b",fontSize:isMob?10:9,cursor:"pointer"}}>
                  <span style={{fontWeight:700}}>{t.name}</span>
                  <span style={{color:"#7c3aed",fontWeight:800,fontSize:8}}>{parseInt(t.people)||1}名</span>
                  <span style={{color:"#dc2626",fontWeight:800,fontSize:8}}>時間なし</span>
                </div>)}
              </div>
            </div>}
            {BUS_BD_HOURS.map(h=>{
              const slot=bdSlots[h];
              const key=String(h).padStart(2,"0");
              const pubOver=slot.pubCount>BUS_CAPACITY;
              const isPubEmpty=slot.pub.length===0;
              const isHiaEmpty=slot.hia.length===0;
              return <div key={h} style={{borderBottom:"1px solid #fecaca"}}>
                {/* PUB (Bus) slot */}
                <div style={{padding:isMob?"6px 10px":"4px 10px",background:isPubEmpty?"#f3f4f6":(pubOver?"#fef2f2":"#fff5f5"),minHeight:isMob?36:32,opacity:isPubEmpty?0.6:1}}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:isPubEmpty?0:3}}>
                    <div style={{display:"flex",gap:isMob?6:4,alignItems:"center",flexWrap:"wrap"}}>
                      <span style={{fontWeight:900,fontSize:isMob?14:12,color:isPubEmpty?"#9ca3af":"#dc2626"}}>{key}:30発</span>
                      <span style={{fontSize:isMob?10:8,fontWeight:700,color:"#dc2626",background:"#fee2e2",padding:"1px 6px",borderRadius:4}}>BDB コースター(2515)</span>
                      {renderDriverSel(key+"_bd","driver")}{renderDriverSel(key+"_bd","assistant")}
                    </div>
                    <span style={{fontSize:isMob?11:10,fontWeight:800,color:isPubEmpty?"#9ca3af":(pubOver?"#dc2626":"#e11d48"),padding:"1px 6px",borderRadius:4,background:isPubEmpty?"#e5e7eb":(pubOver?"#fee2e2":"#ffe4e6")}}>{slot.pubCount}/{BUS_CAPACITY}名</span>
                  </div>
                  {slot.pub.length>0&&<div style={{display:"flex",flexWrap:"wrap"}}>{slot.pub.map(renderTaskChip)}</div>}
                  {slot.pubOverflow.length>0&&<div style={{marginTop:2}}><div style={{fontSize:isMob?10:8,fontWeight:800,color:"#dc2626"}}>⚠ 定員超過 - 未割当:</div><div style={{display:"flex",flexWrap:"wrap"}}>{slot.pubOverflow.map(renderTaskChip)}</div></div>}
                  {pubOver&&<div style={{fontSize:isMob?10:8,fontWeight:800,color:"#dc2626",marginTop:1}}>⚠ 定員超過!</div>}
                </div>
                {/* HIA (HiAce) slot */}
                <div style={{padding:isMob?"4px 10px":"3px 10px",background:isHiaEmpty?"#fafafa":"#fffbeb",borderTop:"1px dashed #e2e8f0",minHeight:isMob?28:24,opacity:isHiaEmpty?0.5:1}}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                    <div style={{display:"flex",gap:4,alignItems:"center"}}>
                      <span style={{fontSize:isMob?10:8,fontWeight:700,color:"#b45309",background:"#fef3c7",padding:"1px 6px",borderRadius:4}}>HIA ハイエース①/②</span>
                    </div>
                    <span style={{fontSize:isMob?10:8,fontWeight:700,color:isHiaEmpty?"#d4d4d4":"#b45309"}}>{slot.hiaCount}/{HIA_CAPACITY}名</span>
                  </div>
                  {slot.hia.length>0&&<div style={{display:"flex",flexWrap:"wrap",marginTop:2}}>{slot.hia.map(renderTaskChip)}</div>}
                  {isHiaEmpty&&<div style={{fontSize:isMob?9:7,color:"#d4d4d4",fontStyle:"italic"}}>手動割当のみ</div>}
                </div>
              </div>;
            })}
            <div style={{background:"#fff5f5",padding:"8px 12px",borderTop:"2px solid #dc2626",fontWeight:800,fontSize:isMob?13:12,color:"#dc2626",textAlign:"center"}}>
              ヤード出発 BDB合計: {totalBD}名 {totalOverflow>0&&`(溢れ${totalOverflow}件)`}
            </div>
          </div>
        </div>;
      })()}
      {/* ★ 旧dash（削除済み - 個別タブに分離） */}
      {(opView==="__removed_dash__")&&(()=>{
        const busSlots=computeBusSlots(sortedTasks);
        const nonBusTasks=sortedTasks.filter(t=>!isBusRequired(t));
        const delColTasks=sortedTasks.filter(t=>t.type==="DEL"||t.type==="COL");
        const washTasks=sortedTasks.filter(t=>t.type==="洗車");
        const otherTasks=sortedTasks.filter(t=>!["PUB","BDB","PU","BD","DEL","COL","洗車"].includes(t.type));
        const isMob=window.innerWidth<=768;
        // ★ チップ操作メニュー（stateはOPScreen上位で定義）
        const changeTaskType=(taskId,newType,newPlace)=>{
          const idx=tasks.findIndex(x=>x._id===taskId);
          if(idx<0)return;
          const u={...tasks[idx],type:newType};
          if(newPlace!==undefined)u.place=newPlace;
          // _changed追跡
          const ch=u._changed?{...u._changed}:{};
          ch.type=true;if(newPlace!==undefined)ch.place=true;
          u._changed=ch;
          upd(idx,u);
          setChipMenu(null);
        };
        const moveTaskTime=(taskId,newTime)=>{
          const idx=tasks.findIndex(x=>x._id===taskId);
          if(idx<0)return;
          const u={...tasks[idx],time:newTime};
          const ch=u._changed?{...u._changed}:{};ch.time=true;u._changed=ch;
          upd(idx,u);
          setChipMenu(null);
        };
        return <div style={{padding:isMob?4:8,position:"relative"}}>
          {/* チップ操作メニュー */}
          {chipMenu&&(()=>{
            const t=tasks.find(x=>x._id===chipMenu.taskId);
            if(!t)return null;
            const isPU=t.type==="PU"||t.type==="PUB";const isBD=t.type==="BD"||t.type==="BDB";
            const isPUB=t.type==="PUB";const isBDB=t.type==="BDB";
            const isDEL=t.type==="DEL";const isCOL=t.type==="COL";
            const btnS={display:"block",width:"100%",padding:"8px 12px",border:"none",borderRadius:6,fontSize:11,fontWeight:700,cursor:"pointer",textAlign:"left",marginBottom:4};
            return <div style={{position:"fixed",inset:0,zIndex:9999}} onClick={()=>setChipMenu(null)}>
              <div onClick={e=>e.stopPropagation()} style={{position:"absolute",left:Math.min(chipMenu.x,window.innerWidth-220),top:Math.min(chipMenu.y,window.innerHeight-300),width:200,background:"#fff",borderRadius:12,boxShadow:"0 8px 32px rgba(0,0,0,.2)",padding:8,zIndex:10000}}>
                <div style={{fontSize:12,fontWeight:900,color:"#1e293b",marginBottom:6,padding:"0 4px"}}>{t.name} ({t.people||1}名)</div>
                <div style={{fontSize:9,color:"#64748b",marginBottom:8,padding:"0 4px"}}>{t.type} / {t.time||"未設定"} / {t.place||"未設定"}</div>
                {/* 種別変更 */}
                {isPUB&&<button onClick={()=>changeTaskType(t._id,"PU","")} style={{...btnS,background:"#ecfdf5",color:"#059669"}}>🚐 PU(HIA)に変更</button>}
                {isBDB&&<button onClick={()=>changeTaskType(t._id,"BD","")} style={{...btnS,background:"#fff1f2",color:"#e11d48"}}>🚐 BD(HIA)に変更</button>}
                {(t.type==="PU"||isDEL)&&<button onClick={()=>changeTaskType(t._id,t.type==="PU"?"DEL":"PU",t.type==="PU"?"DEL":"")} style={{...btnS,background:t.type==="PU"?"#eff6ff":"#ecfdf5",color:t.type==="PU"?"#2563eb":"#059669"}}>{t.type==="PU"?"🚗 DELに変更（スタッフ配送）":"🚐 PU(HIA)に変更"}</button>}
                {(t.type==="BD"||isCOL)&&<button onClick={()=>changeTaskType(t._id,t.type==="BD"?"COL":"BD",t.type==="BD"?"COL":"")} style={{...btnS,background:t.type==="BD"?"#fff7ed":"#fff1f2",color:t.type==="BD"?"#ea580c":"#e11d48"}}>{t.type==="BD"?"🚗 COLに変更（スタッフ回収）":"🚐 BD(HIA)に変更"}</button>}
                {t.type==="PU"&&<button onClick={()=>changeTaskType(t._id,"PUB","")} style={{...btnS,background:"#d1fae5",color:"#047857"}}>🚌 PUB(バス)に変更</button>}
                {t.type==="BD"&&<button onClick={()=>changeTaskType(t._id,"BDB","")} style={{...btnS,background:"#ffe4e6",color:"#be123c"}}>🚌 BDB(バス)に変更</button>}
                {/* 便移動 */}
                {(isPU||isBD)&&<>
                  <div style={{fontSize:9,fontWeight:700,color:"#64748b",padding:"4px 4px 2px",marginTop:4}}>便を変更:</div>
                  <div style={{display:"flex",flexWrap:"wrap",gap:3}}>
                    {BUS_PU_HOURS.map(bh=>{
                      const newTime=String(bh).padStart(2,"0")+":"+(isPU?"00":"30");
                      const isCurrent=t.time===newTime;
                      return <button key={bh} onClick={()=>moveTaskTime(t._id,newTime)} disabled={isCurrent} style={{padding:"4px 8px",borderRadius:4,fontSize:10,fontWeight:isCurrent?800:500,background:isCurrent?"#1e40af":"#f1f5f9",color:isCurrent?"#fff":"#374151",border:"none",cursor:isCurrent?"default":"pointer",opacity:isCurrent?0.6:1}}>{bh}:00</button>;
                    })}
                  </div>
                </>}
                <button onClick={()=>setChipMenu(null)} style={{...btnS,background:"#f1f5f9",color:"#64748b",marginTop:6,textAlign:"center"}}>閉じる</button>
              </div>
            </div>;
          })()}
          {/* バス便タイムライン */}
          <div style={{background:"#fff",borderRadius:12,border:"2px solid #2563eb",overflow:"hidden",marginBottom:12}}>
            <div style={{background:"linear-gradient(135deg,#1e40af,#2563eb)",padding:"8px 12px",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
              <span style={{color:"#fff",fontWeight:900,fontSize:14}}>🚌 マイクロバス運行表</span>
              <span style={{color:"#dbeafe",fontSize:10}}>定員{BUS_CAPACITY}名 / {BUS_PU_HOURS.length}便</span>
            </div>
            {/* ヘッダー */}
            {!isMob&&<div style={{display:"grid",gridTemplateColumns:"60px 1fr 1fr",background:"#f1f5f9",borderBottom:"2px solid #cbd5e1"}}>
              <div style={{padding:"6px 8px",fontWeight:800,fontSize:10,color:"#475569",textAlign:"center"}}>時刻</div>
              <div style={{padding:"6px 8px",fontWeight:800,fontSize:10,color:"#059669",borderLeft:"1px solid #e2e8f0"}}>PU 空港発→ヤード</div>
              <div style={{padding:"6px 8px",fontWeight:800,fontSize:10,color:"#e11d48",borderLeft:"1px solid #e2e8f0"}}>BD ヤード発→空港</div>
            </div>}
            {/* 各便 */}
            {BUS_PU_HOURS.map(h=>{
              const key=String(h).padStart(2,"0");
              const slot=busSlots[key];
              const puOver=slot.puCount>BUS_CAPACITY;
              const bdOver=slot.bdCount>BUS_CAPACITY;
              const puBg=puOver?"#fef2f2":slot.puCount>16?"#fff7ed":slot.puCount>12?"#fefce8":"#f0fdf4";
              const bdBg=bdOver?"#fef2f2":slot.bdCount>16?"#fff7ed":slot.bdCount>12?"#fefce8":"#fff1f2";
              const renderChip=(t,idx)=>{
                const ppl=parseInt(t.people)||1;
                const done=t.done;
                return <div key={idx} onClick={(e)=>{e.stopPropagation();setChipMenu({taskId:t._id,x:e.clientX,y:e.clientY});}} style={{display:"inline-flex",alignItems:"center",gap:4,padding:"3px 8px",margin:2,borderRadius:6,background:done?"#f1f5f9":"#fff",border:"1px solid "+(done?"#e2e8f0":"#cbd5e1"),opacity:done?0.5:1,fontSize:10,cursor:"pointer",transition:"box-shadow .15s"}}>
                  <span style={{cursor:"pointer",fontSize:13}} onClick={(e)=>{e.stopPropagation();const idx2=tasks.findIndex(x=>x._id===t._id);if(idx2>=0){const u={...tasks[idx2],done:!tasks[idx2].done};upd(idx2,u);}}}>{done?"✅":"⬜"}</span>
                  <span style={{fontWeight:700,color:"#1e293b"}}>{t.name}</span>
                  <span style={{color:"#64748b",fontWeight:600}}>{ppl}名</span>
                  {t.flight&&<span style={{color:"#2563eb",fontSize:8}}>✈{t.flight}</span>}
                  {t.plateNo&&<span style={{color:"#94a3b8",fontSize:8}}>{t.plateNo}</span>}
                  {t.time&&<span style={{color:"#64748b",fontSize:8}}>{t.time}</span>}
                </div>;
              };
              if(isMob){
                // モバイル: 縦積みカード
                return <details key={h} style={{borderBottom:"1px solid #e2e8f0"}} open={slot.puCount>0||slot.bdCount>0}>
                  <summary style={{padding:"8px 12px",display:"flex",justifyContent:"space-between",alignItems:"center",cursor:"pointer",listStyle:"none",background:(puOver||bdOver)?"#fef2f2":"#fff"}}>
                    <span style={{fontWeight:900,fontSize:14,color:"#1e293b"}}>{key}:00</span>
                    <div style={{display:"flex",gap:8}}>
                      <span style={{fontSize:10,fontWeight:700,color:puOver?"#dc2626":"#059669",padding:"2px 6px",borderRadius:4,background:puBg}}>PU {slot.puCount}/{BUS_CAPACITY}</span>
                      <span style={{fontSize:10,fontWeight:700,color:bdOver?"#dc2626":"#e11d48",padding:"2px 6px",borderRadius:4,background:bdBg}}>BD {slot.bdCount}/{BUS_CAPACITY}</span>
                    </div>
                  </summary>
                  <div style={{padding:"4px 12px 8px"}}>
                    {slot.pu.length>0&&<div style={{marginBottom:4}}>
                      <div style={{fontSize:9,fontWeight:700,color:"#059669",marginBottom:2}}>PU 空港発→ヤード ({key}:00発)</div>
                      <div style={{display:"flex",flexWrap:"wrap"}}>{slot.pu.map(renderChip)}</div>
                      {puOver&&<div style={{fontSize:10,fontWeight:800,color:"#dc2626",marginTop:2}}>⚠ 定員超過! ({slot.puCount}/{BUS_CAPACITY})</div>}
                    </div>}
                    {slot.bd.length>0&&<div>
                      <div style={{fontSize:9,fontWeight:700,color:"#e11d48",marginBottom:2}}>BD ヤード発→空港 ({key}:30発)</div>
                      <div style={{display:"flex",flexWrap:"wrap"}}>{slot.bd.map(renderChip)}</div>
                      {bdOver&&<div style={{fontSize:10,fontWeight:800,color:"#dc2626",marginTop:2}}>⚠ 定員超過! ({slot.bdCount}/{BUS_CAPACITY})</div>}
                    </div>}
                    {slot.pu.length===0&&slot.bd.length===0&&<div style={{fontSize:10,color:"#94a3b8",padding:4}}>この便の予約なし</div>}
                  </div>
                </details>;
              }
              // PC: グリッド表示
              return <div key={h} style={{display:"grid",gridTemplateColumns:"60px 1fr 1fr",borderBottom:"1px solid #e2e8f0",minHeight:40}}>
                <div style={{padding:"6px 4px",fontWeight:900,fontSize:13,color:"#1e293b",textAlign:"center",borderRight:"1px solid #e2e8f0",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center"}}>
                  <div>{key}:00</div>
                  <div style={{fontSize:8,color:"#94a3b8"}}>{key}:30</div>
                </div>
                <div style={{padding:"4px 6px",background:puBg,borderRight:"1px solid #e2e8f0"}}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:2}}>
                    <span style={{fontSize:9,fontWeight:700,color:"#059669"}}>{key}:00発</span>
                    <span style={{fontSize:10,fontWeight:800,color:puOver?"#dc2626":"#059669",padding:"1px 6px",borderRadius:4,background:puOver?"#fee2e2":"#dcfce7"}}>{slot.puCount}/{BUS_CAPACITY}</span>
                  </div>
                  <div style={{display:"flex",flexWrap:"wrap"}}>{slot.pu.map(renderChip)}</div>
                  {puOver&&<div style={{fontSize:9,fontWeight:800,color:"#dc2626",marginTop:2}}>⚠ 定員超過!</div>}
                </div>
                <div style={{padding:"4px 6px",background:bdBg}}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:2}}>
                    <span style={{fontSize:9,fontWeight:700,color:"#e11d48"}}>{key}:30発</span>
                    <span style={{fontSize:10,fontWeight:800,color:bdOver?"#dc2626":"#e11d48",padding:"1px 6px",borderRadius:4,background:bdOver?"#fee2e2":"#ffe4e6"}}>{slot.bdCount}/{BUS_CAPACITY}</span>
                  </div>
                  <div style={{display:"flex",flexWrap:"wrap"}}>{slot.bd.map(renderChip)}</div>
                  {bdOver&&<div style={{fontSize:9,fontWeight:800,color:"#dc2626",marginTop:2}}>⚠ 定員超過!</div>}
                </div>
              </div>;
            })}
            {/* バス便サマリー */}
            {(()=>{
              const totalPU=Object.values(busSlots).reduce((s,v)=>s+v.puCount,0);
              const totalBD=Object.values(busSlots).reduce((s,v)=>s+v.bdCount,0);
              const overSlots=Object.entries(busSlots).filter(([,v])=>v.puCount>BUS_CAPACITY||v.bdCount>BUS_CAPACITY);
              return <div style={{padding:"8px 12px",background:"#f8fafc",borderTop:"2px solid #cbd5e1",display:"flex",justifyContent:"space-between",alignItems:"center",flexWrap:"wrap",gap:4}}>
                <div style={{fontSize:11,fontWeight:700,color:"#475569"}}>合計: PU {totalPU}名 / BD {totalBD}名</div>
                {overSlots.length>0&&<div style={{fontSize:11,fontWeight:800,color:"#dc2626"}}>⚠ {overSlots.length}便で定員超過</div>}
              </div>;
            })()}
          </div>
          {/* ★ カテゴリ別タスクテーブル共通レンダラー */}
          {(()=>{
            const renderTaskSection=(title,icon,color,borderColor,taskList,showTypeToggle)=>{
              if(taskList.length===0)return null;
              const doneC=taskList.filter(t=>t.done).length;
              return <div style={{background:"#fff",borderRadius:12,border:"2px solid "+borderColor,overflow:"hidden",marginBottom:12}}>
                <div style={{padding:"8px 12px",background:color+"10",borderBottom:"1px solid "+borderColor,display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                  <span style={{fontWeight:800,fontSize:12,color}}>{icon} {title} ({taskList.length}件)</span>
                  <span style={{fontSize:10,fontWeight:700,color:doneC===taskList.length?"#22c55e":"#64748b"}}>完了 {doneC}/{taskList.length}</span>
                </div>
                <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}><thead><tr style={{background:"#f8fafc"}}>
                  {["✓","担当","時間","内容","予約者","人数","車種","No.","場所","メモ",showTypeToggle?"変更":""].filter(Boolean).map((h,i)=><th key={i} style={{padding:"4px 6px",textAlign:"left",fontWeight:600,fontSize:9,color:"#475569",borderBottom:"1px solid #e2e8f0"}}>{h}</th>)}
                </tr></thead><tbody>
                  {taskList.map((t,i)=>{
                    const tm2=TASK_META[t.type]||TASK_META["その他"];
                    return <tr key={t._id||i} style={{borderBottom:"1px solid #f1f5f9",opacity:t.done?0.5:1}}>
                      <td style={{padding:"4px 6px",textAlign:"center"}}><span style={{cursor:"pointer",fontSize:13}} onClick={()=>{const idx2=tasks.findIndex(x=>x._id===t._id);if(idx2>=0){const u={...tasks[idx2],done:!tasks[idx2].done};upd(idx2,u);}}}>{t.done?"✅":"⬜"}</span></td>
                      <td style={{padding:"4px 6px",fontSize:10,fontWeight:600}}>{t.assignee||"-"}</td>
                      <td style={{padding:"4px 6px",fontWeight:700}}>{t.time||"--:--"}</td>
                      <td style={{padding:"4px 6px"}}><span style={{padding:"1px 6px",borderRadius:4,fontSize:9,fontWeight:700,background:tm2.bg,color:tm2.c}}>{t.type}</span></td>
                      <td style={{padding:"4px 6px",fontWeight:600}}>{t.name||""}</td>
                      <td style={{padding:"4px 6px",fontSize:9}}>{t.people||""}</td>
                      <td style={{padding:"4px 6px",fontSize:9}}>{t.vehicle||""}</td>
                      <td style={{padding:"4px 6px",fontSize:9,color:"#64748b"}}>{t.plateNo||""}</td>
                      <td style={{padding:"4px 6px",fontSize:9,color:"#f59e0b"}}>{t.place||""}</td>
                      <td style={{padding:"4px 6px",fontSize:9,color:"#94a3b8"}}>{t.memo||""}</td>
                      {showTypeToggle&&<td style={{padding:"4px 3px"}}>
                        {t.type==="DEL"&&<button onClick={()=>changeTaskType(t._id,"PU","")} style={{padding:"2px 6px",borderRadius:4,fontSize:8,fontWeight:700,background:"#ecfdf5",color:"#059669",border:"none",cursor:"pointer"}}>→PU</button>}
                        {t.type==="COL"&&<button onClick={()=>changeTaskType(t._id,"BD","")} style={{padding:"2px 6px",borderRadius:4,fontSize:8,fontWeight:700,background:"#fff1f2",color:"#e11d48",border:"none",cursor:"pointer"}}>→BD</button>}
                        {t.type==="PU"&&<button onClick={()=>changeTaskType(t._id,"DEL","DEL")} style={{padding:"2px 6px",borderRadius:4,fontSize:8,fontWeight:700,background:"#eff6ff",color:"#2563eb",border:"none",cursor:"pointer"}}>→DEL</button>}
                        {t.type==="BD"&&<button onClick={()=>changeTaskType(t._id,"COL","COL")} style={{padding:"2px 6px",borderRadius:4,fontSize:8,fontWeight:700,background:"#fff7ed",color:"#ea580c",border:"none",cursor:"pointer"}}>→COL</button>}
                      </td>}
                    </tr>;
                  })}
                </tbody></table>
              </div>;
            };
            return <>
              {renderTaskSection("DEL/COL 配送・回収","🚗","#2563eb","#bfdbfe",delColTasks,true)}
              {renderTaskSection("洗車","🧽","#64748b","#e2e8f0",washTasks,false)}
              {otherTasks.length>0&&renderTaskSection("来店・入庫・回収・その他","📋","#475569","#e2e8f0",otherTasks,true)}
            </>;
          })()}
        </div>;
      })()}
      {/* ★ DEL/COLフィルタ（統合ビューに統合済み、後方互換） */}
      {opView==="del_col_legacy"&&(()=>{
        const filtered=sortedTasks.filter(t=>t.type==="DEL"||t.type==="COL"||t.type==="PU"||t.type==="BD"||t.type==="PUB"||t.type==="BDB");
        const doneC=filtered.filter(t=>t.done).length;
        return <div style={{padding:8}}>
          <div style={{background:"#fff",borderRadius:12,border:"2px solid #bfdbfe",overflow:"hidden"}}>
            <div style={{padding:"8px 12px",background:"#eff6ff",borderBottom:"1px solid #bfdbfe",display:"flex",justifyContent:"space-between"}}>
              <span style={{fontWeight:800,fontSize:13,color:"#2563eb"}}>🚗 DEL/COL + PU/BD 全配送タスク</span>
              <span style={{fontSize:10,fontWeight:700,color:doneC===filtered.length?"#22c55e":"#64748b"}}>完了 {doneC}/{filtered.length}</span>
            </div>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}><thead><tr style={{background:"#f8fafc"}}>
              {["✓","担当","時間","内容","予約者","人数","車種","No.","場所","変更"].map((h,i)=><th key={i} style={{padding:"4px 6px",textAlign:"left",fontWeight:600,fontSize:9,color:"#475569",borderBottom:"1px solid #e2e8f0"}}>{h}</th>)}
            </tr></thead><tbody>
              {filtered.map((t,i)=>{
                const tm2=TASK_META[t.type]||TASK_META["その他"];
                const idx=tasks.findIndex(x=>x._id===t._id);
                return <tr key={t._id||i} style={{borderBottom:"1px solid #f1f5f9",opacity:t.done?0.5:1}}>
                  <td style={{padding:"4px 6px",textAlign:"center"}}><span style={{cursor:"pointer",fontSize:13}} onClick={()=>{if(idx>=0){upd(idx,{...tasks[idx],done:!tasks[idx].done});}}}>{t.done?"✅":"⬜"}</span></td>
                  <td style={{padding:"4px 6px",fontSize:10,fontWeight:600}}>{t.assignee||"-"}</td>
                  <td style={{padding:"4px 6px",fontWeight:700}}>{t.time||"--:--"}</td>
                  <td><span style={{padding:"1px 6px",borderRadius:4,fontSize:9,fontWeight:700,background:tm2.bg,color:tm2.c}}>{t.type}</span></td>
                  <td style={{padding:"4px 6px",fontWeight:600}}>{t.name||""}</td>
                  <td style={{padding:"4px 6px",fontSize:9}}>{t.people||""}</td>
                  <td style={{padding:"4px 6px",fontSize:9}}>{t.vehicle||""}</td>
                  <td style={{padding:"4px 6px",fontSize:9,color:"#64748b"}}>{t.plateNo||""}</td>
                  <td style={{padding:"4px 6px",fontSize:9,color:"#f59e0b"}}>{t.place||""}</td>
                  <td style={{padding:"4px 3px"}}>
                    {t.type==="DEL"&&<button onClick={()=>{if(idx>=0){const u={...tasks[idx],type:"PU",place:""};u._changed={...(u._changed||{}),type:true,place:true};upd(idx,u);}}} style={{padding:"2px 6px",borderRadius:4,fontSize:8,fontWeight:700,background:"#ecfdf5",color:"#059669",border:"none",cursor:"pointer"}}>→PU</button>}
                    {t.type==="PU"&&<button onClick={()=>{if(idx>=0){const u={...tasks[idx],type:"DEL",place:"DEL"};u._changed={...(u._changed||{}),type:true,place:true};upd(idx,u);}}} style={{padding:"2px 6px",borderRadius:4,fontSize:8,fontWeight:700,background:"#eff6ff",color:"#2563eb",border:"none",cursor:"pointer"}}>→DEL</button>}
                    {t.type==="COL"&&<button onClick={()=>{if(idx>=0){const u={...tasks[idx],type:"BD",place:""};u._changed={...(u._changed||{}),type:true,place:true};upd(idx,u);}}} style={{padding:"2px 6px",borderRadius:4,fontSize:8,fontWeight:700,background:"#fff1f2",color:"#e11d48",border:"none",cursor:"pointer"}}>→BD</button>}
                    {t.type==="BD"&&<button onClick={()=>{if(idx>=0){const u={...tasks[idx],type:"COL",place:"COL"};u._changed={...(u._changed||{}),type:true,place:true};upd(idx,u);}}} style={{padding:"2px 6px",borderRadius:4,fontSize:8,fontWeight:700,background:"#fff7ed",color:"#ea580c",border:"none",cursor:"pointer"}}>→COL</button>}
                  </td>
                </tr>;
              })}
            </tbody></table>
          </div>
        </div>;
      })()}
      {/* ★ 洗車フィルタ */}
      {opView==="wash"&&(()=>{
        const isMob=window.innerWidth<=768;
        const filtered=sortedTasks.filter(t=>t.type==="洗車");
        const autoWash=filtered.filter(t=>!t.manual);
        const manualWash=filtered.filter(t=>t.manual);
        const doneC=filtered.filter(t=>t.done).length;
        const getNextDayDeparture=(t)=>{
          if(!t.reservationId)return "";
          const res=reservations.find(r=>r.id===t.reservationId);
          if(res&&res.returnTime)return res.returnTime;
          const linked=sortedTasks.find(x=>x.reservationId===t.reservationId&&(x.type==="PU"||x.type==="BD"||x.type==="PUB"||x.type==="BDB"));
          return linked?linked.time||"":"";
        };
        const addWashTask=()=>{
          if(!washAddCat){alert("カテゴリを選択してください");return;}
          if(!washAddVc){alert("車両を選択してください");return;}
          const veh=vehicles.find(v=>v.code===washAddVc);
          const newId="wash_manual_"+Date.now()+"_"+Math.random().toString(36).slice(2,6);
          const newTask={_id:newId,type:"洗車",time:washAddTime||"",name:washAddCat+(veh?" "+veh.name:""),memo:washAddMemo||(veh?veh.name+(veh.no?" ("+veh.no+")":""):""),people:0,place:"",vehicle:veh?veh.type:"",assignedVehicle:washAddVc,plateNo:veh?veh.no:"",reservationId:"",ota:"",tel:"",mail:"",done:false,assignee:"",flight:"",returnDate:"",returnTime:"",returnType:"",colPlace:"",insurance:"",opts:{b:0,c:0,j:0,usb:0},yakkan:false,line:false,payment:false,manual:true,timeChange:"",typeChange:"",_changed:{}};
          setTasks(ts=>{const next=[...ts,newTask];DB._lsSave(next,selDate);return next;});
          DB.upsertTasks([...tasks,newTask],selDate);
          setWashAddCat("");setWashAddVc("");setWashAddTime("");setWashAddMemo("");
        };
        const deleteWashTask=(id)=>{
          if(!window.confirm("この洗車タスクを削除しますか？"))return;
          setTasks(ts=>{const next=ts.filter(x=>x._id!==id);DB._lsSave(next,selDate);return next;});
          DB.deleteTask(id,selDate);
        };
        const renderWashRow=(t)=>{
          const hasOpts=!!(t.opts&&(t.opts.b||t.opts.c||t.opts.j||t.opts.usb));
          const nextDep=getNextDayDeparture(t);
          const vn=t.assignedVehicle?vehicles.find(v=>v.code===t.assignedVehicle):null;
          return <div key={t._id} style={{padding:isMob?"8px 10px":"6px 10px",borderBottom:"1px solid #f1f5f9",opacity:t.done?0.5:1}}>
            <div style={{display:"flex",alignItems:"center",gap:6,fontSize:isMob?13:11}}>
              <span style={{cursor:"pointer",fontSize:isMob?16:13,flexShrink:0}} onClick={()=>{const u=mark({...t,done:!t.done},"done");upd(t._id,u);}}>{t.done?"✅":"⬜"}</span>
              <span style={{fontWeight:700,flex:1,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{t.name||""}</span>
              {t.time&&<span style={{fontSize:isMob?11:10,fontWeight:800,color:"#1e293b",fontFamily:"monospace",background:"#f1f5f9",padding:"1px 6px",borderRadius:4,flexShrink:0}}>{t.time}</span>}
              {vn&&<span style={{color:"#059669",fontSize:isMob?10:9,fontWeight:600,flexShrink:0}}>🚗{vn.name}</span>}
              {t.plateNo&&<span style={{background:"#eff6ff",color:"#1e40af",fontSize:isMob?10:8,padding:"1px 4px",borderRadius:3,fontWeight:700,flexShrink:0}}>{t.plateNo}</span>}
              {t.vehicle&&!vn&&<span style={{color:"#64748b",fontSize:isMob?10:9,flexShrink:0}}>{t.vehicle}</span>}
              {t.assignee&&<span style={{color:"#7c3aed",fontWeight:700,fontSize:isMob?10:9,flexShrink:0}}>👤{t.assignee}</span>}
            </div>
            <div style={{display:"flex",alignItems:"center",gap:4,marginTop:3,fontSize:isMob?10:8,flexWrap:"wrap"}}>
              {t.reservationId&&<span style={{color:"#94a3b8",fontWeight:600}}>{t.reservationId}</span>}
              {hasOpts&&<span style={{display:"inline-flex",gap:2}}>
                {t.opts.b>0&&<span style={{background:"#fef3c7",color:"#92400e",padding:"1px 4px",borderRadius:3,fontWeight:700}}>👶B×{t.opts.b}</span>}
                {t.opts.c>0&&<span style={{background:"#dbeafe",color:"#1e40af",padding:"1px 4px",borderRadius:3,fontWeight:700}}>🧒C×{t.opts.c}</span>}
                {t.opts.j>0&&<span style={{background:"#e0e7ff",color:"#4338ca",padding:"1px 4px",borderRadius:3,fontWeight:700}}>J×{t.opts.j}</span>}
                {t.opts.usb>0&&<span style={{background:"#dcfce7",color:"#166534",padding:"1px 4px",borderRadius:3,fontWeight:700}}>🔌USB×{t.opts.usb}</span>}
              </span>}
              {nextDep&&<span style={{color:"#ea580c",fontWeight:700}}>翌日出発 {nextDep}</span>}
              {t.memo&&<span style={{color:"#475569",fontWeight:600,background:"#fefce8",padding:"1px 4px",borderRadius:3}}>{t.memo}</span>}
              <span style={{flex:1}}></span>
              {t.manual&&<button onClick={()=>deleteWashTask(t._id)} style={{background:"#fef2f2",border:"1px solid #fecaca",borderRadius:4,fontSize:isMob?10:9,color:"#dc2626",fontWeight:700,padding:"2px 8px",cursor:"pointer",flexShrink:0}}>削除</button>}
            </div>
          </div>;
        };
        return <div style={{padding:isMob?4:8,display:"flex",flexDirection:"column",gap:8}}>
          {/* 洗車タスク追加 */}
          <div style={{background:"#fff",borderRadius:12,border:"2px solid #FFD54F",overflow:"hidden"}}>
            <div style={{padding:"8px 12px",background:"linear-gradient(135deg,#795548,#8D6E63)",color:"#fff",fontWeight:800,fontSize:13,display:"flex",alignItems:"center",gap:8}}>
              <span>🧽 洗車タスク</span>
              <span style={{fontSize:10,fontWeight:600,opacity:.7}}>完了 {doneC}/{filtered.length}</span>
            </div>
            <div style={{padding:"10px 12px",background:"#FFFDE7",borderBottom:"1px solid #FFD54F",display:"flex",flexDirection:"column",gap:8}}>
              <div style={{display:"flex",alignItems:"center",gap:6,flexWrap:"wrap"}}>
                <span style={{fontSize:11,fontWeight:800,color:"#5D4037",flexShrink:0}}>➕ 追加</span>
                <select value={washAddCat} onChange={e=>setWashAddCat(e.target.value)} style={{border:"1px solid #D7CCC8",borderRadius:6,padding:"4px 8px",fontSize:isMob?12:11,fontWeight:700,color:"#5D4037",background:"#fff",flex:"0 1 auto"}}>
                  <option value="">カテゴリ</option>
                  {["事前洗車","当日洗車","緊急洗車","引渡前洗車","返却後洗車"].map(c=><option key={c} value={c}>{c}</option>)}
                </select>
                <select value={washAddVc} onChange={e=>setWashAddVc(e.target.value)} style={{border:"1px solid #D7CCC8",borderRadius:6,padding:"4px 8px",fontSize:isMob?12:11,fontWeight:700,color:"#1e40af",background:"#fff",flex:"1 1 120px"}}>
                  <option value="">🚗 車両を選択</option>
                  {vehicles.filter(v=>v.active!==false).map(v=><option key={v.code} value={v.code}>{v.name}{v.no?" ("+v.no+")":""}</option>)}
                </select>
                <select value={washAddTime} onChange={e=>setWashAddTime(e.target.value)} style={{border:"1px solid #D7CCC8",borderRadius:6,padding:"4px 8px",fontSize:isMob?12:11,fontWeight:700,color:"#1e293b",background:"#fff",width:75,flexShrink:0}}>
                  <option value="">時間</option>
                  {TIME_OPTS.filter(o=>o).map(o=><option key={o} value={o}>{o}</option>)}
                </select>
              </div>
              <div style={{display:"flex",alignItems:"center",gap:6}}>
                <input value={washAddMemo} onChange={e=>setWashAddMemo(e.target.value)} placeholder="メモ（省略可）" style={{border:"1px solid #D7CCC8",borderRadius:6,padding:"4px 8px",fontSize:isMob?12:11,color:"#5D4037",background:"#fff",flex:1}}/>
                <button onClick={addWashTask} style={{background:washAddCat&&washAddVc?"linear-gradient(135deg,#795548,#8D6E63)":"#ccc",color:"#fff",border:"none",borderRadius:8,padding:"6px 16px",fontSize:isMob?12:11,fontWeight:800,cursor:washAddCat&&washAddVc?"pointer":"not-allowed",flexShrink:0}}>追加</button>
              </div>
            </div>
          </div>
          {/* 事前洗車（自動生成） */}
          {autoWash.length>0&&<div style={{background:"#fff",borderRadius:12,border:"1px solid #e2e8f0",overflow:"hidden"}}>
            <div style={{padding:"6px 12px",background:"#f8fafc",borderBottom:"1px solid #e2e8f0",display:"flex",alignItems:"center",gap:6}}>
              <span style={{fontWeight:800,fontSize:12,color:"#64748b"}}>📋 事前洗車（翌日出発車両）</span>
              <span style={{fontSize:10,fontWeight:600,color:"#94a3b8"}}>{autoWash.length}件</span>
            </div>
            {autoWash.map(renderWashRow)}
          </div>}
          {/* 手動追加した洗車 */}
          {manualWash.length>0&&<div style={{background:"#fff",borderRadius:12,border:"1px solid #FFD54F",overflow:"hidden"}}>
            <div style={{padding:"6px 12px",background:"#FFFDE7",borderBottom:"1px solid #FFD54F",display:"flex",alignItems:"center",gap:6}}>
              <span style={{fontWeight:800,fontSize:12,color:"#5D4037"}}>✏️ 手動追加した洗車</span>
              <span style={{fontSize:10,fontWeight:600,color:"#8D6E63"}}>{manualWash.length}件</span>
            </div>
            {manualWash.map(renderWashRow)}
          </div>}
          {filtered.length===0&&<div style={{background:"#fff",borderRadius:12,border:"1px solid #e2e8f0",padding:20,textAlign:"center",color:"#94a3b8",fontSize:12}}>洗車タスクなし — 上のボタンから追加できます</div>}
        </div>;
      })()}
      {/* ★ リスト表示モード（全タスクマスター） */}
      {/* ★★★ 来店タブ ★★★ */}
      {opView==="raiten"&&(()=>{
        const isMob=window.innerWidth<=768;
        const raitenTasks=sortedTasks.filter(t=>{if(t.type==="来店"||t.type==="返却")return true;if(["PU","PUB","BD","BDB","DEL","COL","洗車"].includes(t.type))return false;const p=(t.place||"").trim();return/^(来店|店舗|店頭|ヤード|営業所)$/.test(p);}).sort((a,b)=>(a.time||"99:99").localeCompare(b.time||"99:99"));
        const puRaiten=raitenTasks.filter(t=>t.type==="来店");
        const bdRaiten=raitenTasks.filter(t=>t.type==="返却");
        const otherRaiten=raitenTasks.filter(t=>t.type!=="来店"&&t.type!=="返却");
        const renderRow=(t)=>{
          const ppl=parseInt(t.people)||1;
          return <div key={t._id} onClick={()=>setResDetailPopup(t)} style={{display:"flex",alignItems:"center",gap:isMob?6:8,padding:isMob?"10px 14px":"8px 14px",borderBottom:"1px solid #f0f0f0",cursor:"pointer",background:t.done?"#f5f5f5":"#fff",opacity:t.done?.5:1}}>
            <span style={{fontWeight:800,fontSize:isMob?14:12,width:50,flexShrink:0,color:"#546e7a"}}>{t.time||"--:--"}</span>
            <span style={{background:t.type==="PU"||t.type==="PUB"?"#e8f5e9":"#fce4ec",color:t.type==="PU"||t.type==="PUB"?"#2e7d32":"#c62828",fontSize:isMob?10:9,fontWeight:800,padding:"2px 6px",borderRadius:4,flexShrink:0}}>{t.type}</span>
            <span style={{fontWeight:700,fontSize:isMob?14:12,flex:1,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{t.name}</span>
            <span style={{color:"#7b1fa2",fontWeight:800,fontSize:isMob?13:11,flexShrink:0}}>{ppl}名</span>
            <span style={{color:"#78909c",fontSize:isMob?10:9,fontWeight:600,flexShrink:0}}>{t.place||""}</span>
            {t.plateNo&&<span style={{color:"#1565c0",fontSize:isMob?10:9,fontWeight:700,flexShrink:0}}>{t.plateNo}</span>}
            {t.assignee&&<span style={{color:"#6d4c41",fontSize:isMob?10:9,fontWeight:700,background:"#efebe9",padding:"1px 6px",borderRadius:4,flexShrink:0}}>{t.assignee}</span>}
            {t.done&&<span style={{flexShrink:0}}>✅</span>}
          </div>;
        };
        return <div style={{maxWidth:600,margin:"0 auto"}}>
          <div style={{background:"#4e342e",borderRadius:"0 0 10px 10px",padding:"12px 16px",color:"#fff",textAlign:"center"}}>
            <div style={{fontWeight:900,fontSize:isMob?18:20}}>🏪 来店（{raitenTasks.length}件）</div>
            <div style={{fontSize:isMob?10:11,opacity:.7}}>来店・店舗・ヤードでの貸出/返却</div>
          </div>
          {raitenTasks.length===0&&<div style={{textAlign:"center",padding:40,color:"#94a3b8",fontSize:14}}>来店タスクなし</div>}
          {puRaiten.length>0&&<div>
            <div style={{background:"#e8f5e9",padding:"6px 14px",fontWeight:800,fontSize:isMob?13:12,color:"#2e7d32",borderBottom:"1px solid #c8e6c9"}}>🏪 来店（貸出） ({puRaiten.length}件)</div>
            {puRaiten.map(renderRow)}
          </div>}
          {bdRaiten.length>0&&<div>
            <div style={{background:"#fce4ec",padding:"6px 14px",fontWeight:800,fontSize:isMob?13:12,color:"#c62828",borderBottom:"1px solid #f8bbd0"}}>🏪 来店（返却） ({bdRaiten.length}件)</div>
            {bdRaiten.map(renderRow)}
          </div>}
          {otherRaiten.length>0&&<div>
            <div style={{background:"#f5f5f5",padding:"6px 14px",fontWeight:800,fontSize:isMob?13:12,color:"#546e7a",borderBottom:"1px solid #e0e0e0"}}>🏪 その他 ({otherRaiten.length}件)</div>
            {otherRaiten.map(renderRow)}
          </div>}
        </div>;
      })()}
      {opView==="master"&&<div className="bg-white rounded-lg border border-gray-200 overflow-hidden mb-2"><div style={{overflowX:"auto"}}>
        <div style={{padding:"4px 8px",background:"#f0fdf4",borderBottom:"1px solid #e2e8f0",fontSize:10,color:"#065f46",fontWeight:600}}>🔒 閲覧専用 — 行をタップすると編集画面に移動します</div>
        {/* ★ 未入力アラート（場所はDEL/COLのみ必須） */}
        {(()=>{
          const shuttle=["DEL","PU","PUB","COL","BD","BDB"];
          const needPlace=["DEL","COL"];
          const alerts=sortedTasks.filter(t=>!t.done&&shuttle.includes(t.type)).reduce((acc,t)=>{
            const resolvedT=t.timeChange||t._ssTime||t.time||"";
            const resolvedP=(t._placeSource==="manual"?t.place:(t._ssPlace||t.place))||"";
            if(!resolvedT)acc.push({name:t.name||"?",type:t.type,field:"時間"});
            if(needPlace.includes(t.type)&&!resolvedP)acc.push({name:t.name||"?",type:t.type,field:"場所"});
            return acc;
          },[]);
          if(!alerts.length)return null;
          return <div style={{padding:"6px 10px",background:"#fef2f2",borderBottom:"1px solid #fecaca",display:"flex",flexWrap:"wrap",gap:4,alignItems:"center"}}>
            <span style={{fontSize:10,fontWeight:800,color:"#dc2626",flexShrink:0}}>⚠ 未入力 {alerts.length}件:</span>
            {alerts.map((a,i)=><span key={i} style={{fontSize:9,fontWeight:700,color:"#fff",background:a.field==="時間"?"#dc2626":"#ea580c",padding:"1px 6px",borderRadius:4}}>{a.type} {a.name} [{a.field}]</span>)}
          </div>;
        })()}
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:10,whiteSpace:"nowrap"}}><thead><tr style={{background:"#f1f5f9"}}>
          {[{h:"✓",k:"done"},{h:"担当",k:"assignee"},{h:"時間",k:"time"},{h:"内容",k:"type"},{h:"予約者",k:"name"},{h:"顧客",k:null},{h:"人数",k:null},{h:"場所",k:null},{h:"クラス",k:"vehicle"},{h:"車種",k:null},{h:"No.",k:null},{h:"B",k:null},{h:"C",k:null},{h:"J",k:null},{h:"USB",k:null},{h:"補償",k:null},{h:"メモ",k:null},{h:"約款",k:null},{h:"LINE",k:null},{h:"決済",k:null},{h:"返却日",k:null},{h:"返時",k:null},{h:"返種",k:null},{h:"返却場所",k:null},{h:"便名",k:null},{h:"OTA",k:null},{h:"予約番号",k:null},{h:"TEL",k:null},{h:"MAIL",k:null}].map((col,i)=>{
            const w=i<=0?28:i<=1?48:i<=2?56:i<=3?44:i<=4?100:i<=5?28:i<=6?28:i<=7?140:i<=8?30:i<=9?56:i<=10?48:i<=14?24:i<=15?32:i<=16?100:i<=18?26:i===19?64:i<=20?64:i<=21?40:i<=22?40:i<=23?120:i<=24?56:i<=25?28:i<=26?120:i<=27?84:120;
            const sticky=i<=2;
            return <th key={i} onClick={col.k?()=>handleSort(col.k):undefined} style={{position:sticky?"sticky":"static",left:i===0?0:i===1?28:i===2?76:undefined,zIndex:sticky?3:1,background:sortKey===col.k?"#dbeafe":"#f1f5f9",padding:"4px 2px",textAlign:"center",fontWeight:600,fontSize:8,color:col.k?"#1d4ed8":"#475569",borderBottom:"2px solid #cbd5e1",borderRight:sticky&&i===2?"2px solid #cbd5e1":"1px solid #e2e8f0",minWidth:w,maxWidth:w,cursor:col.k?"pointer":"default",userSelect:"none"}}>{col.h}{col.k?<span style={{fontSize:7,marginLeft:1}}>{sortIcon(col.k)}</span>:""}</th>;
          })}
        </tr></thead><tbody>
          {sortedTasks.map((t,ri)=>{
            const isLend=t.type==="DEL"||t.type==="PU"||t.type==="PUB";const isReturn=t.type==="COL"||t.type==="BD"||t.type==="BDB";const isShuttle=isLend||isReturn;const isWash=t.type==="洗車";const tm=TASK_META[t.type]||TASK_META["その他"];
            const resolvedT=t.timeChange||t._ssTime||t.time||"";const resolvedP=(t._placeSource==="manual"?t.place:(t._ssPlace||t.place))||"";
            const missingTime=isShuttle&&!t.done&&!resolvedT;const missingPlace=(t.type==="DEL"||t.type==="COL")&&!t.done&&!resolvedP;
            const srcRes=t.reservationId?reservations.find(r=>r.id===t.reservationId):null;
            const resOptsDirect=srcRes?{b:+(srcRes.optB||0),c:+(srcRes.optC||0),j:+(srcRes.optJ||0),usb:+(srcRes.optUSB||0)}:null;
            const storedOpts=!resOptsDirect&&t.reservationId&&resOpts?resOpts[t.reservationId]:null;
            const liveOpts=resOptsDirect||storedOpts||t.opts||{};
            const isCXL=t.type==="CXL";
            const rowBg=isCXL?"#e5e7eb":t.done?"#f9fafb":isWash?"#FFFDE7":t.manual?"#f0fdf4":ri%2===0?"#fff":"#fafbfc";
            const ch=t._changed||{};
            const isRep=repeaterMap&&t.reservationId&&repeaterMap[t.reservationId];
            const cellR=(i)=>({position:i<3?"sticky":"static",left:i===0?0:i===1?28:i===2?76:undefined,zIndex:i<3?2:0,background:rowBg,padding:"2px 4px",borderBottom:"1px solid #f1f5f9",borderRight:i===2?"2px solid #cbd5e1":"1px solid #f1f5f9",opacity:isCXL?0.4:t.done?0.4:1,verticalAlign:"middle",fontSize:9,textDecoration:isCXL?"line-through":"none",color:isCXL?"#9ca3af":undefined});
            return <tr key={t._id} onClick={e=>{if(isCXL)return;if(e.target.closest&&e.target.closest('[data-staff-cell]'))return;if(t.reservationId){setEditResId(t.reservationId);setEditBlock(null);setOpView("edit");}}} style={{cursor:isCXL?"default":t.reservationId?"pointer":"default"}} title={isCXL?"キャンセル済み":t.reservationId?"タップで編集":""}>
              <td style={{...cellR(0),textAlign:"center",cursor:"pointer"}} onClick={e=>{e.stopPropagation();const u=mark({...t,done:!t.done},"done");upd(t._id,u);}}>{t.done?"✅":"⬜"}</td>
              <td data-staff-cell style={{...cellR(1),fontWeight:600,color:t.assignee?"#111":"#ccc",padding:0}}><select value={t.assignee||""} onChange={e=>{e.stopPropagation();const v=e.target.value;const tgt=t;if(!v&&!window.confirm("担当を解除しますか？"))return;if(v&&!window.confirm("担当を「"+v+"」に変更しますか？"))return;const updated=mark({...tgt,assignee:v},"assignee");upd(tgt._id,updated);}} style={{width:"100%",border:"none",background:"transparent",fontSize:9,fontWeight:600,color:t.assignee?"#111":"#ccc",padding:"2px 2px",cursor:"pointer",appearance:"none",WebkitAppearance:"none",textAlign:"center"}}><option value="">-</option>{activeMembers.map(m=><option key={m}>{m}</option>)}<option value="乗り捨て">乗捨</option><option value="無人">無人</option></select></td>
              <td style={{...cellR(2),fontWeight:700,color:resolvedT?"#1e293b":"#dc2626",background:missingTime?"#fef2f2":(resolvedT&&resolvedT!==t.time)?"#f5f3ff":cellR(2).background,padding:isWash?0:cellR(2).padding}} onClick={e=>{if(isWash)e.stopPropagation();}}>{isWash?<select value={t.time||""} onChange={e=>{e.stopPropagation();const v=e.target.value;const u=mark({...t,time:v},"time");upd(t._id,u);}} style={{width:"100%",border:"none",background:"transparent",fontSize:9,fontWeight:700,color:t.time?"#1e293b":"#ccc",padding:"2px",cursor:"pointer",appearance:"none",WebkitAppearance:"none",textAlign:"center"}}><option value="">-</option>{TIME_OPTS.filter(o=>o).map(o=><option key={o} value={o}>{o}</option>)}</select>:missingTime?<span style={{color:"#dc2626",fontSize:8}}>⚠未</span>:<React.Fragment>{resolvedT||"-"}{resolvedT&&resolvedT!==t.time&&<div style={{fontSize:7,color:"#7c3aed",fontWeight:600,lineHeight:1}}>←{t.time||"空"}</div>}</React.Fragment>}</td>
              <td style={{...cellR(3),fontWeight:700,color:tm.c,background:t.typeChange?"#f5f3ff":cellR(3).background}}>{t.type||"-"}{t.typeChange&&<div style={{fontSize:7,color:"#7c3aed",fontWeight:600,lineHeight:1}}>{t.typeChange}</div>}</td>
              <td style={{...cellR(4),fontWeight:600,color:"#0f172a"}}>{t.name||"-"}</td>
              <td style={{...cellR(5),textAlign:"center"}}>{isRep?<span style={{color:"#7c3aed"}}>✔</span>:""}</td>
              <td style={{...cellR(6),textAlign:"center"}}>{t.people||""}</td>
              <td style={{...cellR(7),background:missingPlace?"#fef2f2":(t._placeSource==="manual"&&resolvedP!==t.place)?"#f5f3ff":cellR(7).background}}>{t.type==="PUB"?<span style={{color:"#059669",fontSize:9,fontWeight:600}}>高松-ヤード</span>:t.type==="BDB"?<span style={{color:"#be123c",fontSize:9,fontWeight:600}}>ヤード-高松</span>:resolvedP?<React.Fragment><a href={"https://www.google.com/maps/search/?api=1&query="+encodeURIComponent("沖縄 "+resolvedP)} target="_blank" rel="noopener noreferrer" style={{color:"#2563eb",textDecoration:"underline",fontSize:9}}>{resolvedP}</a>{t._placeSource==="manual"&&t.place&&resolvedP!==t.place&&<div style={{fontSize:7,color:"#7c3aed",fontWeight:600,lineHeight:1}}>←{t.place}</div>}</React.Fragment>:(missingPlace?<span style={{color:"#dc2626",fontSize:8}}>⚠場所未選択</span>:<span style={{color:"#ccc"}}>-</span>)}</td>
              <td style={{...cellR(8),textAlign:"center",color:"#64748b",fontWeight:700}}>{t.vehicle||"-"}</td>
              <td style={{...cellR(9),fontWeight:700,color:t.assignedVehicle?"#1e40af":"#dc2626"}}>{(()=>{const vn=vehicles.find(x=>x.code===t.assignedVehicle);return vn?vn.name:"未配車";})()}</td>
              <td style={{...cellR(10),fontFamily:"monospace",fontWeight:700,color:t.plateNo?"#2563eb":"#ccc"}}>{t.plateNo||"-"}</td>
              {["b","c","j","usb"].map((k,ki)=><td key={k} style={{...cellR(11+ki),textAlign:"center",fontWeight:700,color:+(liveOpts[k]||0)>0?"#2563eb":"#ddd"}}>{(isLend||isWash)?(+(liveOpts[k]||0)||"-"):""}</td>)}
              <td style={{...cellR(15),fontWeight:600,color:t.insurance==="NOC"?"#b45309":"#64748b"}}>{t.insurance||"-"}</td>
              <td style={{...cellR(16),color:"#475569"}}>{t.memo||""}</td>
              <td style={{...cellR(17),textAlign:"center"}}>{isLend?(t.yakkan?"✓":"-"):""}</td>
              <td style={{...cellR(18),textAlign:"center"}}>{(t.type==="DEL"||t.type==="COL")?(t.line?"✓":"-"):""}</td>
              <td style={{...cellR(19),textAlign:"center"}}>{isLend?(()=>{const jp=t.reservationId&&jalanPay?jalanPay[t.reservationId]:null;const pr=Number(jp&&jp.adjustedPrice?jp.adjustedPrice:(srcRes?(srcRes.finalPrice||srcRes.price):0))||0;if(t.ota==="J"){const status=jp&&jp.payStatus==="完了"?<span style={{color:"#059669",fontWeight:700,fontSize:8}}>済</span>:<span style={{color:"#dc2626",fontWeight:700,fontSize:8}}>未</span>;return <span>{pr?<span style={{fontSize:8,fontWeight:700,color:"#1e40af"}}>¥{pr.toLocaleString()}</span>:""}{status}</span>;}return t.payment?"✓":"-";})():""}</td>
              <td style={cellR(20)}>{isLend?fmtD(t.returnDate):""}</td>
              <td style={cellR(21)}>{isLend?(t.returnTime||""):""}</td>
              <td style={cellR(22)}>{isLend?(t.returnType||""):""}</td>
              <td style={cellR(23)}>{t.colPlace||""}</td>
              <td style={cellR(24)}>{t.flight||""}</td>
              <td style={cellR(25)}>{t.ota?<OBadge ota={t.ota}/>:""}</td>
              <td style={{...cellR(26),fontFamily:"monospace",fontSize:8}}>{t.reservationId||""}</td>
              <td style={cellR(27)}>{t.tel||""}</td>
              <td style={{...cellR(28),fontSize:8}}>{t.mail||""}</td>
            </tr>;
          })}
          {sortedTasks.length===0&&<tr><td colSpan={29} style={{textAlign:"center",padding:16,color:"#94a3b8",fontSize:11}}>この日のタスクはありません</td></tr>}
        </tbody></table>
      </div></div>}
      {/* ★ 編集タブ */}
      {opView==="edit"&&(()=>{
        // 予約IDごとにタスクをグループ化
        const resGroups={};
        sortedTasks.forEach(t=>{
          if(!t.reservationId)return;
          if(t.type==="洗車")return;
          if(!resGroups[t.reservationId])resGroups[t.reservationId]={resId:t.reservationId,tasks:[],name:t.name,ota:t.ota,people:t.people,vehicle:t.vehicle,flight:t.flight,assignedVehicle:t.assignedVehicle,plateNo:t.plateNo};
          resGroups[t.reservationId].tasks.push(t);
        });
        const allGroups=Object.values(resGroups);
        // ★ editResIdがある場合: tasksにグループがなくてもreservationsから生成
        let groups=editResId?allGroups.filter(g=>g.resId===editResId):allGroups;
        if(editResId&&groups.length===0){
          const srcRes=reservations.find(r=>r.id===editResId);
          if(srcRes)groups=[{resId:editResId,tasks:[],name:srcRes.name||"",ota:srcRes.ota||"",people:srcRes.people||0,vehicle:srcRes.vehicleClass||srcRes.vehicle||"",flight:srcRes.flight||"",assignedVehicle:fleet[editResId]||"",plateNo:(()=>{const v=vehicles.find(x=>x.code===fleet[editResId]);return v?v.no:"";})()}];
        }
        const resolvedTime=(tk)=>tk.timeChange||(tk._ssTime)||tk.time||"";
        const resolvedPlace=(tk)=>tk._placeSource==="manual"?tk.place:(tk._ssPlace||tk.place||"");
        const sourceTag=(tk,type)=>{
          if(type==="time"){if(tk.timeChange)return{label:"手動",bg:"#ede9fe",color:"#6d28d9"};if(tk._ssTime)return{label:"SS",bg:"#dbeafe",color:"#1d4ed8"};return{label:"CSV",bg:"#f1f5f9",color:"#64748b"};}
          if(type==="place"){if(tk._placeSource==="manual")return{label:"手動",bg:"#ede9fe",color:"#6d28d9"};if(tk._ssPlace)return{label:"SS",bg:"#dbeafe",color:"#1d4ed8"};return{label:"CSV",bg:"#f1f5f9",color:"#64748b"};}
        };

        // ★ editBlockの編集フィールドレンダラー（出発/返却共通）
        const renderBlockFields=(blk,g,srcRes)=>{
          const hasTk=!!blk.tk;const tk=blk.tk;
          const delTask=g.tasks.find(t=>t.type==="DEL"||t.type==="PU"||t.type==="PUB");
          const colTask=g.tasks.find(t=>t.type==="COL"||t.type==="BD"||t.type==="BDB");
          const CF=(msg)=>window.confirm(msg+"を変更しますか？");
          return <div style={{display:"flex",flexDirection:"column",gap:0}}>
            {/* ===== 貸出方法/返却方法（PU/PUB/DEL/BD/BDB/COL） ===== */}
            {/* ===== 情報バー: 方法 + 変更履歴 + 日時 を1つにまとめる ===== */}
            {hasTk&&<div style={{background:blk.label==="出発"?"#eff6ff":"#fef2f2",borderBottom:"2px solid #e2e8f0"}}>
              <div style={{display:"flex",alignItems:"center",padding:"8px 12px",gap:8,flexWrap:"wrap"}}>
                <span style={{fontSize:11,fontWeight:800,color:blk.label==="出発"?"#1e40af":"#991b1b"}}>{blk.label==="出発"?"📋 貸出方法":"📋 返却方法"}</span>
                <span style={{fontSize:16,fontWeight:900,color:({DEL:"#2563eb",PU:"#2563eb",PUB:"#2d6a4f","来店":"#7c3aed",COL:"#dc2626",BD:"#dc2626",BDB:"#8b3a3a","返却":"#7c3aed"})[tk.type]||"#64748b"}}>{tk.type}</span>
                {tk.typeChange&&<div style={{display:"flex",alignItems:"center",gap:3}}>
                  {tk.typeChange.split("→").map((step,i,arr)=><React.Fragment key={i}>{i>0&&<span style={{fontSize:9,color:"#a78bfa",fontWeight:800}}>→</span>}<span style={{fontSize:10,fontWeight:800,padding:"1px 5px",borderRadius:3,background:i===arr.length-1?"#7c3aed":"#e9e5f5",color:i===arr.length-1?"#fff":"#6d28d9"}}>{step}</span></React.Fragment>)}
                </div>}
                <select value={tk.type} onChange={e=>{const v=e.target.value;if(v===tk.type)return;setTimeout(()=>{if(!window.confirm((blk.label==="出発"?"貸出方法":"返却方法")+"を「"+v+"」に変更しますか？")){setTasks(ts=>[...ts]);return;}const isPUType=v==="PU"||v==="PUB"||v==="DEL"||v==="来店";const wasPUType=tk.type==="PU"||tk.type==="PUB"||tk.type==="DEL"||tk.type==="来店";const placeUpd=v==="PUB"||v==="BDB"?{place:"高松",_placeSource:"manual"}:{};const resFields={};if(tk.reservationId){if(isPUType)resFields.visitType=v==="PUB"?"PU(バス)":v==="PU"?"PU":v==="DEL"?"DEL":v;else resFields.returnType=v==="BDB"?"BD(バス)":v==="BD"?"BD":v==="COL"?"COL":v;}const oldHist=tk.typeChange||"";const newHist=oldHist?(oldHist+"→"+v):(tk.type+"→"+v);const u=mark({...tk,...placeUpd,type:v,typeChange:newHist},"type");upd(tk._id,u,tk.reservationId&&Object.keys(resFields).length?{fields:resFields,type:"内容変更:"+v,source:"manual"}:undefined);},50);}} style={{border:"2px solid "+(blk.label==="出発"?"#93c5fd":"#fca5a5"),borderRadius:8,padding:"4px 10px",fontSize:12,fontWeight:800,color:"#1e293b",cursor:"pointer",marginLeft:"auto",background:"#fff"}}>
                  {blk.label==="出発"?[{v:"PUB",l:"PUB(バス空港発)"},{v:"PU",l:"PU(空港ピックアップ)"},{v:"DEL",l:"DEL(デリバリー)"},{v:"来店",l:"来店"}].map(o=><option key={o.v} value={o.v}>{o.l}</option>):[{v:"BDB",l:"BDB(バスヤード発)"},{v:"BD",l:"BD(空港ドロップ)"},{v:"COL",l:"COL(回収)"},{v:"返却",l:"返却(来店)"}].map(o=><option key={o.v} value={o.v}>{o.l}</option>)}
                </select>
              </div>
            </div>}
            {/* 予約日時はヘッダー帯に移動済み */}

            {/* ===== 送迎時間（3階層） ===== */}
            {hasTk&&(()=>{
              const stag=sourceTag(tk,"time");
              const fmtTs=(iso)=>iso?new Date(iso).toLocaleString("ja-JP",{month:"numeric",day:"numeric",hour:"2-digit",minute:"2-digit"}):"";
              return <div style={{padding:"10px 12px",borderBottom:"1px solid #e2e8f0"}}>
                {/* 確定値ヘッダー */}
                <div style={{display:"flex",alignItems:"baseline",gap:8,marginBottom:8}}>
                  <span style={{fontSize:11,fontWeight:700,color:"#475569"}}>⏰ 送迎時間</span>
                  <span style={{fontSize:20,fontWeight:900,color:"#0f172a",letterSpacing:1}}>{resolvedTime(tk)||"--:--"}</span>
                  <span style={{fontSize:9,fontWeight:700,background:stag.bg,color:stag.color,padding:"2px 8px",borderRadius:4}}>{stag.label}適用中</span>
                </div>
                {/* 3階層 縦並び */}
                <div style={{borderRadius:8,border:"1px solid #e2e8f0",overflow:"hidden"}}>
                  {/* ① CSV（元値） */}
                  <div style={{display:"flex",alignItems:"center",padding:"6px 10px",background:"#f8fafc",borderBottom:"1px solid #e2e8f0",gap:8}}>
                    <span style={{fontSize:9,fontWeight:800,color:"#94a3b8",width:16,textAlign:"center",flexShrink:0}}>①</span>
                    <span style={{fontSize:9,fontWeight:700,color:"#94a3b8",width:50,flexShrink:0}}>CSV元値</span>
                    <span style={{fontSize:13,fontWeight:700,color:"#64748b"}}>{tk.time||"-"}</span>
                    <span style={{marginLeft:"auto",fontSize:8,color:"#cbd5e1"}}>読取専用</span>
                  </div>
                  {/* ② SS（自動取得） */}
                  <div style={{display:"flex",alignItems:"center",padding:"6px 10px",background:"#eff6ff",borderBottom:"1px solid #dbeafe",gap:8}}>
                    <span style={{fontSize:9,fontWeight:800,color:"#3b82f6",width:16,textAlign:"center",flexShrink:0}}>②</span>
                    <span style={{fontSize:9,fontWeight:700,color:"#3b82f6",width:50,flexShrink:0}}>SS自動</span>
                    <span style={{fontSize:13,fontWeight:700,color:tk._ssTime?"#1d4ed8":"#93c5fd"}}>{tk._ssTime||"-"}</span>
                    {tk._ssTimeAt&&<span style={{marginLeft:"auto",fontSize:8,color:"#60a5fa"}}>{fmtTs(tk._ssTimeAt)}</span>}
                    {!tk._ssTimeAt&&<span style={{marginLeft:"auto",fontSize:8,color:"#bfdbfe"}}>未取得</span>}
                  </div>
                  {/* ③ 手動（最優先） */}
                  <div style={{display:"flex",alignItems:"center",padding:"6px 10px",background:tk.timeChange?"#f5f3ff":"#faf5ff",gap:8}}>
                    <span style={{fontSize:9,fontWeight:800,color:"#7c3aed",width:16,textAlign:"center",flexShrink:0}}>③</span>
                    <span style={{fontSize:9,fontWeight:700,color:"#7c3aed",width:50,flexShrink:0}}>手動変更</span>
                    <select value={tk.timeChange||""} onChange={e=>{const v=e.target.value;const prev=tk.timeChange||"";setTimeout(()=>{if(!window.confirm("送迎時間を「"+(v||"クリア")+"」に変更しますか？")){setTasks(ts=>[...ts]);return;}const u={...mark({...tk,timeChange:v},"timeChange"),_timeChangeSource:"manual",_manualTimeAt:new Date().toISOString()};upd(tk._id,u);},50);}} style={{border:"1px solid #ddd6fe",background:"#fff",borderRadius:6,padding:"3px 8px",fontSize:13,fontWeight:700,color:tk.timeChange?"#6d28d9":"#c4b5fd",flex:1,cursor:"pointer",maxWidth:120}}>
                      {TIME_OPTS.map(o=><option key={o} value={o}>{o||"--"}</option>)}
                      {tk.timeChange&&!TIME_OPTS.includes(tk.timeChange)&&<option value={tk.timeChange}>{tk.timeChange}</option>}
                    </select>
                    {tk.timeChange&&<button onClick={()=>{if(!CF("送迎時間の取消"))return;const u={...mark({...tk,timeChange:""},"timeChange"),_timeChangeSource:""};upd(tk._id,u);}} style={{background:"#fef2f2",border:"1px solid #fecaca",borderRadius:6,cursor:"pointer",fontSize:10,color:"#dc2626",padding:"2px 8px",fontWeight:700}}>取消</button>}
                    {tk._manualTimeAt&&<span style={{fontSize:8,color:"#a78bfa"}}>{fmtTs(tk._manualTimeAt)}</span>}
                    {!tk.timeChange&&<span style={{fontSize:8,color:"#d8b4fe",marginLeft:"auto"}}>最優先</span>}
                  </div>
                </div>
              </div>;
            })()}

            {/* ===== 送迎場所（3階層） ===== */}
            {hasTk&&(()=>{
              const stag=sourceTag(tk,"place");
              const fmtTs=(iso)=>iso?new Date(iso).toLocaleString("ja-JP",{month:"numeric",day:"numeric",hour:"2-digit",minute:"2-digit"}):"";
              return <div style={{padding:"10px 12px",borderBottom:"1px solid #e2e8f0"}}>
                {/* 確定値ヘッダー */}
                <div style={{display:"flex",alignItems:"baseline",gap:8,marginBottom:8}}>
                  <span style={{fontSize:11,fontWeight:700,color:"#475569"}}>📍 場所</span>
                  <span style={{fontSize:13,fontWeight:800,color:"#0f172a",flex:1,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{resolvedPlace(tk)||"未定"}</span>
                  <span style={{fontSize:9,fontWeight:700,background:stag.bg,color:stag.color,padding:"2px 8px",borderRadius:4,flexShrink:0}}>{stag.label}適用中</span>
                </div>
                {/* 3階層 縦並び */}
                <div style={{borderRadius:8,border:"1px solid #e2e8f0",overflow:"hidden"}}>
                  {/* ① CSV（元値） */}
                  <div style={{display:"flex",alignItems:"center",padding:"6px 10px",background:"#f8fafc",borderBottom:"1px solid #e2e8f0",gap:8}}>
                    <span style={{fontSize:9,fontWeight:800,color:"#94a3b8",width:16,textAlign:"center",flexShrink:0}}>①</span>
                    <span style={{fontSize:9,fontWeight:700,color:"#94a3b8",width:50,flexShrink:0}}>CSV元値</span>
                    <span style={{fontSize:11,fontWeight:600,color:"#64748b",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{tk.place||"-"}</span>
                    <span style={{marginLeft:"auto",fontSize:8,color:"#cbd5e1",flexShrink:0}}>読取専用</span>
                  </div>
                  {/* ② SS（自動取得） */}
                  <div style={{display:"flex",alignItems:"center",padding:"6px 10px",background:"#eff6ff",borderBottom:"1px solid #dbeafe",gap:8}}>
                    <span style={{fontSize:9,fontWeight:800,color:"#3b82f6",width:16,textAlign:"center",flexShrink:0}}>②</span>
                    <span style={{fontSize:9,fontWeight:700,color:"#3b82f6",width:50,flexShrink:0}}>SS自動</span>
                    <span style={{fontSize:11,fontWeight:600,color:tk._ssPlace?"#1d4ed8":"#93c5fd",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{tk._ssPlace||"-"}</span>
                    {tk._ssPlaceAt&&<span style={{marginLeft:"auto",fontSize:8,color:"#60a5fa",flexShrink:0}}>{fmtTs(tk._ssPlaceAt)}</span>}
                    {!tk._ssPlaceAt&&<span style={{marginLeft:"auto",fontSize:8,color:"#bfdbfe",flexShrink:0}}>未取得</span>}
                  </div>
                  {/* ③ 手動（最優先） */}
                  <div style={{display:"flex",alignItems:"center",padding:"6px 10px",background:tk._placeSource==="manual"?"#f5f3ff":"#faf5ff",gap:8,flexWrap:"wrap"}}>
                    <span style={{fontSize:9,fontWeight:800,color:"#7c3aed",width:16,textAlign:"center",flexShrink:0}}>③</span>
                    <span style={{fontSize:9,fontWeight:700,color:"#7c3aed",width:50,flexShrink:0}}>手動変更</span>
                    {(tk.type==="PUB"||tk.type==="BDB")?
                      <span style={{fontSize:12,fontWeight:700,color:"#059669"}}>高松（固定）</span>
                    :(()=>{
                      const curVal=tk._placeSource==="manual"?tk.place:"";
                      const inputRef=React.createRef();
                      return <React.Fragment>
                        <input ref={inputRef} key={curVal+"_"+tk._id} defaultValue={curVal} style={{border:"1px solid #ddd6fe",background:"#fff",borderRadius:6,padding:"4px 10px",fontSize:12,fontWeight:700,color:curVal?"#6d28d9":"#94a3b8",flex:1}} placeholder="場所を入力..."/>
                        <button onClick={()=>{const v=(inputRef.current?.value||"").trim();if(!v){alert("場所を入力してください");return;}if(!window.confirm("場所を「"+v+"」に変更しますか？"))return;const u={...mark({...tk,place:v},"place"),_placeSource:"manual",_manualPlaceAt:new Date().toISOString()};upd(tk._id,u);}} style={{background:"#7c3aed",color:"#fff",border:"none",borderRadius:6,padding:"4px 12px",fontSize:11,fontWeight:800,cursor:"pointer",flexShrink:0}}>保存</button>
                      </React.Fragment>;
                    })()}
                    {tk._placeSource==="manual"&&<button onClick={()=>{if(!CF("場所の取消"))return;const confirmed=tk._ssPlace||tk.place||"";const u={...mark({...tk,place:confirmed},"place"),_placeSource:tk._ssPlace?"spreadsheet":"",_manualPlaceAt:""};upd(tk._id,u);}} style={{background:"#fef2f2",border:"1px solid #fecaca",borderRadius:6,cursor:"pointer",fontSize:10,color:"#dc2626",padding:"2px 8px",fontWeight:700,flexShrink:0}}>取消</button>}
                    {tk._manualPlaceAt&&<span style={{fontSize:8,color:"#a78bfa",flexShrink:0}}>{fmtTs(tk._manualPlaceAt)}</span>}
                    {!tk._placeSource&&<span style={{fontSize:8,color:"#d8b4fe",marginLeft:"auto",flexShrink:0}}>最優先</span>}
                  </div>
                </div>
              </div>;
            })()}

            {/* ===== 担当（マスター表で設定・表示のみ） ===== */}
            {hasTk&&<div style={{padding:"10px 12px",borderBottom:"1px solid #e2e8f0"}}>
              <div style={{display:"flex",alignItems:"center",gap:8}}>
                <span style={{fontSize:11,fontWeight:700,color:"#475569"}}>👤 担当</span>
                <span style={{fontSize:14,fontWeight:800,color:tk.assignee?"#6d28d9":"#94a3b8"}}>{tk.assignee||"未割当"}</span>
                <span style={{marginLeft:"auto",fontSize:8,color:"#94a3b8",background:"#f1f5f9",padding:"2px 8px",borderRadius:4}}>マスター表で変更</span>
              </div>
            </div>}

            {/* ===== 便名（出発ブロックのみ） ===== */}
            {hasTk&&blk.label==="出発"&&<div style={{padding:"8px 12px",borderBottom:"1px solid #e2e8f0",display:"flex",alignItems:"center",gap:8}}>
              <span style={{fontSize:11,fontWeight:700,color:"#475569",flexShrink:0}}>✈ 便名</span>
              <input key={tk.flight+""} defaultValue={tk.flight||""} onBlur={e=>{const v=e.target.value;if(v===(tk.flight||""))return;if(!CF("便名")){e.target.value=tk.flight||"";return;}const u=mark({...tk,flight:v},"flight");upd(tk._id,u,tk.reservationId?{fields:{flight:v},type:"便名:手動変更",source:"manual"}:undefined);}} style={{border:"1px solid #d1d5db",background:"#fff",borderRadius:8,padding:"5px 10px",fontSize:12,fontWeight:600,color:"#0f172a",flex:1}} placeholder="便名を入力... (例: ANA123)"/>
            </div>}

            {/* ===== メモ（タスクあり時） ===== */}
            {hasTk&&<div style={{padding:"8px 12px",borderBottom:"1px solid #e2e8f0",display:"flex",alignItems:"center",gap:8}}>
              <span style={{fontSize:11,fontWeight:700,color:"#475569",flexShrink:0}}>📝 メモ</span>
              <input key={tk.memo+""} defaultValue={tk.memo||""} onBlur={e=>{const v=e.target.value;if(v===(tk.memo||""))return;upd(tk._id,mark({...tk,memo:v},"memo"));}} style={{border:"1px solid #d1d5db",background:"#fff",borderRadius:8,padding:"5px 10px",fontSize:12,fontWeight:600,color:"#0f172a",flex:1}} placeholder="メモを入力..."/>
            </div>}

            {/* ★ タスクなし時: 3階層と同一構造でreservationsマスターを直接編集 */}
            {!hasTk&&srcRes&&(()=>{
              const resTime=srcRes[blk.timeKey]||"";
              const resPlace=srcRes[blk.placeField]||"";
              const resType=blk.label==="出発"?(srcRes.visitType||""):(srcRes.returnType||"");
              const doResUpd=(fields,label)=>{DB.updateReservationField(g.resId,fields,label,"manual");if(onReservationUpdate)onReservationUpdate(g.resId,fields);};
              const CFR=(msg)=>window.confirm(msg+"を変更しますか？");
              return <React.Fragment>
              <div style={{padding:"6px 12px",background:"#fef3c7",borderBottom:"1px solid #f1f5f9",fontSize:10,color:"#92400e",fontWeight:600}}>
                ⚠ {blk.label==="出発"?"貸出":"返却"}日は {blk.label==="出発"?(srcRes.lendDate||"不明"):(srcRes.returnDate||"不明")} — 予約マスターを直接編集
              </div>
              {/* ===== 貸出方法/返却方法（PUB/PU/DEL/来店 or BDB/BD/COL/返却） ===== */}
              <div style={{display:"flex",alignItems:"center",padding:"10px 12px",borderBottom:"2px solid #e2e8f0",gap:10,background:blk.label==="出発"?"#eff6ff":"#fef2f2"}}>
                <span style={{fontSize:12,fontWeight:800,color:blk.label==="出発"?"#1e40af":"#991b1b",flexShrink:0}}>{blk.label==="出発"?"📋 貸出方法":"📋 返却方法"}</span>
                <span style={{fontSize:18,fontWeight:900,color:({DEL:"#2563eb",PU:"#2563eb",PUB:"#2d6a4f","PU(バス)":"#2d6a4f","来店":"#7c3aed",COL:"#dc2626",BD:"#dc2626",BDB:"#8b3a3a","BD(バス)":"#8b3a3a","返却":"#7c3aed"})[resType]||"#64748b",letterSpacing:1}}>{resType||"未設定"}</span>
                <select value={resType} onChange={e=>{const v=e.target.value;setTimeout(()=>{if(!window.confirm((blk.label==="出発"?"貸出方法":"返却方法")+"を「"+v+"」に変更しますか？"))return;if(blk.label==="出発"){doResUpd({visitType:v},"内容変更:"+v);}else{doResUpd({returnType:v},"内容変更:"+v);}},50);}} style={{border:"2px solid "+(blk.label==="出発"?"#93c5fd":"#fca5a5"),borderRadius:8,padding:"6px 12px",fontSize:13,fontWeight:800,color:"#1e293b",cursor:"pointer",marginLeft:"auto",background:"#fff"}}>
                  {blk.label==="出発"?[{v:"PUB",l:"PUB(バス空港発)"},{v:"PU",l:"PU(空港ピックアップ)"},{v:"PU(バス)",l:"PU(バス)"},{v:"DEL",l:"DEL(デリバリー)"},{v:"来店",l:"来店"}].map(o=><option key={o.v} value={o.v}>{o.l}</option>):[{v:"BDB",l:"BDB(バスヤード発)"},{v:"BD",l:"BD(空港ドロップ)"},{v:"BD(バス)",l:"BD(バス)"},{v:"COL",l:"COL(回収)"},{v:"返却",l:"返却(来店)"}].map(o=><option key={o.v} value={o.v}>{o.l}</option>)}
                  {resType&&![..."PUB,PU,PU(バス),DEL,来店,BDB,BD,BD(バス),COL,返却".split(",")].includes(resType)&&<option value={resType}>{resType}</option>}
                </select>
              </div>
              {/* ===== 送迎時間（3階層: 予約マスターベース） ===== */}
              <div style={{padding:"10px 12px",borderBottom:"1px solid #e2e8f0"}}>
                <div style={{display:"flex",alignItems:"baseline",gap:8,marginBottom:8}}>
                  <span style={{fontSize:11,fontWeight:700,color:"#475569"}}>⏰ 送迎時間</span>
                  <span style={{fontSize:20,fontWeight:900,color:"#0f172a",letterSpacing:1}}>{resTime||"--:--"}</span>
                  <span style={{fontSize:9,fontWeight:700,background:"#f1f5f9",color:"#64748b",padding:"2px 8px",borderRadius:4}}>予約マスター</span>
                </div>
                <div style={{borderRadius:8,border:"1px solid #e2e8f0",overflow:"hidden"}}>
                  <div style={{display:"flex",alignItems:"center",padding:"6px 10px",background:"#f8fafc",borderBottom:"1px solid #e2e8f0",gap:8}}>
                    <span style={{fontSize:9,fontWeight:800,color:"#94a3b8",width:16,textAlign:"center",flexShrink:0}}>①</span>
                    <span style={{fontSize:9,fontWeight:700,color:"#94a3b8",width:50,flexShrink:0}}>CSV元値</span>
                    <span style={{fontSize:13,fontWeight:700,color:"#64748b"}}>{resTime||"-"}</span>
                    <span style={{marginLeft:"auto",fontSize:8,color:"#cbd5e1"}}>読取専用</span>
                  </div>
                  <div style={{display:"flex",alignItems:"center",padding:"6px 10px",background:"#eff6ff",borderBottom:"1px solid #dbeafe",gap:8}}>
                    <span style={{fontSize:9,fontWeight:800,color:"#3b82f6",width:16,textAlign:"center",flexShrink:0}}>②</span>
                    <span style={{fontSize:9,fontWeight:700,color:"#3b82f6",width:50,flexShrink:0}}>SS自動</span>
                    <span style={{fontSize:13,fontWeight:700,color:"#93c5fd"}}>-</span>
                    <span style={{marginLeft:"auto",fontSize:8,color:"#bfdbfe"}}>未取得</span>
                  </div>
                  <div style={{display:"flex",alignItems:"center",padding:"6px 10px",background:"#faf5ff",gap:8}}>
                    <span style={{fontSize:9,fontWeight:800,color:"#7c3aed",width:16,textAlign:"center",flexShrink:0}}>③</span>
                    <span style={{fontSize:9,fontWeight:700,color:"#7c3aed",width:50,flexShrink:0}}>手動変更</span>
                    <select value={resTime} onChange={e=>{const v=e.target.value;setTimeout(()=>{if(!window.confirm("送迎時間を「"+(v||"クリア")+"」に変更しますか？"))return;doResUpd({[blk.timeKey]:v,[blk.timeField]:v},"\u2464\u6642\u9593:\u624b\u52d5\u5909\u66f4");},50);}} style={{border:"1px solid #ddd6fe",background:"#fff",borderRadius:6,padding:"3px 8px",fontSize:13,fontWeight:700,color:resTime?"#6d28d9":"#c4b5fd",flex:1,cursor:"pointer",maxWidth:120}}>
                      {TIME_OPTS.map(o=><option key={o} value={o}>{o||"--"}</option>)}
                      {resTime&&!TIME_OPTS.includes(resTime)&&<option value={resTime}>{resTime}</option>}
                    </select>
                    <span style={{fontSize:8,color:"#d8b4fe",marginLeft:"auto"}}>最優先</span>
                  </div>
                </div>
              </div>
              {/* ===== 送迎場所（3階層: 予約マスターベース） ===== */}
              <div style={{padding:"10px 12px",borderBottom:"1px solid #e2e8f0"}}>
                <div style={{display:"flex",alignItems:"baseline",gap:8,marginBottom:8}}>
                  <span style={{fontSize:11,fontWeight:700,color:"#475569"}}>📍 場所</span>
                  <span style={{fontSize:13,fontWeight:800,color:"#0f172a",flex:1,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{resPlace||"未定"}</span>
                  <span style={{fontSize:9,fontWeight:700,background:"#f1f5f9",color:"#64748b",padding:"2px 8px",borderRadius:4,flexShrink:0}}>予約マスター</span>
                </div>
                <div style={{borderRadius:8,border:"1px solid #e2e8f0",overflow:"hidden"}}>
                  <div style={{display:"flex",alignItems:"center",padding:"6px 10px",background:"#f8fafc",borderBottom:"1px solid #e2e8f0",gap:8}}>
                    <span style={{fontSize:9,fontWeight:800,color:"#94a3b8",width:16,textAlign:"center",flexShrink:0}}>①</span>
                    <span style={{fontSize:9,fontWeight:700,color:"#94a3b8",width:50,flexShrink:0}}>CSV元値</span>
                    <span style={{fontSize:11,fontWeight:600,color:"#64748b",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{resPlace||"-"}</span>
                    <span style={{marginLeft:"auto",fontSize:8,color:"#cbd5e1",flexShrink:0}}>読取専用</span>
                  </div>
                  <div style={{display:"flex",alignItems:"center",padding:"6px 10px",background:"#eff6ff",borderBottom:"1px solid #dbeafe",gap:8}}>
                    <span style={{fontSize:9,fontWeight:800,color:"#3b82f6",width:16,textAlign:"center",flexShrink:0}}>②</span>
                    <span style={{fontSize:9,fontWeight:700,color:"#3b82f6",width:50,flexShrink:0}}>SS自動</span>
                    <span style={{fontSize:11,fontWeight:600,color:"#93c5fd"}}>-</span>
                    <span style={{marginLeft:"auto",fontSize:8,color:"#bfdbfe",flexShrink:0}}>未取得</span>
                  </div>
                  <div style={{display:"flex",alignItems:"center",padding:"6px 10px",background:"#faf5ff",gap:8,flexWrap:"wrap"}}>
                    <span style={{fontSize:9,fontWeight:800,color:"#7c3aed",width:16,textAlign:"center",flexShrink:0}}>③</span>
                    <span style={{fontSize:9,fontWeight:700,color:"#7c3aed",width:50,flexShrink:0}}>手動変更</span>
                    {(()=>{
                      const curVal=resPlace;
                      const quickOpts=["高松","赤嶺駅"];
                      const isQuick=quickOpts.includes(curVal);
                      const isCustom=curVal&&!isQuick;
                      return <React.Fragment>
                        <select value={isQuick?curVal:isCustom?"__custom":""} onChange={e=>{const v=e.target.value;if(v==="__custom"){const custom=window.prompt("場所を入力してください:",curVal||"");if(!custom)return;if(!window.confirm("場所を「"+custom+"」に変更しますか？"))return;doResUpd({[blk.placeField]:custom},"\u2466\u5834\u6240:\u624b\u52d5\u5909\u66f4");return;}setTimeout(()=>{if(!window.confirm("場所を「"+(v||"クリア")+"」に変更しますか？"))return;doResUpd({[blk.placeField]:v},"\u2466\u5834\u6240:\u624b\u52d5\u5909\u66f4");},50);}} style={{border:"1px solid #ddd6fe",background:"#fff",borderRadius:6,padding:"3px 8px",fontSize:11,fontWeight:700,color:curVal?"#6d28d9":"#c4b5fd",flex:1,cursor:"pointer"}}>
                          <option value="">選択してください</option>
                          {quickOpts.map(o=><option key={o} value={o}>{o}</option>)}
                          <option value="__custom">その他(手入力)...</option>
                          {isCustom&&<option value={curVal}>{curVal}</option>}
                        </select>
                        {isCustom&&<input key={curVal} defaultValue={curVal} onBlur={e=>{const v=e.target.value;if(v===curVal)return;if(!CFR("場所")){e.target.value=curVal;return;}doResUpd({[blk.placeField]:v},"\u2466\u5834\u6240:\u624b\u52d5\u5909\u66f4");}} style={{border:"1px solid #ddd6fe",background:"#fff",borderRadius:6,padding:"3px 8px",fontSize:11,fontWeight:700,color:"#6d28d9",flex:"1 0 100%",marginTop:4}} placeholder="場所を入力..."/>}
                      </React.Fragment>;
                    })()}
                    <span style={{fontSize:8,color:"#d8b4fe",marginLeft:"auto",flexShrink:0}}>最優先</span>
                  </div>
                </div>
              </div>
              {/* ===== 担当（マスター表で設定・表示のみ） ===== */}
              <div style={{padding:"10px 12px",borderBottom:"1px solid #e2e8f0"}}>
                <div style={{display:"flex",alignItems:"center",gap:8}}>
                  <span style={{fontSize:11,fontWeight:700,color:"#475569"}}>👤 担当</span>
                  <span style={{fontSize:14,fontWeight:800,color:"#94a3b8"}}>未割当</span>
                  <span style={{marginLeft:"auto",fontSize:8,color:"#94a3b8",background:"#f1f5f9",padding:"2px 8px",borderRadius:4}}>マスター表で変更</span>
                </div>
              </div>
              {/* ===== 便名（出発のみ） ===== */}
              {blk.label==="出発"&&<div style={{padding:"8px 12px",borderBottom:"1px solid #e2e8f0",display:"flex",alignItems:"center",gap:8}}>
                <span style={{fontSize:11,fontWeight:700,color:"#475569",flexShrink:0}}>✈ 便名</span>
                <input key={srcRes.flight+""} defaultValue={srcRes.flight||""} onBlur={e=>{const v=e.target.value;if(v===(srcRes.flight||""))return;if(!CFR("便名")){e.target.value=srcRes.flight||"";return;}doResUpd({flight:v},"便名:手動変更");}} style={{border:"1px solid #d1d5db",background:"#fff",borderRadius:8,padding:"5px 10px",fontSize:12,fontWeight:600,color:"#0f172a",flex:1}} placeholder="便名を入力... (例: ANA123)"/>
              </div>}
              {/* ===== メモ ===== */}
              <div style={{padding:"8px 12px",borderBottom:"1px solid #e2e8f0",display:"flex",alignItems:"center",gap:8}}>
                <span style={{fontSize:11,fontWeight:700,color:"#475569",flexShrink:0}}>📝 メモ</span>
                <span style={{fontSize:11,fontWeight:600,color:"#c4b5fd"}}>タスク生成日に設定可</span>
              </div>
              </React.Fragment>;
            })()}
            {!hasTk&&!srcRes&&<div style={{padding:"20px 12px",textAlign:"center",color:"#94a3b8",fontSize:12}}>予約マスターデータがありません</div>}
          </div>;
        };

        // ★ 共通項目レンダラー（①②③階層統一）
        const renderCommonBlock=(g,srcRes)=>{
          const delTask=g.tasks.find(t=>t.type==="DEL"||t.type==="PU"||t.type==="PUB");
          const colTask=g.tasks.find(t=>t.type==="COL"||t.type==="BD"||t.type==="BDB");
          const hasTasks=!!(delTask||colTask);
          const csvOpts=(delTask||colTask||{}).opts||{};
          const liveOpts=(()=>{const sr=srcRes?{b:+(srcRes.optB||0),c:+(srcRes.optC||0),j:+(srcRes.optJ||0),usb:+(srcRes.optUSB||0)}:null;return sr||csvOpts||{};})();
          const insTask=delTask||colTask;
          const csvIns=(delTask||colTask||{}).insurance||"";
          const insVal=insTask?insTask.insurance:(srcRes?srcRes.insurance:"");
          const vn=vehicles.find(x=>x.code==(fleet[g.resId]||g.assignedVehicle));
          const currentVCode=fleet[g.resId]||g.assignedVehicle||"";
          const csvVehicle=srcRes?(srcRes.vehicleClass||srcRes.vehicle||"-"):g.vehicle||"-";
          // 配車selectの共通onChange
          const onVehicleChange=async(vc)=>{const vn2=vehicles.find(x=>x.code===vc);const tgt=delTask||colTask;if(vc&&!window.confirm("\u300c"+(vn2?vn2.name+" "+vn2.no:"")+"\u300d\u306b\u914d\u8eca\u3057\u307e\u3059\u304b\uff1f"))return;if(!vc&&currentVCode&&!window.confirm("\u914d\u8eca\u3092\u89e3\u9664\u3057\u307e\u3059\u304b\uff1f"))return;tasks.filter(x=>x.reservationId===g.resId).forEach(x=>selfUpdatedIds.current.set(x._id,Date.now()));if(tgt){const newV=vn2?vn2.type:tgt.vehicle;const newP=vn2?vn2.no:"";if(tgt.reservationId)onFleetChange(prev=>{const nf={...(typeof prev==="object"?prev:fleetRef.current)};if(vc)nf[tgt.reservationId]=vc;else delete nf[tgt.reservationId];return nf;});let updAll;setTasks(ts=>{updAll=ts.map(x=>x.reservationId===g.resId?{...x,assignedVehicle:vc,plateNo:newP,vehicle:newV}:x);DB._lsSave(updAll,selDate);return updAll;});pendingSaves.current++;setSaveStatus("saving");await DB.upsertTasks(updAll,selDate);pendingSaves.current--;setSaveStatus(DB._dbSaveOk?(pendingSaves.current>0?"saving":"ok"):"error");if(vn2&&g.resId){DB.updateReservationField(g.resId,{vehicle:vn2.type},"配車変更→クラス同期","op_edit");if(onReservationUpdate)onReservationUpdate(g.resId,{vehicle:vn2.type});}}else{onFleetChange(prev=>{const nf={...(typeof prev==="object"?prev:fleetRef.current)};if(vc)nf[g.resId]=vc;else delete nf[g.resId];return nf;});if(vn2&&g.resId){DB.updateReservationField(g.resId,{vehicle:vn2.type},"配車変更→クラス同期","op_edit");if(onReservationUpdate)onReservationUpdate(g.resId,{vehicle:vn2.type});}}};
          const vSelect=<select value={hasTasks?(delTask||colTask||{}).assignedVehicle||"":currentVCode} onChange={e=>onVehicleChange(e.target.value)} style={{border:"1px solid #ddd6fe",background:"#fff",borderRadius:6,padding:"3px 8px",fontSize:11,fontWeight:700,color:currentVCode?"#6d28d9":"#c4b5fd",flex:1,cursor:"pointer"}}><option value="">未配車</option>{[...new Set(vehicles.map(v=>v.type))].map(cls=><optgroup key={cls} label={cls+"\u30af\u30e9\u30b9"}>{vehicles.filter(v=>v.type===cls).map(v=>{const conflict=v.code!==currentVCode&&checkVehicleConflict(v.code,g.resId,reservations,fleet,maintenance);return <option key={v.code} value={v.code} disabled={conflict}>{v.name} ({v.no}){conflict?" \u00d7":""}</option>;})}</optgroup>)}</select>;

          // ★ 共通の階層行コンポーネント
          const TierRow=({icon,label,csvVal,ssVal,ssTime,currentVal,renderEdit})=><div style={{padding:"10px 12px",borderBottom:"1px solid #e2e8f0"}}>
            <div style={{display:"flex",alignItems:"baseline",gap:8,marginBottom:8}}>
              <span style={{fontSize:11,fontWeight:700,color:"#475569"}}>{icon} {label}</span>
              <span style={{fontSize:14,fontWeight:800,color:currentVal?"#0f172a":"#94a3b8"}}>{currentVal||"-"}</span>
            </div>
            <div style={{borderRadius:8,border:"1px solid #e2e8f0",overflow:"hidden"}}>
              <div style={{display:"flex",alignItems:"center",padding:"6px 10px",background:"#f8fafc",borderBottom:"1px solid #e2e8f0",gap:8}}>
                <span style={{fontSize:9,fontWeight:800,color:"#94a3b8",width:16,textAlign:"center",flexShrink:0}}>①</span>
                <span style={{fontSize:9,fontWeight:700,color:"#94a3b8",width:50,flexShrink:0}}>CSV元値</span>
                <span style={{fontSize:11,fontWeight:600,color:"#64748b"}}>{csvVal||"-"}</span>
                <span style={{marginLeft:"auto",fontSize:8,color:"#cbd5e1"}}>読取専用</span>
              </div>
              <div style={{display:"flex",alignItems:"center",padding:"6px 10px",background:"#eff6ff",borderBottom:"1px solid #dbeafe",gap:8}}>
                <span style={{fontSize:9,fontWeight:800,color:"#3b82f6",width:16,textAlign:"center",flexShrink:0}}>②</span>
                <span style={{fontSize:9,fontWeight:700,color:"#3b82f6",width:50,flexShrink:0}}>SS自動</span>
                <span style={{fontSize:11,fontWeight:600,color:ssVal?"#1d4ed8":"#93c5fd"}}>{ssVal||"-"}</span>
                <span style={{marginLeft:"auto",fontSize:8,color:ssTime?"#60a5fa":"#bfdbfe"}}>{ssTime||"未取得"}</span>
              </div>
              <div style={{display:"flex",alignItems:"center",padding:"6px 10px",background:"#faf5ff",gap:8}}>
                <span style={{fontSize:9,fontWeight:800,color:"#7c3aed",width:16,textAlign:"center",flexShrink:0}}>③</span>
                <span style={{fontSize:9,fontWeight:700,color:"#7c3aed",width:50,flexShrink:0}}>手動変更</span>
                {renderEdit}
                <span style={{fontSize:8,color:"#d8b4fe",flexShrink:0}}>最優先</span>
              </div>
            </div>
          </div>;

          return <div style={{display:"flex",flexDirection:"column",gap:0}}>
            {/* ===== 配車（3階層） ===== */}
            <TierRow icon="🚙" label="配車" csvVal={csvVehicle} ssVal="-" ssTime="未対応" currentVal={vn?(vn.name+" ("+vn.no+")"):"未配車"} renderEdit={vSelect}/>

            {/* ===== オプション B/C/USB（3階層） ===== */}
            {[{k:"b",label:"B",resKey:"optB"},{k:"c",label:"C",resKey:"optC"},{k:"usb",label:"USB",resKey:"optUSB"}].map(opt=>{
              const csvV=+(csvOpts[opt.k]||0);
              const curV=+(liveOpts[opt.k]||0);
              return <TierRow key={opt.k} icon="📦" label={opt.label} csvVal={String(csvV)} ssVal="-" ssTime="未対応" currentVal={String(curV)} renderEdit={
                <input type="number" min="0" max="9" value={curV} onChange={e=>{const v=parseInt(e.target.value)||0;if(!window.confirm(opt.label+"を変更しますか？"))return;const tgt=delTask||colTask;if(tgt){const newOpts={...(tgt.opts||{}),[opt.k]:v};const u=mark({...tgt,opts:newOpts},"opt_"+opt.k);upd(tgt._id,u,tgt.reservationId?{fields:{[opt.resKey]:v},type:"\u2460\u7269\u54c1OP:\u624b\u52d5\u5909\u66f4",source:"manual"}:undefined);}else if(g.resId){DB.updateReservationField(g.resId,{[opt.resKey]:v},"\u2460\u7269\u54c1OP:\u624b\u52d5\u5909\u66f4","manual");if(onReservationUpdate)onReservationUpdate(g.resId,{[opt.resKey]:v});}}} style={{border:"1px solid #ddd6fe",background:"#fff",borderRadius:6,padding:"3px 8px",fontSize:12,width:55,fontWeight:700,color:"#6d28d9",textAlign:"center"}}/>
              }/>;
            })}

            {/* ===== 補償（3階層） ===== */}
            <TierRow icon="🛡️" label="補償" csvVal={csvIns||"-"} ssVal="-" ssTime="未対応" currentVal={insVal||"-"} renderEdit={
              <select value={insVal||""} onChange={e=>{const v=e.target.value;if(v===(insVal||""))return;if(!window.confirm("補償を「"+v+"」に変更しますか？"))return;if(insTask){const u=mark({...insTask,insurance:v},"insurance");upd(insTask._id,u,insTask.reservationId?{fields:{insurance:v},type:"\u2461\u88dc\u511f:\u624b\u52d5\u5909\u66f4",source:"manual"}:undefined);}else if(g.resId){DB.updateReservationField(g.resId,{insurance:v},"\u2461\u88dc\u511f:\u624b\u52d5\u5909\u66f4","manual");if(onReservationUpdate)onReservationUpdate(g.resId,{insurance:v});}}} style={{border:"1px solid #ddd6fe",background:"#fff",borderRadius:6,padding:"3px 8px",fontSize:12,fontWeight:700,color:"#6d28d9",flex:1,cursor:"pointer"}}><option value="">-</option><option value="免責">免責</option><option value="NOC">NOC</option><option value="なし">なし</option></select>
            }/>

            {/* クラス表示は削除済み（マスター表で確認） */}

            {/* ===== メモ（シンプル1行入力） ===== */}
            {(()=>{const memoTask=delTask||colTask;const memoVal=memoTask?memoTask.memo||"":"";
              return <div style={{padding:"8px 12px",borderBottom:"1px solid #e2e8f0",display:"flex",alignItems:"center",gap:8}}>
                <span style={{fontSize:11,fontWeight:700,color:"#475569",flexShrink:0}}>📝 メモ</span>
                {memoTask?<input key={memoVal} defaultValue={memoVal} onBlur={e=>{const v=e.target.value;if(v===memoVal)return;if(!window.confirm("メモを変更しますか？")){e.target.value=memoVal;return;}upd(memoTask._id,mark({...memoTask,memo:v},"memo"));}} style={{border:"1px solid #d1d5db",background:"#fff",borderRadius:8,padding:"5px 10px",fontSize:12,fontWeight:600,color:"#0f172a",flex:1}} placeholder="メモを入力..."/>
                :<span style={{fontSize:11,color:"#94a3b8"}}>タスクなし</span>}
              </div>;
            })()}
          </div>;
        };

        return <div>
          {/* ★ ナビゲーション */}
          <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:8,position:"sticky",top:0,zIndex:10,background:"#f3f4f6",padding:"6px 0"}}>
            <button onClick={()=>{
              if(editBlock){setEditBlock(null);}
              else if(editResId){setEditResId(null);setOpView("master");}
              else{setOpView("master");}
            }} style={{background:"#334155",color:"#fff",border:"none",borderRadius:8,padding:"6px 14px",fontSize:12,fontWeight:700,cursor:"pointer",boxShadow:"0 1px 3px rgba(0,0,0,.15)"}}>
              {editBlock?"← 戻る":editResId?"← マスター":"← マスター"}
            </button>
            {editResId&&!editBlock&&<span style={{fontSize:11,color:"#64748b"}}>予約: <span style={{fontFamily:"monospace",fontWeight:700,color:"#0f172a"}}>{editResId}</span></span>}
            {editBlock&&<span style={{fontSize:11,fontWeight:700,color:editBlock==="dep"?"#1e40af":editBlock==="ret"?"#b91c1c":"#334155"}}>
              {editBlock==="dep"?"🚗 出発 編集":editBlock==="ret"?"🔑 返却 編集":"🚙 配車・オプション"}
            </span>}
            <button onClick={()=>{if(onGoFleet)onGoFleet();else onClose();}} style={{background:"linear-gradient(135deg,#059669,#10b981)",color:"#fff",border:"2px solid #34d399",borderRadius:8,padding:"5px 14px",fontSize:12,fontWeight:800,cursor:"pointer",marginLeft:"auto",boxShadow:"0 2px 6px rgba(5,150,105,.4)"}}>🚗 配車表</button>
            {!editResId&&<button onClick={()=>{setOpView("master");}} style={{background:"#f1f5f9",color:"#475569",border:"1px solid #d1d5db",borderRadius:8,padding:"4px 12px",fontSize:11,fontWeight:600,cursor:"pointer"}}>マスター一覧</button>}
          </div>

          {/* ★ 予約未選択時: 全件リスト */}
          {!editResId&&<div>
            {groups.length===0&&<div style={{textAlign:"center",padding:32,color:"#94a3b8",fontSize:13}}>予約データがありません</div>}
            <div style={{display:"flex",flexDirection:"column",gap:4}}>
              {groups.map(g=>{
                const vn=vehicles.find(x=>x.code===g.assignedVehicle);
                const hasChange=g.tasks.some(t=>t.timeChange||t._placeSource==="manual"||t._timeChangeSource==="manual");
                const delTask=g.tasks.find(t=>t.type==="DEL"||t.type==="PU"||t.type==="PUB");
                const colTask=g.tasks.find(t=>t.type==="COL"||t.type==="BD"||t.type==="BDB");
                const delTime=delTask?resolvedTime(delTask):"";
                const colTime=colTask?resolvedTime(colTask):"";
                return <div key={g.resId} onClick={()=>{setEditResId(g.resId);setEditBlock(null);}} style={{background:"#fff",borderRadius:10,border:hasChange?"2px solid #7c3aed":"1px solid #e2e8f0",padding:"10px 12px",cursor:"pointer",boxShadow:"0 1px 3px rgba(0,0,0,.06)"}}>
                  <div style={{display:"flex",alignItems:"center",gap:5,marginBottom:3}}>
                    {g.ota&&<OBadge ota={g.ota}/>}
                    <span style={{fontWeight:800,fontSize:13,color:"#0f172a",flex:1}}>{g.name||"名前なし"}</span>
                    {hasChange&&<span style={{fontSize:8,fontWeight:700,color:"#fff",background:"#7c3aed",padding:"1px 6px",borderRadius:8}}>変更あり</span>}
                    <span style={{fontSize:11,color:"#94a3b8"}}>▶</span>
                  </div>
                  <div style={{display:"flex",gap:4,flexWrap:"wrap",fontSize:10,color:"#475569"}}>
                    {g.tasks.map(t=><span key={t._id+"_type"} style={{fontSize:9,fontWeight:700,color:"#fff",background:t.type==="DEL"||t.type==="PU"||t.type==="PUB"?"#2563eb":t.type==="COL"||t.type==="BD"||t.type==="BDB"?"#dc2626":"#64748b",padding:"0 5px",borderRadius:4}}>{t.type}</span>)}
                    <span style={{fontWeight:700}}>{g.people||0}名</span>
                    <span style={{fontWeight:700,color:"#2563eb"}}>{g.vehicle||""}</span>
                    <span style={{fontWeight:700,color:g.assignedVehicle?"#059669":"#dc2626"}}>{vn?vn.name:"未配車"}</span>
                    {delTime&&<span style={{fontWeight:700}}>🚗{delTime}</span>}
                    {colTime&&<span style={{fontWeight:700}}>🔑{colTime}</span>}
                  </div>
                </div>;
              })}
            </div>
          </div>}

          {/* ★ 予約選択済み + ブロック未選択: 入口カード表示 */}
          {editResId&&!editBlock&&(()=>{
            const g=groups[0];
            if(!g)return <div style={{textAlign:"center",padding:32,color:"#94a3b8",fontSize:13}}>予約データが見つかりません</div>;
            const srcRes=reservations.find(r=>r.id===g.resId);
            const delTask=g.tasks.find(t=>t.type==="DEL"||t.type==="PU"||t.type==="PUB");
            const colTask=g.tasks.find(t=>t.type==="COL"||t.type==="BD"||t.type==="BDB");
            const vn=vehicles.find(x=>x.code===g.assignedVehicle);
            const hasChange=g.tasks.some(t=>t.timeChange||t._placeSource==="manual"||t._timeChangeSource==="manual");
            const delTime=delTask?resolvedTime(delTask):"";
            const colTime=colTask?resolvedTime(colTask):"";
            const delPlace=delTask?resolvedPlace(delTask):"";
            const colPlace=colTask?resolvedPlace(colTask):"";
            return <div style={{display:"flex",flexDirection:"column",gap:8}}>
              {/* 予約ヘッダー */}
              <div style={{background:"#fff",borderRadius:12,border:hasChange?"2px solid #7c3aed":"1px solid #e2e8f0",padding:"12px 14px",boxShadow:"0 1px 4px rgba(0,0,0,.06)"}}>
                <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:6}}>
                  {g.ota&&<OBadge ota={g.ota}/>}
                  <span style={{fontWeight:800,fontSize:15,color:"#0f172a",flex:1}}>{g.name||"名前なし"}</span>
                  {hasChange&&<span style={{fontSize:9,fontWeight:700,color:"#fff",background:"#7c3aed",padding:"2px 8px",borderRadius:8}}>変更あり</span>}
                </div>
                <div style={{display:"flex",gap:6,flexWrap:"wrap",fontSize:11,color:"#475569"}}>
                  {g.tasks.map(t=><span key={t._id+"_type"} style={{fontSize:10,fontWeight:700,color:"#fff",background:t.type==="DEL"||t.type==="PU"||t.type==="PUB"?"#2563eb":t.type==="COL"||t.type==="BD"||t.type==="BDB"?"#dc2626":"#64748b",padding:"1px 6px",borderRadius:4}}>{t.type}</span>)}
                  <span style={{fontFamily:"monospace",background:"#f1f5f9",padding:"1px 6px",borderRadius:4,fontSize:10}}>{g.resId}</span>
                  <span style={{fontWeight:700}}>{g.people||0}名</span>
                  <span style={{fontWeight:700,color:"#2563eb"}}>{g.vehicle||""}</span>
                  <span style={{fontWeight:700,color:g.assignedVehicle?"#059669":"#dc2626"}}>{vn?vn.name:"未配車"}</span>
                  {g.flight&&<span style={{color:"#2563eb"}}>✈{g.flight}</span>}
                </div>
                {srcRes&&<div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:"2px 12px",marginTop:6,fontSize:10,color:"#64748b"}}>
                  <div>貸出: <span style={{fontWeight:700,color:"#0f172a"}}>{srcRes.lendDate||"-"} {srcRes.lendTime||""}</span></div>
                  <div>返却: <span style={{fontWeight:700,color:"#0f172a"}}>{srcRes.returnDate||"-"} {srcRes.returnTime||""}</span></div>
                  <div>人数: <span style={{fontWeight:700,color:"#0f172a"}}>{srcRes.people||0}名</span></div>
                </div>}
                {/* 個人情報セクション: 氏名・TEL・MAIL（表示のみ） */}
                {srcRes&&<div style={{marginTop:8,padding:"8px 10px",background:"#f8fafc",borderRadius:8,border:"1px solid #e2e8f0"}}>
                  <div style={{display:"flex",alignItems:"center",gap:4,marginBottom:4}}>
                    <span style={{fontSize:9,fontWeight:700,color:"#94a3b8"}}>個人情報</span>
                    <span style={{fontSize:8,color:"#94a3b8",background:"#e2e8f0",padding:"1px 6px",borderRadius:4,marginLeft:"auto"}}>編集不可</span>
                  </div>
                  <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:4}}>
                    <span style={{fontSize:10,fontWeight:700,color:"#475569",width:36,flexShrink:0}}>氏名</span>
                    <span style={{fontSize:12,fontWeight:800,color:"#0f172a"}}>{srcRes.name||g.name||"-"}</span>
                  </div>
                  <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:4}}>
                    <span style={{fontSize:10,fontWeight:700,color:"#475569",width:36,flexShrink:0}}>TEL</span>
                    <span style={{fontSize:11,fontWeight:600,color:"#0f172a"}}>{srcRes.tel||"-"}</span>
                  </div>
                  <div style={{display:"flex",alignItems:"center",gap:6}}>
                    <span style={{fontSize:10,fontWeight:700,color:"#475569",width:36,flexShrink:0}}>MAIL</span>
                    <span style={{fontSize:11,fontWeight:600,color:"#475569",wordBreak:"break-all"}}>{srcRes.mail||"-"}</span>
                  </div>
                </div>}
              </div>

              {/* ★ 3つの入口カード */}
              {/* 出発カード */}
              {(()=>{
                const dType=delTask?delTask.type:(srcRes?.visitType||"未設定");
                const dTime=delTask?delTime:(srcRes?.lendTime||"");
                const dPlace=delTask?delPlace:(srcRes?.delPlace||"");
                const dDate=srcRes?.lendDate||"";
                const dHasTask=!!delTask;
                const dTag=delTask?sourceTag(delTask,"time"):null;
                return <div onClick={()=>setEditBlock("dep")} style={{background:"linear-gradient(135deg,#1e40af,#2563eb)",borderRadius:12,padding:"14px 16px",cursor:"pointer",boxShadow:"0 2px 8px rgba(30,64,175,.25)",display:"flex",alignItems:"center",gap:12}}>
                  <div style={{fontSize:28}}>🚗</div>
                  <div style={{flex:1}}>
                    <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:4}}>
                      <span style={{fontSize:15,fontWeight:800,color:"#fff"}}>出発</span>
                      <span style={{fontSize:14,fontWeight:800,background:"rgba(255,255,255,.25)",padding:"1px 8px",borderRadius:6}}>{dType}</span>
                      <span style={{fontSize:16,fontWeight:900,color:"#fff",fontFamily:"monospace"}}>{dTime||"--:--"}</span>
                    </div>
                    <div style={{display:"flex",alignItems:"center",gap:6,fontSize:11,color:"rgba(255,255,255,.8)",fontWeight:600,flexWrap:"wrap"}}>
                      <span>{dDate}</span>
                      {dPlace&&<span>· {dPlace}</span>}
                      {!dHasTask&&<span style={{fontSize:8,fontWeight:700,background:"rgba(255,255,255,.25)",padding:"1px 6px",borderRadius:4}}>別日タスク</span>}
                      {dTag&&dTag.label!=="CSV"&&<span style={{fontSize:8,fontWeight:700,background:"rgba(255,255,255,.25)",padding:"1px 6px",borderRadius:4}}>{dTag.label}変更</span>}
                    </div>
                  </div>
                  <div style={{fontSize:18,color:"rgba(255,255,255,.6)"}}>▶</div>
                </div>;
              })()}

              {/* 返却カード */}
              {(()=>{
                const rType=colTask?colTask.type:(srcRes?.returnType||"未設定");
                const rTime=colTask?colTime:(srcRes?.returnTime||"");
                const rPlace=colTask?colPlace:(srcRes?.colPlace||"");
                const rDate=srcRes?.returnDate||"";
                const rHasTask=!!colTask;
                const rTag=colTask?sourceTag(colTask,"time"):null;
                return <div onClick={()=>setEditBlock("ret")} style={{background:"linear-gradient(135deg,#991b1b,#dc2626)",borderRadius:12,padding:"14px 16px",cursor:"pointer",boxShadow:"0 2px 8px rgba(153,27,27,.25)",display:"flex",alignItems:"center",gap:12}}>
                  <div style={{fontSize:28}}>🔑</div>
                  <div style={{flex:1}}>
                    <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:4}}>
                      <span style={{fontSize:15,fontWeight:800,color:"#fff"}}>返却</span>
                      <span style={{fontSize:14,fontWeight:800,background:"rgba(255,255,255,.25)",padding:"1px 8px",borderRadius:6}}>{rType}</span>
                      <span style={{fontSize:16,fontWeight:900,color:"#fff",fontFamily:"monospace"}}>{rTime||"--:--"}</span>
                    </div>
                    <div style={{display:"flex",alignItems:"center",gap:6,fontSize:11,color:"rgba(255,255,255,.8)",fontWeight:600,flexWrap:"wrap"}}>
                      <span>{rDate}</span>
                      {rPlace&&<span>· {rPlace}</span>}
                      {!rHasTask&&<span style={{fontSize:8,fontWeight:700,background:"rgba(255,255,255,.25)",padding:"1px 6px",borderRadius:4}}>別日タスク</span>}
                      {rTag&&rTag.label!=="CSV"&&<span style={{fontSize:8,fontWeight:700,background:"rgba(255,255,255,.25)",padding:"1px 6px",borderRadius:4}}>{rTag.label}変更</span>}
                    </div>
                  </div>
                  <div style={{fontSize:18,color:"rgba(255,255,255,.6)"}}>▶</div>
                </div>;
              })()}

              {/* 共通カード */}
              <div onClick={()=>setEditBlock("common")} style={{background:"linear-gradient(135deg,#1e293b,#334155)",borderRadius:12,padding:"16px 16px",cursor:"pointer",boxShadow:"0 2px 8px rgba(30,41,59,.25)",transition:"transform .1s",display:"flex",alignItems:"center",gap:12}}>
                <div style={{fontSize:28}}>🚙</div>
                <div style={{flex:1}}>
                  <div style={{fontSize:15,fontWeight:800,color:"#fff",marginBottom:2}}>配車・オプション</div>
                  <div style={{fontSize:11,color:"rgba(255,255,255,.8)",fontWeight:600}}>
                    {vn?<span>{vn.name} ({vn.no})</span>:<span style={{color:"#fca5a5"}}>未配車</span>}
                  </div>
                </div>
                <div style={{fontSize:18,color:"rgba(255,255,255,.6)"}}>▶</div>
              </div>
            </div>;
          })()}

          {/* ★ ブロック選択済み: 編集フィールド表示 */}
          {editResId&&editBlock&&(()=>{
            const g=groups[0];
            if(!g)return null;
            const srcRes=reservations.find(r=>r.id===g.resId);
            const delTask=g.tasks.find(t=>t.type==="DEL"||t.type==="PU"||t.type==="PUB");
            const colTask=g.tasks.find(t=>t.type==="COL"||t.type==="BD"||t.type==="BDB");
            if(editBlock==="dep"){
              const blk={tk:delTask,label:"出発",icon:"🚗",bg:"#1e40af",timeField:"delTime",placeField:"delPlace",dateKey:"lendDate",timeKey:"lendTime"};
              return <div style={{background:"#fff",borderRadius:12,border:"2px solid #2563eb",overflow:"hidden",boxShadow:"0 2px 8px rgba(37,99,235,.15)"}}>
                <div style={{background:"linear-gradient(135deg,#1e40af,#2563eb)",color:"#fff",padding:"10px 14px",display:"flex",flexDirection:"column",gap:6}}>
                  <div style={{display:"flex",alignItems:"center",gap:8,flexWrap:"wrap",fontSize:14,fontWeight:800}}>
                    <span style={{fontSize:20}}>🚗</span><span>出発</span>
                    {delTask&&<span style={{fontSize:14,fontWeight:800,background:"rgba(255,255,255,.25)",padding:"2px 10px",borderRadius:6}}>{delTask.type}</span>}
                    {!delTask&&srcRes&&<span style={{fontSize:12,fontWeight:700,background:"rgba(255,255,255,.2)",padding:"2px 10px",borderRadius:6}}>貸出: {srcRes.visitType||"未設定"}</span>}
                    <span style={{fontSize:13,fontWeight:800}}>{g.name||srcRes?.name||""}</span>
                    <span style={{fontSize:10,fontWeight:600,background:"rgba(255,255,255,.2)",padding:"2px 8px",borderRadius:4,fontFamily:"monospace"}}>{g.resId}</span>
                  </div>
                  {srcRes&&<div style={{display:"flex",alignItems:"center",gap:6,flexWrap:"wrap"}}>
                    <span style={{fontSize:11,fontWeight:700,opacity:.8}}>📅</span>
                    <span style={{fontSize:11,fontWeight:600,opacity:.7}}>{srcRes.lendDate||"-"} {srcRes.lendTime||""}</span>
                    <span style={{fontSize:10,opacity:.5}}>→</span>
                    <input type="date" value={srcRes.lendDate||""} onChange={e=>{const v=e.target.value;setTimeout(()=>{if(!window.confirm("予約日を「"+v+"」に変更しますか？")){e.target.value=srcRes.lendDate||"";return;}DB.updateReservationField(g.resId,{lendDate:v},"\u2462\u671f\u9593:\u624b\u52d5\u5909\u66f4","manual");if(onReservationUpdate)onReservationUpdate(g.resId,{lendDate:v});setTimeout(()=>loadTasks(selDate,true),500);},50);}} style={{border:"1px solid rgba(255,255,255,.3)",borderRadius:6,padding:"3px 6px",fontSize:11,color:"#fff",background:"rgba(255,255,255,.15)",width:115}}/>
                    <select value={srcRes.lendTime||""} onChange={e=>{const v=e.target.value;setTimeout(()=>{if(!window.confirm("予約時間を「"+(v||"クリア")+"」に変更しますか？"))return;DB.updateReservationField(g.resId,{lendTime:v},"\u2462\u671f\u9593:\u624b\u52d5\u5909\u66f4","manual");if(onReservationUpdate)onReservationUpdate(g.resId,{lendTime:v});setTimeout(()=>loadTasks(selDate,true),500);},50);}} style={{border:"1px solid rgba(255,255,255,.3)",borderRadius:6,padding:"3px 6px",fontSize:11,color:"#fff",background:"rgba(255,255,255,.15)",width:70}}>
                      {TIME_OPTS.map(o=><option key={o} value={o} style={{color:"#000"}}>{o||"-"}</option>)}
                      {srcRes.lendTime&&!TIME_OPTS.includes(srcRes.lendTime)&&<option value={srcRes.lendTime} style={{color:"#000"}}>{srcRes.lendTime}</option>}
                    </select>
                  </div>}
                </div>
                {renderBlockFields(blk,g,srcRes)}
              </div>;
            }
            if(editBlock==="ret"){
              const blk={tk:colTask,label:"返却",icon:"🔑",bg:"#b91c1c",timeField:"colTime",placeField:"colPlace",dateKey:"returnDate",timeKey:"returnTime"};
              return <div style={{background:"#fff",borderRadius:12,border:"2px solid #dc2626",overflow:"hidden",boxShadow:"0 2px 8px rgba(220,38,38,.15)"}}>
                <div style={{background:"linear-gradient(135deg,#991b1b,#dc2626)",color:"#fff",padding:"10px 14px",display:"flex",flexDirection:"column",gap:6}}>
                  <div style={{display:"flex",alignItems:"center",gap:8,flexWrap:"wrap",fontSize:14,fontWeight:800}}>
                    <span style={{fontSize:20}}>🔑</span><span>返却</span>
                    {colTask&&<span style={{fontSize:14,fontWeight:800,background:"rgba(255,255,255,.25)",padding:"2px 10px",borderRadius:6}}>{colTask.type}</span>}
                    {!colTask&&srcRes&&<span style={{fontSize:12,fontWeight:700,background:"rgba(255,255,255,.2)",padding:"2px 10px",borderRadius:6}}>返却: {srcRes.returnType||"未設定"}</span>}
                    <span style={{fontSize:13,fontWeight:800}}>{g.name||srcRes?.name||""}</span>
                    <span style={{fontSize:10,fontWeight:600,background:"rgba(255,255,255,.2)",padding:"2px 8px",borderRadius:4,fontFamily:"monospace"}}>{g.resId}</span>
                  </div>
                  {srcRes&&<div style={{display:"flex",alignItems:"center",gap:6,flexWrap:"wrap"}}>
                    <span style={{fontSize:11,fontWeight:700,opacity:.8}}>📅</span>
                    <span style={{fontSize:11,fontWeight:600,opacity:.7}}>{srcRes.returnDate||"-"} {srcRes.returnTime||""}</span>
                    <span style={{fontSize:10,opacity:.5}}>→</span>
                    <input type="date" value={srcRes.returnDate||""} onChange={e=>{const v=e.target.value;setTimeout(()=>{if(!window.confirm("予約日を「"+v+"」に変更しますか？")){e.target.value=srcRes.returnDate||"";return;}DB.updateReservationField(g.resId,{returnDate:v},"\u2462\u671f\u9593:\u624b\u52d5\u5909\u66f4","manual");if(onReservationUpdate)onReservationUpdate(g.resId,{returnDate:v});setTimeout(()=>loadTasks(selDate,true),500);},50);}} style={{border:"1px solid rgba(255,255,255,.3)",borderRadius:6,padding:"3px 6px",fontSize:11,color:"#fff",background:"rgba(255,255,255,.15)",width:115}}/>
                    <select value={srcRes.returnTime||""} onChange={e=>{const v=e.target.value;setTimeout(()=>{if(!window.confirm("予約時間を「"+(v||"クリア")+"」に変更しますか？"))return;DB.updateReservationField(g.resId,{returnTime:v},"\u2462\u671f\u9593:\u624b\u52d5\u5909\u66f4","manual");if(onReservationUpdate)onReservationUpdate(g.resId,{returnTime:v});setTimeout(()=>loadTasks(selDate,true),500);},50);}} style={{border:"1px solid rgba(255,255,255,.3)",borderRadius:6,padding:"3px 6px",fontSize:11,color:"#fff",background:"rgba(255,255,255,.15)",width:70}}>
                      {TIME_OPTS.map(o=><option key={o} value={o} style={{color:"#000"}}>{o||"-"}</option>)}
                      {srcRes.returnTime&&!TIME_OPTS.includes(srcRes.returnTime)&&<option value={srcRes.returnTime} style={{color:"#000"}}>{srcRes.returnTime}</option>}
                    </select>
                  </div>}
                </div>
                {renderBlockFields(blk,g,srcRes)}
              </div>;
            }
            if(editBlock==="common"){
              const vn=g.assignedVehicle?vehicles.find(v=>v.code===g.assignedVehicle):null;
              return <div style={{background:"#fff",borderRadius:12,border:"2px solid #334155",overflow:"hidden",boxShadow:"0 2px 8px rgba(30,41,59,.15)"}}>
                <div style={{background:"linear-gradient(135deg,#1e293b,#334155)",color:"#fff",padding:"10px 14px",fontSize:14,fontWeight:800,display:"flex",alignItems:"center",gap:8,flexWrap:"wrap"}}>
                  <span style={{fontSize:20}}>🚙</span><span>配車・オプション</span>
                  <span style={{fontSize:13,fontWeight:800,marginLeft:4}}>{g.name||srcRes?.name||""}</span>
                  <span style={{fontSize:10,fontWeight:600,background:"rgba(255,255,255,.2)",padding:"2px 8px",borderRadius:4,fontFamily:"monospace"}}>{g.resId}</span>
                  {(vn||g.vehicle)&&<span style={{fontSize:11,fontWeight:700,background:"rgba(255,255,255,.2)",padding:"2px 8px",borderRadius:4}}>{vn?vn.name+(vn.no?" ("+vn.no+")":""):g.vehicle}</span>}
                </div>
                {renderCommonBlock(g,srcRes)}
              </div>;
            }
            return null;
          })()}
        </div>;
      })()}
      <TimeTable tasks={tasks} staffCount={staffCount}/>
      {/* LINE送信モーダル */}
      {lineModal&&(()=>{
        const m=lineModal;const custName=(m.name||"")+"様";
        const clipCopy=(txt)=>navigator.clipboard.writeText(txt);
        const close=()=>setLineModal(null);
        const btnS=(bg,border,color)=>({display:"block",width:"100%",padding:"14px 16px",background:bg,border:"2px solid "+border,borderRadius:12,fontSize:14,fontWeight:700,color,cursor:"pointer",marginBottom:8,textAlign:"left"});
        return <div onClick={close} style={{position:"fixed",top:0,left:0,right:0,bottom:0,background:"rgba(0,0,0,.5)",zIndex:9999,display:"flex",alignItems:"center",justifyContent:"center",padding:16}}>
          <div onClick={e=>e.stopPropagation()} style={{background:"#fff",borderRadius:16,padding:20,width:"100%",maxWidth:360,maxHeight:"90vh",overflowY:"auto",boxShadow:"0 20px 60px rgba(0,0,0,.25)"}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
              <div style={{fontSize:15,fontWeight:800,color:"#1e293b"}}>📱 {m.name}</div>
              <button onClick={close} style={{background:"none",border:"none",fontSize:20,color:"#94a3b8",cursor:"pointer",padding:"4px 8px"}}>✕</button>
            </div>
            <div style={{fontSize:11,color:"#64748b",marginBottom:12,padding:"6px 10px",background:"#f8fafc",borderRadius:8}}>
              {m.vehName&&<span>{m.vehName} </span>}{m.plateNo&&<span>({m.plateNo}) </span>}{m.place&&<span>📍{m.place}</span>}
            </div>
            {m.isDel?<div>
              <div style={{fontSize:11,fontWeight:700,color:"#059669",marginBottom:6}}>LINE テンプレート</div>
              <button onClick={()=>{const msg=`【車両到着のお知らせ】\n${custName}\n\nお待たせいたしました。\n只今スタッフが指定場所に到着いたしました。\n\n場所: ${m.place}\n車種: ${m.vehName}\nナンバー: ${m.plateNo}\n\nご準備整い次第、受け取り対応をお願い申し上げます。\nお手続きは全て完了しておりますので、車両の受け渡しのみスムーズにお貸出させていただきます。`;clipCopy(msg).then(()=>{alert("📋 到着メッセージをコピーしました\n\nL Messageで「"+m.name+"」を検索して貼り付け");close();});}} style={btnS("#f0fdf4","#86efac","#15803d")}>📱① 到着のお知らせ</button>
              <button onClick={()=>{const msg=`【車両位置情報のお知らせ】\n${custName}\n\n現在車両をデリバリー中です。\n詳細はマップリンクから位置情報をご確認ください。\n\n＜車両情報＞\nお届け場所: ${m.place}\n車種: ${m.vehName}\nナンバー: ${m.plateNo}\n\n＜車両位置情報＞\n`;clipCopy(msg).then(()=>{alert("📋 位置情報メッセージをコピーしました\n\nL Messageで「"+m.name+"」を検索して貼り付け");close();});}} style={btnS("#eff6ff","#93c5fd","#1d4ed8")}>📱② 位置情報のお知らせ</button>
            </div>:<div>
              <button onClick={()=>{const msg=`【ご返却場所到着のお知らせ】\n${custName}\n\n回収スタッフがご返却場所に到着致しました。\nご準備できましたら対応のほどお願い申しあげます。\n何卒よろしくお願いいたします。`;clipCopy(msg).then(()=>{alert("📋 COLメッセージをコピーしました\n\nL Messageで「"+m.name+"」を検索して貼り付け");close();});}} style={btnS("#f0fdf4","#86efac","#15803d")}>📱① 返却場所到着のお知らせ</button>
              <button onClick={()=>{const msg=`【乗り捨て対応のお願い】\n${custName}\n\nご返却時刻の混雑により、大変お手数ではございますが返却予定場所近隣駐車場に乗り捨て駐車いただきたく、ご連絡させていただきました。\nお待たせする時間回避の目的のためご協力の程何卒よろしくお願いいたします。\n\n✅駐車完了しましたら"鍵と駐車券"をダッシュボード内に格納し、鍵を開けた状態でそのままお降りくださいませ。\n✅燃料の給油とお忘れ物（ETCカード等）のないようご注意ください。\n✅駐車場所が確定しましたら詳細場所をご連絡いただけますと幸いです。\n例：駐車場看板写真/GoogleマップURL/住所/駐車場名/●階等\n\n駐車後の車両トラブルに関しては一切の責任は問いませんのでご安心くださいませ。\n万一の盗難等の際にも弊社セキュリティにて追跡可能となっております。`;clipCopy(msg).then(()=>{alert("📋 乗り捨て依頼メッセージをコピーしました\n\nL Messageで「"+m.name+"」を検索して貼り付け");close();});}} style={btnS("#fef2f2","#fca5a5","#b91c1c")}>📱② 乗り捨て依頼</button>
            </div>}
          </div>
        </div>;
      })()}
    </div>
  </div>;
}

function AddTaskForm({onAdd,onClose,activeMembers,vehicles}){
  const[type,setType]=useState("事前駐車");const[time,setTime]=useState("09:00");const[name,setName]=useState("");const[customerName,setCustomerName]=useState("");const[assignee,setAssignee]=useState("");const[vehicle,setVehicle]=useState("");const[place,setPlace]=useState("");const[memo,setMemo]=useState("");
  const classes=[...new Set(vehicles.map(v=>v.type))];
  const submit=()=>{if(!type)return;const v=vehicles.find(x=>x.code===vehicle);onAdd({_id:uid(),type,time,name:customerName||name,assignee,vehicle:v?v.type:"",place,people:0,insurance:"",done:false,memo,reservationId:"",ota:"",assignedVehicle:vehicle,plateNo:v?v.no:"",manual:true});onClose();};
  return <div className="modal-overlay" onClick={onClose}><div className="modal-box" style={{maxWidth:420,padding:20}} onClick={e=>e.stopPropagation()}>
    <h3 className="font-bold text-sm mb-3">タスク追加</h3>
    <div className="space-y-2">
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}><div><label className="text-xs text-gray-500">種別</label><select value={type} onChange={e=>setType(e.target.value)} className="input-s">{Object.keys(TASK_META).map(k=><option key={k}>{k}</option>)}</select></div><div><label className="text-xs text-gray-500">時間</label><input value={time} onChange={e=>setTime(e.target.value)} className="input-s"/></div></div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}><div><label className="text-xs text-gray-500">予約者名</label><input value={customerName} onChange={e=>setCustomerName(e.target.value)} className="input-s" placeholder="お客様名"/></div><div><label className="text-xs text-gray-500">担当</label><select value={assignee} onChange={e=>setAssignee(e.target.value)} className="input-s"><option value="">未定</option>{activeMembers.map(m=><option key={m}>{m}</option>)}</select></div></div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}><div><label className="text-xs text-gray-500">車両</label><select value={vehicle} onChange={e=>setVehicle(e.target.value)} className="input-s"><option value="">—</option>{classes.map(cls=><optgroup key={cls} label={cls+"クラス"}>{vehicles.filter(v=>v.type===cls).map(v=><option key={v.id} value={v.code}>{v.name}({v.no})</option>)}</optgroup>)}</select></div><div><label className="text-xs text-gray-500">場所</label><input value={place} onChange={e=>setPlace(e.target.value)} className="input-s" placeholder="新千歳空港 etc."/></div></div>
      <input value={memo} onChange={e=>setMemo(e.target.value)} className="input-s" placeholder="メモ"/>
    </div>
    <div className="flex justify-end gap-2 mt-3"><button onClick={onClose} className="btn-ghost">キャンセル</button><button onClick={submit} className="btn-primary">追加</button></div>
  </div></div>;
}

/* ==========================================
   📊 ダッシュボード
   ========================================== */


function Dashboard({data,fleet,vehicles,maintenance}){
  // ビュー切替（月別 vs 年間推移）
  const[dashView,setDashView]=useState("monthly"); // "monthly" | "annual"
  const[annTab,setAnnTab]=useState("revenue"); // 年間推移サブタブ
  // 月選択
  const allMonths=useMemo(()=>{
    const ms=new Set();
    data.forEach(r=>{if(r.lendDate)ms.add(toYM(r.lendDate));if(r.returnDate)ms.add(toYM(r.returnDate));});
    return[...ms].sort();
  },[data]);
  const curYM=toYM(new Date());
  const[selYM,setSelYM]=useState(curYM);
  const prevYM=ymOff(selYM,-1);

  // 対象月のデータ抽出（返却日が選択月に含まれる予約＝売上計上基準）キャンセル除外
  const monthData=useMemo(()=>data.filter(r=>r.status!=="cancelled"&&r.returnDate&&toYM(r.returnDate)===selYM),[data,selYM]);
  const prevMonthData=useMemo(()=>data.filter(r=>r.status!=="cancelled"&&r.returnDate&&toYM(r.returnDate)===prevYM),[data,prevYM]);

  // === KPI計算 ===
  // 売上
  const totalRevenue=useMemo(()=>monthData.reduce((s,r)=>s+(Number(r.price)||0),0),[monthData]);
  const prevRevenue=useMemo(()=>prevMonthData.reduce((s,r)=>s+(Number(r.price)||0),0),[prevMonthData]);
  const revDiff=prevRevenue>0?((totalRevenue-prevRevenue)/prevRevenue*100):0;

  // 予約件数
  const totalCount=monthData.length;
  const prevCount=prevMonthData.length;

  // 平均単価
  const avgPrice=totalCount>0?Math.round(totalRevenue/totalCount):0;
  const prevAvgPrice=prevCount>0?Math.round(prevRevenue/prevCount):0;

  // OTA別売上
  const otaStats=useMemo(()=>{
    const m={};
    monthData.forEach(r=>{const k=r.ota||"?";if(!m[k])m[k]={count:0,revenue:0};m[k].count++;m[k].revenue+=(Number(r.price)||0);});
    return Object.entries(m).sort((a,b)=>b[1].revenue-a[1].revenue);
  },[monthData]);

  // 稼働率計算（配車画面と同じロジック: 日付Setで重複排除 + メンテナンス込み + 月内限定）
  const daysInMo=daysInMonth(selYM);
  const activeVehicles=vehicles.length||8;
  const totalVehDays=activeVehicles*daysInMo;
  const maint=maintenance||[];
  const curUtil=useMemo(function(){
    var dim=daysInMo;
    var parts=selYM.split("-");var yy=Number(parts[0]);var mm=Number(parts[1])-1;
    var ms=new Date(yy,mm,1);var me=new Date(yy,mm,dim);
    // 予約による稼働日（車両別Set）
    var vdm={};
    data.forEach(function(r){
      if(r.status==="cancelled")return;
      if(!r.lendDate||!r.returnDate)return;
      var vc=fleet[r.id];if(!vc)return;
      if(!vdm[vc])vdm[vc]=new Set();
      var ld=new Date(norm(r.lendDate)+"T00:00:00");var rd=new Date(norm(r.returnDate)+"T00:00:00");
      var s=ld>ms?new Date(ld):new Date(ms);var e=rd<me?new Date(rd):new Date(me);
      for(var d=new Date(s);d<=e;d.setDate(d.getDate()+1)){vdm[vc].add(toLD(d));}
    });
    // メンテナンス日（車両別Set）→ 最大稼働日数から減算用
    var maintMap={};
    maint.forEach(function(mt){
      if(!mt.vehicleCode||!mt.startDate||!mt.endDate)return;
      if(!maintMap[mt.vehicleCode])maintMap[mt.vehicleCode]=new Set();
      var ld=new Date(norm(mt.startDate)+"T00:00:00");var rd=new Date(norm(mt.endDate)+"T00:00:00");
      var s=ld>ms?new Date(ld):new Date(ms);var e=rd<me?new Date(rd):new Date(me);
      for(var d=new Date(s);d<=e;d.setDate(d.getDate()+1)){maintMap[mt.vehicleCode].add(toLD(d));}
    });
    var totalRental=0;Object.values(vdm).forEach(function(s){totalRental+=s.size;});
    var totalMaint=0;Object.values(maintMap).forEach(function(s){totalMaint+=s.size;});
    return{totalRental:totalRental,totalMaint:totalMaint,vehDayMap:vdm,maintMap:maintMap};
  },[selYM,data,fleet,maint,daysInMo]);
  const usedDays=curUtil.totalRental;
  const curVehDayMap=curUtil.vehDayMap;
  const curMaintMap=curUtil.maintMap;
  const totalMaintDays=curUtil.totalMaint;
  const availVehDays=totalVehDays-totalMaintDays;
  const utilRate=availVehDays>0?Math.round(usedDays/availVehDays*100):0;
  // 前月稼働率
  const prevDaysInMo=daysInMonth(prevYM);
  const prevTotalVehDays=activeVehicles*prevDaysInMo;
  const prevUtil=useMemo(function(){
    var dim=prevDaysInMo;
    var parts=prevYM.split("-");var yy=Number(parts[0]);var mm=Number(parts[1])-1;
    var ms=new Date(yy,mm,1);var me=new Date(yy,mm,dim);
    // 予約稼働日
    var vdm={};
    data.forEach(function(r){
      if(r.status==="cancelled")return;
      if(!r.lendDate||!r.returnDate)return;
      var vc=fleet[r.id];if(!vc)return;
      if(!vdm[vc])vdm[vc]=new Set();
      var ld=new Date(norm(r.lendDate)+"T00:00:00");var rd=new Date(norm(r.returnDate)+"T00:00:00");
      var s=ld>ms?new Date(ld):new Date(ms);var e=rd<me?new Date(rd):new Date(me);
      for(var d=new Date(s);d<=e;d.setDate(d.getDate()+1)){vdm[vc].add(toLD(d));}
    });
    // メンテ日数
    var maintTotal=0;
    maint.forEach(function(mt){
      if(!mt.vehicleCode||!mt.startDate||!mt.endDate)return;
      var mSet=new Set();
      var ld=new Date(norm(mt.startDate)+"T00:00:00");var rd=new Date(norm(mt.endDate)+"T00:00:00");
      var s=ld>ms?new Date(ld):new Date(ms);var e=rd<me?new Date(rd):new Date(me);
      for(var d=new Date(s);d<=e;d.setDate(d.getDate()+1)){mSet.add(toLD(d));}
      maintTotal+=mSet.size;
    });
    var rental=0;Object.values(vdm).forEach(function(s){rental+=s.size;});
    return{rental:rental,maintTotal:maintTotal};
  },[prevYM,data,fleet,maint,prevDaysInMo]);
  const prevUsedDays=prevUtil.rental;
  const prevAvailVehDays=prevTotalVehDays-prevUtil.maintTotal;
  const prevUtilRate=prevAvailVehDays>0?Math.round(prevUsedDays/prevAvailVehDays*100):0;

  // 車両別売上（fleet配車コードで集計 + 月内実稼働日数で計算）
  const vehStats=useMemo(function(){
    var m={};
    monthData.forEach(function(r){
      var vc=fleet[r.id]||"未配車";
      if(!m[vc])m[vc]={count:0,revenue:0,days:0};
      m[vc].count++;m[vc].revenue+=(Number(r.price)||0);
    });
    Object.keys(m).forEach(function(vc){
      if(curVehDayMap&&curVehDayMap[vc]){m[vc].days=curVehDayMap[vc].size;}
    });
    return Object.entries(m).sort(function(a,b){return b[1].revenue-a[1].revenue;});
  },[monthData,fleet,curVehDayMap]);

  // 日別売上（棒グラフ用）
  const dailyRevenue=useMemo(()=>{
    const m={};
    for(let d=1;d<=daysInMo;d++){
      const ds=selYM+"-"+String(d).padStart(2,"0");
      m[ds]=0;
    }
    monthData.forEach(r=>{
      if(!r.returnDate||!r.price)return;
      const ds=r.returnDate;if(m[ds]!==undefined)m[ds]+=(Number(r.price)||0);
    });
    return Object.entries(m).map(([d,v])=>({day:parseInt(d.split("-")[2]),value:v}));
  },[monthData,selYM,daysInMo]);
  const maxDaily=Math.max(1,...dailyRevenue.map(d=>d.value));

  // 月次推移データ（データが存在する全月を表示）
  const monthlyTrend=useMemo(()=>{
    const dataMonths=new Set();
    data.forEach(r=>{if(r.status!=="cancelled"&&r.returnDate)dataMonths.add(toYM(r.returnDate));});
    dataMonths.add(curYM);
    const sorted=[...dataMonths].sort();
    const firstYM=sorted[0],lastYM=sorted[sorted.length-1];
    const months=[];let ym=firstYM;
    for(let i=0;i<36&&ym<=lastYM;i++){months.push(ym);ym=ymOff(ym,1);}
    return months.map(ym=>{
      const md=data.filter(r=>r.status!=="cancelled"&&r.returnDate&&toYM(r.returnDate)===ym);
      return{ym,label:(parseInt(ym.split("-")[1]))+"月",revenue:md.reduce((s,r)=>s+(Number(r.price)||0),0),count:md.length};
    });
  },[data,curYM]);
  const maxMonthlyRev=Math.max(1,...monthlyTrend.map(m=>m.revenue));

  // 車種別稼働率（メンテ日数を最大稼働日数から減算）
  const vehUtilDetail=useMemo(()=>{
    return vehicles.map(v=>{
      const days=(curVehDayMap[v.code]||new Set()).size;
      const mDays=(curMaintMap[v.code]||new Set()).size;
      const avail=daysInMo-mDays;
      return{code:v.code,name:v.name,no:v.no,days,maintDays:mDays,availDays:avail,rate:avail>0?Math.round(days/avail*100):0};
    }).sort((a,b)=>b.rate-a.rate);
  },[vehicles,curVehDayMap,curMaintMap,daysInMo]);

  // === 年間推移 ===
  const ANN_CLASS_C={"A":"#7c3aed","B":"#0284c7","C":"#059669","S":"#d97706","F":"#db2777","H":"#64748b"};
  const annTabItems=[
    {id:"revenue",label:"売上",ico:"💰"},{id:"utilization",label:"稼働率",ico:"🚗"},
    {id:"classRev",label:"クラス売上",ico:"🏷️"},{id:"vehRev",label:"車両売上",ico:"🚙"},
    {id:"classUtil",label:"クラス稼働",ico:"📊"},{id:"vehUtil",label:"車両稼働",ico:"📅"}
  ];
  // === 年間推移データ ===
  const annualData=useMemo(function(){
    if(dashView!=="annual")return null;
    // 対象月リスト: データ全体から存在する月を取得（最大24ヶ月）
    var dataMonths=new Set();
    data.forEach(function(r){if(r.status!=="cancelled"&&r.returnDate)dataMonths.add(toYM(r.returnDate));});
    dataMonths.add(curYM);
    var sorted=[].concat(Array.from(dataMonths)).sort();
    // 最初の月から最後の月まで連続的に
    var firstYM=sorted[0],lastYM=sorted[sorted.length-1];
    var months=[];var ym=firstYM;
    for(var i=0;i<36&&ym<=lastYM;i++){months.push(ym);ym=ymOff(ym,1);}

    var maint=maintenance||[];
    var codeToType={};vehicles.forEach(function(v){codeToType[v.code]=v.type;});

    var result=months.map(function(ym){
      var dim=daysInMonth(ym);
      var parts=ym.split("-");var yy=Number(parts[0]);var mm=Number(parts[1])-1;
      var moStart=new Date(yy,mm,1);var moEnd=new Date(yy,mm,dim);
      var md=data.filter(function(r){return r.status!=="cancelled"&&r.returnDate&&toYM(r.returnDate)===ym;});

      // 1. グロス売上
      var grossRev=md.reduce(function(s,r){return s+(Number(r.price)||0);},0);
      var count=md.length;

      // 2. 稼働率計算（メンテ日数を最大稼働日数から減算）
      var vdm={};
      data.forEach(function(r){
        if(r.status==="cancelled")return;
        if(!r.lendDate||!r.returnDate)return;
        var vc=fleet[r.id];if(!vc)return;
        if(!vdm[vc])vdm[vc]=new Set();
        var ld=new Date(norm(r.lendDate)+"T00:00:00");var rd=new Date(norm(r.returnDate)+"T00:00:00");
        var s=ld>moStart?new Date(ld):new Date(moStart);var e=rd<moEnd?new Date(rd):new Date(moEnd);
        for(var d=new Date(s);d<=e;d.setDate(d.getDate()+1)){vdm[vc].add(toLD(d));}
      });
      // メンテ日数（車両別）
      var maintMapA={};
      maint.forEach(function(mt){
        if(!mt.vehicleCode||!mt.startDate||!mt.endDate)return;
        if(!maintMapA[mt.vehicleCode])maintMapA[mt.vehicleCode]=new Set();
        var ld=new Date(norm(mt.startDate)+"T00:00:00");var rd=new Date(norm(mt.endDate)+"T00:00:00");
        var s=ld>moStart?new Date(ld):new Date(moStart);var e=rd<moEnd?new Date(rd):new Date(moEnd);
        for(var d=new Date(s);d<=e;d.setDate(d.getDate()+1)){maintMapA[mt.vehicleCode].add(toLD(d));}
      });
      var totalUsed=0;Object.values(vdm).forEach(function(s){totalUsed+=s.size;});
      var totalMaintA=0;Object.values(maintMapA).forEach(function(s){totalMaintA+=s.size;});
      var totalPossible=vehicles.length*dim;
      var availPossible=totalPossible-totalMaintA;
      var grossRate=availPossible>0?Math.round(totalUsed/availPossible*100):0;

      // 3. クラス別売上
      var classRev={};
      INIT_CLASSES.forEach(function(cl){classRev[cl.type]={label:cl.label,revenue:0,count:0};});
      md.forEach(function(r){
        var vc=fleet[r.id];var tp=vc?codeToType[vc]:r.vehicle;
        var key=tp&&classRev[tp]?tp:"?";
        if(!classRev[key])classRev[key]={label:"不明",revenue:0,count:0};
        classRev[key].count++;classRev[key].revenue+=(Number(r.price)||0);
      });

      // 4. 車両別売上
      var vehRev={};
      md.forEach(function(r){
        var vc=fleet[r.id]||"未配車";
        if(!vehRev[vc])vehRev[vc]={revenue:0,count:0,days:0};
        vehRev[vc].count++;vehRev[vc].revenue+=(Number(r.price)||0);
      });
      Object.keys(vehRev).forEach(function(vc){
        if(vdm[vc])vehRev[vc].days=vdm[vc].size;
      });

      // 5. クラス別稼働率（メンテ日数を最大稼働日数から減算）
      var classUtil={};
      INIT_CLASSES.forEach(function(cl){classUtil[cl.type]={label:cl.label,vehCount:0,used:0,maintD:0};});
      vehicles.forEach(function(v){if(classUtil[v.type])classUtil[v.type].vehCount++;});
      vehicles.forEach(function(v){
        var tp=codeToType[v.code];if(!tp||!classUtil[tp])return;
        if(vdm[v.code]){classUtil[tp].used+=vdm[v.code].size;}
        if(maintMapA[v.code]){classUtil[tp].maintD+=maintMapA[v.code].size;}
      });
      Object.keys(classUtil).forEach(function(tp){
        var e=classUtil[tp];
        e.totalPossible=e.vehCount*dim;
        e.availDays=e.totalPossible-e.maintD;
        e.rate=e.availDays>0?Math.round(e.used/e.availDays*100):0;
      });

      // 6. 車両別稼働率（メンテ日数を最大稼働日数から減算）
      var vehUtil={};
      vehicles.forEach(function(v){
        var days=vdm[v.code]?vdm[v.code].size:0;
        var mD=maintMapA[v.code]?maintMapA[v.code].size:0;
        var avail=dim-mD;
        vehUtil[v.code]={name:v.name,no:v.no,type:v.type,days:days,maintDays:mD,availDays:avail,rate:avail>0?Math.round(days/avail*100):0};
      });

      return{ym:ym,label:(parseInt(parts[1]))+"月",grossRev:grossRev,count:count,grossRate:grossRate,
             classRev:classRev,vehRev:vehRev,classUtil:classUtil,vehUtil:vehUtil,dim:dim,totalUsed:totalUsed};
    });
    return{months:months,data:result};
  },[dashView,data,fleet,vehicles,maintenance,curYM]);

  // 年間推移の集計値
  const annSummary=useMemo(function(){
    if(!annualData)return{maxRev:1,maxRate:1,totalRev:0,totalCount:0,avgRate:0,yearLabel:""};
    var ad=annualData;
    var maxR=1;var maxRt=1;var totR=0;var totC=0;var sumRate=0;
    ad.data.forEach(function(m){if(m.grossRev>maxR)maxR=m.grossRev;if(m.grossRate>maxRt)maxRt=m.grossRate;totR+=m.grossRev;totC+=m.count;sumRate+=m.grossRate;});
    var avgR=ad.data.length>0?Math.round(sumRate/ad.data.length):0;
    var ySet={};ad.months.forEach(function(ym){ySet[ym.split("-")[0]]=1;});
    var yrs=Object.keys(ySet).sort();
    var yl=yrs.length===1?yrs[0]+"年":yrs[0]+"〜"+yrs[yrs.length-1]+"年";
    return{maxRev:maxR,maxRate:maxRt,totalRev:totR,totalCount:totC,avgRate:avgR,yearLabel:yl};
  },[annualData]);

  // フォーマットヘルパー
  const fmtY=n=>{if(n>=10000)return(n/10000).toFixed(n>=100000?0:1)+"万";return n.toLocaleString();};
  const diffBadge=(cur,prev,unit="%")=>{
    const d=cur-prev;
    if(d===0)return <span style={{fontSize:9,color:"#94a3b8"}}>±0{unit}</span>;
    return <span style={{fontSize:9,fontWeight:700,color:d>0?"#059669":"#dc2626"}}>{d>0?"▲":"▼"}{Math.abs(d).toFixed(unit==="%"?1:0)}{unit}</span>;
  };
  const cardS={background:"#fff",borderRadius:14,padding:14,border:"1px solid #e2e8f0",marginBottom:10,boxShadow:"0 1px 3px rgba(0,0,0,.05)"};
  const OTA_C={S:"#0ea5e9",J:"#ec4899",R:"#ef4444",A:"#22c55e",O:"#6366f1",RC:"#f97316"};

  return <div style={{maxWidth:640,margin:"0 auto"}}>
    {/* ビュー切替タブ */}
    <div style={{display:"flex",gap:0,marginBottom:12,background:"#f1f5f9",borderRadius:10,padding:3}}>
      <button onClick={()=>setDashView("monthly")} style={{flex:1,padding:"7px 0",borderRadius:8,fontSize:12,fontWeight:700,border:"none",cursor:"pointer",transition:"all .2s",
        background:dashView==="monthly"?"#fff":"transparent",color:dashView==="monthly"?"#1e293b":"#94a3b8",
        boxShadow:dashView==="monthly"?"0 1px 3px rgba(0,0,0,.1)":"none"}}>📊 月別</button>
      <button onClick={()=>setDashView("annual")} style={{flex:1,padding:"7px 0",borderRadius:8,fontSize:12,fontWeight:700,border:"none",cursor:"pointer",transition:"all .2s",
        background:dashView==="annual"?"#fff":"transparent",color:dashView==="annual"?"#1e293b":"#94a3b8",
        boxShadow:dashView==="annual"?"0 1px 3px rgba(0,0,0,.1)":"none"}}>📈 年間推移</button>
    </div>

    {dashView==="monthly"&&<>
    {/* 月選択 */}
    <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:12}}>
      <button onClick={()=>setSelYM(ymOff(selYM,-1))} className="btn-ghost" style={{padding:"4px 10px",fontSize:12}}>◀</button>
      <div style={{textAlign:"center"}}>
        <div style={{fontSize:18,fontWeight:900,color:"#1e293b"}}>{ymLabel(selYM)}</div>
        <div style={{fontSize:10,color:"#94a3b8"}}>ダッシュボード</div>
      </div>
      <button onClick={()=>{const maxYM=allMonths.length?allMonths[allMonths.length-1]:curYM;if(selYM<maxYM)setSelYM(ymOff(selYM,1));}} className="btn-ghost" style={{padding:"4px 10px",fontSize:12,opacity:selYM>=(allMonths.length?allMonths[allMonths.length-1]:curYM)?0.3:1}}>▶</button>
    </div>

    {/* KPIカード */}
    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginBottom:12}}>
      <div style={{...cardS,background:"linear-gradient(135deg,#eff6ff,#dbeafe)"}}>
        <div style={{fontSize:10,color:"#2563eb",fontWeight:600,marginBottom:4}}>💰 月間売上</div>
        <div style={{fontSize:22,fontWeight:900,color:"#1e40af"}}>¥{fmtY(totalRevenue)}</div>
        <div style={{marginTop:2}}>{diffBadge(totalRevenue,prevRevenue," 円")}<span style={{fontSize:8,color:"#94a3b8",marginLeft:4}}>vs 前月</span></div>
      </div>
      <div style={{...cardS,background:"linear-gradient(135deg,#ecfdf5,#d1fae5)"}}>
        <div style={{fontSize:10,color:"#059669",fontWeight:600,marginBottom:4}}>📋 予約件数</div>
        <div style={{fontSize:22,fontWeight:900,color:"#065f46"}}>{totalCount}<span style={{fontSize:12}}>件</span></div>
        <div style={{marginTop:2}}>{diffBadge(totalCount,prevCount," 件")}<span style={{fontSize:8,color:"#94a3b8",marginLeft:4}}>vs 前月</span></div>
      </div>
      <div style={{...cardS,background:"linear-gradient(135deg,#fefce8,#fef9c3)"}}>
        <div style={{fontSize:10,color:"#ca8a04",fontWeight:600,marginBottom:4}}>💵 平均単価</div>
        <div style={{fontSize:22,fontWeight:900,color:"#854d0e"}}>¥{fmtY(avgPrice)}</div>
        <div style={{marginTop:2}}>{diffBadge(avgPrice,prevAvgPrice," 円")}<span style={{fontSize:8,color:"#94a3b8",marginLeft:4}}>vs 前月</span></div>
      </div>
      <div style={{...cardS,background:"linear-gradient(135deg,#faf5ff,#ede9fe)"}}>
        <div style={{fontSize:10,color:"#7c3aed",fontWeight:600,marginBottom:4}}>🚗 稼働率</div>
        <div style={{fontSize:22,fontWeight:900,color:"#5b21b6"}}>{utilRate}<span style={{fontSize:12}}>%</span></div>
        <div style={{marginTop:2}}>{diffBadge(utilRate,prevUtilRate)}<span style={{fontSize:8,color:"#94a3b8",marginLeft:4}}>vs 前月</span></div>
      </div>
    </div>

    {/* 日別売上グラフ */}
    <div style={cardS}>
      <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>📊 日別売上</div>
      <div style={{display:"flex",alignItems:"flex-end",gap:1,height:100}}>
        {dailyRevenue.map((d,i)=>{
          const h=maxDaily>0?Math.max(2,d.value/maxDaily*90):2;
          const isToday=selYM===curYM&&d.day===new Date().getDate();
          return <div key={i} style={{flex:1,display:"flex",flexDirection:"column",alignItems:"center",gap:1}}>
            <div style={{width:"100%",height:h,background:isToday?"#2563eb":d.value>0?"#93c5fd":"#e2e8f0",borderRadius:"2px 2px 0 0",transition:"height .3s"}} title={d.day+"日: ¥"+d.value.toLocaleString()}></div>
            {(d.day===1||d.day===10||d.day===20||d.day===daysInMo)&&<div style={{fontSize:7,color:"#94a3b8"}}>{d.day}</div>}
          </div>;
        })}
      </div>
    </div>

    {/* 月次推移 */}
    <div style={cardS}>
      <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>📈 月次売上推移</div>
      <div style={{display:"flex",alignItems:"flex-end",gap:3,height:100}}>
        {monthlyTrend.map((m,i)=>{
          const h=maxMonthlyRev>0?Math.max(4,m.revenue/maxMonthlyRev*85):4;
          const isCur=m.ym===selYM;
          return <div key={i} style={{flex:1,display:"flex",flexDirection:"column",alignItems:"center",gap:2}}>
            {m.revenue>0&&<div style={{fontSize:7,color:isCur?"#1e40af":"#94a3b8",fontWeight:isCur?700:400}}>{fmtY(m.revenue)}</div>}
            <div style={{width:"100%",height:h,background:isCur?"#2563eb":"#bfdbfe",borderRadius:3,transition:"height .3s"}}></div>
            <div style={{fontSize:7,color:isCur?"#1e40af":"#94a3b8",fontWeight:isCur?700:400}}>{m.label}</div>
          </div>;
        })}
      </div>
    </div>

    {/* OTA別売上 */}
    <div style={cardS}>
      <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>🏢 OTA別売上</div>
      {otaStats.length===0&&<div style={{textAlign:"center",fontSize:11,color:"#94a3b8",padding:12}}>データなし</div>}
      {otaStats.map(([ota,st])=>{
        const pct=totalRevenue>0?Math.round(st.revenue/totalRevenue*100):0;
        const c=OTA_C[ota]||"#64748b";
        return <div key={ota} style={{marginBottom:8}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:3}}>
            <div style={{display:"flex",alignItems:"center",gap:6}}>
              <span style={{display:"inline-block",padding:"1px 8px",borderRadius:6,fontSize:10,fontWeight:700,background:c+"18",color:c}}>{ota}</span>
              <span style={{fontSize:10,color:"#64748b"}}>{st.count}件</span>
            </div>
            <div style={{fontSize:12,fontWeight:700,color:"#1e293b"}}>¥{st.revenue.toLocaleString()}<span style={{fontSize:9,color:"#94a3b8",marginLeft:4}}>{pct}%</span></div>
          </div>
          <div style={{height:6,background:"#f1f5f9",borderRadius:3,overflow:"hidden"}}>
            <div style={{height:"100%",width:pct+"%",background:c,borderRadius:3,transition:"width .5s"}}></div>
          </div>
        </div>;
      })}
    </div>

    {/* 車両別売上 */}
    <div style={cardS}>
      <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>🚗 車両別売上</div>
      {vehStats.length===0&&<div style={{textAlign:"center",fontSize:11,color:"#94a3b8",padding:12}}>データなし</div>}
      <div style={{overflowX:"auto"}}>
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
          <thead><tr style={{borderBottom:"2px solid #e2e8f0"}}>
            <th style={{textAlign:"left",padding:"4px 6px",fontSize:10,color:"#64748b",fontWeight:600}}>車両</th>
            <th style={{textAlign:"right",padding:"4px 6px",fontSize:10,color:"#64748b",fontWeight:600}}>件数</th>
            <th style={{textAlign:"right",padding:"4px 6px",fontSize:10,color:"#64748b",fontWeight:600}}>日数</th>
            <th style={{textAlign:"right",padding:"4px 6px",fontSize:10,color:"#64748b",fontWeight:600}}>売上</th>
            <th style={{textAlign:"right",padding:"4px 6px",fontSize:10,color:"#64748b",fontWeight:600}}>構成比</th>
          </tr></thead>
          <tbody>
            {vehStats.map(([vc,st])=>{
              const pct=totalRevenue>0?Math.round(st.revenue/totalRevenue*100):0;
              const veh=vehicles.find(v=>v.code===vc);
              const c=V_COLORS[vc]||"#64748b";
              return <tr key={vc} style={{borderBottom:"1px solid #f1f5f9"}}>
                <td style={{padding:"6px",display:"flex",alignItems:"center",gap:4}}>
                  <span style={{width:8,height:8,borderRadius:"50%",background:c,flexShrink:0}}></span>
                  <span style={{fontWeight:700}}>{vc}</span>
                  {veh&&<span style={{fontSize:9,color:"#94a3b8"}}>{veh.no}</span>}
                </td>
                <td style={{textAlign:"right",padding:"6px"}}>{st.count}</td>
                <td style={{textAlign:"right",padding:"6px"}}>{st.days}日</td>
                <td style={{textAlign:"right",padding:"6px",fontWeight:700,color:"#1e293b"}}>¥{st.revenue.toLocaleString()}</td>
                <td style={{textAlign:"right",padding:"6px"}}>
                  <div style={{display:"flex",alignItems:"center",justifyContent:"flex-end",gap:4}}>
                    <div style={{width:40,height:5,background:"#f1f5f9",borderRadius:3,overflow:"hidden"}}><div style={{height:"100%",width:pct+"%",background:c,borderRadius:3}}></div></div>
                    <span style={{fontSize:9,color:"#64748b",minWidth:24}}>{pct}%</span>
                  </div>
                </td>
              </tr>;
            })}
            <tr style={{borderTop:"2px solid #e2e8f0",fontWeight:800}}>
              <td style={{padding:"6px"}}>合計</td>
              <td style={{textAlign:"right",padding:"6px"}}>{totalCount}</td>
              <td style={{textAlign:"right",padding:"6px"}}></td>
              <td style={{textAlign:"right",padding:"6px",color:"#1e40af"}}>¥{totalRevenue.toLocaleString()}</td>
              <td style={{textAlign:"right",padding:"6px"}}>100%</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    {/* 車両別稼働率 */}
    <div style={cardS}>
      <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>📅 車両別稼働率（{ymLabel(selYM)}・{daysInMo}日間）</div>
      {vehUtilDetail.map(v=>{
        const c=V_COLORS[v.code]||"#64748b";
        return <div key={v.code} style={{marginBottom:6}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:2}}>
            <div style={{display:"flex",alignItems:"center",gap:4}}>
              <span style={{width:8,height:8,borderRadius:"50%",background:c,flexShrink:0}}></span>
              <span style={{fontSize:11,fontWeight:700}}>{v.code}</span>
              <span style={{fontSize:9,color:"#94a3b8"}}>{v.name} ({v.no})</span>
            </div>
            <div style={{fontSize:11}}><span style={{fontWeight:700,color:v.rate>=70?"#059669":v.rate>=40?"#d97706":"#dc2626"}}>{v.rate}%</span><span style={{fontSize:9,color:"#94a3b8",marginLeft:4}}>{v.days}/{v.availDays}日</span>{v.maintDays>0&&<span style={{fontSize:8,color:"#2563eb",marginLeft:3}}>🔧{v.maintDays}日</span>}</div>
          </div>
          <div style={{height:6,background:"#f1f5f9",borderRadius:3,overflow:"hidden"}}>
            <div style={{height:"100%",width:v.rate+"%",background:v.rate>=70?c:v.rate>=40?"#fbbf24":"#fca5a5",borderRadius:3,transition:"width .5s"}}></div>
          </div>
        </div>;
      })}
      <div style={{marginTop:8,padding:"6px 10px",background:"#f8fafc",borderRadius:8,display:"flex",justifyContent:"space-between",alignItems:"center"}}>
        <div><span style={{fontSize:11,fontWeight:700,color:"#1e293b"}}>全体稼働率</span>{totalMaintDays>0&&<span style={{fontSize:9,color:"#2563eb",marginLeft:6}}>🔧メンテ{totalMaintDays}日除外</span>}</div>
        <span style={{fontSize:14,fontWeight:900,color:utilRate>=70?"#059669":utilRate>=40?"#d97706":"#dc2626"}}>{utilRate}%</span>
      </div>
    </div>

    {/* クラス別売上 */}
    {(()=>{
      const CLASS_C={"A":"#7c3aed","B":"#0284c7","C":"#059669","S":"#d97706","F":"#db2777","H":"#64748b"};
      // 車両コード→クラスtype マッピング
      const codeToType={};vehicles.forEach(v=>{codeToType[v.code]=v.type;});
      // クラス別集計
      const classRevMap={};
      INIT_CLASSES.forEach(cl=>{classRevMap[cl.type]={label:cl.label,count:0,revenue:0,days:0};});
      monthData.forEach(r=>{
        const vc=fleet[r.id];
        const tp=vc?codeToType[vc]:r.vehicle;
        const key=tp&&classRevMap[tp]?tp:"?";
        if(!classRevMap[key])classRevMap[key]={label:"不明",count:0,revenue:0,days:0};
        classRevMap[key].count++;classRevMap[key].revenue+=(Number(r.price)||0);
        if(r.lendDate&&r.returnDate){
          const ld=new Date(r.lendDate+"T00:00:00"),rd=new Date(r.returnDate+"T00:00:00");
          classRevMap[key].days+=Math.max(1,Math.ceil((rd-ld)/(1000*60*60*24)));
        }
      });
      // クラスごとの車両台数
      const classVehCnt={};vehicles.forEach(v=>{classVehCnt[v.type]=(classVehCnt[v.type]||0)+1;});
      const classEntries=Object.entries(classRevMap).filter(([,v])=>v.count>0).sort((a,b)=>b[1].revenue-a[1].revenue);
      const maxClassRev=Math.max(1,...classEntries.map(([,v])=>v.revenue));
      const maxPerVeh=Math.max(1,...classEntries.map(([tp,v])=>{const vc=classVehCnt[tp]||1;return Math.round(v.revenue/vc);}));
      return <div style={cardS}>
        <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>🏷️ クラス別売上</div>
        {classEntries.length===0&&<div style={{textAlign:"center",fontSize:11,color:"#94a3b8",padding:12}}>データなし</div>}
        {classEntries.map(([tp,st])=>{
          const pct=totalRevenue>0?Math.round(st.revenue/totalRevenue*100):0;
          const c=CLASS_C[tp]||"#64748b";
          const avgP=st.count>0?Math.round(st.revenue/st.count):0;
          const vehCnt=classVehCnt[tp]||1;
          const perVeh=Math.round(st.revenue/vehCnt);
          return <div key={tp} style={{marginBottom:12}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:3}}>
              <div style={{display:"flex",alignItems:"center",gap:6}}>
                <span style={{display:"inline-flex",alignItems:"center",justifyContent:"center",width:24,height:24,borderRadius:6,background:c+"18",color:c,fontSize:12,fontWeight:900}}>{tp}</span>
                <div>
                  <div style={{fontSize:11,fontWeight:700,color:"#1e293b"}}>{st.label}</div>
                  <div style={{fontSize:9,color:"#94a3b8"}}>{st.count}件 ・{st.days}日 ・平均¥{avgP.toLocaleString()}/件</div>
                </div>
              </div>
              <div style={{textAlign:"right"}}>
                <div style={{fontSize:13,fontWeight:800,color:"#1e293b"}}>¥{st.revenue.toLocaleString()}</div>
                <div style={{fontSize:9,color:"#64748b"}}>{pct}%</div>
              </div>
            </div>
            <div style={{height:8,background:"#f1f5f9",borderRadius:4,overflow:"hidden",marginBottom:4}}>
              <div style={{height:"100%",width:Math.round(st.revenue/maxClassRev*100)+"%",background:c,borderRadius:4,transition:"width .5s"}}></div>
            </div>
            <div style={{display:"flex",alignItems:"center",gap:6,paddingLeft:30}}>
              <div style={{fontSize:9,color:"#64748b",whiteSpace:"nowrap"}}>1台あたり ({vehCnt}台)</div>
              <div style={{flex:1,height:6,background:"#f1f5f9",borderRadius:3,overflow:"hidden"}}>
                <div style={{height:"100%",width:Math.round(perVeh/maxPerVeh*100)+"%",background:c+"88",borderRadius:3,transition:"width .5s"}}></div>
              </div>
              <div style={{fontSize:10,fontWeight:700,color:c,whiteSpace:"nowrap"}}>¥{perVeh.toLocaleString()}</div>
            </div>
          </div>;
        })}
      </div>;
    })()}

    {/* クラス別稼働率 */}
    {(()=>{
      const CLASS_C={"A":"#7c3aed","B":"#0284c7","C":"#059669","S":"#d97706","F":"#db2777","H":"#64748b"};
      const codeToType={};vehicles.forEach(v=>{codeToType[v.code]=v.type;});
      // クラスごとの車両台数
      const classVehCount={};
      INIT_CLASSES.forEach(cl=>{classVehCount[cl.type]=0;});
      vehicles.forEach(v=>{if(classVehCount[v.type]!==undefined)classVehCount[v.type]++;});
      // クラスごとの稼働日＆メンテ日（curVehDayMap/curMaintMapから集約）
      const classUsedDays={};const classMaintDays={};
      INIT_CLASSES.forEach(cl=>{classUsedDays[cl.type]={};classMaintDays[cl.type]={};});
      vehicles.forEach(v=>{
        const tp=codeToType[v.code];if(!tp||!classUsedDays[tp])return;
        if(curVehDayMap[v.code]){classUsedDays[tp][v.code]=curVehDayMap[v.code];}
        if(curMaintMap[v.code]){classMaintDays[tp][v.code]=curMaintMap[v.code];}
      });
      const classUtilEntries=INIT_CLASSES.map(cl=>{
        const vehCount=classVehCount[cl.type]||0;
        const totalPossible=vehCount*daysInMo;
        let used=0;let maintD=0;
        Object.values(classUsedDays[cl.type]||{}).forEach(s=>used+=s.size);
        Object.values(classMaintDays[cl.type]||{}).forEach(s=>maintD+=s.size);
        const avail=totalPossible-maintD;
        const rate=avail>0?Math.round(used/avail*100):0;
        return{type:cl.type,label:cl.label,vehCount,used,totalPossible,availDays:avail,maintDays:maintD,rate};
      }).filter(e=>e.vehCount>0);
      return <div style={cardS}>
        <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>📅 クラス別稼働率（{ymLabel(selYM)}）</div>
        {classUtilEntries.map(e=>{
          const c=CLASS_C[e.type]||"#64748b";
          return <div key={e.type} style={{marginBottom:8}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:2}}>
              <div style={{display:"flex",alignItems:"center",gap:6}}>
                <span style={{display:"inline-flex",alignItems:"center",justifyContent:"center",width:22,height:22,borderRadius:6,background:c+"18",color:c,fontSize:11,fontWeight:900}}>{e.type}</span>
                <div>
                  <span style={{fontSize:11,fontWeight:700}}>{e.label}</span>
                  <span style={{fontSize:9,color:"#94a3b8",marginLeft:4}}>({e.vehCount}台)</span>
                </div>
              </div>
              <div style={{fontSize:11}}>
                <span style={{fontWeight:700,color:e.rate>=70?"#059669":e.rate>=40?"#d97706":"#dc2626"}}>{e.rate}%</span>
                <span style={{fontSize:9,color:"#94a3b8",marginLeft:4}}>{e.used}/{e.availDays}日</span>{e.maintDays>0&&<span style={{fontSize:8,color:"#2563eb",marginLeft:3}}>🔧{e.maintDays}日</span>}
              </div>
            </div>
            <div style={{height:8,background:"#f1f5f9",borderRadius:4,overflow:"hidden"}}>
              <div style={{height:"100%",width:e.rate+"%",background:e.rate>=70?c:e.rate>=40?"#fbbf24":"#fca5a5",borderRadius:4,transition:"width .5s"}}></div>
            </div>
          </div>;
        })}
      </div>;
    })()}


    </>}

    {/* ========== 年間推移ビュー ========== */}
    {dashView==="annual"&&annualData&&<div>
        <div style={{textAlign:"center",marginBottom:12}}>
          <div style={{fontSize:18,fontWeight:900,color:"#1e293b"}}>{annSummary.yearLabel} 年間推移</div>
          <div style={{fontSize:10,color:"#94a3b8"}}>{annualData.data.length}ヶ月分のデータ</div>
        </div>

        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:6,marginBottom:12}}>
          <div style={{...cardS,textAlign:"center",padding:10}}>
            <div style={{fontSize:9,color:"#2563eb",fontWeight:600}}>年間売上</div>
            <div style={{fontSize:16,fontWeight:900,color:"#1e40af"}}>¥{fmtY(annSummary.totalRev)}</div>
          </div>
          <div style={{...cardS,textAlign:"center",padding:10}}>
            <div style={{fontSize:9,color:"#059669",fontWeight:600}}>年間件数</div>
            <div style={{fontSize:16,fontWeight:900,color:"#065f46"}}>{annSummary.totalCount}件</div>
          </div>
          <div style={{...cardS,textAlign:"center",padding:10}}>
            <div style={{fontSize:9,color:"#7c3aed",fontWeight:600}}>平均稼働率</div>
            <div style={{fontSize:16,fontWeight:900,color:"#5b21b6"}}>{annSummary.avgRate}%</div>
          </div>
        </div>

        <div style={{display:"flex",gap:0,flexWrap:"wrap",marginBottom:10,background:"#f8fafc",borderRadius:8,padding:2}}>
          {annTabItems.map(function(t){return <button key={t.id} onClick={function(){setAnnTab(t.id);}} style={{
            flex:"1 1 auto",padding:"5px 4px",borderRadius:6,fontSize:10,fontWeight:600,border:"none",cursor:"pointer",
            background:annTab===t.id?"#fff":"transparent",color:annTab===t.id?"#1e293b":"#94a3b8",
            boxShadow:annTab===t.id?"0 1px 2px rgba(0,0,0,.08)":"none",whiteSpace:"nowrap"
          }}>{t.ico} {t.label}</button>;})}
        </div>

        {annTab==="revenue"&&<div style={cardS}>
          <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>💰 月別売上推移</div>
          <div style={{display:"flex",alignItems:"flex-end",gap:3,height:120}}>
            {annualData.data.map(function(m,i){
              var h=annSummary.maxRev>0?Math.max(4,m.grossRev/annSummary.maxRev*100):4;
              return <div key={i} style={{flex:1,display:"flex",flexDirection:"column",alignItems:"center",gap:2}}>
                {m.grossRev>0&&<div style={{fontSize:7,color:"#1e40af",fontWeight:600,transform:"rotate(-45deg)",transformOrigin:"bottom center",whiteSpace:"nowrap"}}>{fmtY(m.grossRev)}</div>}
                <div style={{width:"100%",height:h,background:"#3b82f6",borderRadius:3,transition:"height .3s"}} title={m.ym+": ¥"+m.grossRev.toLocaleString()+" ("+m.count+"件)"}></div>
                <div style={{fontSize:7,color:"#64748b"}}>{m.label}</div>
              </div>;
            })}
          </div>
          <div style={{overflowX:"auto",marginTop:10}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
              <thead><tr style={{borderBottom:"2px solid #e2e8f0"}}>
                <th style={{textAlign:"left",padding:"3px 4px",color:"#64748b",fontWeight:600}}>月</th>
                <th style={{textAlign:"right",padding:"3px 4px",color:"#64748b",fontWeight:600}}>売上</th>
                <th style={{textAlign:"right",padding:"3px 4px",color:"#64748b",fontWeight:600}}>件数</th>
                <th style={{textAlign:"right",padding:"3px 4px",color:"#64748b",fontWeight:600}}>平均</th>
              </tr></thead>
              <tbody>{annualData.data.map(function(m,i){
                var avg=m.count>0?Math.round(m.grossRev/m.count):0;
                return <tr key={i} style={{borderBottom:"1px solid #f1f5f9"}}>
                  <td style={{padding:"4px",fontWeight:600}}>{ymLabel(m.ym)}</td>
                  <td style={{textAlign:"right",padding:"4px",fontWeight:700,color:"#1e40af"}}>¥{m.grossRev.toLocaleString()}</td>
                  <td style={{textAlign:"right",padding:"4px"}}>{m.count}件</td>
                  <td style={{textAlign:"right",padding:"4px",color:"#64748b"}}>¥{avg.toLocaleString()}</td>
                </tr>;
              })}
              <tr style={{borderTop:"2px solid #e2e8f0",fontWeight:800}}>
                <td style={{padding:"4px"}}>合計/平均</td>
                <td style={{textAlign:"right",padding:"4px",color:"#1e40af"}}>¥{annSummary.totalRev.toLocaleString()}</td>
                <td style={{textAlign:"right",padding:"4px"}}>{annSummary.totalCount}件</td>
                <td style={{textAlign:"right",padding:"4px",color:"#64748b"}}>¥{annSummary.totalCount>0?Math.round(annSummary.totalRev/annSummary.totalCount).toLocaleString():0}</td>
              </tr></tbody>
            </table>
          </div>
        </div>}

        {annTab==="utilization"&&<div style={cardS}>
          <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>🚗 月別稼働率推移</div>
          <div style={{display:"flex",alignItems:"flex-end",gap:3,height:120,position:"relative"}}>
            <div style={{position:"absolute",left:0,right:0,bottom:50,height:1,borderBottom:"1px dashed #e2e8f0",zIndex:0}}></div>
            {annualData.data.map(function(m,i){
              var h=Math.max(4,m.grossRate);var c=m.grossRate>=70?"#059669":m.grossRate>=40?"#d97706":"#dc2626";
              return <div key={i} style={{flex:1,display:"flex",flexDirection:"column",alignItems:"center",gap:2,zIndex:1}}>
                <div style={{fontSize:8,color:c,fontWeight:700}}>{m.grossRate}%</div>
                <div style={{width:"100%",height:h,background:c,borderRadius:3,transition:"height .3s"}} title={m.ym+": "+m.grossRate+"%"}></div>
                <div style={{fontSize:7,color:"#64748b"}}>{m.label}</div>
              </div>;
            })}
          </div>
          <div style={{overflowX:"auto",marginTop:10}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
              <thead><tr style={{borderBottom:"2px solid #e2e8f0"}}>
                <th style={{textAlign:"left",padding:"3px 4px",color:"#64748b",fontWeight:600}}>月</th>
                <th style={{textAlign:"right",padding:"3px 4px",color:"#64748b",fontWeight:600}}>稼働率</th>
                <th style={{textAlign:"right",padding:"3px 4px",color:"#64748b",fontWeight:600}}>稼働日</th>
                <th style={{textAlign:"right",padding:"3px 4px",color:"#64748b",fontWeight:600}}>日数</th>
              </tr></thead>
              <tbody>{annualData.data.map(function(m,i){
                var totalP=vehicles.length*m.dim;
                return <tr key={i} style={{borderBottom:"1px solid #f1f5f9"}}>
                  <td style={{padding:"4px",fontWeight:600}}>{ymLabel(m.ym)}</td>
                  <td style={{textAlign:"right",padding:"4px",fontWeight:700,color:m.grossRate>=70?"#059669":m.grossRate>=40?"#d97706":"#dc2626"}}>{m.grossRate}%</td>
                  <td style={{textAlign:"right",padding:"4px"}}>{m.totalUsed}日</td>
                  <td style={{textAlign:"right",padding:"4px",color:"#64748b"}}>{totalP}日</td>
                </tr>;
              })}</tbody>
            </table>
          </div>
        </div>}

        {annTab==="classRev"&&<div style={cardS}>
          <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>🏷️ クラス別売上推移</div>
          <div style={{overflowX:"auto"}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
              <thead><tr style={{borderBottom:"2px solid #e2e8f0"}}>
                <th style={{textAlign:"left",padding:"3px 4px",color:"#64748b",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>月</th>
                {INIT_CLASSES.map(function(cl){return <th key={cl.type} style={{textAlign:"right",padding:"3px 4px",fontWeight:700,minWidth:55}}>
                  <span style={{color:ANN_CLASS_C[cl.type]||"#64748b"}}>{cl.type}</span>
                </th>;})}
                <th style={{textAlign:"right",padding:"3px 4px",color:"#1e293b",fontWeight:700}}>合計</th>
              </tr></thead>
              <tbody>{annualData.data.map(function(m,i){
                return <tr key={i} style={{borderBottom:"1px solid #f1f5f9"}}>
                  <td style={{padding:"4px",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>{m.label}</td>
                  {INIT_CLASSES.map(function(cl){var d=m.classRev[cl.type];return <td key={cl.type} style={{textAlign:"right",padding:"4px",color:d&&d.revenue>0?"#1e293b":"#e2e8f0"}}>{d&&d.revenue>0?"¥"+fmtY(d.revenue):"-"}</td>;})}
                  <td style={{textAlign:"right",padding:"4px",fontWeight:700,color:"#1e40af"}}>¥{fmtY(m.grossRev)}</td>
                </tr>;
              })}
              <tr style={{borderTop:"2px solid #e2e8f0",fontWeight:800}}>
                <td style={{padding:"4px",position:"sticky",left:0,background:"#fff",zIndex:1}}>合計</td>
                {INIT_CLASSES.map(function(cl){var total=annualData.data.reduce(function(s,m){var d=m.classRev[cl.type];return s+(d?d.revenue:0);},0);return <td key={cl.type} style={{textAlign:"right",padding:"4px",color:ANN_CLASS_C[cl.type]||"#64748b"}}>{total>0?"¥"+fmtY(total):"-"}</td>;})}
                <td style={{textAlign:"right",padding:"4px",color:"#1e40af"}}>¥{fmtY(annSummary.totalRev)}</td>
              </tr></tbody>
            </table>
          </div>
          <div style={{fontSize:11,fontWeight:700,color:"#1e293b",margin:"14px 0 6px"}}>📊 1台あたり売上</div>
          <div style={{overflowX:"auto"}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
              <thead><tr style={{borderBottom:"2px solid #e2e8f0"}}>
                <th style={{textAlign:"left",padding:"3px 4px",color:"#64748b",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>月</th>
                {INIT_CLASSES.filter(function(cl){return vehicles.some(function(v){return v.type===cl.type;});}).map(function(cl){var vc=vehicles.filter(function(v){return v.type===cl.type;}).length;return <th key={cl.type} style={{textAlign:"right",padding:"3px 4px",fontWeight:700,minWidth:55}}>
                  <span style={{color:ANN_CLASS_C[cl.type]||"#64748b"}}>{cl.type}</span><span style={{fontSize:7,color:"#94a3b8"}}> ({vc}台)</span>
                </th>;})}
              </tr></thead>
              <tbody>{annualData.data.map(function(m,i){
                return <tr key={i} style={{borderBottom:"1px solid #f1f5f9"}}>
                  <td style={{padding:"4px",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>{m.label}</td>
                  {INIT_CLASSES.filter(function(cl){return vehicles.some(function(v){return v.type===cl.type;});}).map(function(cl){var d=m.classRev[cl.type];var vc=vehicles.filter(function(v){return v.type===cl.type;}).length;var pv=d&&d.revenue>0&&vc>0?Math.round(d.revenue/vc):0;return <td key={cl.type} style={{textAlign:"right",padding:"4px",color:pv>0?"#1e293b":"#e2e8f0"}}>{pv>0?"¥"+fmtY(pv):"-"}</td>;})}
                </tr>;
              })}
              <tr style={{borderTop:"2px solid #e2e8f0",fontWeight:800}}>
                <td style={{padding:"4px",position:"sticky",left:0,background:"#fff",zIndex:1}}>平均</td>
                {INIT_CLASSES.filter(function(cl){return vehicles.some(function(v){return v.type===cl.type;});}).map(function(cl){var total=annualData.data.reduce(function(s,m){var d=m.classRev[cl.type];return s+(d?d.revenue:0);},0);var vc=vehicles.filter(function(v){return v.type===cl.type;}).length;var months=annualData.data.length;var avg=vc>0&&months>0?Math.round(total/vc/months):0;return <td key={cl.type} style={{textAlign:"right",padding:"4px",color:ANN_CLASS_C[cl.type]||"#64748b"}}>{avg>0?"¥"+fmtY(avg):"-"}</td>;})}
              </tr></tbody>
            </table>
          </div>
        </div>}

        {annTab==="vehRev"&&<div style={cardS}>
          <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>🚙 車両別売上推移</div>
          <div style={{overflowX:"auto"}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
              <thead><tr style={{borderBottom:"2px solid #e2e8f0"}}>
                <th style={{textAlign:"left",padding:"3px 4px",color:"#64748b",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>月</th>
                {vehicles.map(function(v){return <th key={v.code} style={{textAlign:"right",padding:"3px 4px",fontWeight:700,minWidth:50}}><span style={{color:V_COLORS[v.code]||"#64748b"}}>{v.code}</span></th>;})}
              </tr></thead>
              <tbody>{annualData.data.map(function(m,i){
                return <tr key={i} style={{borderBottom:"1px solid #f1f5f9"}}>
                  <td style={{padding:"4px",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>{m.label}</td>
                  {vehicles.map(function(v){var d=m.vehRev[v.code];return <td key={v.code} style={{textAlign:"right",padding:"4px",color:d&&d.revenue>0?"#1e293b":"#e2e8f0"}}>{d&&d.revenue>0?"¥"+fmtY(d.revenue):"-"}</td>;})}
                </tr>;
              })}
              <tr style={{borderTop:"2px solid #e2e8f0",fontWeight:800}}>
                <td style={{padding:"4px",position:"sticky",left:0,background:"#fff",zIndex:1}}>合計</td>
                {vehicles.map(function(v){var total=annualData.data.reduce(function(s,m){var d=m.vehRev[v.code];return s+(d?d.revenue:0);},0);return <td key={v.code} style={{textAlign:"right",padding:"4px",color:V_COLORS[v.code]||"#64748b"}}>{total>0?"¥"+fmtY(total):"-"}</td>;})}
              </tr></tbody>
            </table>
          </div>
        </div>}

        {annTab==="classUtil"&&<div style={cardS}>
          <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>📊 クラス別稼働率推移</div>
          <div style={{overflowX:"auto"}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
              <thead><tr style={{borderBottom:"2px solid #e2e8f0"}}>
                <th style={{textAlign:"left",padding:"3px 4px",color:"#64748b",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>月</th>
                {INIT_CLASSES.filter(function(cl){return vehicles.some(function(v){return v.type===cl.type;});}).map(function(cl){return <th key={cl.type} style={{textAlign:"right",padding:"3px 4px",fontWeight:700,minWidth:45}}><span style={{color:ANN_CLASS_C[cl.type]||"#64748b"}}>{cl.type}</span></th>;})}
                <th style={{textAlign:"right",padding:"3px 4px",color:"#1e293b",fontWeight:700}}>全体</th>
              </tr></thead>
              <tbody>{annualData.data.map(function(m,i){
                return <tr key={i} style={{borderBottom:"1px solid #f1f5f9"}}>
                  <td style={{padding:"4px",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>{m.label}</td>
                  {INIT_CLASSES.filter(function(cl){return vehicles.some(function(v){return v.type===cl.type;});}).map(function(cl){var d=m.classUtil[cl.type];var r=d?d.rate:0;var c=r>=70?"#059669":r>=40?"#d97706":"#dc2626";return <td key={cl.type} style={{textAlign:"right",padding:"4px",color:d&&d.vehCount>0?c:"#e2e8f0",fontWeight:600}}>{d&&d.vehCount>0?r+"%":"-"}</td>;})}
                  <td style={{textAlign:"right",padding:"4px",fontWeight:700,color:m.grossRate>=70?"#059669":m.grossRate>=40?"#d97706":"#dc2626"}}>{m.grossRate}%</td>
                </tr>;
              })}</tbody>
            </table>
          </div>
        </div>}

        {annTab==="vehUtil"&&<div style={cardS}>
          <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>📅 車両別稼働率推移</div>
          <div style={{overflowX:"auto"}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
              <thead><tr style={{borderBottom:"2px solid #e2e8f0"}}>
                <th style={{textAlign:"left",padding:"3px 4px",color:"#64748b",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>月</th>
                {vehicles.map(function(v){return <th key={v.code} style={{textAlign:"right",padding:"3px 4px",fontWeight:700,minWidth:40}}><span style={{color:V_COLORS[v.code]||"#64748b"}}>{v.code}</span></th>;})}
              </tr></thead>
              <tbody>{annualData.data.map(function(m,i){
                return <tr key={i} style={{borderBottom:"1px solid #f1f5f9"}}>
                  <td style={{padding:"4px",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>{m.label}</td>
                  {vehicles.map(function(v){var d=m.vehUtil[v.code];var r=d?d.rate:0;var c=r>=70?"#059669":r>=40?"#d97706":"#dc2626";return <td key={v.code} style={{textAlign:"right",padding:"4px",color:d?c:"#e2e8f0",fontWeight:600}}>{d?r+"%":"-"}</td>;})}
                </tr>;
              })}
              <tr style={{borderTop:"2px solid #e2e8f0",fontWeight:800}}>
                <td style={{padding:"4px",position:"sticky",left:0,background:"#fff",zIndex:1}}>平均</td>
                {vehicles.map(function(v){var rates=annualData.data.map(function(m){return m.vehUtil[v.code]?m.vehUtil[v.code].rate:0;});var avg=rates.length>0?Math.round(rates.reduce(function(a,b){return a+b;},0)/rates.length):0;var c=avg>=70?"#059669":avg>=40?"#d97706":"#dc2626";return <td key={v.code} style={{textAlign:"right",padding:"4px",color:c,fontWeight:700}}>{avg}%</td>;})}
              </tr></tbody>
            </table>
          </div>
        </div>}

      </div>}

  </div>;
}

/* ==========================================
   過去タスク
   ========================================== */
function PastTasksTable({today}){
  const[tasks,setTasks]=useState([]);const[loading,setLoading]=useState(false);
  const[search,setSearch]=useState("");const[typeFilter,setTypeFilter]=useState("all");
  // デフォルト: 過去7日
  const[fromDate,setFromDate]=useState(()=>{const d=new Date();d.setDate(d.getDate()-7);return toLD(d);});
  const[toDate,setToDate]=useState(()=>{const d=new Date();d.setDate(d.getDate()-1);return toLD(d);});
  const loadPast=async()=>{setLoading(true);try{const t=await DB.fetchTasksRange(fromDate,toDate);setTasks(t);}catch(e){console.error(e);}setLoading(false);};
  useEffect(()=>{loadPast();},[fromDate,toDate]);
  const types=[...new Set(tasks.map(t=>t.type))].sort();
  const filtered=useMemo(()=>tasks.filter(t=>{
    if(typeFilter!=="all"&&t.type!==typeFilter)return false;
    if(search&&!t.name?.includes(search)&&!t.reservationId?.includes(search)&&!t.place?.includes(search)&&!t.memo?.includes(search))return false;
    return true;
  }),[tasks,search,typeFilter]);
  // 日付ごとにグループ化
  const grouped=useMemo(()=>{const m={};filtered.forEach(t=>{const d=t._date||"不明";if(!m[d])m[d]=[];m[d].push(t);});return Object.entries(m).sort((a,b)=>b[0].localeCompare(a[0]));},[filtered]);
  const WK=["日","月","火","水","木","金","土"];
  const fmtDate=(d)=>{const dt=new Date(d+"T00:00:00");return `${dt.getMonth()+1}/${dt.getDate()}(${WK[dt.getDay()]})`;};
  return <div className="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div className="p-3 border-b border-gray-200 flex items-center gap-2 flex-wrap">
      <span style={{fontSize:11,fontWeight:600,color:"#374151"}}>期間:</span>
      <input type="date" value={fromDate} onChange={e=>setFromDate(e.target.value)} style={{fontSize:11,padding:"2px 6px",borderRadius:6,border:"1px solid #d1d5db"}}/>
      <span style={{fontSize:11,color:"#9ca3af"}}>〜</span>
      <input type="date" value={toDate} onChange={e=>setToDate(e.target.value)} style={{fontSize:11,padding:"2px 6px",borderRadius:6,border:"1px solid #d1d5db"}}/>
      <input value={search} onChange={e=>setSearch(e.target.value)} placeholder="検索（名前/予約番号）" className="input-s" style={{width:140}}/>
      <div className="flex gap-1"><button onClick={()=>setTypeFilter("all")} className={`px-2 py-1 rounded text-xs font-semibold ${typeFilter==="all"?"bg-gray-800 text-white":"bg-gray-100 text-gray-600"}`}>All</button>{types.map(tp=><button key={tp} onClick={()=>setTypeFilter(tp)} className="px-2 py-1 rounded text-xs font-semibold" style={{background:typeFilter===tp?(TASK_META[tp]||{}).c||"#6b7280":"#f3f4f6",color:typeFilter===tp?"#fff":(TASK_META[tp]||{}).c||"#6b7280"}}>{tp}</button>)}</div>
      <span className="ml-auto text-xs text-gray-500">{loading?"読込中...":filtered.length+"件"}</span>
    </div>
    <div style={{overflowX:"auto",maxHeight:"70vh"}}>
      {grouped.map(([date,items])=><div key={date}>
        <div style={{background:"#f8fafc",padding:"4px 10px",borderBottom:"1px solid #e5e7eb",fontWeight:700,fontSize:12,color:"#374151",position:"sticky",top:0,zIndex:1}}>{fmtDate(date)} <span style={{fontWeight:400,color:"#9ca3af",fontSize:10}}>— {items.length}件</span></div>
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}><thead className="bg-gray-50"><tr>{["種別","時間","予約者","車種","ナンバー","担当","場所","メモ","完了"].map(h=><th key={h} className="px-2 py-1 text-left font-semibold text-gray-600 border-b border-gray-200" style={{fontSize:10}}>{h}</th>)}</tr></thead><tbody>
          {items.map((t,i)=><tr key={t._id||i} className="border-b border-gray-100 hover:bg-blue-50" style={{opacity:t.done?0.5:1}}>
            <td className="px-2 py-1"><span style={{background:(TASK_META[t.type]||{}).bg||"#f3f4f6",color:(TASK_META[t.type]||{}).c||"#374151",padding:"1px 5px",borderRadius:4,fontSize:10,fontWeight:600}}>{t.type}</span></td>
            <td className="px-2 py-1" style={{fontSize:10}}>{t.time||"-"}</td>
            <td className="px-2 py-1 font-medium">{t.name||"-"}</td>
            <td className="px-2 py-1">{t.vehicle||"-"}</td>
            <td className="px-2 py-1 font-mono" style={{fontSize:9}}>{t.plateNo||"-"}</td>
            <td className="px-2 py-1">{t.assignee||"-"}</td>
            <td className="px-2 py-1" style={{fontSize:9,maxWidth:120,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{t.place||t.colPlace||"-"}</td>
            <td className="px-2 py-1" style={{fontSize:9,color:"#6b7280",maxWidth:100,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{t.memo||"-"}</td>
            <td className="px-2 py-1 text-center">{t.done?"✅":"—"}</td>
          </tr>)}
        </tbody></table>
      </div>)}
      {!loading&&grouped.length===0&&<div style={{padding:24,textAlign:"center",color:"#9ca3af",fontSize:13}}>該当する過去タスクがありません</div>}
    </div>
  </div>;
}

/* ==========================================
   統合データ
   ========================================== */
function DataTable({data,fleet,vehicles,sheetPlaces,onUpdatePlaces,onOpenReservation,onCancelReservation,onRestoreReservation}){
  const today=toLD(new Date());
  const[s,setS]=useState("");const[otaF,setOtaF]=useState("all");const[plLoading,setPlLoading]=useState(false);
  const[statusF,setStatusF]=useState("active"); // "active", "cancelled", "all"
  // ★ 期間フィルタ: "future"(今日以降), "month"(月指定), "year"(年指定), "all"
  const[periodMode,setPeriodMode]=useState("future");
  const[selMonth,setSelMonth]=useState(()=>{const d=new Date();return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0");});
  const[selYear,setSelYear]=useState(()=>String(new Date().getFullYear()));
  // ★ ソート
  const[sortKey,setSortKey]=useState("lendDate");const[sortAsc,setSortAsc]=useState(true);
  const handleSort=(k)=>{if(sortKey===k)setSortAsc(!sortAsc);else{setSortKey(k);setSortAsc(true);}};
  const sortIcon=(k)=>sortKey===k?(sortAsc?"▲":"▼"):"";

  // ★ 利用可能な月・年を算出
  const{months,years}=useMemo(()=>{
    const ms=new Set();const ys=new Set();
    data.forEach(r=>{if(r.lendDate){const ym=r.lendDate.slice(0,7);ms.add(ym);ys.add(r.lendDate.slice(0,4));}});
    return{months:[...ms].sort(),years:[...ys].sort()};
  },[data]);

  // ★ フィルタリング
  const list=useMemo(()=>{
    let filtered=data.filter(r=>{
      // ステータスフィルタ
      if(statusF==="active"&&r.status==="cancelled")return false;
      if(statusF==="cancelled"&&r.status!=="cancelled")return false;
      // OTAフィルタ
      if(otaF!=="all"&&r.ota!==otaF)return false;
      // テキスト検索
      if(s&&!r.name.includes(s)&&!r.id.includes(s))return false;
      // 期間フィルタ
      if(periodMode==="future")return r.lendDate>=today||r.returnDate>=today;
      if(periodMode==="month")return r.lendDate&&r.lendDate.startsWith(selMonth);
      if(periodMode==="year")return r.lendDate&&r.lendDate.startsWith(selYear);
      return true; // "all"
    });
    // ソート
    filtered.sort((a,b)=>{
      const va=a[sortKey]||"";const vb=b[sortKey]||"";
      if(va<vb)return sortAsc?-1:1;if(va>vb)return sortAsc?1:-1;return 0;
    });
    return filtered;
  },[data,otaF,s,statusF,periodMode,selMonth,selYear,today,sortKey,sortAsc]);

  const doFetchPlaces=async()=>{
    const resIds=list.map(r=>r.id);
    if(!resIds.length){alert("表示中の予約データがありません");return;}
    setPlLoading(true);
    try{
      const placeMap=await fetchPlaceData(resIds);
      const matched=Object.keys(placeMap).length;
      if(!matched){setPlLoading(false);alert("該当する予約番号がスプレッドシートに見つかりませんでした");return;}
      onUpdatePlaces({...sheetPlaces,...placeMap});
      alert(matched+"件の場所情報を取得しました");
    }catch(e){alert("場所データ取得エラー: "+e.message);}
    setPlLoading(false);
  };
  const getPlace=(resId)=>sheetPlaces[resId]||{};
  const getVehicle=(resId)=>{const code=fleet[resId];if(!code)return null;return vehicles.find(v=>v.code===code);};

  const cxlCount=useMemo(()=>data.filter(r=>r.status==="cancelled").length,[data]);
  // ★ カラム定義（マスターに準拠）
  const cols=[
    {h:"状態",w:44,k:"status"},
    {h:"OTA",w:30,k:"ota"},
    {h:"予約者",w:100,k:"name"},
    {h:"貸出日",w:70,k:"lendDate"},
    {h:"時間",w:45,k:"lendTime"},
    {h:"種別",w:40,k:"visitType"},
    {h:"返却日",w:70,k:"returnDate"},
    {h:"返時",w:45,k:"returnTime"},
    {h:"返種",w:40,k:"returnType"},
    {h:"車種",w:48,k:"vehicleClass"},
    {h:"配車",w:60,k:null},
    {h:"No.",w:52,k:null},
    {h:"人数",w:30,k:"people"},
    {h:"B",w:22,k:null},{h:"C",w:22,k:null},{h:"J",w:22,k:null},{h:"USB",w:28,k:null},
    {h:"補償",w:36,k:"insurance"},
    {h:"DEL場所",w:120,k:null},
    {h:"COL場所",w:120,k:null},
    {h:"便名",w:56,k:"flight"},
    {h:"予約番号",w:120,k:"id"},
    {h:"TEL",w:84,k:"tel"},
  ];

  return <div style={{background:"#fff",borderRadius:12,border:"1px solid #e2e8f0",overflow:"hidden",boxShadow:"0 1px 3px rgba(0,0,0,.06)"}}>
    {/* ★ ヘッダー: 期間切替 + 検索 + OTAフィルタ */}
    <div style={{padding:"8px 10px",borderBottom:"1px solid #e2e8f0",display:"flex",flexDirection:"column",gap:6}}>
      {/* 期間切替ボタン */}
      <div style={{display:"flex",gap:3,alignItems:"center",flexWrap:"wrap"}}>
        {[{k:"future",l:"未来"},{k:"month",l:"月別"},{k:"year",l:"年別"},{k:"all",l:"全件"}].map(p=>
          <button key={p.k} onClick={()=>setPeriodMode(p.k)} style={{padding:"4px 10px",borderRadius:6,border:"none",fontSize:10,fontWeight:700,cursor:"pointer",background:periodMode===p.k?"#1e293b":"#f1f5f9",color:periodMode===p.k?"#fff":"#475569"}}>{p.l}</button>
        )}
        {periodMode==="month"&&<select value={selMonth} onChange={e=>setSelMonth(e.target.value)} style={{border:"1px solid #d1d5db",borderRadius:6,padding:"3px 6px",fontSize:10,fontWeight:600}}>
          {months.map(m=><option key={m} value={m}>{m}</option>)}
        </select>}
        {periodMode==="year"&&<select value={selYear} onChange={e=>setSelYear(e.target.value)} style={{border:"1px solid #d1d5db",borderRadius:6,padding:"3px 6px",fontSize:10,fontWeight:600}}>
          {years.map(y=><option key={y} value={y}>{y}</option>)}
        </select>}
        <span style={{marginLeft:"auto",fontSize:10,fontWeight:700,color:"#475569"}}>{list.length}件</span>
      </div>
      {/* 検索 + OTA + 場所取得 */}
      <div style={{display:"flex",gap:4,alignItems:"center",flexWrap:"wrap"}}>
        <input value={s} onChange={e=>setS(e.target.value)} placeholder="予約者名・予約番号" style={{border:"1px solid #d1d5db",borderRadius:6,padding:"4px 8px",fontSize:10,width:150}}/>
        <div style={{display:"flex",gap:2}}>
          <button onClick={()=>setOtaF("all")} style={{padding:"3px 7px",borderRadius:4,border:"none",fontSize:9,fontWeight:700,cursor:"pointer",background:otaF==="all"?"#1e293b":"#f1f5f9",color:otaF==="all"?"#fff":"#64748b"}}>All</button>
          {Object.keys(OTA).map(k=><button key={k} onClick={()=>setOtaF(k)} style={{padding:"3px 7px",borderRadius:4,border:"none",fontSize:9,fontWeight:700,cursor:"pointer",background:otaF===k?OTA[k].c:OTA[k].bg,color:otaF===k?"#fff":OTA[k].c}}>{k}</button>)}
        </div>
        <button onClick={doFetchPlaces} disabled={plLoading} style={{padding:"3px 8px",borderRadius:6,border:"none",fontSize:9,fontWeight:700,cursor:"pointer",background:plLoading?"#94a3b8":"#fbbf24",color:"#78350f"}}>{plLoading?"取得中...":"📍場所取得"}</button>
        <div style={{display:"flex",gap:2,marginLeft:4,borderLeft:"1px solid #e2e8f0",paddingLeft:4}}>
          {[{k:"active",l:"有効",bg:"#dcfce7",c:"#166534"},{k:"cancelled",l:"CXL"+( cxlCount>0?" ("+cxlCount+")":""),bg:"#fee2e2",c:"#991b1b"},{k:"all",l:"全件",bg:"#f1f5f9",c:"#475569"}].map(p=>
            <button key={p.k} onClick={()=>setStatusF(p.k)} style={{padding:"3px 7px",borderRadius:4,border:"none",fontSize:9,fontWeight:700,cursor:"pointer",background:statusF===p.k?p.c:p.bg,color:statusF===p.k?"#fff":p.c}}>{p.l}</button>
          )}
        </div>
      </div>
    </div>

    {/* ★ テーブル（マスター準拠） */}
    <div style={{overflowX:"auto",maxHeight:"75vh"}}>
      <table style={{width:"100%",borderCollapse:"collapse",fontSize:10,whiteSpace:"nowrap"}}>
        <thead><tr style={{background:"#f1f5f9"}}>
          {cols.map((col,i)=>{
            const sticky=i<=2;
            return <th key={i} onClick={col.k?()=>handleSort(col.k):undefined} style={{position:sticky?"sticky":"static",left:i===0?0:i===1?44:i===2?74:undefined,zIndex:sticky?3:1,background:sortKey===col.k?"#dbeafe":"#f1f5f9",padding:"4px 3px",textAlign:"center",fontWeight:600,fontSize:8,color:col.k?"#1d4ed8":"#475569",borderBottom:"2px solid #cbd5e1",borderRight:sticky&&i===2?"2px solid #cbd5e1":"1px solid #e2e8f0",minWidth:col.w,maxWidth:col.w,cursor:col.k?"pointer":"default",userSelect:"none"}}>{col.h}{col.k?<span style={{fontSize:7,marginLeft:1}}>{sortIcon(col.k)}</span>:""}</th>;
          })}
        </tr></thead>
        <tbody>
          {list.map((r,ri)=>{
            const pl=getPlace(r.id);
            const vn=getVehicle(r.id);
            const isFuture=r.lendDate>=today;
            const isPast=r.returnDate<today;
            const isCxl=r.status==="cancelled";
            const rowBg=isCxl?"#f1f1f1":isPast?"#f9fafb":ri%2===0?"#fff":"#fafbfc";
            const cellR=(i)=>({position:i<=2?"sticky":"static",left:i===0?0:i===1?44:i===2?74:undefined,zIndex:i<=2?2:0,background:rowBg,padding:"3px 4px",borderBottom:"1px solid #f1f5f9",borderRight:i===2?"2px solid #cbd5e1":"1px solid #f1f5f9",opacity:isCxl?0.5:isPast?0.4:1,verticalAlign:"middle",fontSize:9});
            return <tr key={r.id+ri} style={{cursor:"pointer"}} title="タップで詳細">
              <td style={{...cellR(0),textAlign:"center",padding:"2px"}}>{isCxl?
                <button onClick={e=>{e.stopPropagation();if(window.confirm(r.name+" 様のキャンセルを復元しますか？"))onRestoreReservation(r.id);}} style={{background:"#fbbf24",color:"#78350f",border:"none",borderRadius:4,fontSize:7,fontWeight:800,padding:"2px 4px",cursor:"pointer",lineHeight:1}}>復元</button>
                :<button onClick={e=>{e.stopPropagation();if(window.confirm(r.name+" 様の予約をキャンセルしますか？\n\n予約番号: "+r.id+"\n貸出: "+fmtD(r.lendDate)+" "+r.lendTime+"\n返却: "+fmtD(r.returnDate)+" "+r.returnTime+"\n\n※OPシートはCXL表示、配車表から除外されます"))onCancelReservation(r.id);}} style={{background:"#fee2e2",color:"#dc2626",border:"none",borderRadius:4,fontSize:7,fontWeight:800,padding:"2px 4px",cursor:"pointer",lineHeight:1}}>CXL</button>
              }</td>
              <td onClick={()=>{if(!isCxl&&onOpenReservation)onOpenReservation(r.id,r.lendDate);}} style={{...cellR(1),textAlign:"center"}}>{r.ota?<OBadge ota={r.ota}/>:""}</td>
              <td onClick={()=>{if(!isCxl&&onOpenReservation)onOpenReservation(r.id,r.lendDate);}} style={{...cellR(2),fontWeight:600,color:isCxl?"#9ca3af":"#0f172a",textDecoration:isCxl?"line-through":"none"}}>{r.name||"-"}</td>
              <td style={{...cellR(3),fontWeight:700,color:r.lendDate===today?"#dc2626":"#1e293b"}}>{r.lendDate||"-"}</td>
              <td style={cellR(4)}>{r.lendTime||"-"}</td>
              <td style={{...cellR(5),fontWeight:600}}><span style={{background:(TASK_META[r.visitType]||{bg:"#f1f5f9"}).bg,color:(TASK_META[r.visitType]||{c:"#64748b"}).c,padding:"1px 4px",borderRadius:3,fontSize:8,fontWeight:700}}>{r.visitType||"-"}</span></td>
              <td style={{...cellR(6),fontWeight:700}}>{r.returnDate||"-"}</td>
              <td style={cellR(7)}>{r.returnTime||"-"}</td>
              <td style={{...cellR(8),fontWeight:600}}><span style={{background:(TASK_META[r.returnType]||{bg:"#f1f5f9"}).bg,color:(TASK_META[r.returnType]||{c:"#64748b"}).c,padding:"1px 4px",borderRadius:3,fontSize:8,fontWeight:700}}>{r.returnType||"-"}</span></td>
              <td style={{...cellR(9),fontWeight:700,color:"#2563eb"}}>{r.vehicleClass||r.vehicle||"-"}</td>
              <td style={{...cellR(10),fontWeight:700,color:vn?"#1e40af":"#dc2626"}}>{vn?vn.name:fleet[r.id]?"("+fleet[r.id]+")":"未配車"}</td>
              <td style={{...cellR(11),fontFamily:"monospace",fontWeight:700,color:vn?"#2563eb":"#ccc"}}>{vn?vn.no:"-"}</td>
              <td style={{...cellR(12),textAlign:"center",fontWeight:700}}>{r.people||""}</td>
              <td style={{...cellR(13),textAlign:"center",fontWeight:700,color:+(r.optB||0)>0?"#2563eb":"#ddd"}}>{+(r.optB||0)||"-"}</td>
              <td style={{...cellR(14),textAlign:"center",fontWeight:700,color:+(r.optC||0)>0?"#2563eb":"#ddd"}}>{+(r.optC||0)||"-"}</td>
              <td style={{...cellR(15),textAlign:"center",fontWeight:700,color:+(r.optJ||0)>0?"#2563eb":"#ddd"}}>{+(r.optJ||0)||"-"}</td>
              <td style={{...cellR(16),textAlign:"center",fontWeight:700,color:+(r.optUSB||0)>0?"#2563eb":"#ddd"}}>{+(r.optUSB||0)||"-"}</td>
              <td style={{...cellR(17),fontWeight:600,color:r.insurance==="NOC"?"#b45309":"#64748b"}}>{r.insurance||"-"}</td>
              <td style={{...cellR(18),fontSize:8,color:pl.delPlace?"#059669":"#94a3b8",fontWeight:pl.delPlace?600:400}}>{pl.delPlace||r.delPlace||"-"}</td>
              <td style={{...cellR(19),fontSize:8,color:pl.colPlace?"#059669":"#94a3b8",fontWeight:pl.colPlace?600:400}}>{pl.colPlace||r.colPlace||"-"}</td>
              <td style={{...cellR(20),color:"#2563eb"}}>{r.flight?"✈"+r.flight:""}</td>
              <td style={{...cellR(21),fontFamily:"monospace",fontSize:7}}>{r.id||""}</td>
              <td style={cellR(22)}>{r.tel||""}</td>
            </tr>;
          })}
          {list.length===0&&<tr><td colSpan={cols.length} style={{textAlign:"center",padding:20,color:"#94a3b8",fontSize:11}}>該当する予約がありません</td></tr>}
        </tbody>
      </table>
    </div>
  </div>;
}

/* ==========================================
   App
   ========================================== */
function App(){
  const[data,setData]=useState([]);const[tab,setTab_]=useState("top");const[tabHistory,setTabHistory]=useState([]);const[taskSumOpen,setTaskSumOpen]=useState(false);const[tomSumOpen,setTomSumOpen]=useState(false);const[topSchedOpen,setTopSchedOpen]=useState(false);
  const setTab=useCallback((newTab)=>{setTab_(prev=>{if(prev&&prev!==newTab){setTabHistory(h=>[...h,prev].slice(-20));}return newTab;});},[]);
  const goBack=useCallback(()=>{setTabHistory(h=>{if(h.length===0)return h;const prev=h[h.length-1];setTab_(prev);return h.slice(0,-1);});},[]);
  const today=toLD(new Date());const importingRef=useRef(false);
  const[fleet,setFleet_]=useState({});const[unassignedReasons,setUnassignedReasons]=useState({});
  const setFleet=React.useCallback((v)=>{
    const val=typeof v==="function"?v:()=>v;
    setFleet_(prev=>{const next=val(prev);
      if(next._unassignedReasons){const r={...next._unassignedReasons};const cleaned={...next};delete cleaned._unassignedReasons;setUnassignedReasons(r);return cleaned;}
      return next;
    });
  },[]);
  const[maintenance,setMaintenance]=useState(()=>DB._maintLsLoad()||[]);
  const[shifts,setShifts]=useState(()=>{
    const ls=DB._shiftsLsLoad();
    if(ls&&Object.keys(ls).length)return ls;
    if(typeof INIT_SHIFTS!=="undefined"&&Object.keys(INIT_SHIFTS).length){DB._shiftsLsSave(INIT_SHIFTS);return INIT_SHIFTS;}
    return {};
  });
  const[showOP,setShowOP]=useState(false);const[showFloatFleet,setShowFloatFleet]=useState(false);const[floatFleetSize,setFloatFleetSize]=useState("half");const[jalanPay,setJalanPay]=useState({});
  const[staff,setStaff]=useState(()=>{
    const ls=DB._staffLsLoad();
    if(ls&&ls.length)return ls;
    return INIT_STAFF;
  });
  const[attendance,setAttendance]=useState({});
  const[vehicles,setVehicles]=useState(INIT_VEHICLES);
  const vehicleClasses=INIT_CLASSES;
  // --- BUDDICA Fleet state ---
  const[hmCars,setHmCars]=useState([]);const[hmCarData,setHmCarData]=useState([]);const[hmLogs,setHmLogs]=useState([]);const[hmClasses,setHmClasses]=useState([]);
  const hmReload=async()=>{const[c,cd,l,cl]=await Promise.all([DB.hm.fetchCars(vehicles),DB.hm.fetchCarData(),DB.hm.fetchLogs(),DB.hm.fetchClasses()]);setHmCars(c);setHmCarData(cd);setHmLogs(l);setHmClasses(cl);markDbSync("hmCars");};
  // Supabase未接続時もBUDDICAデータをロード
  useEffect(()=>{if(!SB_ENABLED)hmReload().catch(e=>console.warn("[HM local]",e));},[]);
  const[pendingPlaces,setPendingPlaces]=useState(null);
  const[sheetPlaces,setSheetPlaces]=useState(()=>{try{return JSON.parse(localStorage.getItem("tkm_sheet_places")||"{}}");}catch(e){return{};}});
  const saveSheetPlaces=(p)=>{setSheetPlaces(p);try{localStorage.setItem("tkm_sheet_places",JSON.stringify(p));}catch(e){}};
  // オプション情報をlocalStorageで管理（DB非依存）
  const[resOpts,setResOpts]=useState(()=>{try{return JSON.parse(localStorage.getItem("tkm_res_opts")||"{}}");}catch(e){return{};}});
  const saveResOpts=(newOpts)=>{setResOpts(newOpts);try{localStorage.setItem("tkm_res_opts",JSON.stringify(newOpts));}catch(e){}};
  const[csvFiles,setCsvFiles]=useState({});const[csvLogs,setCsvLogs]=useState([]);const[csvPlaceLogs,setCsvPlaceLogs]=useState([]);
  const[importDiag,setImportDiag]=useState(null); // インポート売上診断
  const[sbConnected,setSbConnected]=useState(false);
  const sbConnectedRef=useRef(false);
  const[importLockBy,setImportLockBy]=useState(null);
  const[dbLoaded,setDbLoaded]=useState(!SB_ENABLED);

  // 同期状態トラッキング: 各カテゴリの最終DB同期時刻 + ローカル最終変更時刻
  const[syncStatus,setSyncStatus]=useState({
    reservations:{dbTime:null,localTime:null,count:0,dbCount:0},
    fleet:{dbTime:null,localTime:null},
    staff:{dbTime:null,localTime:null,count:0,dbCount:0},
    vehicles:{dbTime:null,localTime:null,count:0,dbCount:0},
    shifts:{dbTime:null,localTime:null},
    maintenance:{dbTime:null,localTime:null},
    accounting:{dbTime:null,localTime:null},
    hmCars:{dbTime:null,localTime:null},
  });
  const markLocalChange=(cat)=>setSyncStatus(p=>({...p,[cat]:{...p[cat],localTime:Date.now()}}));
  const markDbSync=(cat,extra={})=>setSyncStatus(p=>({...p,[cat]:{...p[cat],dbTime:Date.now(),...extra}}));
  // ★ ローカル変更が未同期かどうかをrefで参照（silentRefresh内で使用）
  const syncStatusRef=React.useRef(syncStatus);syncStatusRef.current=syncStatus;

  // --- Supabase 初期ロード ---
  const[bgLoading,setBgLoading]=useState(false); // バックグラウンド更新中フラグ
  useEffect(()=>{
    if(!SB_ENABLED)return;
    // ★ キャッシュ即時表示: 前回の成功データがあれば即UI表示
    try{
      const cached=JSON.parse(localStorage.getItem("tkm_cached_init")||"null");
      if(cached&&cached.res&&cached.res.length>0){
        console.log("[init] キャッシュ即時表示: "+cached.res.length+"件");
        setData(cached.res);
        if(cached.staff&&cached.staff.length)setStaff(cached.staff);
        if(cached.vehicles&&cached.vehicles.length)setVehicles(cached.vehicles);
        if(cached.shifts)setShifts(cached.shifts);
        if(cached.fleet&&Object.keys(cached.fleet).length)setFleet(cached.fleet);
        if(cached.maintenance&&cached.maintenance.length)setMaintenance(cached.maintenance);
        setDbLoaded(true);
        setBgLoading(true); // バックグラウンド更新中表示
      }
    }catch(e){}
    // ★ 2.5秒タイムアウト: キャッシュなし時の通信遅延フォールバック
    const loadTimeout=setTimeout(()=>{
      setDbLoaded(prev=>{
        if(!prev){console.warn("[init] 2.5秒タイムアウト → LS表示に切替");setSbConnected(false);}
        return true;
      });
    },2500);
    // ★ changed_jsonカラムチェックはバックグラウンド（UIロードをブロックしない）
    if(sb&&!window._changedColChecked){
      window._changedColChecked=true;
      (async()=>{try{
        const{data:test,error:testErr}=await sb.from("tkm_tasks").select("changed_json").limit(1);
        if(testErr||test===null){
          DB._hasChangedCol=false;
          try{await sb.rpc("exec_sql",{sql:"ALTER TABLE tkm_tasks ADD COLUMN IF NOT EXISTS changed_json text DEFAULT '{}'"});DB._hasChangedCol=true;}catch(e2){}
        }else{DB._hasChangedCol=true;}
      }catch(e){DB._hasChangedCol=false;}})();
    }
    (async()=>{
      try{
        console.log("[init] DB読込開始...");
        // ★ Phase1: 必須3テーブルを先行取得
        const[resDB,flDB,stDB]=await Promise.all([
          DB.fetchReservations(),DB.fetchFleet(),DB.fetchStaff()
        ]);
        console.log("[init] Phase1完了: 予約="+resDB.length+"件, fleet="+Object.keys(flDB).length+"件, staff="+(stDB?stDB.length:0)+"件");
        // ★ DB優先: Supabaseが権威。DB=0件なら空を受け入れる
        let useRes=resDB;
        if(resDB.length>0){try{localStorage.setItem("tkm_res_backup_v2",JSON.stringify(resDB));}catch(e){}}
        else{try{localStorage.removeItem("tkm_res_backup_v2");}catch(e){}}
        if(useRes.length)setData(useRes);
        if(stDB&&stDB.length)setStaff(stDB);
        const fleetCount=Object.keys(flDB).length;
        if(fleetCount>0){setFleet(flDB);}
        // ★ Phase1完了 → 即UIを表示
        clearTimeout(loadTimeout);
        setSbConnected(true);
        setDbLoaded(true);
        console.log("[init] Phase1完了 → UI表示");

        // ★ Phase2: 残りテーブルをバックグラウンド取得
        setBgLoading(true);
        const[vhDB,shDB,mtDB,plDB]=await Promise.all([
          DB.fetchVehicles(),DB.fetchShifts(),DB.fetchMaintenance(),DB.fetchPlaces()
        ]);
        console.log("[init] Phase2完了: vehicles="+(vhDB?vhDB.length:0)+"台, shifts=OK");
        if(vhDB&&vhDB.length)setVehicles(vhDB);
        if(shDB)setShifts(shDB);
        if(mtDB&&mtDB.length)setMaintenance(mtDB);
        // ★ fleetが空で予約と車両がある場合、自動配車を実行してDBに保存
        if(fleetCount===0&&useRes.length&&vhDB&&vhDB.length){
          const fleetBackup=DB._fleetBackupLoad();
          if(fleetBackup&&fleetBackup.count>5){
            console.warn("[init] fleetCount=0だがバックアップあり("+fleetBackup.count+"件) → バックアップ復元。自動配車は実行しません");
            setFleet(fleetBackup.data);
            DB.upsertFleet(fleetBackup.data).catch(e=>console.error("[init] fleet復元保存エラー:",e));
          }else{
            setTimeout(()=>{
              const newFleet=autoAssign(useRes,vhDB,{},mtDB||[]);
              setFleet(newFleet);
              DB.upsertFleet(newFleet).catch(e=>console.error("[init] fleet保存エラー:",e));
            },0);
          }
        }
        // ★ キャッシュ保存（次回即時表示用）
        try{localStorage.setItem("tkm_cached_init",JSON.stringify({
          res:useRes.slice(0,500),staff:stDB,vehicles:vhDB,
          shifts:shDB,fleet:flDB,maintenance:mtDB,ts:Date.now()
        }));}catch(e){}
        // --- バックグラウンド処理 ---
        (async()=>{
          try{const attDB=await DB.fetchAttendance();if(attDB&&Object.keys(attDB).length)setAttendance(attDB);}catch(e){}
          try{const jpDB=await DB.fetchJalanPayment();if(jpDB)setJalanPay(jpDB);}catch(e){}
          if(plDB&&Object.keys(plDB).length){
            setSheetPlaces(prev=>{const merged={...prev,...plDB};try{localStorage.setItem("tkm_sheet_places",JSON.stringify(merged));}catch(e){}return merged;});
          }
        })();
        setBgLoading(false);
      }catch(e){console.error("DB load error:",e);clearTimeout(loadTimeout);setDbLoaded(true);setBgLoading(false);}
      // BUDDICA Fleet data (バックグラウンド)
      (async()=>{
        try{await hmReload();}catch(e){console.error("[HM] reload error:",e);}
        try{await DB._acctMigrate();}catch(e){console.warn("[acct] migrate:",e);}
      })();
      // 初期ロード完了 → 全カテゴリ同期済み
      const now=Date.now();
      setSyncStatus({
        reservations:{dbTime:now,localTime:null,count:0,dbCount:0},
        fleet:{dbTime:now,localTime:null},
        staff:{dbTime:now,localTime:null,count:0,dbCount:0},
        vehicles:{dbTime:now,localTime:null,count:0,dbCount:0},
        shifts:{dbTime:now,localTime:null},
        maintenance:{dbTime:now,localTime:null},
      });
    })();
  },[]);

  // --- 手動リロード（スマホ用） ---
  const[reloading,setReloading]=useState(0); // 0=idle, 1=loading, 2=done
  const reloadAll=async()=>{
    if(!SB_ENABLED||reloading===1||importingRef.current)return;
    setReloading(1);
    try{
      const[resDB,flDB,stDB,vhDB,shDB,mtDB]=await Promise.all([
        DB.fetchReservations(),DB.fetchFleet(),DB.fetchStaff(),DB.fetchVehicles(),DB.fetchShifts(),DB.fetchMaintenance()
      ]);
      // ★ DB優先: DB=0件なら空を受け入れる
      let useRes=resDB||[];
      if(useRes.length>0){try{localStorage.setItem("tkm_res_backup_v2",JSON.stringify(useRes));}catch(e){}}
      else{try{localStorage.removeItem("tkm_res_backup_v2");}catch(e){}}
      if(useRes.length)setData(useRes);
      if(flDB)setFleet(flDB);
      if(stDB)setStaff(stDB);
      if(vhDB)setVehicles(vhDB);
      if(shDB&&Object.keys(shDB).length){setShifts(shDB);}
      else{const shLS=DB._shiftsLsLoad();if(shLS&&Object.keys(shLS).length){setShifts(shLS);}
      else if(typeof INIT_SHIFTS!=="undefined"&&Object.keys(INIT_SHIFTS).length){setShifts(INIT_SHIFTS);DB._shiftsLsSave(INIT_SHIFTS);}}
      if(mtDB&&mtDB.length)setMaintenance(mtDB);
      try{await hmReload();}catch(e){}
      // 全カテゴリ同期完了
      const now=Date.now();
      setSyncStatus({
        reservations:{dbTime:now,localTime:null,count:useRes.length,dbCount:useRes.length},
        fleet:{dbTime:now,localTime:null},
        staff:{dbTime:now,localTime:null,count:stDB?stDB.length:0,dbCount:stDB?stDB.length:0},
        vehicles:{dbTime:now,localTime:null,count:vhDB?vhDB.length:0,dbCount:vhDB?vhDB.length:0},
        shifts:{dbTime:now,localTime:null},
        maintenance:{dbTime:now,localTime:null},
      });
    }catch(e){console.error("reload error:",e);}
    setReloading(2);
    setTimeout(()=>setReloading(0),1200);
  };
  // --- タブ復帰時+定期ポーリングでDB再読み込み（Realtime未受信の変更を補完）---
  const silentRefresh=React.useCallback(async()=>{
    if(!SB_ENABLED||importingRef.current||reloading===1)return;
    try{
      const[resDB,flDB,stDB,vhDB,shDB,mtDB]=await Promise.all([
        DB.fetchReservations(),DB.fetchFleet(),DB.fetchStaff(),DB.fetchVehicles(),DB.fetchShifts(),DB.fetchMaintenance()
      ]);
      if(importingRef.current)return;
      // ★ DB優先: DB=0件なら空を受け入れる
      let useRes=resDB;
      if(resDB.length>0){try{localStorage.setItem("tkm_res_backup_v2",JSON.stringify(resDB));}catch(e){}}
      else{try{localStorage.removeItem("tkm_res_backup_v2");}catch(e){}}
      if(useRes.length)setData(useRes);
      // ★ fleet: ローカル変更がDB同期より新しい場合は上書きしない（車両変更保護）
      if(flDB&&Object.keys(flDB).length){
        const ss=syncStatusRef.current.fleet;
        const hasPendingLocal=ss.localTime&&(!ss.dbTime||ss.localTime>ss.dbTime);
        if(hasPendingLocal){console.log("[silentRefresh] fleet skip: pending local change");}
        else{setFleet(flDB);fleetRefApp.current=flDB;}
      }
      if(stDB&&stDB.length)setStaff(stDB);
      if(vhDB&&vhDB.length)setVehicles(vhDB);
      if(shDB&&Object.keys(shDB).length){setShifts(shDB);DB._shiftsLsSave(shDB);}
      if(mtDB&&mtDB.length)setMaintenance(mtDB);
      try{const attDB=await DB.fetchAttendance();if(attDB&&Object.keys(attDB).length)setAttendance(attDB);}catch(e){}
      try{await hmReload();}catch(e){}
      // 同期ステータス更新
      const now=Date.now();
      setSyncStatus(p=>({...p,
        reservations:{dbTime:now,localTime:p.reservations.localTime,count:useRes.length,dbCount:useRes.length},
        fleet:{dbTime:now,localTime:p.fleet.localTime},
        staff:{dbTime:now,localTime:p.staff.localTime,count:stDB?stDB.length:0,dbCount:stDB?stDB.length:0},
        vehicles:{dbTime:now,localTime:p.vehicles.localTime,count:vhDB?vhDB.length:0,dbCount:vhDB?vhDB.length:0},
        shifts:{dbTime:now,localTime:p.shifts.localTime},
        maintenance:{dbTime:now,localTime:p.maintenance.localTime},
      }));
    }catch(e){console.error("[silentRefresh]",e);}
  },[reloading]);
  useEffect(()=>{
    if(!SB_ENABLED)return;
    // タブ復帰時に即時リフレッシュ
    const onVis=()=>{if(document.visibilityState==="visible")silentRefresh();};
    document.addEventListener("visibilitychange",onVis);
    // Realtime接続時は60秒、切断時は10秒でポーリング
    let timer=null;
    const startPoll=()=>{if(timer)clearInterval(timer);const iv=sbConnected?60000:10000;timer=setInterval(()=>{if(document.visibilityState==="visible")silentRefresh();},iv);};
    startPoll();
    return()=>{document.removeEventListener("visibilitychange",onVis);if(timer)clearInterval(timer);};
  },[silentRefresh,sbConnected]);

  // --- Supabase Realtime ---
  const silentRefreshRef=useRef(silentRefresh);silentRefreshRef.current=silentRefresh;
  useEffect(()=>{
    if(!sb)return;
    const ch=sb.channel("tkm-realtime")
      .on("postgres_changes",{event:"*",schema:"public",table:"tkm_reservations"},payload=>{
        if(importingRef.current)return;
        if(payload.eventType==="INSERT"||payload.eventType==="UPDATE"){
          const r=DB._fromDbRes(payload.new);
          setData(prev=>{
            const idx=prev.findIndex(x=>x.id===r.id);
            let n;
            if(idx>=0){
              n=[...prev];
              if(!r.price&&prev[idx].price){console.warn(`[RT] price保護: ${r.id} DB=0 → メモリ=${prev[idx].price}`);r.price=prev[idx].price;}
              n[idx]=r;
            } else {
              n=[...prev,r];
            }
            try{localStorage.setItem("tkm_res_backup_v2",JSON.stringify(n));}catch(e){}
            return n;
          });
        }else if(payload.eventType==="DELETE"){
          setData(prev=>{const n=prev.filter(x=>x.id!==payload.old.id);try{localStorage.setItem("tkm_res_backup_v2",JSON.stringify(n));}catch(e){}return n;});
        }
        markDbSync("reservations");
      })
      .on("postgres_changes",{event:"*",schema:"public",table:"tkm_fleet"},payload=>{
        if(importingRef.current)return;
        // ★ ローカル変更が未同期の場合、RTからの上書きをスキップ
        const ss=syncStatusRef.current.fleet;
        if(ss.localTime&&(!ss.dbTime||ss.localTime>ss.dbTime)){console.log("[RT fleet] skip: pending local");return;}
        if(payload.eventType==="DELETE"){
          setFleet(prev=>{const rid=payload.old.reservation_id;const vc=prev[rid];if(vc){try{const log=JSON.parse(localStorage.getItem("tkm_fleet_rt_del_log")||"[]");log.push({rid,vc,ts:Date.now()});if(log.length>100)log.splice(0,log.length-100);localStorage.setItem("tkm_fleet_rt_del_log",JSON.stringify(log));}catch(e){}}const n={...prev};delete n[rid];return n;});
        }else{
          setFleet(prev=>{const n={...prev,[payload.new.reservation_id]:payload.new.vehicle_code};fleetRefApp.current=n;return n;});
        }
        markDbSync("fleet");
      })
      .on("postgres_changes",{event:"*",schema:"public",table:"tkm_tasks"},()=>{})
      .on("postgres_changes",{event:"INSERT",schema:"public",table:"tkm_shifts"},payload=>{
        const s=payload.new;if(!s||!s.date)return;
        setShifts(prev=>{const n={...prev};if(!n[s.date])n[s.date]=[];const arr=n[s.date].filter(x=>x.name!==s.staff_name);arr.push({name:s.staff_name,symbol:s.symbol,start:s.start_time,end:s.end_time,memo:s.memo});n[s.date]=arr;return{...n};});
        markDbSync("shifts");
      })
      .on("postgres_changes",{event:"UPDATE",schema:"public",table:"tkm_shifts"},payload=>{
        const s=payload.new;if(!s||!s.date)return;
        setShifts(prev=>{const n={...prev};if(!n[s.date])n[s.date]=[];const arr=n[s.date].filter(x=>x.name!==s.staff_name);arr.push({name:s.staff_name,symbol:s.symbol,start:s.start_time,end:s.end_time,memo:s.memo});n[s.date]=arr;return{...n};});
        markDbSync("shifts");
      })
      .on("postgres_changes",{event:"DELETE",schema:"public",table:"tkm_shifts"},payload=>{
        const s=payload.old;if(!s||!s.date)return;
        setShifts(prev=>{const n={...prev};if(n[s.date]){n[s.date]=n[s.date].filter(x=>x.name!==s.staff_name);}return{...n};});
        markDbSync("shifts");
      })
      .on("postgres_changes",{event:"*",schema:"public",table:"tkm_staff"},async()=>{
        const st=await DB.fetchStaff();if(st&&st.length)setStaff(st);markDbSync("staff");
      })
      .on("postgres_changes",{event:"*",schema:"public",table:"tkm_vehicles"},async()=>{
        const vh=await DB.fetchVehicles();if(vh&&vh.length)setVehicles(vh);markDbSync("vehicles");
      })
      .on("postgres_changes",{event:"*",schema:"public",table:"tkm_attendance"},async()=>{
        try{const attDB=await DB.fetchAttendance();if(attDB&&Object.keys(attDB).length)setAttendance(attDB);}catch(e){}
      })
      .on("postgres_changes",{event:"*",schema:"public",table:"tkm_cars"},async()=>{
        console.log("[RT] tkm_cars changed → hmReload");
        try{if(typeof hmReload==="function")await hmReload();}catch(e){}
        markDbSync("hmCars");
      })
      .on("postgres_changes",{event:"*",schema:"public",table:"tkm_maintenance"},async()=>{
        console.log("[RT] tkm_maintenance changed → refetch");
        try{const m=await DB.fetchMaintenance();if(m)setMaintenance(m);}catch(e){}
        markDbSync("maintenance");
      })
      .subscribe((status,err)=>{
        console.log("[Realtime]",status,err||"");
        const wasDisconnected=!sbConnectedRef.current;
        setSbConnected(status==="SUBSCRIBED");
        sbConnectedRef.current=(status==="SUBSCRIBED");
        if(status==="SUBSCRIBED"&&wasDisconnected){
          console.log("[Realtime] 復帰→即座にsilentRefresh");
          silentRefreshRef.current();
        }
        if(status==="CHANNEL_ERROR"||status==="TIMED_OUT"){
          console.warn("[Realtime] 接続エラー→3秒後に再接続");
          setTimeout(()=>{try{ch.subscribe();}catch(e){}},3000);
        }
      });
    // ★ Broadcast受信: CSV取込ロック通知
    DB._initBroadcast();
    if(DB._broadcastCh){
      DB._broadcastCh.on("broadcast",{event:"import-lock"},(msg)=>{
        const p=msg.payload||{};
        setImportLockBy(p.locked?p.user||"\u4ED6\u7AEF\u672B":null);
        if(p.locked)console.log("[Broadcast] import-lock ON by",p.user);
        else console.log("[Broadcast] import-lock OFF");
      });
    }
    return()=>{sb.removeChannel(ch);if(DB._broadcastCh){sb.removeChannel(DB._broadcastCh);DB._broadcastCh=null;}};
  },[]);

  // --- Supabase連携ラッパー（DB呼び出しをsetState外で実行）---
  const setStaffSync=useCallback((fn)=>{
    const next=typeof fn==="function"?fn(staff):fn;
    setStaff(next);markLocalChange("staff");
    DB.saveStaff(next).then(()=>markDbSync("staff")).catch(e=>console.error("saveStaff error:",e));
  },[staff]);
  const setVehiclesSync=useCallback((fn)=>{
    const next=typeof fn==="function"?fn(vehicles):fn;
    setVehicles(next);markLocalChange("vehicles");
    DB.saveVehicles(next).then(()=>markDbSync("vehicles")).catch(e=>console.error("saveVehicles error:",e));
  },[vehicles]);
  const setShiftsSync=useCallback((fn)=>{
    const next=typeof fn==="function"?fn(shifts):fn;
    setShifts(next);markLocalChange("shifts");
    DB._shiftsLsSave(next);
    Object.keys(next).forEach(date=>{if(next[date]&&next[date].length)DB.saveShiftsForDate(date,next[date]);});
  },[shifts]);
  // 給与画面からの強制同期用
  window.__spkForceShifts=setShifts;
  const fleetRefApp=React.useRef(fleet);fleetRefApp.current=fleet;
  const setFleetSync=useCallback((nextFleet)=>{
    const resolved=typeof nextFleet==="function"?nextFleet(fleetRefApp.current):nextFleet;
    setFleet(resolved);fleetRefApp.current=resolved;markLocalChange("fleet");
    DB.upsertFleet(resolved).then(()=>markDbSync("fleet")).catch(e=>console.error("upsertFleet error:",e));
  },[]);

  // 配車変更 + OPシートタスク同時更新
  const reassignVehicle=useCallback(async(resId,newVc)=>{
    // ★ DB最新チェック: ダブルブッキング防止（サーバーサイド完全チェック）
    if(sb&&newVc){
      try{
        const res=data.find(r=>r.id===resId);
        if(res){
          // DB側で直接「この車両に配車済み & 期間重複する予約」を検索
          const ld=norm(res.lendDate),rd=norm(res.returnDate);
          const{data:overlapping}=await sb.from("tkm_fleet")
            .select("reservation_id,vehicle_code,tkm_reservations!inner(start_date,end_date,name,status)")
            .eq("vehicle_code",newVc)
            .neq("reservation_id",resId)
            .lte("tkm_reservations.start_date",rd)
            .gte("tkm_reservations.end_date",ld);
          if(overlapping&&overlapping.length){
            const active=overlapping.filter(o=>o.tkm_reservations&&o.tkm_reservations.status!=="cancelled");
            if(active.length){
              const first=active[0];
              const cName=first.tkm_reservations?first.tkm_reservations.name:"不明";
              const cStart=first.tkm_reservations?first.tkm_reservations.start_date:"";
              const cEnd=first.tkm_reservations?first.tkm_reservations.end_date:"";
              alert("⚠ この車両は「"+cName+"」様の予約("+cStart+"〜"+cEnd+")と期間が重複しています。\n別の端末で配車された可能性があります。\n\n最新データを取得します。");
              silentRefresh();
              return;
            }
          }
        }
      }catch(e){console.warn("[reassign] DB check error:",e);}
    }
    // ★ 配車解除の場合
    if(!newVc){
      const nf={...fleetRefApp.current};delete nf[resId];
      fleetRefApp.current=nf;setFleet(nf);markLocalChange("fleet");
      DB.deleteFleetOne(resId).then(()=>markDbSync("fleet")).catch(e=>console.error("deleteFleetOne error:",e));
      DB._fleetLsSave(nf);
      // タスクの配車情報もクリア
      if(SB_ENABLED){const res=data.find(r=>r.id===resId);if(res){try{const _clr=async(d)=>{if(!d)return;const tks=await DB.fetchTasks(d);if(!tks||!tks.length)return;const upd=tks.map(t=>t.reservationId===resId?{...t,assignedVehicle:"",plateNo:""}:t);if(JSON.stringify(upd)!==JSON.stringify(tks))await DB.upsertTasks(upd,d);};const ld=norm(res.lendDate),rd=norm(res.returnDate);await _clr(ld);if(rd!==ld)await _clr(rd);await _clr(dOff(ld,-1));}catch(e){console.error("[reassign clear]",e);}}}
      return;
    }
    // ★ 差分更新: upsertFleet(全量)ではなくupdateFleetOne(1件)を使用
    const nextFleet={...fleetRefApp.current,[resId]:newVc};
    fleetRefApp.current=nextFleet;
    setFleet(nextFleet);markLocalChange("fleet");
    DB.updateFleetOne(resId,newVc).then(()=>markDbSync("fleet")).catch(e=>console.error("updateFleetOne error:",e));
    DB._fleetLsSave(nextFleet);
    const vn=vehicles.find(x=>x.code===newVc);
    // ★ reservations.vehicleも同期（クラス変更を予約マスターに反映）
    if(vn){await DB.updateReservationField(resId,{vehicle:vn.type},"配車変更→クラス同期","fleet");setData(prev=>prev.map(r=>r.id===resId?{...r,vehicle:vn.type}:r));}
    if(!SB_ENABLED||!vn)return;
    // OPシートの該当タスクも更新（全日分チェック）
    const res=data.find(r=>r.id===resId);if(!res)return;
    const ld=norm(res.lendDate),rd=norm(res.returnDate);
    // 貸出日のタスクを更新
    try{
      const tasks=await DB.fetchTasks(ld);
      if(tasks&&tasks.length){
        const updated=tasks.map(t=>t.reservationId===resId?{...t,assignedVehicle:newVc,plateNo:vn.no||"",vehicle:vn.type||t.vehicle}:t);
        if(JSON.stringify(updated)!==JSON.stringify(tasks))await DB.upsertTasks(updated,ld);
      }
      if(rd!==ld){const tasks2=await DB.fetchTasks(rd);if(tasks2&&tasks2.length){const updated2=tasks2.map(t=>t.reservationId===resId?{...t,assignedVehicle:newVc,plateNo:vn.no||"",vehicle:vn.type||t.vehicle}:t);if(JSON.stringify(updated2)!==JSON.stringify(tasks2))await DB.upsertTasks(updated2,rd);}}
      // 前日の洗車タスクも更新
      const prevDay=dOff(ld,-1);
      const tasks3=await DB.fetchTasks(prevDay);
      if(tasks3&&tasks3.length){const updated3=tasks3.map(t=>t.reservationId===resId?{...t,assignedVehicle:newVc,plateNo:vn.no||"",vehicle:vn.type||t.vehicle}:t);if(JSON.stringify(updated3)!==JSON.stringify(tasks3))await DB.upsertTasks(updated3,prevDay);}
    }catch(e){console.error("task vehicle update error:",e);}
  },[data,vehicles,silentRefresh]);

  const imp=useCallback(async(d)=>{
    importingRef.current=true; // ★ 全てのDB再読込・RT更新をブロック
    DB.broadcastImportLock(true, "\u30B9\u30BF\u30C3\u30D5");
    // ★ 全priceをNumber型に正規化
    let imported=d.map(r=>({...r,price:Number(r.price)||0,finalPrice:Number(r.finalPrice)||0}));
    if(pendingPlaces&&Object.keys(pendingPlaces).length>0){
      imported=imported.map(r=>{const p=pendingPlaces[r.id];if(p)return{...r,delPlace:p.delPlace||r.delPlace,colPlace:p.colPlace||r.colPlace};return r;});
    }
    // ★ 重複ID解消: 同じIDが複数OTAに存在する場合、price>0の方を優先
    const dedupMap=new Map();
    imported.forEach(r=>{const ex=dedupMap.get(r.id);if(ex){if((Number(r.price)||0)>(Number(ex.price)||0))dedupMap.set(r.id,r);else{/* 既存の方がprice高い→既存のpriceを現在のに反映 */if(!r.price&&ex.price){r.price=ex.price;}}}else dedupMap.set(r.id,r);});
    imported=[...dedupMap.values()];
    // 既存データとマージ: インポートしたOTAの予約はCSV内容で置換、他OTAはそのまま
    const importedOTAs=new Set(imported.map(r=>r.ota));
    const importedIds=new Set(imported.map(r=>r.id));
    const kept=data.filter(r=>!importedOTAs.has(r.ota)||importedIds.has(r.id));
    const map=new Map(kept.map(r=>[r.id,r]));
    // ★ マージ時もprice>0優先
    imported.forEach(r=>{const ex=map.get(r.id);if(ex&&!r.price&&ex.price){r.price=ex.price;}map.set(r.id,r);});
    const allData=[...map.values()].map(r=>({...r,price:Number(r.price)||0})); // 全データのprice正規化
    // ★ localStorageにもバックアップ保存（DB障害時の保険）
    try{localStorage.setItem("tkm_res_backup_v2",JSON.stringify(allData));}catch(e){}
    setData(allData);
    // 配車データ
    // ★ インポート前に配車データをバックアップ
    try{const fleetCnt=Object.keys(fleet).filter(k=>k!=="_unassignedReasons").length;if(fleetCnt>0){localStorage.setItem("tkm_fleet_pre_import",JSON.stringify({data:fleet,ts:Date.now(),count:fleetCnt}));console.log("[imp] 配車バックアップ保存:",fleetCnt+"件");}}catch(e){}
    const allIds=new Set(allData.map(r=>r.id));
    const cleanFleet={};Object.entries(fleet).forEach(([rid,vc])=>{if(allIds.has(rid))cleanFleet[rid]=vc;});
    const newFleet=autoAssign(allData,vehicles,cleanFleet,maintenance);
    setFleet(newFleet);
    setTab("fleet");
    // オプション情報をlocalStorageに保存
    const newResOpts={...resOpts};
    imported.forEach(r=>{newResOpts[r.id]={b:+(r.optB||0),c:+(r.optC||0),j:+(r.optJ||0),usb:+(r.optUSB||0)};});
    saveResOpts(newResOpts);
    // ★ じゃらん予約のfinalPrice→jalanPay.adjustedPriceに自動セット
    const jImported=imported.filter(r=>r.ota==="J"&&r.finalPrice);
    if(jImported.length>0){
      const jpCopy={...jalanPay};
      jImported.forEach(r=>{
        const existing=jpCopy[r.id]||{};
        jpCopy[r.id]={...existing,adjustedPrice:String(r.finalPrice),category:existing.category||"売上",payStatus:existing.payStatus||"未完了",sendDate:existing.sendDate||"",refundDate:existing.refundDate||"",content:existing.content||"",linkUrl:existing.linkUrl||""};
      });
      setJalanPay(jpCopy);
      // DB保存も
      jImported.forEach(r=>{const d=jpCopy[r.id];DB.saveJalanPayment(r.id,d);});
      console.log("[imp] じゃらんfinalPrice→adjustedPrice自動セット:",jImported.length+"件");
    }
    // ★ DB保存（バックグラウンド・エラー時はalert）
    const removedIds=data.filter(r=>importedOTAs.has(r.ota)&&!importedIds.has(r.id)).map(r=>r.id);
    (async()=>{
      try{
        if(removedIds.length){try{const delFleetLog=removedIds.map(id=>({id,vc:fleet[id]||"none"}));console.warn("[imp] 配車削除対象:",JSON.stringify(delFleetLog));localStorage.setItem("tkm_fleet_del_log",JSON.stringify({ts:Date.now(),deleted:delFleetLog}));}catch(e){}await DB.deleteReservations(removedIds);removedIds.forEach(id=>DB.deleteFleetOne(id));}
        // 30件ずつバッチupsert
        for(let i=0;i<imported.length;i+=30){
          const chunk=imported.slice(i,i+30);
          await DB.upsertReservations(chunk);
        }
        await DB.upsertFleet(newFleet);
      }catch(e){
        console.error("[imp] DB保存エラー:",e);
        alert("⚠️ DB保存でエラーが発生しました: "+e.message+"\nページをリロードしないでください。データはメモリ上に保持されています。");
      }
      // ★ DB保存完了後もしばらくガードを維持（RTイベントの遅延対策）
      setTimeout(()=>{importingRef.current=false;DB.broadcastImportLock(false,"");},15000);
    })();
    // ★ インポート結果をalertで通知（件数＋売上）
    // --- 今回インポート分だけのOTA別サマリー ---
    const impOtaSum={};imported.forEach(r=>{const k=r.ota||"?";if(!impOtaSum[k])impOtaSum[k]={cnt:0,sum:0,z:0};impOtaSum[k].cnt++;impOtaSum[k].sum+=(Number(r.price)||0);if(!r.price)impOtaSum[k].z++;});
    const impOtaStr=Object.entries(impOtaSum).map(([k,v])=>`  ${k}: ${v.cnt}件 ¥${v.sum.toLocaleString()}${v.z?` (${v.z}件=0)`:""}`).join("\n");
    // --- 全体の月別サマリー ---
    const mBreak={};allData.forEach(r=>{const ym=r.returnDate?r.returnDate.substring(0,7):"?";if(!mBreak[ym])mBreak[ym]={cnt:0,sum:0,zeros:[]};mBreak[ym].cnt++;mBreak[ym].sum+=(Number(r.price)||0);if(!r.price)mBreak[ym].zeros.push(r);});
    const mStr=Object.entries(mBreak).sort(([a],[b])=>a.localeCompare(b)).map(([k,v])=>`${k}: ${v.cnt}件 ¥${v.sum.toLocaleString()}${v.zeros.length?` ⚠️${v.zeros.length}件price=0`:""}`).join("\n");
    const totalSum=allData.reduce((s,r)=>s+(Number(r.price)||0),0);
    const zeroAll=allData.filter(r=>!r.price);
    const zeroDetail=zeroAll.length>0?`\n\n⚠️ price=0: ${zeroAll.length}件\n`+zeroAll.slice(0,10).map(r=>`  ${r.ota}/${r.id}/${r.name}`).join("\n")+(zeroAll.length>10?`\n  ...他${zeroAll.length-10}件`:""):"";
    // ★ 画面上に売上診断バナーを表示（alertの代わり）
    const diagOta={};allData.forEach(r=>{const k=r.ota||"?";if(!diagOta[k])diagOta[k]={cnt:0,sum:0,z:0};diagOta[k].cnt++;diagOta[k].sum+=(Number(r.price)||0);if(!r.price)diagOta[k].z++;});
    setImportDiag({ts:new Date().toLocaleTimeString(),total:allData.length,totalSum,mBreak,diagOta,zeroAll:zeroAll.slice(0,20)});
    alert(`✅ ${allData.length}件取込完了 / 総売上¥${totalSum.toLocaleString()}\n\n【今回インポート分 OTA別】\n${impOtaStr}\n\n【全体 月別内訳】\n${mStr}${zeroDetail}\n\n※ 画面右上「v${APP_VERSION}」表示を確認\n※DB保存中です。15秒間お待ちください。`);
    // インポート後、既存タスクのオプション情報を強制更新
    (async()=>{
      const rOptsMap={};imported.forEach(r=>{rOptsMap[r.id]={b:+(r.optB||0),c:+(r.optC||0),j:+(r.optJ||0),usb:+(r.optUSB||0)};});
      const affDates=new Set();
      imported.forEach(r=>{
        if(r.lendDate){affDates.add(r.lendDate);affDates.add(dOff(r.lendDate,-1));}
        if(r.returnDate)affDates.add(r.returnDate);
      });
      for(const d of affDates){
        try{
          const ts=await DB.fetchTasks(d);
          if(!ts||!ts.length)continue;
          let ch=false;
          const upd=ts.map(t=>{
            const ro=rOptsMap[t.reservationId];if(!ro)return t;
            const co=t.opts||{};
            if(+(ro.b||0)!==+(co.b||0)||+(ro.c||0)!==+(co.c||0)||+(ro.j||0)!==+(co.j||0)||+(ro.usb||0)!==+(co.usb||0)){ch=true;return{...t,opts:{...ro}};}
            return t;
          });
          if(ch)DB.upsertTasks(upd,d);
        }catch(e){}
      }
    })();
  },[data,vehicles,fleet,pendingPlaces,maintenance]);

  const addReservation=useCallback((r,vehicleCode)=>{
    const newData=[...data,r];
    setData(newData);
    DB.upsertReservations([r]);
    if(vehicleCode){
      setFleet(prev=>({...prev,[r.id]:vehicleCode}));
      DB.updateFleetOne(r.id,vehicleCode);
    }else{
      // 自動配車
      const newFleet=autoAssign(newData,vehicles,fleet,maintenance);
      setFleet(newFleet);
      DB.upsertFleet(newFleet);
    }
  },[data,vehicles,fleet,maintenance]);

  const bulkAddReservation=useCallback((rArr,fl)=>{
    const ids=new Set(data.map(r=>r.id));
    const newOnes=rArr.filter(r=>!ids.has(r.id));
    setData(prev=>[...prev,...newOnes]);
    setFleet(prev=>({...prev,...fl}));
    DB.upsertReservations(newOnes);
    DB.upsertFleet(fl);
  },[data]);

  const cancelReservation=useCallback(async(id)=>{
    const res=data.find(r=>r.id===id);if(!res)return;
    // ★ ソフトキャンセル: status="cancelled" に変更（削除しない）
    setData(prev=>prev.map(r=>r.id===id?{...r,status:"cancelled"}:r));
    // 配車解除
    setFleet(prev=>{const nf={...prev};delete nf[id];return nf;});markLocalChange("fleet");
    await DB.deleteFleetOne(id);markDbSync("fleet");
    // DB: statusをcancelledに更新
    await DB.updateReservationField(id,{status:"cancelled"},"キャンセル処理","manual");
    // ★ 関連タスクをCXLに変更（削除ではなくグレー表示用）
    if(res){try{const _cxl=async(d)=>{if(!d)return;const tks=await DB.fetchTasks(d);if(!tks)return;const updated=tks.map(tk=>tk.reservationId===id?{...tk,type:"CXL",done:true,assignee:"",assignedVehicle:"",plateNo:""}:tk);if(JSON.stringify(updated)!==JSON.stringify(tks))await DB.upsertTasks(updated,d);};const ld=norm(res.lendDate),rd=norm(res.returnDate);await _cxl(ld);if(rd!==ld)await _cxl(rd);await _cxl(dOff(ld,-1));}catch(e){console.error("[cancel task CXL]",e);}}
  },[data]);
  // ★ キャンセル復元
  const restoreReservation=useCallback(async(id)=>{
    setData(prev=>prev.map(r=>r.id===id?{...r,status:"confirmed"}:r));
    await DB.updateReservationField(id,{status:"confirmed"},"キャンセル復元","manual");
    // ★ タスクのCXL状態を解除
    const res=data.find(r=>r.id===id);
    if(res){try{const rd=norm(res.returnDate);const _restore=async(d)=>{if(!d)return;const tks=await DB.fetchTasks(d);if(!tks||!tks.length)return;const updated=tks.map(t=>t.reservationId===id&&t.type==="CXL"?{...t,type:d===rd?"COL":"DEL",done:false}:t);if(JSON.stringify(updated)!==JSON.stringify(tks))await DB.upsertTasks(updated,d);};const ld=norm(res.lendDate);await _restore(ld);if(rd!==ld)await _restore(rd);await _restore(dOff(ld,-1));}catch(e){console.error("[restore task]",e);}}
  },[data]);

  const updatePlaces=useCallback((places)=>{
    let matched=0;
    const updated=data.map(r=>{
      const p=places[r.id];
      if(p){matched++;return{...r,delPlace:p.delPlace||r.delPlace,colPlace:p.colPlace||r.colPlace};}
      return r;
    });
    setData(updated);
    const unmatched=Object.keys(places).length-matched;
    // DB保存
    DB.upsertPlaces(places);
    const changed=updated.filter(r=>places[r.id]);
    if(changed.length)DB.upsertReservations(changed);
    return{matched,unmatched};
  },[data]);

  const oc=useMemo(()=>{const c={};data.forEach(t=>{c[t.ota]=(c[t.ota]||0)+1;});return c;},[data]);
  const navItems=[{id:"top",ico:"🏠",l:"TOP"},{id:"import",ico:"📁",l:"CSV"},{id:"staff",ico:"👥",l:"スタッフ"},{id:"shift",ico:"📅",l:"出勤簿"},{id:"attendance",ico:"⏰",l:"給与"},{id:"fleet",ico:"🚗",l:"配車"},{id:"jalanpay",ico:"💳",l:"決済"},{id:"vehicle",ico:"🔧",l:"車両"},{id:"parking",ico:"🅿️",l:"駐車場"},{id:"accounting",ico:"🧾",l:"会計"},{id:"customer",ico:"👑",l:"顧客"},{id:"license",ico:"🪪",l:"免許証",external:true},{id:"data",ico:"📋",l:"データ"},{id:"history",ico:"📜",l:"過去"},{id:"foreign",ico:"🌍",l:"外国人"}];

  const repeaterInfo=useMemo(()=>buildRepeaterMap(data),[data]);

  if(!dbLoaded)return <div onClick={()=>setDbLoaded(true)} style={{minHeight:"100vh",display:"flex",alignItems:"center",justifyContent:"center",background:"#f3f4f6",cursor:"pointer"}}><div style={{textAlign:"center"}}><div style={{width:48,height:48,border:"4px solid #e5e7eb",borderTopColor:"#2563eb",borderRadius:"50%",animation:"spin 1s linear infinite",margin:"0 auto 12px"}}></div><p style={{color:"#64748b",fontSize:13}}>データ読込中...</p><p style={{color:"#94a3b8",fontSize:11,marginTop:8}}>タップでスキップ</p></div></div>;
  const BgLoadingBar=()=>bgLoading?<div style={{position:"fixed",top:0,left:0,right:0,height:3,zIndex:99999,background:"#e5e7eb"}}><div style={{height:"100%",background:"#2563eb",animation:"bgbar 1.5s ease-in-out infinite",width:"40%"}}></div><style>{`@keyframes bgbar{0%{margin-left:-40%}100%{margin-left:100%}}`}</style></div>:null;

  return <div style={{height:"100vh",display:"flex",flexDirection:"column",overflow:"hidden"}}>
    <BgLoadingBar/>
    {SB_ENABLED&&<div className="sync-desktop"><SyncBadge connected={sbConnected}/></div>}
    {showOP&&<OPScreen reservations={data} today={today} shifts={shifts} fleet={fleet} onFleetChange={setFleetSync} onClose={()=>setShowOP(false)} onGoFleet={()=>{setShowFloatFleet(f=>!f);}} vehicles={vehicles} staff={staff} resOpts={resOpts} sheetPlaces={sheetPlaces} onUpdateSheetPlaces={saveSheetPlaces} repeaterMap={repeaterInfo.isRepeater} jalanPay={jalanPay} maintenance={maintenance} onReservationUpdate={(resId,fields)=>{setData(prev=>{const next=prev.map(r=>r.id===resId?{...r,...fields}:r);/* ★ OPシートタスクにも連動 */const updated=next.find(r=>r.id===resId);if(updated&&Object.keys(fields).some(k=>["delTime","delPlace","colTime","colPlace","insurance","vehicle","name","people","optB","optC","optJ","optUSB"].includes(k))){const syncF={};if(fields.name!==undefined)syncF.name=fields.name;if(fields.people!==undefined)syncF.people=fields.people;if(fields.insurance!==undefined)syncF.insurance=fields.insurance;if(fields.vehicle!==undefined)syncF.vehicle=fields.vehicle;const syncOpts=(fields.optB!==undefined||fields.optC!==undefined||fields.optJ!==undefined||fields.optUSB!==undefined)?{b:+(fields.optB??updated.optB??0),c:+(fields.optC??updated.optC??0),j:+(fields.optJ??updated.optJ??0),usb:+(fields.optUSB??updated.optUSB??0)}:null;const _syncT=async(d)=>{if(!d)return;const tks=await DB.fetchTasks(d);if(!tks||!tks.length)return;const upd=tks.map(tk=>{if(tk.reservationId!==resId)return tk;const u={...tk};if(syncF.name!==undefined)u.name=syncF.name;if(syncF.people!==undefined)u.people=syncF.people;if(syncF.insurance!==undefined)u.insurance=syncF.insurance;if(syncF.vehicle!==undefined)u.vehicle=syncF.vehicle;if(syncOpts)u.opts=syncOpts;if((tk.type==="DEL"||tk.type==="PU"||tk.type==="PUB")&&tk._timeChangeSource!=="manual"&&fields.delTime!==undefined)u.time=fields.delTime;if((tk.type==="DEL"||tk.type==="PU"||tk.type==="PUB")&&tk._placeSource!=="manual"&&fields.delPlace!==undefined)u.place=fields.delPlace;if((tk.type==="COL"||tk.type==="BD"||tk.type==="BDB")&&tk._timeChangeSource!=="manual"&&fields.colTime!==undefined)u.time=fields.colTime;if((tk.type==="COL"||tk.type==="BD"||tk.type==="BDB")&&tk._placeSource!=="manual"&&fields.colPlace!==undefined)u.place=fields.colPlace;return u;});if(JSON.stringify(upd)!==JSON.stringify(tks))DB.upsertTasks(upd,d);};try{const ld=norm(updated.lendDate),rd=norm(updated.returnDate);_syncT(ld);if(rd!==ld)_syncT(rd);}catch(e){console.error("[resUpdate→tasks sync]",e);}}return next;});}}/>}
    {/* ★ フローティング配車表パネル（PC専用） */}
    {showFloatFleet&&<div style={{position:"fixed",bottom:0,right:0,width:floatFleetSize==="full"?"100%":"50%",height:floatFleetSize==="full"?"70vh":"45vh",zIndex:250,background:"#fff",borderTop:"3px solid #059669",borderLeft:floatFleetSize!=="full"?"3px solid #059669":"none",boxShadow:"0 -4px 20px rgba(0,0,0,.2)",display:"flex",flexDirection:"column",borderRadius:floatFleetSize==="full"?"12px 12px 0 0":"12px 0 0 0"}}>
      <div style={{display:"flex",alignItems:"center",padding:"6px 12px",background:"#059669",gap:6,flexShrink:0,borderRadius:floatFleetSize==="full"?"9px 9px 0 0":"9px 0 0 0"}}>
        <span style={{fontSize:12,fontWeight:800,color:"#fff"}}>🚗 配車表</span>
        <button onClick={()=>setFloatFleetSize(s=>s==="half"?"full":"half")} style={{background:"rgba(255,255,255,.2)",border:"none",color:"#fff",fontSize:10,fontWeight:700,padding:"2px 8px",borderRadius:4,cursor:"pointer",marginLeft:"auto"}}>{floatFleetSize==="full"?"↘ 縮小":"↗ 拡大"}</button>
        <button onClick={()=>setShowFloatFleet(false)} style={{background:"rgba(255,255,255,.2)",border:"none",color:"#fff",fontSize:12,fontWeight:800,padding:"2px 8px",borderRadius:4,cursor:"pointer"}}>✕</button>
      </div>
      <div style={{flex:1,overflow:"hidden"}}>
        <FleetTimeline data={data} fleet={fleet} onFleetChange={setFleetSync} today={today} maintenance={maintenance} onMaintenanceChange={setMaintenance} vehicles={vehicles} vehicleClasses={vehicleClasses} onAddReservation={addReservation} onBulkAddReservation={bulkAddReservation} onCancelReservation={cancelReservation} onReassignVehicle={reassignVehicle} unassignedReasons={unassignedReasons} hmReload={hmReload}/>
      </div>
    </div>}
    <div style={{display:showOP?"none":"flex",flex:1,overflow:"hidden",flexDirection:"column"}}>
      <div className={"top-nav"+(tab==="top"?" hide-on-top":"")}>
        {navItems.filter(n=>{const always=["top","import","vehicle","staff","shift","attendance","fleet","jalanpay","history","customer","foreign","accounting","license"];return always.includes(n.id)||data.length>0;}).map(n=><button key={n.id} onClick={()=>{if(n.external){window.open("license.html","_blank");}else{setTab(n.id);}}} className={tab===n.id?"active":""}><span className="ico">{n.ico}</span>{n.l}</button>)}
        <button onClick={()=>setTab("top")} style={{color:"#60a5fa"}}><span className="ico">🏠</span>TOP</button>
        {SB_ENABLED&&<button onClick={reloadAll} disabled={reloading===1} style={{background:reloading===2?"#d1fae5":"none",border:"none",cursor:reloading===1?"wait":"pointer",fontSize:14,padding:"2px 4px",borderRadius:6,opacity:reloading===1?0.5:1,transition:"background .3s"}}>{reloading===1?"⏳":reloading===2?"✅":"🔄"}</button>}
        {SB_ENABLED&&<SyncBadge connected={sbConnected} inline={true}/>}
      </div>
      <div style={{display:"flex",flex:1,overflow:"hidden"}}>
      <div className={"sidebar"+(tab==="top"?" hide-on-top":"")}>
        <div style={{width:36,height:36,borderRadius:8,background:"linear-gradient(135deg,#3b82f6,#1d4ed8)",display:"flex",alignItems:"center",justifyContent:"center",color:"#fff",fontWeight:800,fontSize:14,marginBottom:8}}>O</div>
        {navItems.filter(n=>{const always=["top","import","vehicle","staff","shift","attendance","fleet","jalanpay","history","customer","foreign","accounting","license"];return always.includes(n.id)||data.length>0;}).map(n=><button key={n.id} onClick={()=>{if(n.external){window.open("license.html","_blank");}else{setTab(n.id);}}} className={tab===n.id?"active":""}><span className="ico">{n.ico}</span>{n.l}</button>)}
        <button onClick={()=>setTab("top")} style={{marginTop:4,background:"linear-gradient(135deg,#1e40af,#2563eb)",color:"#fff",borderRadius:10}}><span className="ico">🏠</span><span style={{fontSize:8}}>TOP</span></button>
      </div>
      <div className="main-area" style={{flex:1,overflow:tab==="fleet"?"hidden":"auto",padding:tab==="fleet"?0:12,display:"flex",flexDirection:"column"}}>
        {importLockBy&&<div style={{background:"#fef3c7",borderBottom:"2px solid #f59e0b",padding:"8px 16px",display:"flex",alignItems:"center",gap:8,position:"sticky",top:0,zIndex:200,flexShrink:0}}>
          <span style={{fontSize:16}}>&#9888;&#65039;</span>
          <span style={{fontSize:12,fontWeight:700,color:"#92400e"}}>CSV\u53D6\u8FBC\u4E2D\u3067\u3059\u3002\u7DE8\u96C6\u306F\u4E00\u6642\u7684\u306B\u4FDD\u7559\u3055\u308C\u308B\u3053\u3068\u304C\u3042\u308A\u307E\u3059\u3002</span>
        </div>}
        {tab!=="top"&&tabHistory.length>0&&(tab==="fleet"?
          <div style={{padding:"6px 10px",flexShrink:0,background:"#f8fafc",borderBottom:"1px solid #e2e8f0"}}>
            <button onClick={goBack} style={{display:"inline-flex",alignItems:"center",gap:4,padding:"4px 12px",fontSize:12,fontWeight:600,color:"#3b82f6",background:"#eff6ff",border:"1px solid #bfdbfe",borderRadius:8,cursor:"pointer"}}>← 前ページに戻る</button>
          </div>
        :
          <div style={{marginBottom:4,flexShrink:0}}>
            <button onClick={goBack} style={{display:"inline-flex",alignItems:"center",gap:4,padding:"4px 12px",fontSize:12,fontWeight:600,color:"#3b82f6",background:"#eff6ff",border:"1px solid #bfdbfe",borderRadius:8,cursor:"pointer"}}>← 前ページに戻る</button>
          </div>
        )}
        {tab!=="fleet"&&tab!=="parking"&&tab!=="top"&&<div style={{marginBottom:8,display:"flex",alignItems:"center",justifyContent:"space-between",flexWrap:"wrap",gap:8,flexShrink:0}}>
          <div className="flex items-center gap-2"><div style={{width:28,height:28,borderRadius:6,background:"linear-gradient(135deg,#3b82f6,#1d4ed8)",display:"flex",alignItems:"center",justifyContent:"center",color:"#fff",fontWeight:800,fontSize:12}}>O</div><div><div className="font-bold text-sm text-gray-900">BUDDICA高松店 タスク管理</div>{data.length>0&&<div className="text-xs text-gray-500 flex items-center gap-1">{data.length}件{Object.entries(oc).map(([k,v])=><span key={k}><OBadge ota={k}/>{v}</span>)}</div>}</div></div>
          <button onClick={()=>setTab("top")} className="px-3 py-1.5 rounded-lg text-xs font-bold text-white shadow" style={{background:"linear-gradient(135deg,#1e40af,#2563eb)"}}>🏠 TOPへ戻る</button>
        </div>}
        <div className="fade-in" style={{flex:1,minHeight:0,display:(tab==="fleet")?"flex":"block",flexDirection:"column"}}>
          {tab==="top"&&(()=>{
            const sections=[
              {title:"日常業務",color:"#2563eb",items:[
                {id:"fleet",ico:"🚗",l:"配車",desc:"予約の車両配車・タイムライン",badge:data.length>0?data.length+"件":null},
                {id:"jalanpay",ico:"💳",l:"じゃらん決済",desc:"じゃらん予約の決済確認",badge:(()=>{const j=data.filter(r=>r.ota==="J");const undone=j.filter(r=>!jalanPay[r.id]||jalanPay[r.id].payStatus!=="完了").length;return undone>0?undone+"件未完了":null;})()},
                {id:"import",ico:"📁",l:"CSV取込",desc:"OTA予約CSVインポート"},
              ]},
              {title:"スタッフ管理",color:"#059669",items:[
                {id:"shift",ico:"📅",l:"出勤簿",desc:"シフト表の作成・編集"},
                {id:"attendance",ico:"⏰",l:"給与",desc:"予算・実績・給与明細"},
                {id:"staff",ico:"👥",l:"スタッフ",desc:"スタッフ情報・時給設定"},
              ]},
              {title:"会計",color:"#d97706",items:[
                {id:"accounting",ico:"🧾",l:"会計管理",desc:"現金出納帳・予約外売上"},
              ]},
              {title:"データ・分析",color:"#7c3aed",items:[
                {id:"dashboard",ico:"🔒",l:"経営",desc:"売上・稼働率（オーナー専用）"},
                {id:"customer",ico:"👑",l:"顧客",desc:"リピーター分析"},
                {id:"foreign",ico:"🌍",l:"外国人利用率",desc:"外国人利用率の分析・推移"},
                {id:"license",ico:"🪪",l:"免許証",desc:"免許証画像アップロード",external:true},
                {id:"data",ico:"📋",l:"データ",desc:"予約マスター・未来予約確認"},
                {id:"history",ico:"📜",l:"過去タスク",desc:"過去のタスク履歴"},
              ]},
              {title:"設定",color:"#64748b",items:[
                {id:"vehicle",ico:"🔧",l:"車両",desc:"車両マスタ・クラス管理"},
              ]},
            ];
            return <div style={{maxWidth:700,margin:"0 auto",paddingBottom:20}}>
              <div style={{textAlign:"center",marginBottom:20,paddingTop:8}}>
                <div style={{display:"inline-flex",alignItems:"center",justifyContent:"center",width:56,height:56,borderRadius:16,background:"linear-gradient(135deg,#3b82f6,#1d4ed8)",marginBottom:10}}>
                  <span style={{color:"#fff",fontWeight:900,fontSize:24}}>O</span>
                </div>
                <div style={{fontSize:20,fontWeight:900,color:"#1e293b"}}>BUDDICA高松店 タスク管理</div>
                <div style={{fontSize:10,color:"#94a3b8",marginTop:2}}>{APP_VERSION} ・ {data.length>0?data.length+"件の予約データ":"データ未読込"}{SB_ENABLED&&sbConnected?" ・ 🟢 同期中":SB_ENABLED?" ・ 🔴 未接続":""}</div>
                {data.length>0&&<button onClick={()=>setShowOP(true)} style={{marginTop:10,padding:"8px 20px",borderRadius:12,border:"none",cursor:"pointer",background:"linear-gradient(135deg,#1e40af,#2563eb)",color:"#fff",fontSize:13,fontWeight:700,boxShadow:"0 2px 8px rgba(37,99,235,.3)"}}>📋 OPシートを開く</button>}
              </div>
              {(()=>{
                const kyogiList=Object.values(attendance).filter(r=>r.memo&&r.memo.startsWith("協議中"));
                if(!kyogiList.length)return null;
                return <div style={{marginBottom:16}}>
                  {kyogiList.map((r,i)=>{
                    const detail=r.memo.replace(/^協議中:/,"");
                    return <div key={i} style={{display:"flex",alignItems:"flex-start",gap:10,padding:"12px 14px",borderRadius:12,background:"rgba(251,191,36,.12)",border:"1px solid rgba(251,191,36,.3)",marginBottom:8}}>
                      <span style={{fontSize:20,flexShrink:0}}>⚠️</span>
                      <div style={{flex:1}}>
                        <div style={{fontSize:13,fontWeight:900,color:"#fbbf24"}}>{r.name}さんより修正リクエストを受けています</div>
                        <div style={{fontSize:11,color:"rgba(251,191,36,.7)",marginTop:2}}>{r.date}　{detail}</div>
                      </div>
                    </div>;
                  })}
                </div>;
              })()}
              <MemoBox today={today}/>
              <LeadTimeWidget data={data} vehicles={vehicles} fleet={fleet} maintenance={maintenance}/>
              <ExtraUnpaidWidget/>
              <SquareInvoiceWidget/>
              {/* ===== 問い合わせ / 車両チェック ===== */}
              <div style={{display:"flex",gap:8,marginBottom:8}}>
                <a href="https://handyman-inquiry.vercel.app/" target="_blank" rel="noopener" style={{textDecoration:"none",flex:1}}>
                  <div style={{display:"flex",alignItems:"center",gap:8,padding:"10px 14px",borderRadius:12,background:"#f0f9ff",border:"1px solid #bae6fd",cursor:"pointer",userSelect:"none",boxShadow:"0 1px 3px rgba(0,0,0,.05)"}}>
                    <span style={{fontSize:16}}>📬</span>
                    <span style={{fontSize:13,fontWeight:700,color:"#1e293b"}}>問い合わせ</span>
                    <span style={{marginLeft:"auto",fontSize:11,color:"#94a3b8",fontWeight:700}}>→</span>
                  </div>
                </a>
                <a href="https://nosh2318.github.io/handyman-damage/" target="_blank" rel="noopener" style={{textDecoration:"none",flex:1}}>
                  <div style={{display:"flex",alignItems:"center",gap:8,padding:"10px 14px",borderRadius:12,background:"#fef2f2",border:"1px solid #fecaca",cursor:"pointer",userSelect:"none",boxShadow:"0 1px 3px rgba(0,0,0,.05)"}}>
                    <span style={{fontSize:16}}>🚗</span>
                    <span style={{fontSize:13,fontWeight:700,color:"#1e293b"}}>車両チェック</span>
                    <span style={{marginLeft:"auto",fontSize:11,color:"#94a3b8",fontWeight:700}}>→</span>
                  </div>
                </a>
              </div>
              {/* ===== タスクサマリー / 本日スケジュール 横並びヘッダー ===== */}
              {data.length>0&&<div style={{display:"flex",gap:8,marginBottom:8}}>
                <div style={{flex:1}} onClick={()=>setTaskSumOpen(o=>!o)}>
                  <div style={{display:"flex",alignItems:"center",gap:8,padding:"10px 14px",borderRadius:12,background:"#f8fafc",border:"1px solid #e2e8f0",cursor:"pointer",userSelect:"none",boxShadow:"0 1px 3px rgba(0,0,0,.05)"}}>
                    <span style={{fontSize:16}}>👤</span>
                    <span style={{fontSize:13,fontWeight:700,color:"#1e293b"}}>タスクサマリー</span>
                    <span style={{marginLeft:"auto",fontSize:11,color:"#94a3b8",fontWeight:700}}>{taskSumOpen?"▲":"▼"}</span>
                  </div>
                </div>
                <div style={{flex:1}} onClick={()=>setTopSchedOpen(o=>!o)}>
                  <div style={{display:"flex",alignItems:"center",gap:8,padding:"10px 14px",borderRadius:12,background:"#f8fafc",border:"1px solid #e2e8f0",cursor:"pointer",userSelect:"none",boxShadow:"0 1px 3px rgba(0,0,0,.05)"}}>
                    <span style={{fontSize:16}}>🗓</span>
                    <span style={{fontSize:13,fontWeight:700,color:"#1e293b"}}>本日スケジュール</span>
                    <span style={{marginLeft:"auto",fontSize:11,color:"#94a3b8",fontWeight:700}}>{topSchedOpen?"▲":"▼"}</span>
                  </div>
                </div>
              </div>}
              {/* ===== 本日 個人別タスクサマリー ===== */}
              {taskSumOpen&&data.length>0&&(()=>{
                const todayStr=today;
                const todayD=new Date(todayStr+"T00:00:00");
                const todayLabel=(todayD.getMonth()+1)+"/"+todayD.getDate()+"("+["日","月","火","水","木","金","土"][todayD.getDay()]+")";
                const todayShifts=shifts[todayStr]||[];
                const offSymbols=new Set(["公","希","有"]);
                const onDuty=todayShifts.filter(s=>!offSymbols.has(s.symbol));
                const PersonalTasks=({dateStr,dateLabel,shiftList})=>{
                  const[dbTasks,setDbTasks]=useState([]);
                  const[loaded,setLoaded]=useState(false);
                  const prevJsonRef=useRef("");
                  const refetchTasks=()=>{DB.fetchTasks(dateStr).then(t=>{if(!t)return;const j=JSON.stringify(t);if(j!==prevJsonRef.current){prevJsonRef.current=j;setDbTasks(t);}}).catch(()=>{});};
                  useEffect(()=>{
                    DB.fetchTasks(dateStr).then(t=>{const j=JSON.stringify(t||[]);prevJsonRef.current=j;setDbTasks(t||[]);setLoaded(true);}).catch(()=>setLoaded(true));
                    // ★ Realtime購読: OPシートでの完了チェックを即反映
                    let ch=null;
                    if(sb){
                      ch=sb.channel("top-tasks-"+dateStr).on("postgres_changes",{event:"*",schema:"public",table:"tkm_tasks",filter:"date=eq."+dateStr},()=>{refetchTasks();}).subscribe();
                    }
                    // フォールバック: Realtime接続できない場合は15秒ポーリング
                    const iv=setInterval(refetchTasks,15000);
                    return()=>{clearInterval(iv);if(ch)sb.removeChannel(ch);};
                  },[dateStr]);
                  if(!loaded)return <div style={{fontSize:10,color:"#94a3b8",padding:8}}>読込中...</div>;
                  if(dbTasks.length===0)return <div style={{fontSize:10,color:"#94a3b8",padding:8}}>OPシートにタスク未登録</div>;
                  const offS=new Set(["公","希","有"]);
                  const duty=shiftList.filter(s=>!offS.has(s.symbol)).map(s=>s.name);
                  const byPerson={};
                  duty.forEach(n=>{byPerson[n]=[];});
                  const unassigned=[];
                  dbTasks.forEach(t=>{
                    const a=t.assignee||"";
                    if(a&&byPerson[a]!==undefined){byPerson[a].push(t);}
                    else if(a&&!duty.includes(a)){if(!byPerson[a])byPerson[a]=[];byPerson[a].push(t);}
                    else{unassigned.push(t);}
                  });
                  const sortT=(a,b)=>{if(a.done!==b.done)return a.done?1:-1;return(a.time||"99:99").localeCompare(b.time||"99:99");};
                  const tc={DEL:"#dc2626",COL:"#2563eb",PU:"#059669",BD:"#7c3aed","洗車":"#f59e0b"};
                  // ★ タスク種別内訳を集計
                  const typeCounts={};dbTasks.forEach(t=>{typeCounts[t.type]=(typeCounts[t.type]||0)+1;});
                  const ProgressBar=({done,total,color})=>{const pct=total>0?Math.round(done/total*100):0;return <div style={{display:"flex",alignItems:"center",gap:6,width:"100%"}}>
                    <div style={{flex:1,height:10,borderRadius:5,background:"#e2e8f0",overflow:"hidden"}}><div style={{width:pct+"%",height:"100%",borderRadius:5,background:pct>=100?"#22c55e":pct<50?"#ef4444":color||"#3b82f6",transition:"width .3s"}}></div></div>
                    <span style={{fontSize:11,fontWeight:800,color:pct>=100?"#22c55e":pct<50?"#ef4444":"#3b82f6",whiteSpace:"nowrap"}}>{pct}%</span>
                  </div>;};
                  const rT=(t,i)=><div key={i} style={{fontSize:10,padding:"3px 0",borderBottom:"1px solid #f1f5f9",display:"flex",gap:6,alignItems:"center",opacity:t.done?0.45:1}}>
                    <span style={{fontSize:12,width:16,textAlign:"center"}}>{t.done?"✅":"⬜"}</span>
                    <span style={{padding:"1px 5px",borderRadius:4,fontSize:8,fontWeight:700,background:(tc[t.type]||"#64748b")+"18",color:tc[t.type]||"#64748b"}}>{t.type}</span>
                    <span style={{fontWeight:700,color:t.done?"#94a3b8":"#374151",minWidth:36,textDecoration:t.done?"line-through":"none"}}>{t.time||"--:--"}</span>
                    <span style={{fontWeight:600,fontSize:10,textDecoration:t.done?"line-through":"none",color:t.done?"#94a3b8":"#1e293b"}}>{t.name}</span>
                    <span style={{color:"#94a3b8",fontSize:9}}>{t.plateNo||""}</span>
                    {t.place&&<span style={{color:"#f59e0b",fontSize:8}}>📍{t.place}</span>}
                  </div>;
                  const doneCount=dbTasks.filter(t=>t.done).length;
                  const totalWork=dbTasks.length;
                  const remainCount=totalWork-doneCount;
                  return <>
                    <div style={{marginBottom:8,padding:"8px 10px",borderRadius:8,background:remainCount===0?"#f0fdf4":"#fff"}}>
                      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6}}>
                        <span style={{fontSize:18,fontWeight:900,color:remainCount===0?"#16a34a":"#1e293b"}}>完了 {doneCount}/{totalWork}</span>
                        <span style={{fontSize:11,fontWeight:800,color:remainCount===0?"#22c55e":"#ef4444"}}>{remainCount===0?"全完了!":"残 "+remainCount+"件"}</span>
                      </div>
                      <ProgressBar done={doneCount} total={totalWork}/>
                      <div style={{display:"flex",gap:6,marginTop:6,flexWrap:"wrap"}}>
                        {Object.entries(typeCounts).map(([type,cnt])=><span key={type} style={{padding:"2px 6px",borderRadius:4,fontSize:9,fontWeight:700,background:(tc[type]||"#64748b")+"18",color:tc[type]||"#64748b"}}>{type}:{cnt}</span>)}
                      </div>
                    </div>
                    <div style={{fontSize:9,color:"#64748b",marginBottom:6}}>割当済{dbTasks.filter(t=>t.assignee).length}件 / 未割当{unassigned.length}件</div>
                    {Object.entries(byPerson).map(([name,pts])=>{
                      const sorted=pts.sort(sortT);
                      const sh=shiftList.find(s=>s.name===name);
                      const doneN=sorted.filter(t=>t.done).length;
                      const remN=sorted.length-doneN;
                      const allDone=sorted.length>0&&doneN===sorted.length;
                      return <details key={name} style={{marginBottom:4}}>
                        <summary style={{display:"flex",alignItems:"center",gap:6,padding:"5px 8px",borderRadius:6,background:allDone?"#f0fdf4":"#f8fafc",cursor:"pointer",listStyle:"none",userSelect:"none"}}>
                          <span style={{fontSize:9,color:"#94a3b8"}}>▶</span>
                          <span style={{fontSize:11,fontWeight:700,color:allDone?"#16a34a":"#1e293b"}}>{allDone?"✅ ":""}{name}</span>
                          <span style={{fontSize:9,color:"#64748b"}}>{sh?((sh.start||"")+"〜"+(sh.end||"")):""}</span>
                          <div style={{marginLeft:"auto",display:"flex",alignItems:"center",gap:6}}>
                            {sorted.length>0&&<div style={{width:40,height:5,borderRadius:3,background:"#e2e8f0",overflow:"hidden"}}><div style={{width:(sorted.length>0?Math.round(doneN/sorted.length*100):0)+"%",height:"100%",borderRadius:3,background:allDone?"#22c55e":"#3b82f6"}}></div></div>}
                            <span style={{fontSize:9,fontWeight:700,color:allDone?"#22c55e":remN>0?"#ef4444":"#94a3b8"}}>{allDone?"完了":remN>0?"残"+remN:"0"}</span>
                            <span style={{fontSize:10,fontWeight:800,color:sorted.length>0?"#2563eb":"#94a3b8"}}>{sorted.length}件</span>
                          </div>
                        </summary>
                        <div style={{paddingLeft:20,paddingTop:3,paddingBottom:3}}>
                          {sorted.length>0?sorted.map(rT):<div style={{fontSize:9,color:"#94a3b8",padding:"3px 0"}}>担当タスクなし</div>}
                        </div>
                      </details>;
                    })}
                    {unassigned.length>0&&<details style={{marginTop:4}}>
                      <summary style={{display:"flex",alignItems:"center",gap:6,padding:"5px 8px",borderRadius:6,background:"#fef2f2",cursor:"pointer",listStyle:"none",userSelect:"none"}}>
                        <span style={{fontSize:9,color:"#94a3b8"}}>▶</span>
                        <span style={{fontSize:11,fontWeight:700,color:"#dc2626"}}>未割当</span>
                        <span style={{fontSize:10,fontWeight:800,color:"#dc2626",marginLeft:"auto"}}>{unassigned.length}件</span>
                      </summary>
                      <div style={{paddingLeft:20,paddingTop:3}}>
                        {unassigned.sort(sortT).map(rT)}
                      </div>
                    </details>}
                  </>;
                };
                return <div style={{marginBottom:16,padding:"14px 16px",borderRadius:14,border:"2px solid #3b82f6",background:"linear-gradient(135deg,#eff6ff,#dbeafe)"}}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
                    <div style={{fontSize:14,fontWeight:900,color:"#1e40af"}}>👤 本日の個人別タスク（{todayLabel}）</div>
                    <div style={{fontSize:11,fontWeight:700,color:"#2563eb"}}>出勤{onDuty.length}名</div>
                  </div>
                  {onDuty.length>0?<div style={{display:"flex",gap:6,marginBottom:8,flexWrap:"wrap"}}>
                    {onDuty.map((s,i)=><span key={i} style={{padding:"3px 10px",borderRadius:6,background:"#dbeafe",fontSize:10,fontWeight:700,color:"#1e40af"}}>{s.name}{s.start?" "+s.start+"〜"+s.end:""}</span>)}
                  </div>:<div style={{fontSize:10,color:"#94a3b8",marginBottom:8}}>シフト未登録</div>}
                  <PersonalTasks dateStr={todayStr} dateLabel={todayLabel} shiftList={todayShifts}/>
                </div>;
              })()}
              {/* ===== 翌日 個人別タスクサマリー ===== */}
              {taskSumOpen&&data.length>0&&(()=>{
                const tmrw2=new Date();tmrw2.setDate(tmrw2.getDate()+1);
                const tmrwStr2=tmrw2.toISOString().slice(0,10);
                const tmrwLabel2=(tmrw2.getMonth()+1)+"/"+tmrw2.getDate()+"("+["日","月","火","水","木","金","土"][tmrw2.getDay()]+")";
                const tmrwShifts2=shifts[tmrwStr2]||[];
                const offSymbols2=new Set(["公","希","有"]);
                const onDuty2=tmrwShifts2.filter(s=>!offSymbols2.has(s.symbol));
                const PersonalTasks2=({dateStr,shiftList})=>{
                  const[dbTasks,setDbTasks]=useState([]);
                  const[loaded,setLoaded]=useState(false);
                  const prevJsonRef2=useRef("");
                  const refetchTasks2=()=>{DB.fetchTasks(dateStr).then(t=>{if(!t)return;const j=JSON.stringify(t);if(j!==prevJsonRef2.current){prevJsonRef2.current=j;setDbTasks(t);}}).catch(()=>{});};
                  useEffect(()=>{
                    DB.fetchTasks(dateStr).then(t=>{const j=JSON.stringify(t||[]);prevJsonRef2.current=j;setDbTasks(t||[]);setLoaded(true);}).catch(()=>setLoaded(true));
                    // ★ Realtime購読: タスク完了を即反映
                    let ch=null;
                    if(sb){
                      ch=sb.channel("top-tasks2-"+dateStr).on("postgres_changes",{event:"*",schema:"public",table:"tkm_tasks",filter:"date=eq."+dateStr},()=>{refetchTasks2();}).subscribe();
                    }
                    const iv=setInterval(refetchTasks2,30000);
                    return()=>{clearInterval(iv);if(ch)sb.removeChannel(ch);};
                  },[dateStr]);
                  if(!loaded)return <div style={{fontSize:10,color:"#94a3b8",padding:8}}>読込中...</div>;
                  if(dbTasks.length===0)return <div style={{fontSize:10,color:"#94a3b8",padding:8}}>OPシートにタスク未登録（OPシートで翌日を開くと自動生成されます）</div>;
                  const offS=new Set(["公","希","有"]);
                  const duty=shiftList.filter(s=>!offS.has(s.symbol)).map(s=>s.name);
                  const byPerson={};
                  duty.forEach(n=>{byPerson[n]=[];});
                  const unassigned=[];
                  dbTasks.forEach(t=>{
                    const a=t.assignee||"";
                    if(a&&byPerson[a]!==undefined){byPerson[a].push(t);}
                    else if(a&&!duty.includes(a)){if(!byPerson[a])byPerson[a]=[];byPerson[a].push(t);}
                    else{unassigned.push(t);}
                  });
                  const sortT=(a,b)=>{if(a.done!==b.done)return a.done?1:-1;return(a.time||"99:99").localeCompare(b.time||"99:99");};
                  const tc={DEL:"#dc2626",COL:"#2563eb",PU:"#059669",BD:"#7c3aed","洗車":"#f59e0b"};
                  const typeCounts2={};dbTasks.forEach(t=>{typeCounts2[t.type]=(typeCounts2[t.type]||0)+1;});
                  const ProgressBar2=({done,total,color})=>{const pct=total>0?Math.round(done/total*100):0;return <div style={{display:"flex",alignItems:"center",gap:6,width:"100%"}}>
                    <div style={{flex:1,height:10,borderRadius:5,background:"#e2e8f0",overflow:"hidden"}}><div style={{width:pct+"%",height:"100%",borderRadius:5,background:pct>=100?"#22c55e":pct<50?"#ef4444":color||"#f59e0b",transition:"width .3s"}}></div></div>
                    <span style={{fontSize:11,fontWeight:800,color:pct>=100?"#22c55e":pct<50?"#ef4444":"#f59e0b",whiteSpace:"nowrap"}}>{pct}%</span>
                  </div>;};
                  const rT=(t,i)=><div key={i} style={{fontSize:10,padding:"3px 0",borderBottom:"1px solid #f1f5f9",display:"flex",gap:6,alignItems:"center",opacity:t.done?0.45:1}}>
                    <span style={{fontSize:12,width:16,textAlign:"center"}}>{t.done?"✅":"⬜"}</span>
                    <span style={{padding:"1px 5px",borderRadius:4,fontSize:8,fontWeight:700,background:(tc[t.type]||"#64748b")+"18",color:tc[t.type]||"#64748b"}}>{t.type}</span>
                    <span style={{fontWeight:700,color:t.done?"#94a3b8":"#374151",minWidth:36,textDecoration:t.done?"line-through":"none"}}>{t.time||"--:--"}</span>
                    <span style={{fontWeight:600,fontSize:10,textDecoration:t.done?"line-through":"none",color:t.done?"#94a3b8":"#1e293b"}}>{t.name}</span>
                    <span style={{color:"#94a3b8",fontSize:9}}>{t.plateNo||""}</span>
                    {t.place&&<span style={{color:"#f59e0b",fontSize:8}}>📍{t.place}</span>}
                  </div>;
                  const totalWork=dbTasks.length;
                  const doneCount=dbTasks.filter(t=>t.done).length;
                  const remainCount=totalWork-doneCount;
                  return <>
                    <div style={{marginBottom:8,padding:"8px 10px",borderRadius:8,background:remainCount===0?"#fefce8":"#fff"}}>
                      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6}}>
                        <span style={{fontSize:18,fontWeight:900,color:remainCount===0?"#16a34a":"#92400e"}}>完了 {doneCount}/{totalWork}</span>
                        <span style={{fontSize:11,fontWeight:800,color:remainCount===0?"#22c55e":"#ef4444"}}>{remainCount===0?"全完了!":"残 "+remainCount+"件"}</span>
                      </div>
                      <ProgressBar2 done={doneCount} total={totalWork}/>
                      <div style={{display:"flex",gap:6,marginTop:6,flexWrap:"wrap"}}>
                        {Object.entries(typeCounts2).map(([type,cnt])=><span key={type} style={{padding:"2px 6px",borderRadius:4,fontSize:9,fontWeight:700,background:(tc[type]||"#64748b")+"18",color:tc[type]||"#64748b"}}>{type}:{cnt}</span>)}
                      </div>
                    </div>
                    <div style={{fontSize:9,color:"#64748b",marginBottom:6}}>割当済{dbTasks.filter(t=>t.assignee).length}件 / 未割当{unassigned.length}件</div>
                    {Object.entries(byPerson).map(([name,pts])=>{
                      const sorted=pts.sort(sortT);
                      const sh=shiftList.find(s=>s.name===name);
                      const doneN=sorted.filter(t=>t.done).length;
                      const remN=sorted.length-doneN;
                      const allDone=sorted.length>0&&doneN===sorted.length;
                      return <details key={name} style={{marginBottom:4}}>
                        <summary style={{display:"flex",alignItems:"center",gap:6,padding:"5px 8px",borderRadius:6,background:allDone?"#f0fdf4":"#f8fafc",cursor:"pointer",listStyle:"none",userSelect:"none"}}>
                          <span style={{fontSize:9,color:"#94a3b8"}}>▶</span>
                          <span style={{fontSize:11,fontWeight:700,color:allDone?"#16a34a":"#1e293b"}}>{allDone?"✅ ":""}{name}</span>
                          <span style={{fontSize:9,color:"#64748b"}}>{sh?((sh.start||"")+"〜"+(sh.end||"")):""}</span>
                          <div style={{marginLeft:"auto",display:"flex",alignItems:"center",gap:6}}>
                            {sorted.length>0&&<div style={{width:40,height:5,borderRadius:3,background:"#e2e8f0",overflow:"hidden"}}><div style={{width:(sorted.length>0?Math.round(doneN/sorted.length*100):0)+"%",height:"100%",borderRadius:3,background:allDone?"#22c55e":"#f59e0b"}}></div></div>}
                            <span style={{fontSize:9,fontWeight:700,color:allDone?"#22c55e":remN>0?"#ef4444":"#94a3b8"}}>{allDone?"完了":remN>0?"残"+remN:"0"}</span>
                            <span style={{fontSize:10,fontWeight:800,color:sorted.length>0?"#b45309":"#94a3b8"}}>{sorted.length}件</span>
                          </div>
                        </summary>
                        <div style={{paddingLeft:20,paddingTop:3,paddingBottom:3}}>
                          {sorted.length>0?sorted.map(rT):<div style={{fontSize:9,color:"#94a3b8",padding:"3px 0"}}>担当タスクなし</div>}
                        </div>
                      </details>;
                    })}
                    {unassigned.length>0&&<details style={{marginTop:4}}>
                      <summary style={{display:"flex",alignItems:"center",gap:6,padding:"5px 8px",borderRadius:6,background:"#fef2f2",cursor:"pointer",listStyle:"none",userSelect:"none"}}>
                        <span style={{fontSize:9,color:"#94a3b8"}}>▶</span>
                        <span style={{fontSize:11,fontWeight:700,color:"#dc2626"}}>未割当</span>
                        <span style={{fontSize:10,fontWeight:800,color:"#dc2626",marginLeft:"auto"}}>{unassigned.length}件</span>
                      </summary>
                      <div style={{paddingLeft:20,paddingTop:3}}>
                        {unassigned.sort(sortT).map(rT)}
                      </div>
                    </details>}
                  </>;
                };
                return <div style={{marginBottom:16,padding:"14px 16px",borderRadius:14,border:"2px solid #f59e0b",background:"linear-gradient(135deg,#fffbeb,#fef3c7)"}}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
                    <div style={{fontSize:14,fontWeight:900,color:"#92400e"}}>👤 翌日の個人別タスク（{tmrwLabel2}）</div>
                    <div style={{fontSize:11,fontWeight:700,color:"#b45309"}}>出勤{onDuty2.length}名</div>
                  </div>
                  {onDuty2.length>0?<div style={{display:"flex",gap:6,marginBottom:8,flexWrap:"wrap"}}>
                    {onDuty2.map((s,i)=><span key={i} style={{padding:"3px 10px",borderRadius:6,background:"#fde68a",fontSize:10,fontWeight:700,color:"#92400e"}}>{s.name}{s.start?" "+s.start+"〜"+s.end:""}</span>)}
                  </div>:<div style={{fontSize:10,color:"#94a3b8",marginBottom:8}}>シフト未登録</div>}
                  <PersonalTasks2 dateStr={tmrwStr2} shiftList={tmrwShifts2}/>
                </div>;
              })()}
              {/* ===== 翌日業務サマリー（削除済み） ===== */}
              {false&&(()=>{
                const tmrw=new Date();tmrw.setDate(tmrw.getDate()+1);
                const tmrwStr=tmrw.toISOString().slice(0,10);
                const tmrwLabel=(tmrw.getMonth()+1)+"/"+tmrw.getDate()+"("+["日","月","火","水","木","金","土"][tmrw.getDay()]+")";
                // 翌日の予約を収集
                const tmrwRes=data.filter(r=>r.status!=="cancelled"&&(r.lendDate===tmrwStr||r.returnDate===tmrwStr));
                if(tmrwRes.length===0)return null;
                // タスク分類
                const tasks={DEL:[],COL:[],PU:[],BD:[],WASH:[]};
                tmrwRes.forEach(r=>{
                  const fv=fleet[r.id];const veh=fv?vehicles.find(v=>v.code===fv):null;
                  const info={time:"",name:r.name,cls:r.vehicle,ota:r.ota,plate:veh?veh.no:"未配車",id:r.id,insurance:r.insurance,optB:+(r.optB||0),optC:+(r.optC||0),optJ:+(r.optJ||0),optUSB:+(r.optUSB||0)};
                  const dpOk=r.delPlace&&r.delPlace.trim()&&!/^(来店|店舗|店頭|ヤード|営業所|ー+|-+|なし|無し)$/.test(r.delPlace.trim());
                  const cpOk=r.colPlace&&r.colPlace.trim()&&!/^(来店|店舗|店頭|ヤード|営業所|ー+|-+|なし|無し)$/.test(r.colPlace.trim());
                  if(r.lendDate===tmrwStr){
                    const isDel=(r.visitType==="DEL"||dpOk);
                    if(isDel){tasks.DEL.push({...info,time:r.delTime||r.lendTime,place:r.delPlace||""});}
                    else{tasks.PU.push({...info,time:r.lendTime});}
                  }
                  if(r.returnDate===tmrwStr){
                    const isCol=(r.returnType==="COL"||cpOk);
                    if(isCol){tasks.COL.push({...info,time:r.colTime||r.returnTime,place:r.colPlace||""});}
                    else{tasks.BD.push({...info,time:r.returnTime});}
                  }
                });
                // 洗車: 翌日出発で配車済みの車両
                tmrwRes.filter(r=>r.lendDate===tmrwStr&&fleet[r.id]).forEach(r=>{
                  const fv=fleet[r.id];const veh=fv?vehicles.find(v=>v.code===fv):null;
                  if(veh)tasks.WASH.push({time:"",name:r.name,cls:r.vehicle,plate:veh.no,ota:r.ota});
                });
                const allTasks=[...tasks.DEL,...tasks.COL,...tasks.PU,...tasks.BD];
                // ① じゃらん決済アラート
                const jalanAlerts=tmrwRes.filter(r=>r.ota==="J"&&r.lendDate===tmrwStr);
                // ② オプション準備アラート
                const optAlerts=tmrwRes.filter(r=>(+(r.optB||0))+(+(r.optC||0))+(+(r.optJ||0))+(+(r.optUSB||0))>0);
                // ③ 時間詰まりアラート（60分以内に複数タスク）
                const timeAlerts=[];
                const sortedAll=[...tasks.DEL,...tasks.COL,...tasks.PU,...tasks.BD].filter(t=>t.time).sort((a,b)=>(a.time||"").localeCompare(b.time||""));
                for(let i=0;i<sortedAll.length-1;i++){
                  const t1=sortedAll[i],t2=sortedAll[i+1];
                  if(t1.time&&t2.time){
                    const m1=parseInt(t1.time.split(":")[0])*60+parseInt(t1.time.split(":")[1]||0);
                    const m2=parseInt(t2.time.split(":")[0])*60+parseInt(t2.time.split(":")[1]||0);
                    if(Math.abs(m2-m1)<=60)timeAlerts.push({t1,t2,gap:Math.abs(m2-m1)});
                  }
                }
                // ④ NOC以外の補償アラート（COL/BD返却時の車両チェック）
                const insAlerts=tmrwRes.filter(r=>r.returnDate===tmrwStr&&r.insurance!=="NOC");
                // ⑤ 出勤メンバー
                const tmrwShifts=shifts[tmrwStr]||[];
                const taskLabel={DEL:"🚗 DEL",COL:"🔄 COL",PU:"🏪 PU",BD:"🏠 BD",WASH:"🧽 洗車"};
                const taskColor={DEL:"#dc2626",COL:"#2563eb",PU:"#059669",BD:"#7c3aed",WASH:"#f59e0b"};
                const taskRow=(type,list)=>{
                  if(list.length===0)return null;
                  const sorted=list.sort((a,b)=>(a.time||"").localeCompare(b.time||""));
                  return <details key={type} style={{marginBottom:6}}>
                    <summary style={{display:"flex",alignItems:"center",gap:6,padding:"6px 8px",borderRadius:8,background:taskColor[type]+"0a",cursor:"pointer",listStyle:"none",userSelect:"none"}}>
                      <span style={{fontSize:10,transition:"transform .2s",color:"#64748b"}}>▶</span>
                      <span style={{padding:"2px 8px",borderRadius:6,background:taskColor[type]+"18",color:taskColor[type],fontSize:11,fontWeight:800}}>{taskLabel[type]}</span>
                      <span style={{fontSize:12,fontWeight:800,color:"#1e293b"}}>{list.length}件</span>
                      <span style={{fontSize:9,color:"#94a3b8",marginLeft:"auto"}}>{sorted[0]&&sorted[0].time?sorted[0].time:""}{sorted.length>1&&sorted[sorted.length-1].time?" 〜 "+sorted[sorted.length-1].time:""}</span>
                    </summary>
                    <div style={{paddingLeft:16,paddingTop:4}}>
                      {sorted.map((t,i)=><div key={i} style={{fontSize:10,padding:"3px 0",borderBottom:"1px solid #f1f5f9",display:"flex",gap:8,alignItems:"center"}}>
                        <span style={{fontWeight:700,color:"#374151",minWidth:36}}>{t.time||"--:--"}</span>
                        <span style={{fontWeight:600}}>{t.name}</span>
                        <span style={{color:"#64748b",fontSize:9}}>{t.cls}クラス</span>
                        <span style={{color:"#94a3b8",fontSize:9}}>{t.plate}</span>
                        {t.place&&<span style={{color:"#f59e0b",fontSize:9}}>📍{t.place}</span>}
                      </div>)}
                    </div>
                  </details>;
                };
                return <div style={{marginBottom:16}}>
                  <div onClick={()=>setTomSumOpen(o=>!o)} style={{display:"flex",alignItems:"center",gap:8,padding:"10px 14px",borderRadius:12,background:"#f8fafc",border:"1px solid #e2e8f0",cursor:"pointer",userSelect:"none",boxShadow:"0 1px 3px rgba(0,0,0,.05)",marginBottom:tomSumOpen?6:0}}>
                    <span style={{fontSize:16}}>📋</span>
                    <span style={{fontSize:13,fontWeight:700,color:"#1e293b"}}>翌日業務サマリー（{tmrwLabel}）</span>
                    <span style={{marginLeft:"auto",display:"flex",alignItems:"center",gap:8}}>
                      <span style={{fontSize:11,fontWeight:700,color:"#64748b"}}>{allTasks.length}タスク</span>
                      <span style={{fontSize:11,color:"#94a3b8",fontWeight:700}}>{tomSumOpen?"▲":"▼"}</span>
                    </span>
                  </div>
                  {tomSumOpen&&<div style={{padding:"14px 16px",borderRadius:14,border:"2px solid #fbbf24",background:"linear-gradient(135deg,#fffbeb,#fef3c7)"}}>

                  {/* タスク数サマリー */}
                  <div style={{display:"flex",gap:6,marginBottom:10,flexWrap:"wrap"}}>
                    {[["DEL",tasks.DEL],["COL",tasks.COL],["PU",tasks.PU],["BD",tasks.BD],["WASH",tasks.WASH]].map(([k,v])=>
                      <div key={k} style={{padding:"4px 10px",borderRadius:8,background:taskColor[k]+"15",border:"1px solid "+taskColor[k]+"30"}}>
                        <span style={{fontSize:10,fontWeight:800,color:taskColor[k]}}>{taskLabel[k]} {v.length}</span>
                      </div>
                    )}
                  </div>
                  {/* タスク詳細 */}
                  {taskRow("DEL",tasks.DEL)}
                  {taskRow("PU",tasks.PU)}
                  {taskRow("COL",tasks.COL)}
                  {taskRow("BD",tasks.BD)}
                  {taskRow("WASH",tasks.WASH)}
                  {/* アラート */}
                  {(jalanAlerts.length>0||optAlerts.length>0||timeAlerts.length>0||insAlerts.length>0)&&<details open style={{marginTop:8}}>
                    <summary style={{padding:"8px 12px",borderRadius:"10px 10px 0 0",background:"#fef2f2",border:"1px solid #fecaca",borderBottom:"none",fontSize:11,fontWeight:800,color:"#dc2626",cursor:"pointer",listStyle:"none",userSelect:"none"}}>▼ ⚠️ アラート（{jalanAlerts.length+optAlerts.length+timeAlerts.length+insAlerts.length}件）</summary>
                    <div style={{padding:"8px 12px",borderRadius:"0 0 10px 10px",background:"#fef2f2",border:"1px solid #fecaca",borderTop:"none"}}>
                    {jalanAlerts.length>0&&<details style={{marginBottom:6}}>
                      <summary style={{fontSize:10,fontWeight:700,color:"#be123c",cursor:"pointer",listStyle:"none",userSelect:"none"}}><span style={{fontSize:9,color:"#94a3b8"}}>▶</span> 💳 じゃらん現地決済（{jalanAlerts.length}件）</summary>
                      <div style={{paddingLeft:16,paddingTop:2}}>{jalanAlerts.map((r,i)=><div key={i} style={{fontSize:9,color:"#64748b"}}>・{r.lendTime} {r.name} ¥{(r.price||0).toLocaleString()}</div>)}</div>
                    </details>}
                    {optAlerts.length>0&&<details style={{marginBottom:6}}>
                      <summary style={{fontSize:10,fontWeight:700,color:"#b45309",cursor:"pointer",listStyle:"none",userSelect:"none"}}><span style={{fontSize:9,color:"#94a3b8"}}>▶</span> 🪑 オプション準備（{optAlerts.length}件）</summary>
                      <div style={{paddingLeft:16,paddingTop:2}}>{optAlerts.map((r,i)=>{const opts=[];if(+(r.optB||0))opts.push("B×"+r.optB);if(+(r.optC||0))opts.push("C×"+r.optC);if(+(r.optJ||0))opts.push("J×"+r.optJ);if(+(r.optUSB||0))opts.push("USB×"+r.optUSB);
                        return <div key={i} style={{fontSize:9,color:"#64748b"}}>・{r.name} → {opts.join(", ")}</div>;})}</div>
                    </details>}
                    {timeAlerts.length>0&&<details style={{marginBottom:6}}>
                      <summary style={{fontSize:10,fontWeight:700,color:"#7c2d12",cursor:"pointer",listStyle:"none",userSelect:"none"}}><span style={{fontSize:9,color:"#94a3b8"}}>▶</span> ⏰ 時間詰まり（{timeAlerts.length}件）</summary>
                      <div style={{paddingLeft:16,paddingTop:2}}>{timeAlerts.map((a,i)=><div key={i} style={{fontSize:9,color:"#64748b"}}>・{a.t1.time} {a.t1.name} ↔ {a.t2.time} {a.t2.name}（{a.gap}分差）</div>)}</div>
                    </details>}
                    {insAlerts.length>0&&<details style={{marginBottom:6}}>
                      <summary style={{fontSize:10,fontWeight:700,color:"#991b1b",cursor:"pointer",listStyle:"none",userSelect:"none"}}><span style={{fontSize:9,color:"#94a3b8"}}>▶</span> 🛡️ 補償チェック（NOC以外: {insAlerts.length}件）</summary>
                      <div style={{paddingLeft:16,paddingTop:2}}>{insAlerts.map((r,i)=>{const retType=(r.returnType==="COL")?"COL":"BD";return <div key={i} style={{fontSize:9,color:"#64748b"}}>・{r.returnTime} {r.name} [{retType}] 補償:{r.insurance} → 車両チェック必要</div>;})}</div>
                    </details>}
                    </div>
                  </details>}
                  {/* 出勤メンバー */}
                  <div style={{marginTop:8,padding:"8px 12px",borderRadius:10,background:"#f0fdf4",border:"1px solid #bbf7d0"}}>
                    <div style={{fontSize:11,fontWeight:800,color:"#166534",marginBottom:4}}>👥 出勤メンバー</div>
                    {tmrwShifts.length>0?<div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
                      {tmrwShifts.map((s,i)=><span key={i} style={{padding:"3px 10px",borderRadius:6,background:"#dcfce7",fontSize:10,fontWeight:700,color:"#166534"}}>{s.name}{s.start?" "+s.start+"〜"+s.end:""}</span>)}
                    </div>:<div style={{fontSize:10,color:"#94a3b8"}}>シフト未登録</div>}
                  </div>
                </div>}</div>;
              })()}
              {/* ===== 本日スケジュール（折りたたみ） ===== */}
              {data.length>0&&(()=>{
                const TopSchedule=()=>{
                  const[schTasks,setSchTasks]=useState([]);const[schLoaded,setSchLoaded]=useState(false);
                  useEffect(()=>{DB.fetchTasks(today).then(t=>{setSchTasks(t||[]);setSchLoaded(true);}).catch(()=>setSchLoaded(true));
                    let ch=null;if(sb){ch=sb.channel("top-sched-"+today).on("postgres_changes",{event:"*",schema:"public",table:"tkm_tasks",filter:"date=eq."+today},()=>{DB.fetchTasks(today).then(t=>{if(t)setSchTasks(t);});}).subscribe();}
                    return()=>{if(ch)sb.removeChannel(ch);};
                  },[]);
                  if(!schLoaded)return <div style={{padding:12,fontSize:10,color:"#94a3b8"}}>読込中...</div>;
                  const timedWash=schTasks.filter(t=>t.type==="洗車"&&t.time);
                  const untimedWash=schTasks.filter(t=>t.type==="洗車"&&!t.time);
                  const allSch=[...schTasks.filter(t=>t.type!=="洗車"&&t.type!=="CXL"),...timedWash].sort((a,b)=>{const ta=a.timeChange||a._ssTime||a.time||"99:99";const tb=b.timeChange||b._ssTime||b.time||"99:99";return ta.localeCompare(tb);});
                  if(allSch.length===0&&untimedWash.length===0)return <div style={{padding:12,fontSize:10,color:"#94a3b8"}}>タスクなし</div>;
                  const isMob=window.innerWidth<=768;
                  const tS=(tp)=>({PUB:{bg:"#dcfce7",c:"#166534",b:"#86efac"},PU:{bg:"#dbeafe",c:"#1e40af",b:"#93c5fd"},DEL:{bg:"#dbeafe",c:"#1d4ed8",b:"#60a5fa"},BDB:{bg:"#fce4ec",c:"#881337",b:"#fda4af"},BD:{bg:"#fee2e2",c:"#991b1b",b:"#fca5a5"},COL:{bg:"#ffedd5",c:"#9a3412",b:"#fdba74"},"来店":{bg:"#f3e8ff",c:"#6b21a8",b:"#c4b5fd"},"返却":{bg:"#f3e8ff",c:"#6b21a8",b:"#c4b5fd"},"洗車":{bg:"#FFFDE7",c:"#795548",b:"#FFD54F"}})[tp]||{bg:"#f1f5f9",c:"#475569",b:"#cbd5e1"};
                  return <div>
                    {allSch.map(t=>{
                      const rT=t.timeChange||t._ssTime||t.time||"--:--";const ts=tS(t.type);const ppl=parseInt(t.people)||0;
                      return <div key={t._id} onClick={()=>{setShowOP(true);}} style={{display:"flex",alignItems:"stretch",borderBottom:"1px solid #f1f5f9",cursor:"pointer",opacity:t.done?.4:1}}>
                        <div style={{width:50,flexShrink:0,display:"flex",alignItems:"center",justifyContent:"center",fontWeight:800,fontSize:11,color:"#334155",fontFamily:"monospace",background:"#f8fafc",borderRight:"1px solid #f1f5f9"}}>{rT}</div>
                        <div style={{width:40,flexShrink:0,display:"flex",alignItems:"center",justifyContent:"center",background:ts.bg,borderRight:"2px solid "+ts.b}}><span style={{fontSize:10,fontWeight:800,color:ts.c}}>{t.type}</span></div>
                        <div style={{flex:1,padding:"5px 8px",minWidth:0,display:"flex",alignItems:"center",gap:6,flexWrap:"wrap"}}>
                          <span style={{fontWeight:700,fontSize:11,color:"#0f172a",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{t.type==="洗車"?(t.name||"洗車"):(t.name||"")}</span>
                          {t.type==="洗車"&&t.memo&&<span style={{fontSize:9,color:"#795548",fontWeight:600}}>{t.memo}</span>}
                          {ppl>0&&<span style={{fontSize:10,fontWeight:700,color:"#7c3aed"}}>{ppl}名</span>}
                          {t.assignee&&<span style={{fontSize:9,background:"#ede9fe",color:"#6d28d9",fontWeight:700,padding:"1px 5px",borderRadius:3}}>👤{t.assignee}</span>}
                          {t.done&&<span>✅</span>}
                        </div>
                      </div>;
                    })}
                    {untimedWash.length>0&&<div style={{padding:"4px 8px",background:"#FFFDE7",borderTop:"1px solid #FFD54F",fontSize:10,color:"#795548",fontWeight:600}}>🧽 時間未定洗車 {untimedWash.length}件</div>}
                  </div>;
                };
                return topSchedOpen?<div style={{marginBottom:8}}>
                  <div style={{borderRadius:12,border:"1px solid #e2e8f0",overflow:"hidden",background:"#fff",boxShadow:"0 1px 3px rgba(0,0,0,.05)"}}><TopSchedule/></div>
                </div>:null;
              })()}
              {sections.map(function(sec){return <div key={sec.title} style={{marginBottom:16}}>
                <div style={{fontSize:11,fontWeight:800,color:sec.color,textTransform:"uppercase",letterSpacing:1,marginBottom:8,paddingLeft:4}}>{sec.title}</div>
                <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(200px,1fr))",gap:8}}>
                  {sec.items.map(function(item){return <button key={item.id} onClick={function(){if(item.external){window.open("license.html","_blank");}else{setTab(item.id);}}} style={{
                    display:"flex",alignItems:"center",gap:12,padding:"14px 16px",borderRadius:14,border:"1px solid #e2e8f0",
                    background:"#fff",cursor:"pointer",textAlign:"left",transition:"all .15s",boxShadow:"0 1px 3px rgba(0,0,0,.04)"
                  }} onMouseOver={function(e){e.currentTarget.style.borderColor=sec.color;e.currentTarget.style.boxShadow="0 2px 8px rgba(0,0,0,.08)";}}
                     onMouseOut={function(e){e.currentTarget.style.borderColor="#e2e8f0";e.currentTarget.style.boxShadow="0 1px 3px rgba(0,0,0,.04)";}}>
                    <div style={{width:42,height:42,borderRadius:12,background:sec.color+"12",display:"flex",alignItems:"center",justifyContent:"center",fontSize:22,flexShrink:0}}>{item.ico}</div>
                    <div style={{flex:1,minWidth:0}}>
                      <div style={{fontSize:14,fontWeight:700,color:"#1e293b"}}>{item.l}</div>
                      <div style={{fontSize:10,color:"#94a3b8",marginTop:1,lineHeight:1.3}}>{item.desc}</div>
                    </div>
                    {item.badge&&<span style={{padding:"2px 8px",borderRadius:10,fontSize:9,fontWeight:700,background:sec.color+"18",color:sec.color,flexShrink:0}}>{item.badge}</span>}
                  </button>;})}
                </div>
              </div>;})}
              {/* 同期ステータスパネル（最下部） */}
              {SB_ENABLED&&(()=>{
                const now=Date.now();
                const cats=[
                  {key:"reservations",label:"予約",ico:"📁"},
                  {key:"fleet",label:"配車",ico:"🚗"},
                  {key:"staff",label:"スタッフ",ico:"👥"},
                  {key:"vehicles",label:"車両",ico:"🔧"},
                  {key:"shifts",label:"出勤簿",ico:"📅"},
                  {key:"maintenance",label:"整備",ico:"🔩"},
                  {key:"accounting",label:"会計",ico:"🧾"},
                  {key:"hmCars",label:"整備管理",ico:"🏭"},
                ];
                const getStatus=(cat)=>{
                  const s=syncStatus[cat.key];
                  if(!s||!s.dbTime)return{status:"ok",label:"待機中",color:"#64748b",bg:"#f8fafc"};
                  const age=now-s.dbTime;
                  const hasUnsaved=s.localTime&&s.localTime>s.dbTime;
                  if(hasUnsaved)return{status:"unsaved",label:"未保存あり",color:"#dc2626",bg:"#fef2f2"};
                  if(!sbConnected&&age>60000)return{status:"stale",label:Math.floor(age/60000)+"分前",color:"#f59e0b",bg:"#fffbeb"};
                  if(age<5000)return{status:"fresh",label:"同期済",color:"#059669",bg:"#f0fdf4"};
                  if(age<60000)return{status:"ok",label:Math.floor(age/1000)+"秒前",color:"#059669",bg:"#f0fdf4"};
                  if(age<300000)return{status:"ok",label:Math.floor(age/60000)+"分前",color:"#64748b",bg:"#f8fafc"};
                  return{status:"old",label:Math.floor(age/60000)+"分前",color:"#f59e0b",bg:"#fffbeb"};
                };
                const hasIssue=cats.some(c=>{const st=getStatus(c);return st.status==="unsaved"||st.status==="stale"||st.status==="unknown";});
                return <div style={{marginTop:16,padding:"10px 14px",borderRadius:12,border:"1px solid "+(hasIssue?"#fde68a":"#d1fae5"),background:hasIssue?"#fffbeb":"#f0fdf4"}}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
                    <div style={{fontSize:11,fontWeight:700,color:hasIssue?"#92400e":"#166534"}}>
                      {hasIssue?"⚠️ 同期状態に注意":"✅ 全カテゴリ同期済み"}
                    </div>
                    <button onClick={reloadAll} disabled={reloading===1} style={{padding:"4px 12px",borderRadius:8,border:"1px solid #d1d5db",background:"#fff",fontSize:11,fontWeight:600,color:"#374151",cursor:reloading===1?"wait":"pointer"}}>
                      {reloading===1?"同期中...":"🔄 今すぐ同期"}
                    </button>
                  </div>
                  <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(100px,1fr))",gap:6}}>
                    {cats.map(cat=>{
                      const st=getStatus(cat);
                      return <div key={cat.key} style={{display:"flex",alignItems:"center",gap:6,padding:"6px 8px",borderRadius:8,background:st.bg,border:"1px solid "+st.color+"30"}}>
                        <span style={{fontSize:14}}>{cat.ico}</span>
                        <div style={{flex:1,minWidth:0}}>
                          <div style={{fontSize:10,fontWeight:700,color:"#374151"}}>{cat.label}</div>
                          <div style={{fontSize:9,color:st.color,fontWeight:600}}>{st.label}</div>
                        </div>
                        <div style={{width:8,height:8,borderRadius:4,background:st.status==="fresh"||st.status==="ok"?"#22c55e":st.status==="unsaved"?"#ef4444":st.status==="stale"?"#f59e0b":"#94a3b8",flexShrink:0}}></div>
                      </div>;
                    })}
                  </div>
                  {!sbConnected&&<div style={{marginTop:8,padding:"6px 10px",borderRadius:8,background:"#fef2f2",border:"1px solid #fecaca",fontSize:10,color:"#dc2626",fontWeight:600}}>
                    🔴 リアルタイム接続が切断されています。他端末の変更がすぐに反映されない可能性があります。「今すぐ同期」で最新データを取得してください。
                  </div>}
                </div>;
              })()}
            </div>;
          })()}
          {tab==="customer"&&<CustomerList data={data}/>}
          {tab==="kpi"&&<KpiTab store="tkm" data={data} vehicles={vehicles} fleet={fleet}/>}
          {tab==="analytics"&&<AnalyticsTab data={data} sheetPlaces={sheetPlaces}/>}
          {tab==="foreign"&&<ForeignVisitorAnalysis data={data}/>}
          {tab==="accounting"&&<PASGuard label="会計管理"><AccountingPanel staff={staff} onSynced={()=>markDbSync("accounting")}/></PASGuard>}
          {tab==="import"&&<CSVPanel onImport={imp} onUpdatePlaces={updatePlaces} dataCount={data.length} pendingPlaces={pendingPlaces} onSetPendingPlaces={setPendingPlaces} files={csvFiles} setFiles={setCsvFiles} logs={csvLogs} setLogs={setCsvLogs} placeLogs={csvPlaceLogs} setPlaceLogs={setCsvPlaceLogs}/>}
          {tab==="staff"&&<PASGuard label="スタッフ情報"><StaffManager staff={staff} onStaffChange={setStaffSync} onDeleteStaff={(name)=>DB.deleteStaff(name)}/></PASGuard>}
          {tab==="shift"&&<ShiftCalendar shifts={shifts} onShiftsChange={setShiftsSync} today={today} staff={staff} sbSaveShift={DB.saveShift} reservations={data} fleet={fleet} vehicles={vehicles}/>}
          {tab==="attendance"&&<PASGuard label="給与計算"><AttendanceManager shifts={shifts} staff={staff} today={today} attendance={attendance} onAttendanceChange={setAttendance}/></PASGuard>}
          {tab==="fleet"&&<FleetTimeline data={data} fleet={fleet} onFleetChange={setFleetSync} today={today} maintenance={maintenance} onMaintenanceChange={setMaintenance} vehicles={vehicles} vehicleClasses={vehicleClasses} onAddReservation={addReservation} onBulkAddReservation={bulkAddReservation} onCancelReservation={cancelReservation} onReassignVehicle={reassignVehicle} unassignedReasons={unassignedReasons} hmReload={hmReload}/>}
          {tab==="vehicle"&&<VehicleTab vehicles={vehicles} onVehiclesChange={setVehiclesSync} vehicleClasses={vehicleClasses} onDeleteVehicle={(code)=>{DB.deleteVehicle(code);/* 車両削除→fleet残留エントリ除去 */const nf={...fleetRefApp.current};let cleaned=false;Object.entries(nf).forEach(([rid,vc])=>{if(vc===code){delete nf[rid];cleaned=true;}});if(cleaned){setFleet(nf);fleetRefApp.current=nf;markLocalChange("fleet");DB.upsertFleet(nf).catch(e=>console.error("fleet cleanup error:",e));}}} hmCars={hmCars} hmCarData={hmCarData} hmLogs={hmLogs} hmClasses={hmClasses} hmReload={hmReload} maintenance={maintenance} onMaintenanceChange={setMaintenance} data={data} fleet={fleet}/>}
          {tab==="jalanpay"&&<JalanPayment data={data} jalanPay={jalanPay} onJalanPayChange={(id,d)=>{setJalanPay(p=>({...p,[id]:d}));DB.saveJalanPayment(id,d);}}/>}
          {tab==="dashboard"&&<PASGuard label="経営管理（オーナー専用）"><ManagementTab store="tkm"/></PASGuard>}
          {tab==="parking"&&<div style={{maxWidth:700,margin:"0 auto",textAlign:"center",padding:40}}>
            <div style={{fontSize:48,marginBottom:12}}>🅿️</div>
            <div style={{fontSize:18,fontWeight:800,color:"#1e293b",marginBottom:8}}>駐車場管理</div>
            <div style={{fontSize:12,color:"#94a3b8"}}>この機能は準備中です</div>
          </div>}
          {tab==="data"&&data.length===0&&<div style={{textAlign:"center",padding:40,color:"#94a3b8",fontSize:13}}>予約データがありません。CSVをインポートしてください。</div>}
          {tab==="data"&&data.length>0&&<DataTable data={data} fleet={fleet} vehicles={vehicles} sheetPlaces={sheetPlaces} onUpdatePlaces={saveSheetPlaces} onOpenReservation={(resId,lendDate)=>{/* TODO: OPシートを開いてeditResIdを設定 */}} onCancelReservation={cancelReservation} onRestoreReservation={restoreReservation}/>}
          {tab==="history"&&<PastTasksTable today={today}/>}
        </div>
      </div>
    </div>
    </div>
  </div>;
}

const APP_VERSION="v1.0.0-TKM";
// バージョンチェック: 古いキャッシュを検出したら強制リロード
(function(){
  const stored=localStorage.getItem("tkm_app_version");
  if(stored&&stored!==APP_VERSION){
    localStorage.setItem("tkm_app_version",APP_VERSION);
    console.log("[TKM] Version changed: "+stored+" → "+APP_VERSION+", reloading...");
    location.reload(true);
  }else{
    localStorage.setItem("tkm_app_version",APP_VERSION);
  }
})();
function Root(){
  const[ready,setReady]=useState(sbAuthReady);
  const[auth,setAuth]=useState(!SB_ENABLED||localStorage.getItem("tkm_auth")==="1");
  useEffect(()=>{
    if(!ready) sbAuthPromise.then(()=>setReady(true));
  },[]);
  if(!ready) return null;
  if(!auth)return <LoginScreen onLogin={()=>setAuth(true)}/>;
  return <><App/><div style={{position:"fixed",bottom:2,right:8,fontSize:11,color:"#64748b",fontWeight:700,zIndex:9999,pointerEvents:"none",background:"rgba(255,255,255,.8)",padding:"1px 6px",borderRadius:4}}>{APP_VERSION}</div></>;
}
ReactDOM.render(<Root/>,document.getElementById("root"));
// ★ React描画完了 → スプラッシュを非表示
if(typeof window.hideSplash==='function') window.hideSplash();
</script>
</body>
</html>
