  R:{key:"R",name:"楽天",c:"#ef4444",bg:"#fef2f2",det:r=>r.join(",").includes("楽天予約番号"),parse:(r,h)=>{const g=makeG(r,h);const ld=g("貸渡日時"),rd=g("返却日時"),mL=g("貸渡方法")||g("受渡方法"),mR=g("返却方法"),st=g("予約ステータス"),opts=g("付帯サービス")||"";console.log("[R-OPTS]",g("楽天予約番号"),"付帯サービス=",opts.substring(0,120),"cols="+r.length);const ss=detectSeats(opts,r,h,g);let pr=parsePrice(g)("料金合計","合計金額","基本料金","売上金額","請求金額","オプション込料金","事業者売上料金","確定料金");
// price=0なら全列スキャンで金額候補を探す
if(!pr){for(let ci=0;ci<h.length;ci++){const hn=h[ci]||"";const cv=r[ci]||"";if(!cv||cv==="0")continue;const n=+(cv.replace(/[,，¥￥\s]/g,""));if(!isNaN(n)&&n>=100&&n<10000000&&(hn.includes("金額")||hn.includes("料金")||hn.includes("売上")||hn.includes("合計"))&&n>pr)pr=n;}}
