function toLD(dt){return dt.getFullYear()+"-"+String(dt.getMonth()+1).padStart(2,"0")+"-"+String(dt.getDate()).padStart(2,"0");}
function fmtD(d){if(!d)return"";const s=String(d);const dt=new Date(s.length===10?s+"T00:00:00":s);if(isNaN(dt))return d;const w=["日","月","火","水","木","金","土"];return`${dt.getMonth()+1}/${dt.getDate()}(${w[dt.getDay()]})`;}
function fmtFull(d){if(!d)return"";const s=String(d);const dt=new Date(s.length===10?s+"T00:00:00":s);if(isNaN(dt))return d;const w=["日","月","火","水","木","金","土"];return`${dt.getFullYear()}年${dt.getMonth()+1}月${dt.getDate()}日(${w[dt.getDay()]})`;}
function dOff(b,n){const d=new Date(b+"T00:00:00");d.setDate(d.getDate()+n);return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0")+"-"+String(d.getDate()).padStart(2,"0");}
function norm(d){if(!d)return"";const s=String(d).replace(/\//g,"-");if(s.length<=10)return s;const dt=new Date(s);if(isNaN(dt))return s.substring(0,10);return toLD(dt);}
function sD(a,b){return norm(a)===norm(b);}
// 車両重複チェック: targetVcに対してresIdの期間と1日でもかぶる予約orメンテがあるか
function checkVehicleConflict(targetVc,resId,data,fleet,maintenance){
  const res=data.find(r=>r.id===resId);if(!res)return null;
  const ld=norm(res.lendDate),rd=norm(res.returnDate);
  // 予約重複チェック
  const conflict=data.find(r=>r.id!==resId&&r.status!=="cancelled"&&fleet[r.id]===targetVc&&norm(r.lendDate)<=rd&&norm(r.returnDate)>=ld);
  if(conflict)return conflict;
  // メンテナンス重複チェック
  if(maintenance&&maintenance.length){
    const maintConflict=maintenance.find(m=>m.vehicleCode===targetVc&&norm(m.startDate)<=rd&&norm(m.endDate)>=ld);
    if(maintConflict)return{_isMaint:true,name:"メンテナンス("+maintConflict.label+")",lendDate:maintConflict.startDate,returnDate:maintConflict.endDate};
  }
  return null;
}
function toYM(d){const s=String(d);const dt=new Date(s.length===10?s+"T00:00:00":s);return`${dt.getFullYear()}-${String(dt.getMonth()+1).padStart(2,"0")}`;}
function daysInMonth(ym){const[y,m]=ym.split("-").map(Number);return new Date(y,m,0).getDate();}
function ymLabel(ym){const[y,m]=ym.split("-").map(Number);return`${y}年${m}月`;}
function ymOff(ym,n){const[y,m]=ym.split("-").map(Number);const d=new Date(y,m-1+n,1);return`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}`;}
let _id=0;function uid(){return"t"+(++_id);}
let _vid=100;function vuid(){return"v"+(++_vid);}

/* ===== Googleスプレッドシートから場所データ取得 ===== */
const PLACE_SHEET_CSV="";  // ← BUDDICA高松店用スプレッドシートURLを設定
function parsePlaceCSV(text){
  const lines=[];let cur="";let inQ=false;
  for(let i=0;i<text.length;i++){
    const c=text[i];
    if(c==='"'){if(inQ&&text[i+1]==='"'){cur+='"';i++;}else{inQ=!inQ;}}
    else if(c===","&&!inQ){lines.length===0?lines.push([cur]):lines[lines.length-1].push(cur);cur="";}
    else if((c==="\n"||(c==="\r"&&text[i+1]==="\n"))&&!inQ){
      if(c==="\r")i++;
      if(lines.length===0){lines.push([cur]);lines.push([]);}else{lines[lines.length-1].push(cur);lines.push([]);}
      cur="";
    }else{cur+=c;}
  }
  if(cur||lines.length>0){if(lines.length===0)lines.push([cur]);else lines[lines.length-1].push(cur);}
  return lines.filter(r=>r.some(c=>c.trim()));
}
async function fetchPlaceData(targetResIds){
  const resp=await fetch(PLACE_SHEET_CSV);
  if(!resp.ok)throw new Error("CSV取得失敗: "+resp.status);
  const text=await resp.text();
  const rows=parsePlaceCSV(text);
  // ★ ヘッダー行を自動検出（空行をスキップ）
  let headerIdx=-1;
  for(let i=0;i<Math.min(20,rows.length);i++){
    const textCells=rows[i].filter(c=>c.trim()&&!/^\d{4}\//.test(c.trim()));
    if(textCells.length>=5){headerIdx=i;break;}
  }
  if(headerIdx<0)throw new Error("ヘッダー行が見つかりません");
  const header=rows[headerIdx];
  // ★ 予約番号列を自動検出
  let resCol=-1;
  header.forEach((h,i)=>{if(h.includes("予約番号")||h.includes("予約ID")||h.includes("Reservation"))resCol=i;});
  if(resCol<0){
    for(let ci=0;ci<header.length;ci++){
      const sample=rows.slice(headerIdx+1,Math.min(headerIdx+6,rows.length)).map(r=>r[ci]||"");
      if(sample.some(s=>/^[A-Z0-9]{8,}$/.test(s.trim()))){resCol=ci;break;}
    }
  }
  if(resCol<0)throw new Error("予約番号の列が見つかりません");
  // ★ 場所列を自動検出（H列=DEL場所, Y列=返却・送迎場所=COL場所）
  let delPlaceCol=-1,colPlaceCol=-1;
  header.forEach((h,i)=>{
    const t=h.trim();
    if(t==="場所"&&delPlaceCol<0)delPlaceCol=i;
    if(t.includes("返却")&&t.includes("場所"))colPlaceCol=i;
  });
  if(delPlaceCol<0)delPlaceCol=7; // fallback: H列
  if(colPlaceCol<0)colPlaceCol=24; // fallback: Y列
  const targetSet=new Set(targetResIds);
  const result={};
  rows.slice(headerIdx+1).forEach(r=>{
    const rid=(r[resCol]||"").trim();
    if(!rid||!targetSet.has(rid))return;
    const del=(r[delPlaceCol]||"").trim();
    const col=(r[colPlaceCol]||"").trim();
    if(result[rid]){
      if(del&&!result[rid].delPlace)result[rid].delPlace=del;
      if(col&&!result[rid].colPlace)result[rid].colPlace=col;
    }else{
      result[rid]={delPlace:del,colPlace:col};
    }
  });
  return result;
}

/* ===== スプレッドシートからDEL/COL時間データ取得 ===== */
async function fetchTimeData(targetResIds){
  const resp=await fetch(PLACE_SHEET_CSV);
  if(!resp.ok)throw new Error("CSV取得失敗: "+resp.status);
  const text=await resp.text();
  const rows=parsePlaceCSV(text);
  // ★ ヘッダー行を自動検出（空行をスキップ）
  let headerIdx=-1;
  for(let i=0;i<Math.min(20,rows.length);i++){
    const textCells=rows[i].filter(c=>c.trim()&&!/^\d{4}\//.test(c.trim()));
    if(textCells.length>=5){headerIdx=i;break;}
  }
  if(headerIdx<0)throw new Error("ヘッダー行が見つかりません");
  const header=rows[headerIdx];
  let resCol=-1;
  header.forEach((h,i)=>{if(h.includes("予約番号")||h.includes("予約ID")||h.includes("Reservation"))resCol=i;});
  if(resCol<0){
    for(let ci=0;ci<header.length;ci++){
      const sample=rows.slice(headerIdx+1,Math.min(headerIdx+6,rows.length)).map(r=>r[ci]||"");
      if(sample.some(s=>/^[A-Z0-9]{8,}$/.test(s.trim()))){resCol=ci;break;}
    }
  }
  if(resCol<0)throw new Error("予約番号の列が見つかりません");
  // ★ 時間列を自動検出（C列=DEL時間, W列=返却時間=COL時間）
  let delTimeCol=-1,colTimeCol=-1;
  header.forEach((h,i)=>{
    const t=h.trim();
    if(t==="時間"&&delTimeCol<0)delTimeCol=i;
    if(t==="返却時間")colTimeCol=i;
  });
  if(delTimeCol<0)delTimeCol=2; // fallback: C列
  if(colTimeCol<0)colTimeCol=22; // fallback: W列
  const targetSet=new Set(targetResIds);
  const result={};
  rows.slice(headerIdx+1).forEach(r=>{
    const rid=(r[resCol]||"").trim();
    if(!rid||!targetSet.has(rid))return;
    const delT=(r[delTimeCol]||"").trim();
    const colT=(r[colTimeCol]||"").trim();
    if(result[rid]){
      if(delT&&!result[rid].delTime)result[rid].delTime=delT;
      if(colT&&!result[rid].colTime)result[rid].colTime=colT;
    }else{
      result[rid]={delTime:delT,colTime:colT};
    }
  });
  return result;
}

/* ===== じゃらん決済スプレッドシートから支払データ取得 ===== */
const JALAN_PAY_SHEET_CSV="";  // ← 高松店用じゃらん決済スプレッドシートURLをここに設定
async function fetchJalanPaySheetData(targetResIds){
  if(!JALAN_PAY_SHEET_CSV)throw new Error("スプレッドシートURLが未設定です。\nJALAN_PAY_SHEET_CSV を設定してください。");
  const resp=await fetch(JALAN_PAY_SHEET_CSV);
  if(!resp.ok)throw new Error("CSV取得失敗: "+resp.status);
  const text=await resp.text();
  const rows=parsePlaceCSV(text);
  if(rows.length<2)throw new Error("データが空です");
  // 予約番号列を自動検出
  const header=rows[0];
  let resCol=-1;
  header.forEach((h,i)=>{if(h.includes("予約番号")||h.includes("予約ID")||h.includes("Reservation"))resCol=i;});
  if(resCol<0){
    for(let ci=0;ci<header.length;ci++){
      const sample=rows.slice(1,Math.min(6,rows.length)).map(r=>r[ci]||"");
      if(sample.some(s=>/^[A-Z0-9]{8,}$/.test(s.trim()))){resCol=ci;break;}
    }
  }
  if(resCol<0)throw new Error("予約番号の列が見つかりません");
  const payDateCol=3; // D列(index3) = 支払日
  const amountCol=5;  // F列(index5) = 金額
  const targetSet=new Set(targetResIds);
  const result={};
  rows.slice(1).forEach(r=>{
    const rid=(r[resCol]||"").trim();
    if(!rid||!targetSet.has(rid))return;
    const payDate=(r[payDateCol]||"").trim();
    const amount=(r[amountCol]||"").trim().replace(/[,¥￥\s]/g,"");
    // D列に日付が入っていれば支払済み
    if(payDate){
      result[rid]={adjustedPrice:amount||"0",payStatus:"完了",payDate:payDate};
    }
  });
  return result;
}

/* ===== タスク生成 ===== */
function generateTasks(reservations,date,fleet,vehicles){
  const tasks=[];
  const tomorrow=dOff(date,1);
  // 翌日出発の配車済み車両を収集（洗車タスク用）
  const tomorrowDELVehicles=new Set();
  reservations.forEach(r=>{
    if(r.status==="cancelled")return; // キャンセル済み除外
    if(sD(r.lendDate,tomorrow)&&fleet[r.id]){tomorrowDELVehicles.add(fleet[r.id]);}
  });
  reservations.forEach(r=>{
    if(r.status==="cancelled")return; // ★ キャンセル済みはタスク生成しない
    const fv=fleet[r.id];const veh=fv?vehicles.find(v=>v.code===fv):null;
    const base={reservationId:r.id,ota:r.ota,tel:r.tel||"",mail:r.mail||"",done:false,assignee:"",memo:"",assignedVehicle:fv||"",plateNo:veh?veh.no:"",insuranceChange:"",opts:{b:+(r.optB||0),c:+(r.optC||0),j:+(r.optJ||0),usb:+(r.optUSB||0)},yakkan:false,line:false,payment:false};
    // ★ NHA: DEL/PU判定 = visitType OR お届け場所の有無（Step2 CSV含む）
    const dpOk=r.delPlace&&r.delPlace.trim()&&!/^(来店|店舗|店頭|ヤード|営業所|ー+|-+|なし|無し|FALSE|false|0)$/.test(r.delPlace.trim());
    const cpOk=r.colPlace&&r.colPlace.trim()&&!/^(来店|店舗|店頭|ヤード|営業所|ー+|-+|なし|無し|FALSE|false|0)$/.test(r.colPlace.trim());
    const lendType=(r.visitType==="DEL"||dpOk)?"DEL":"PU";
    const retType=(r.returnType==="COL"||cpOk)?"COL":"BD";
    if(sD(r.lendDate,date)){const lTask={...base,_id:uid(),type:lendType,time:r.delTime||r.lendTime,name:r.name,people:r.people,place:r.delPlace||"",vehicle:r.vehicle,insurance:r.insurance,flight:r.flight,returnDate:r.returnDate,returnTime:r.returnTime,returnType:retType,colPlace:r.colPlace||""};if(lTask.type==="PU"&&isBusRequired(lTask))lTask.type="PUB";tasks.push(lTask);}
    if(sD(r.returnDate,date)){const place=r.colPlace||"";const rTask={...base,_id:uid(),type:retType,time:r.colTime||r.returnTime,name:r.name,people:r.people,place,vehicle:r.vehicle,insurance:r.insurance,flight:""};if(rTask.type==="BD"&&isBusRequired(rTask))rTask.type="BDB";tasks.push(rTask);}
  });
  // 洗車タスク: 翌日DELの配車済み車両のみ（未配車分はloadTasks内で追加管理）
  tomorrowDELVehicles.forEach(vc=>{
    const veh=vehicles.find(v=>v.code===vc);
    const tRes=reservations.find(r=>sD(r.lendDate,tomorrow)&&fleet[r.id]===vc);
    if(!veh)return;
    if(tasks.find(t=>t.type==="洗車"&&t.assignedVehicle===vc))return;
    const wType=tRes?(tRes.visitType==="DEL"?"DEL":"PU"):"DEL";
    tasks.push({_id:uid(),type:"洗車",time:"",name:`翌日出発: ${tRes?tRes.name:""}`,people:0,place:"",vehicle:veh.type,insurance:"",flight:"",reservationId:tRes?tRes.id:"",ota:tRes?tRes.ota:"",tel:"",mail:"",done:false,assignee:"",memo:`${fmtD(tomorrow)} ${wType} ${tRes?tRes.lendTime:""} ${tRes?tRes.name:""}`,assignedVehicle:vc,plateNo:veh.no,insuranceChange:"",opts:{b:+(tRes&&tRes.optB||0),c:+(tRes&&tRes.optC||0),j:+(tRes&&tRes.optJ||0),usb:+(tRes&&tRes.optUSB||0)},yakkan:false,line:false,payment:false,returnDate:"",returnTime:"",returnType:"",colPlace:""});
  });
  return tasks.sort((a,b)=>{
    // 洗車は最後にまとめる
    if(a.type==="洗車"&&b.type!=="洗車")return 1;
    if(a.type!=="洗車"&&b.type==="洗車")return -1;
    return(a.time||"").localeCompare(b.time||"");
  });
}

/* ===== 自動配車ロジック ===== */
function autoAssign(reservations,vehicles,existingFleet,maintenance){
  const fleet={...existingFleet};
  const maints=maintenance||[];
  // キャンセル済み除外
  // オフィシャル/直予約(HP)を最優先、次に貸出日順
  const sorted=[...reservations].filter(r=>r.status!=="cancelled").sort((a,b)=>{
    const aO=a.ota==="HP"?0:1,bO=b.ota==="HP"?0:1;
    if(aO!==bO)return aO-bO;
    return norm(a.lendDate).localeCompare(norm(b.lendDate));
  });
  const _reasons={};
  // 各車両の割当回数カウンタ（均等配車用）
  const usageCount={};
  vehicles.forEach(v=>{usageCount[v.code]=0;});
  // 既存割当をカウント
  Object.values(existingFleet).forEach(vc=>{if(vc&&typeof vc==="string")usageCount[vc]=(usageCount[vc]||0)+1;});

  // 車両が期間中に空いているか判定（washBuffer=trueで前日も確保）
  function isAvailable(v,rL,rR,rId,washBuffer){
    const checkL=washBuffer?dOff(rL,-1):rL;
    const inMaint=maints.some(m=>{
      if(m.vehicleCode!==v.code)return false;
      const mL=norm(m.startDate),mR=norm(m.endDate);
      return checkL<=mR&&rR>=mL;
    });
    if(inMaint)return{ok:false,reason:`${v.code}:メンテ中`};
    const conflictRes=sorted.find(other=>{
      if(other.id===rId)return false;
      if(fleet[other.id]!==v.code)return false;
      const oL=norm(other.lendDate),oR=norm(other.returnDate);
      return checkL<=oR&&rR>=oL;
    });
    if(conflictRes)return{ok:false,reason:`${v.code}:${conflictRes.name||conflictRes.id}と重複`};
    return{ok:true};
  }

  // 候補リストを使用回数昇順にソート（均等配車）
  function sortByUsage(list){
    return[...list].sort((a,b)=>(usageCount[a.code]||0)-(usageCount[b.code]||0));
  }

  // 候補リストから空き車両を探す（washBuffer付き→なしのフォールバック）
  function tryAssign(list,rL,rR,rId){
    const sorted1=sortByUsage(list);
    // Pass 1: 洗車バッファ（前日空き）付きで探す
    for(const v of sorted1){
      const chk=isAvailable(v,rL,rR,rId,true);
      if(chk.ok)return{v,tried:[]};
    }
    // Pass 2: バッファなし（詰め配車）で探す
    let tried=[];
    for(const v of sorted1){
      const chk=isAvailable(v,rL,rR,rId,false);
      if(!chk.ok){tried.push(chk.reason);continue;}
      return{v,tried};
    }
    return{v:null,tried};
  }

  sorted.forEach(r=>{
    if(fleet[r.id])return;
    const cls=r.vehicle;
    const pvc=r.preferVc||"";
    const rL=norm(r.lendDate),rR=norm(r.returnDate);
    // ★ サブクラスフォールバック: A2→A, B2→B（車両未登録時）
    const SUBCLASS_FB={"A2":"A","B2":"B"};
    let candidates=vehicles.filter(v=>v.type===cls);
    let usedCls=cls;
    if(candidates.length===0&&SUBCLASS_FB[cls]){usedCls=SUBCLASS_FB[cls];candidates=vehicles.filter(v=>v.type===usedCls);}
    if(candidates.length===0){
      _reasons[r.id]=`クラス"${cls}"の車両が登録されていません`;
      return;
    }
    let allTried=[];
    // ① preferVcがある場合: 指定車種を最優先
    if(pvc){
      const preferred=candidates.filter(v=>v.code.startsWith(pvc));
      if(preferred.length>0){
        const res=tryAssign(preferred,rL,rR,r.id);
        if(res.v){fleet[r.id]=res.v.code;usageCount[res.v.code]=(usageCount[res.v.code]||0)+1;return;}
        allTried=allTried.concat(res.tried);
      }
    }
    // ② 同クラスの他車種（or preferVcなしの場合は全候補）
    const fallback=pvc?candidates.filter(v=>!v.code.startsWith(pvc)):candidates;
    if(fallback.length>0){
      const res=tryAssign(fallback,rL,rR,r.id);
      if(res.v){fleet[r.id]=res.v.code;usageCount[res.v.code]=(usageCount[res.v.code]||0)+1;return;}
      allTried=allTried.concat(res.tried);
    }
    _reasons[r.id]=pvc
      ?`${cls}クラス(車種指定:${pvc})全${candidates.length}台が使用中(${allTried.join(", ")})`
      :`${cls}クラス全${candidates.length}台が使用中(${allTried.join(", ")})`;
  });
  fleet._unassignedReasons=_reasons;
  return fleet;
}

function OBadge({ota}){const o=OTA[ota];if(!o)return null;return <span style={{background:o.bg,color:o.c,padding:"1px 6px",borderRadius:4,fontSize:10,fontWeight:700,border:`1px solid ${o.c}22`}}>{o.key}</span>;}

/* Google Maps リンク生成 */
function mapsUrl(place){if(!place)return "";return "https://www.google.com/maps/search/?api=1&query="+encodeURIComponent(place+" 高松");}
function PlaceLink({place,style}){if(!place||place==="—"||place==="-")return <span style={style}>{place||""}</span>;const skip=!place.trim()||place.trim().length<2||/^(なし|無し|無|ー+|-+|FALSE|false|0)$/.test(place.trim());if(skip)return <span style={style}>{place}</span>;return <a href={mapsUrl(place)} target="_blank" rel="noopener noreferrer" style={{...style,color:"#2563eb",textDecoration:"underline",cursor:"pointer"}} title={`Googleマップで「${place}」を検索`}>{place}</a>;}
function EditablePlace({value,field,mark:markFn,task,updFn,getResChanges}){
  const[editing,setEditing]=React.useState(false);
  const[customMode,setCustomMode]=React.useState(false);
  const[modalVal,setModalVal]=React.useState(value||"");
  const isMobile=window.innerWidth<=768;
  const hasLink=value&&value.trim()&&value.trim().length>=2&&!/^(なし|無し|無|ー+|-+|FALSE|false|0|—)$/.test(value.trim());
  const isPreset=TKM_PLACE_OPTIONS.includes(value);
  // ★ スマホ: モーダル風の場所編集
  if(editing&&isMobile)return <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,.4)",display:"flex",alignItems:"flex-end",justifyContent:"center",zIndex:9999}} onClick={e=>{if(e.target===e.currentTarget){setEditing(false);setCustomMode(false);}}}>
    <div style={{width:"100%",maxWidth:500,background:"#fff",borderRadius:"16px 16px 0 0",padding:"16px 16px env(safe-area-inset-bottom,16px)"}} onClick={e=>e.stopPropagation()}>
      <div style={{fontSize:13,fontWeight:700,color:"#1e293b",marginBottom:10}}>📍 {field==="colPlace"?"回収場所":"送迎場所"}を編集</div>
      <div style={{display:"flex",flexDirection:"column",gap:8}}>
        <select value={isPreset?value:customMode?"__custom":""} onChange={e=>{const v=e.target.value;if(v==="__custom"){setCustomMode(true);setModalVal("");return;}setCustomMode(false);updFn(task._id,markFn({...task,[field]:v},field),getResChanges?getResChanges(v):undefined);setEditing(false);}} style={{border:"1px solid #d1d5db",borderRadius:8,padding:"10px 12px",fontSize:14,width:"100%"}}>
          <option value="">選択してください</option>{TKM_PLACE_OPTIONS.map(p=><option key={p} value={p}>{p}</option>)}<option value="__custom">その他(手入力)...</option>{value&&!isPreset&&<option value={value}>{value}</option>}
        </select>
        {customMode&&<input autoFocus value={modalVal} onChange={e=>setModalVal(e.target.value)} placeholder="場所を入力" style={{border:"1px solid #3b82f6",borderRadius:8,padding:"10px 12px",fontSize:14,width:"100%",outline:"none"}}/>}
        <div style={{display:"flex",gap:8}}>
          <button onClick={()=>{setEditing(false);setCustomMode(false);}} style={{flex:1,padding:"10px",borderRadius:8,border:"1px solid #d1d5db",background:"#fff",fontSize:13,cursor:"pointer"}}>キャンセル</button>
          {customMode&&<button onClick={()=>{updFn(task._id,markFn({...task,[field]:modalVal},field),getResChanges?getResChanges(modalVal):undefined);setEditing(false);setCustomMode(false);}} style={{flex:1,padding:"10px",borderRadius:8,border:"none",background:"#2563eb",color:"#fff",fontSize:13,fontWeight:700,cursor:"pointer"}}>保存</button>}
        </div>
      </div>
    </div>
  </div>;
  // PC: 従来のインライン編集
  if(editing&&customMode)return <input autoFocus value={value||""} onChange={e=>{const nv=e.target.value;updFn(task._id,markFn({...task,[field]:nv},field),getResChanges?getResChanges(nv):undefined);}} onBlur={()=>{setEditing(false);setCustomMode(false);}} onKeyDown={e=>{if(e.key==="Enter")e.target.blur();}} style={{border:"1px solid #3b82f6",background:"#eff6ff",fontSize:9,width:"100%",padding:"1px 3px",borderRadius:3,outline:"none"}} placeholder="場所を入力"/>;
  if(editing)return <select autoFocus value={isPreset?value:"__custom"} onChange={e=>{const v=e.target.value;if(v==="__custom"){setCustomMode(true);return;}updFn(task._id,markFn({...task,[field]:v},field),getResChanges?getResChanges(v):undefined);setEditing(false);}} onBlur={()=>setEditing(false)} style={{border:"1px solid #3b82f6",background:"#eff6ff",fontSize:8,width:"100%",padding:"1px 2px",borderRadius:3,outline:"none"}}><option value="">-</option>{TKM_PLACE_OPTIONS.map(p=><option key={p} value={p}>{p}</option>)}<option value="__custom">その他(手入力)...</option>{value&&!isPreset&&value!=="__custom"&&<option value={value}>{value}</option>}</select>;
  return <div style={{display:"flex",alignItems:"center",gap:2,width:"100%",minHeight:18}}>
    {hasLink?<><a href={mapsUrl(value)} target="_blank" rel="noopener noreferrer" style={{fontSize:9,color:"#2563eb",textDecoration:"underline",cursor:"pointer",flex:1,minWidth:0,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}} title={`Googleマップで「${value}」を検索`}>{value}</a><button onClick={()=>setEditing(true)} style={{background:"none",border:"none",cursor:"pointer",fontSize:9,color:"#94a3b8",padding:0,lineHeight:1,flexShrink:0}}>✏️</button></>:<span style={{fontSize:9,color:value?"#334155":"#ccc",flex:1,cursor:"text"}} onClick={()=>setEditing(true)}>{value||"-"}</span>}
  </div>;
}

/* ==========================================
   CSV取込
   ========================================== */
function CSVPanel({onImport,onUpdatePlaces,dataCount,pendingPlaces,onSetPendingPlaces,files,setFiles,logs,setLogs,placeLogs,setPlaceLogs}){
  const handle=(e,k)=>{const f=e.target.files?.[0];if(!f)return;readFile(f,text=>{const rows=parseCSV(text);let res;if(k){const cfg=OTA[k];if(cfg){const skipStoreFilter=!!cfg.skipStoreFilter;for(let i=0;i<Math.min(rows.length,10);i++){if(cfg.det(rows[i])){const hd=rows[i],data=[];let totalValid=0,skippedOther=0;for(let j=i+1;j<rows.length;j++){if(rows[j].length<3||!rows[j][0])continue;try{const p=cfg.parse(rows[j],hd);if(p&&p.lendDate&&p.status!=="cancelled"){totalValid++;if(!skipStoreFilter){const rowText=rows[j].join(",").toUpperCase();if(!rowText.includes("高松")){skippedOther++;continue;}}p.delTime=p.delTime||p.lendTime;p.colTime=p.colTime||p.returnTime;p.delPlace=p.delPlace||"";p.colPlace=p.colPlace||"";data.push(p);}}catch(e){}}res={ota:k,data,totalValid,skippedOther};break;}}}}if(!res)res=detectParse(rows);if(!res){setLogs(p=>[...p,{t:"err",m:`${f.name}: 検出失敗`}]);return;}const now=new Date();const ts=`${now.getMonth()+1}/${now.getDate()} ${String(now.getHours()).padStart(2,"0")}:${String(now.getMinutes()).padStart(2,"0")}`;setFiles(p=>({...p,[res.ota]:{name:f.name,data:res.data,importedAt:ts}}));const isOfficial=OTA[res.ota]?.skipStoreFilter;const skipMsg=res.skippedOther>0?` (他店舗${res.skippedOther}件除外)`:"";const countLabel=isOfficial?`${res.data.length}件 (OTA${res.totalValid-res.data.length}件除外)`:`高松${res.data.length}件${skipMsg}`;
    // 月別内訳を生成
    const monthBreak={};let totalPrice=0;res.data.forEach(r=>{const ym=r.returnDate?r.returnDate.substring(0,7):"不明";monthBreak[ym]=(monthBreak[ym]||0)+1;totalPrice+=(r.price||0);});
    const monthStr=Object.entries(monthBreak).sort(([a],[b])=>a.localeCompare(b)).map(([ym,cnt])=>`${ym.replace("-","/")}:${cnt}件`).join(" / ");
    setLogs(p=>[...p,{t:"ok",m:`[${ts}] ${f.name} → ${OTA[res.ota].name} ${countLabel} ¥${totalPrice.toLocaleString()} 【全期間】${monthStr}`}]);});};
  const total=Object.values(files).reduce((s,f)=>s+f.data.length,0);
  return <div style={{maxWidth:960,margin:"0 auto"}}>
    <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mb-4">
      <h3 className="text-base font-bold mb-1">Step 1: CSVアップロード</h3>
      <p className="text-xs text-gray-500 mb-3">各OTAのCSVを選択（Shift_JIS / UTF-8 自動判別）</p>
      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(100px,1fr))",gap:8}}>
        {Object.entries(OTA).map(([k,cfg])=>{const up=files[k];return <label key={k} className="flex flex-col items-center p-3 rounded-xl border-2 border-dashed cursor-pointer transition hover:shadow-md" style={{borderColor:up?cfg.c:"#d1d5db",background:up?cfg.bg:"#fff"}}>
          <div className="w-8 h-8 rounded-full text-white flex items-center justify-center text-sm font-bold mb-1" style={{background:cfg.c}}>{k}</div>
          <span className="font-semibold text-xs">{cfg.name}</span>
          {up?<><div className="text-xs font-bold mt-1" style={{color:cfg.c}}>{up.data.length}件</div><div style={{fontSize:8,color:"#64748b",marginTop:1}}>{up.importedAt}</div></>:<span className="text-xs text-gray-400 mt-1">選択</span>}
          <input type="file" accept=".csv,.txt" className="hidden" onChange={e=>handle(e,k)} />
        </label>;})}
      </div>
    </div>
    {logs.length>0&&<div className="bg-white rounded-xl shadow-sm border border-gray-200 p-3 mb-4">{logs.map((l,i)=><div key={i} className="text-xs px-2 py-1 rounded mb-1" style={{background:l.t==="err"?"#fef2f2":"#f0fdf4",color:l.t==="err"?"#b91c1c":"#15803d"}}>{l.t==="err"?"✗":"✓"} {l.m}</div>)}</div>}
    {total>0&&(()=>{
      const rawD=Object.values(files).flatMap(f=>f.data);
      // ★ 重複ID解消: price>0の予約を優先（楽天price=0 vs RC正しいprice の問題対策）
      const dmap=new Map();let dupCnt=0;
      rawD.forEach(r=>{const ex=dmap.get(r.id);if(ex){dupCnt++;if((Number(r.price)||0)>(Number(ex.price)||0))dmap.set(r.id,r);}else dmap.set(r.id,r);});
      const allD=[...dmap.values()];
      const mBreak={};let tPrice=0;
      allD.forEach(r=>{const ym=r.returnDate?r.returnDate.substring(0,7):"不明";mBreak[ym]=(mBreak[ym]||{cnt:0,sum:0});mBreak[ym].cnt++;mBreak[ym].sum+=(r.price||0);tPrice+=(r.price||0);});
      const sortedM=Object.entries(mBreak).sort(([a],[b])=>a.localeCompare(b));
      return <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
      <div className="flex items-center gap-2 mb-3 flex-wrap">{Object.entries(files).map(([k,f])=><div key={k} className="flex items-center gap-1"><OBadge ota={k}/><span className="text-xs font-bold">{f.data.length}件</span></div>)}<span className="text-gray-400">→</span><span className="text-base font-black text-blue-700">合計 {allD.length}件 / ¥{tPrice.toLocaleString()}</span>{dupCnt>0&&<span className="text-xs text-amber-600 font-bold">（重複{dupCnt}件→price優先で統合）</span>}</div>
      <div style={{fontSize:10,color:"#475569",marginBottom:8,padding:"6px 8px",background:"#f8fafc",borderRadius:6}}>📅 返却月別: {sortedM.map(([ym,d])=><span key={ym} style={{marginRight:8}}><b>{ym.replace("-","/")}</b>:{d.cnt}件(¥{d.sum.toLocaleString()})</span>)}</div>
      <button onClick={()=>onImport(allD)} className="btn-primary" style={{padding:"10px 24px",fontSize:14}}>統合してタスクを生成 →</button>
    </div>;})()}
    <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mt-4">
      <h3 className="text-base font-bold mb-1" style={{display:"flex",alignItems:"center",gap:8}}><span style={{background:"#4f46e5",color:"#fff",borderRadius:"50%",width:24,height:24,display:"inline-flex",alignItems:"center",justifyContent:"center",fontSize:12,fontWeight:700}}>2</span>場所CSV取込</h3>
      <p className="text-xs text-gray-500 mb-3">予約番号でお届け場所・回収場所を一括更新 → OPシートにGoogleマップリンク付きで表示されます<br/>CSVフォーマット: 予約番号, お届け場所, 回収場所{dataCount===0&&<span style={{color:"#b45309",fontWeight:600}}><br/>※ Step 1のCSV取込後にマッチングされます（先に読み込みも可能）</span>}</p>
      <div className="flex items-center gap-3 flex-wrap">
        <label className="px-4 py-2 rounded-lg text-xs font-semibold border-2 border-dashed border-indigo-300 bg-indigo-50 text-indigo-700 cursor-pointer hover:bg-indigo-100"><span>📍 場所CSVを選択</span><input type="file" accept=".csv,.txt,.tsv" className="hidden" onChange={e=>{
          const f=e.target.files?.[0];if(!f)return;
          readFile(f,text=>{
            const rows=parseCSV(text);if(rows.length<2){setPlaceLogs([{t:"err",m:"CSVが空です"}]);return;}
            // ヘッダー行を自動検出（最初の10行以内で「予約番号」を含む行を探す）
            let hdIdx=-1,hd=null;
            for(let hi=0;hi<Math.min(rows.length,10);hi++){
              if(rows[hi].some(h=>h&&(h.includes("予約番号")||h==="ID"||h==="id"))){hdIdx=hi;hd=rows[hi];break;}
            }
            if(!hd){setPlaceLogs([{t:"err",m:"「予約番号」列が見つかりません"}]);return;}
            const idxId=hd.findIndex(h=>h.includes("予約番号")||h==="ID"||h==="id");
            const idxDel=hd.findIndex(h=>h.includes("届け")||(h.includes("場所")&&!h.includes("回収")&&!h.includes("返却")));
            const idxCol=hd.findIndex(h=>h.includes("回収")||h.includes("返却場所"));
            if(idxId<0){setPlaceLogs([{t:"err",m:"「予約番号」列が見つかりません"}]);return;}
            const places={};let cnt=0;
            for(let i=hdIdx+1;i<rows.length;i++){
              const r=rows[i];const rid=r[idxId]?.trim();if(!rid)continue;
              const del=idxDel>=0?r[idxDel]?.trim()||"":"";
              const col=idxCol>=0?r[idxCol]?.trim()||"":"";
              if(del||col){places[rid]={delPlace:del,colPlace:col};cnt++;}
            }
            if(cnt===0){setPlaceLogs([{t:"err",m:"有効なデータがありません"}]);return;}
            const now2=new Date();const ts2=`${now2.getMonth()+1}/${now2.getDate()} ${String(now2.getHours()).padStart(2,"0")}:${String(now2.getMinutes()).padStart(2,"0")}`;
            onSetPendingPlaces(places);
            if(dataCount>0){const result=onUpdatePlaces(places);setPlaceLogs([{t:"ok",m:`[${ts2}] ${f.name}: ${cnt}件読込 → ${result.matched}件マッチ, ${result.unmatched}件未マッチ`}]);}
            else{setPlaceLogs([{t:"ok",m:`[${ts2}] ${f.name}: ${cnt}件読込済み（Step 1のCSV取込後に自動マッチングされます）`}]);}
          });
        }}/></label>
        <span className="text-xs text-gray-400">予約番号 + お届け場所 + 回収場所</span>
      </div>
      {placeLogs.length>0&&<div className="mt-2">{placeLogs.map((l,i)=><div key={i} className="text-xs px-2 py-1 rounded mb-1" style={{background:l.t==="err"?"#fef2f2":"#f0fdf4",color:l.t==="err"?"#b91c1c":"#15803d"}}>{l.t==="err"?"✗":"✓"} {l.m}</div>)}</div>}
      {pendingPlaces&&Object.keys(pendingPlaces).length>0&&dataCount===0&&<div className="mt-2 px-2 py-1 rounded text-xs" style={{background:"#fef3c7",color:"#92400e"}}>📍 場所データ {Object.keys(pendingPlaces).length}件 読込済み — Step 1のインポート待ち</div>}
    </div>
  </div>;
}

/* ==========================================
   車両管理画面
   ========================================== */
function VehicleManager({vehicles,onVehiclesChange,vehicleClasses,onDeleteVehicle}){
  const[editId,setEditId]=useState(null);
  const[form,setForm]=useState({name:"",no:"",type:"A",seats:5,active:true});
  const[addMode,setAddMode]=useState(false);

  const startEdit=(v)=>{setEditId(v.id);setForm({name:v.name,no:v.no,type:v.type,seats:v.seats,active:v.active!==false});};
  const save=()=>{
    if(editId){
      onVehiclesChange(vehicles.map(v=>v.id===editId?{...v,name:form.name,no:form.no,type:form.type,seats:+form.seats,active:form.active}:v));
      setEditId(null);
    }
  };
  const addNew=()=>{
    const code=form.name.replace(/[\s-]/g,"").substring(0,3).toUpperCase()||"NEW";
    onVehiclesChange([...vehicles,{id:code,code,name:form.name,no:form.no,type:form.type,seats:+form.seats,active:form.active}]);
    setForm({name:"",no:"",type:"A",seats:5,active:true});setAddMode(false);
  };
  const remove=(id)=>{const v=vehicles.find(x=>x.id===id);onVehiclesChange(vehicles.filter(x=>x.id!==id));if(v&&onDeleteVehicle)onDeleteVehicle(v.code);};

  const grouped=useMemo(()=>{
    return vehicleClasses.map(vc=>({...vc,items:vehicles.filter(v=>v.type===vc.type)}));
  },[vehicles,vehicleClasses]);

  const fileRef=useRef(null);
  const importFromFile=(e)=>{
    const file=e.target.files[0];if(!file)return;
    const ext=file.name.split(".").pop().toLowerCase();
    const reader=new FileReader();
    reader.onload=async(ev)=>{
      try{
        let rows=[];
        if(ext==="csv"||ext==="tsv"){
          const text=ev.target.result;
          const sep=ext==="tsv"?"\t":",";
          const lines=text.split(/\r?\n/).filter(l=>l.trim());
          const hd=lines[0].split(sep).map(s=>s.trim().replace(/^"|"$/g,""));
          const ci=(name)=>hd.findIndex(h=>h.includes(name));
          const iCode=ci("車両コード"),iName=ci("車名"),iNo=ci("ナンバー"),iType=ci("クラス"),iSeats=ci("定員");
          for(let i=1;i<lines.length;i++){
            const cols=lines[i].split(sep).map(s=>s.trim().replace(/^"|"$/g,""));
            if(!cols[iName||0])continue;
            rows.push({code:cols[iCode]||"",name:cols[iName]||"",no:cols[iNo]||"",type:cols[iType]||"C",seats:+(cols[iSeats]||5)});
          }
        }else if(ext==="xlsx"||ext==="xls"){
          /* SheetJS (XLSX) で非同期パース */
          const XLSX=await window.loadXlsx().catch(()=>null);
          if(!XLSX){alert("Excelファイル読み込みに失敗しました。\n代わりにCSVで保存してください。");return;}
          const wb=XLSX.read(new Uint8Array(ev.target.result),{type:"array"});
          const ws=wb.Sheets[wb.SheetNames[0]];
          const json=XLSX.utils.sheet_to_json(ws,{defval:""});
          json.forEach(r=>{
            const name=r["車名"]||r["name"]||"";if(!name)return;
            rows.push({code:r["車両コード"]||r["code"]||"",name,no:String(r["ナンバー"]||r["no"]||""),type:r["クラス"]||r["type"]||"C",seats:+(r["乗車定員"]||r["seats"]||5)});
          });
        }
        if(rows.length===0){alert("取込可能なデータが見つかりませんでした");return;}
        const newVehicles=rows.map((r,i)=>{const c=r.code||r.name.replace(/[\s\-（）()]/g,"").substring(0,5).toUpperCase()||("V"+(i+1));return{id:c,code:c,name:r.name,no:r.no,type:r.type,seats:r.seats,active:true};});
        if(confirm("📋 "+newVehicles.length+"台の車両データを取り込みます。\n\n現在の車両データは上書きされます。\nよろしいですか？")){
          onVehiclesChange(newVehicles);
          alert("✅ "+newVehicles.length+"台を取り込みました");
        }
      }catch(err){alert("❌ ファイル読み込みエラー: "+err.message);}
    };
    if(ext==="xlsx"||ext==="xls")reader.readAsArrayBuffer(file);else reader.readAsText(file,"UTF-8");
    e.target.value="";
  };

  return <div style={{maxWidth:800,margin:"0 auto"}}>
    <div className="flex items-center justify-between mb-3">
      <h3 className="text-base font-bold text-gray-800">車両登録管理</h3>
      <div style={{display:"flex",gap:6}}>
        <button onClick={()=>fileRef.current?.click()} style={{padding:"6px 12px",fontSize:12,fontWeight:600,color:"#059669",background:"#ecfdf5",border:"1px solid #a7f3d0",borderRadius:8,cursor:"pointer"}}>📥 Excel/CSV取込</button>
        <input ref={fileRef} type="file" accept=".xlsx,.xls,.csv,.tsv" onChange={importFromFile} style={{display:"none"}}/>
        <button onClick={()=>{setAddMode(true);setEditId(null);setForm({name:"",no:"",type:"A",seats:5,active:true});}} className="btn-primary">＋ 車両追加</button>
      </div>
    </div>

    {(addMode||editId)&&<div className="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-4">
      <h4 className="font-bold text-sm mb-2 text-blue-800">{editId?"車両を編集":"新規車両登録"}</h4>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr 80px",gap:8}}>
        <div><label className="text-xs text-gray-600">クラス</label><select value={form.type} onChange={e=>setForm({...form,type:e.target.value})} className="input-s">{vehicleClasses.map(c=><option key={c.type} value={c.type}>{c.type}クラス</option>)}</select></div>
        <div><label className="text-xs text-gray-600">車種</label><input value={form.name} onChange={e=>setForm({...form,name:e.target.value})} className="input-s" placeholder="ヴェルファイア"/></div>
        <div><label className="text-xs text-gray-600">ナンバー</label><input value={form.no} onChange={e=>setForm({...form,no:e.target.value})} className="input-s" placeholder="7673"/></div>
        <div><label className="text-xs text-gray-600">定員</label><input type="number" value={form.seats} onChange={e=>setForm({...form,seats:e.target.value})} className="input-s"/></div>
      </div>
      <div style={{marginTop:6}}>
        <label style={{display:"flex",alignItems:"center",gap:6,cursor:"pointer",fontSize:12}}>
          <input type="checkbox" checked={form.active} onChange={e=>setForm({...form,active:e.target.checked})}/>
          <span style={{fontWeight:700,color:form.active?"#059669":"#dc2626"}}>稼働車両</span>
          <span style={{fontSize:10,color:"#94a3b8"}}>(OFFにすると稼働率・成績計算から除外)</span>
        </label>
      </div>
      <div className="flex gap-2 mt-3">
        {editId?<button onClick={save} className="btn-primary">保存</button>:<button onClick={addNew} className="btn-primary">登録</button>}
        <button onClick={()=>{setEditId(null);setAddMode(false);}} className="btn-ghost">キャンセル</button>
      </div>
    </div>}

    {grouped.map(g=><div key={g.type} className="mb-3">
      <div className="flex items-center gap-2 mb-1">
        <span className="text-xs font-bold text-white px-2 py-0.5 rounded" style={{background:"#2563eb"}}>{g.type}</span>
        <span className="text-xs text-gray-600 font-semibold">{g.label}</span>
        <span className="text-xs text-gray-400">({g.items.length}台)</span>
      </div>
      {g.items.length===0?<div className="text-xs text-gray-400 pl-4 mb-2">車両未登録</div>:
      <div className="bg-white rounded-lg border border-gray-200 overflow-hidden mb-2">
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
          <thead><tr style={{background:"#f8fafc"}}><th className="px-3 py-1.5 text-left text-xs font-semibold text-gray-500 border-b">車種</th><th className="px-3 py-1.5 text-left text-xs font-semibold text-gray-500 border-b">ナンバー</th><th className="px-3 py-1.5 text-center text-xs font-semibold text-gray-500 border-b">定員</th><th className="px-3 py-1.5 text-center text-xs font-semibold text-gray-500 border-b">稼働</th><th className="px-3 py-1.5 text-right text-xs font-semibold text-gray-500 border-b">操作</th></tr></thead>
          <tbody>{g.items.map(v=><tr key={v.id} className="border-b border-gray-100 hover:bg-blue-50">
            <td className="px-3 py-1.5 font-semibold">{v.name}</td>
            <td className="px-3 py-1.5 font-mono font-bold" style={{color:"#2563eb"}}>{v.no}</td>
            <td className="px-3 py-1.5 text-center">{v.seats}名</td>
            <td className="px-3 py-1.5 text-center">{v.active!==false?<span style={{color:"#059669",fontWeight:700,fontSize:10}}>●稼働</span>:<span style={{color:"#dc2626",fontWeight:700,fontSize:10}}>○除外</span>}</td>
            <td className="px-3 py-1.5 text-right">
              <button onClick={()=>startEdit(v)} className="text-xs text-blue-600 hover:underline mr-2">編集</button>
              <button onClick={()=>remove(v.id)} className="text-xs text-red-500 hover:underline">削除</button>
            </td>
          </tr>)}</tbody>
        </table>
      </div>}
    </div>)}
    <div className="text-xs text-gray-400 mt-4">合計: {vehicles.length}台（稼働: {vehicles.filter(v=>v.active!==false).length}台）</div>
  </div>;
}

/* ==========================================
   車両タブ（マスター＋整備管理）
   ========================================== */
/* ===== 車輌保守管理台帳 ===== */
function VehicleMaintenanceBook({vehicles}){
  // === 保守データはlocalStorageで管理（車両リストはマスターから生成） ===
  const LS_KEY="tkm_vmt_maint";
  const loadMaint=()=>{try{const s=localStorage.getItem(LS_KEY);return s?JSON.parse(s):{};}catch(e){return{};}};
  const saveMaint=(d)=>{try{localStorage.setItem(LS_KEY,JSON.stringify(d));}catch(e){}};
  const VMT_VERSION="tkm_vmt_v2"; // バージョン変更で旧データ強制クリア
  const[maintData,setMaintData]=useState(()=>{
    // バージョンチェック: 旧データがあればクリアしてブランク初期化
    const ver=localStorage.getItem("tkm_vmt_version")||"";
    if(ver!==VMT_VERSION){
      localStorage.removeItem(LS_KEY);
      localStorage.removeItem("tkm_vmt_data");
      localStorage.setItem("tkm_vmt_version",VMT_VERSION);
      // INIT_VMTからブランク初期化
      if(typeof INIT_VMT!=="undefined"){const m={};INIT_VMT.forEach(r=>{m[r.plate]={inspectionDate:"",oilChangeDate:"",oilChangeKm:0,currentOdo:0,alert:0,odoMonthEnd:{},oilExchange:"",batteryExchange:"",tireExchange:"",tireCost:0,coolant:"",seatClean:"",glassCoat:"",bodyCoat:"",repairs:[{place:"",date:""},{place:"",date:""},{place:"",date:""}]};});saveMaint(m);return m;}
      return {};
    }
    const ls=loadMaint();
    if(!Object.keys(ls).length){
      // INIT_VMTからの初期化
      if(typeof INIT_VMT!=="undefined"){const m={};INIT_VMT.forEach(r=>{m[r.plate]={inspectionDate:r.inspectionDate||"",oilChangeDate:r.oilChangeDate||"",oilChangeKm:r.oilChangeKm||0,currentOdo:r.currentOdo||0,alert:r.alert||0,odoMonthEnd:r.odoMonthEnd||{},oilExchange:r.oilExchange||"",batteryExchange:r.batteryExchange||"",tireExchange:r.tireExchange||"",tireCost:r.tireCost||0,coolant:r.coolant||"",seatClean:r.seatClean||"",glassCoat:r.glassCoat||"",bodyCoat:r.bodyCoat||"",repairs:r.repairs||[{place:"",date:""},{place:"",date:""},{place:"",date:""}]};});saveMaint(m);return m;}
    }
    return ls;
  });
  const persistMaint=(next)=>{setMaintData(next);saveMaint(next);};
  const getMaint=(plate)=>maintData[plate]||{inspectionDate:"",oilChangeDate:"",oilChangeKm:0,currentOdo:0,alert:0,odoMonthEnd:{},oilExchange:"",batteryExchange:"",tireExchange:"",tireCost:0,coolant:"",seatClean:"",glassCoat:"",bodyCoat:"",repairs:[{place:"",date:""},{place:"",date:""},{place:"",date:""}]};
  const updateMaint=(plate,updates)=>{const cur=getMaint(plate);const next={...maintData,[plate]:{...cur,...updates}};persistMaint(next);};

  // 送迎車定義
  const SHUTTLE=[{code:"HIA01",name:"ハイエース①",no:"7062",type:"送迎車"},{code:"HIA02",name:"ハイエース②",no:"1713",type:"送迎車"},{code:"COS01",name:"コースター",no:"2515",type:"送迎車"}];

  // マスター車両＋送迎車 → 表示リスト（常にマスター基準）
  const rows=useMemo(()=>{
    const list=[...(vehicles||[])];
    SHUTTLE.forEach(s=>{if(!list.find(v=>v.no===s.no))list.push(s);});
    return list.map(v=>{const m=getMaint(v.no);return{...v,plate:v.no,classCode:v.type,vehicleCode:v.code?.replace(/\d+$/,"")||v.name,...m};});
  },[vehicles,maintData]);

  const[editPlate,setEditPlate]=useState(null);
  const[editRow,setEditRow]=useState(null);
  const[filterClass,setFilterClass]=useState("all");
  const[search,setSearch]=useState("");

  const classTypes=useMemo(()=>{const s=new Set();rows.forEach(r=>r.classCode&&s.add(r.classCode));return["all",...[...s].sort()];},[rows]);
  const filtered=useMemo(()=>{
    let list=rows;
    if(filterClass!=="all")list=list.filter(r=>r.classCode===filterClass);
    if(search){const s=search.toLowerCase();list=list.filter(r=>(r.code||"").toLowerCase().includes(s)||(r.name||"").toLowerCase().includes(s)||(r.no||"").includes(s));}
    return list;
  },[rows,filterClass,search]);

  const getAlert=(r)=>{
    const alerts=[];const today=new Date();
    if(r.inspectionDate){const d=new Date(r.inspectionDate);const diff=Math.floor((d-today)/(1000*60*60*24));if(diff<0)alerts.push({type:"danger",msg:"車検切れ"});else if(diff<30)alerts.push({type:"warning",msg:"車検残"+diff+"日"});}
    if(r.oilChangeKm&&r.currentOdo){const next=Number(r.oilChangeKm)+5000;const rem=next-Number(r.currentOdo);if(rem<0)alerts.push({type:"danger",msg:"オイル超過"+Math.abs(rem)+"km"});else if(rem<1000)alerts.push({type:"warning",msg:"オイル残"+rem+"km"});}
    return alerts;
  };

  // 編集保存
  const saveRow=()=>{
    if(!editRow||!editPlate)return;
    const{classCode,vehicleCode,plate,code,name,no,type,seats,...maint}=editRow;
    updateMaint(editPlate,maint);
    setEditPlate(null);setEditRow(null);
  };

  // 月末ODO
  const[odoMonth,setOdoMonth]=useState(new Date().toISOString().slice(0,7));
  const[odoInput,setOdoInput]=useState("");
  const[odoPlate,setOdoPlate]=useState(null);
  const saveOdo=()=>{
    if(!odoPlate||!odoInput)return;
    const cur=getMaint(odoPlate);
    updateMaint(odoPlate,{odoMonthEnd:{...cur.odoMonthEnd,[odoMonth]:Number(odoInput)},currentOdo:Number(odoInput)});
    setOdoInput("");setOdoPlate(null);
  };

  const inputSt={padding:"5px 8px",border:"1px solid #d1d5db",borderRadius:6,fontSize:11,width:"100%"};
  const labelSt={fontSize:10,fontWeight:600,color:"#64748b",marginBottom:2,display:"block"};

  // 編集モーダル（車両情報は読取専用、保守データのみ編集）
  const editModal=editRow&&<div style={{position:"fixed",top:0,left:0,right:0,bottom:0,background:"rgba(0,0,0,.5)",zIndex:9999,display:"flex",alignItems:"center",justifyContent:"center",padding:12}} onClick={()=>{setEditPlate(null);setEditRow(null);}}>
    <div style={{background:"#fff",borderRadius:12,maxWidth:700,width:"100%",maxHeight:"90vh",overflow:"auto",padding:20}} onClick={e=>e.stopPropagation()}>
      <div style={{fontSize:16,fontWeight:800,marginBottom:8}}>保守データ編集</div>
      <div style={{fontSize:12,color:"#64748b",marginBottom:16,background:"#f8fafc",padding:"8px 12px",borderRadius:6}}>
        <span style={{fontWeight:700,color:"#1e40af"}}>{editRow.classCode}</span> {editRow.name||editRow.vehicleCode} <span style={{fontWeight:700}}>{editRow.plate}</span>
        <span style={{fontSize:10,color:"#94a3b8",marginLeft:8}}>※車両情報の変更はマスタータブで行ってください</span>
      </div>
      <div style={{fontSize:13,fontWeight:700,marginBottom:8,color:"#1e40af"}}>車検・点検</div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:12}}>
        <div><label style={labelSt}>車検期限</label><input type="date" value={editRow.inspectionDate||""} onChange={e=>setEditRow({...editRow,inspectionDate:e.target.value})} style={inputSt}/></div>
        <div><label style={labelSt}>オイル交換日</label><input type="date" value={editRow.oilChangeDate||""} onChange={e=>setEditRow({...editRow,oilChangeDate:e.target.value})} style={inputSt}/></div>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:12}}>
        <div><label style={labelSt}>オイル交換時km</label><input type="number" value={editRow.oilChangeKm||""} onChange={e=>setEditRow({...editRow,oilChangeKm:Number(e.target.value)})} style={inputSt}/></div>
        <div><label style={labelSt}>現在ODO</label><input type="number" value={editRow.currentOdo||""} onChange={e=>setEditRow({...editRow,currentOdo:Number(e.target.value)})} style={inputSt}/></div>
      </div>
      <div style={{fontSize:13,fontWeight:700,marginBottom:8,color:"#059669"}}>消耗パーツ</div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10,marginBottom:12}}>
        <div><label style={labelSt}>オイル交換実施日</label><input type="date" value={editRow.oilExchange||""} onChange={e=>setEditRow({...editRow,oilExchange:e.target.value})} style={inputSt}/></div>
        <div><label style={labelSt}>バッテリー交換</label><input type="date" value={editRow.batteryExchange||""} onChange={e=>setEditRow({...editRow,batteryExchange:e.target.value})} style={inputSt}/></div>
        <div><label style={labelSt}>タイヤ交換</label><input type="date" value={editRow.tireExchange||""} onChange={e=>setEditRow({...editRow,tireExchange:e.target.value})} style={inputSt}/></div>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:12}}>
        <div><label style={labelSt}>タイヤ料金</label><input type="number" value={editRow.tireCost||""} onChange={e=>setEditRow({...editRow,tireCost:Number(e.target.value)})} style={inputSt}/></div>
        <div><label style={labelSt}>クーラント液</label><input type="date" value={editRow.coolant||""} onChange={e=>setEditRow({...editRow,coolant:e.target.value})} style={inputSt}/></div>
      </div>
      <div style={{fontSize:13,fontWeight:700,marginBottom:8,color:"#7c3aed"}}>メンテナンス</div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10,marginBottom:12}}>
        <div><label style={labelSt}>シート洗浄</label><input type="date" value={editRow.seatClean||""} onChange={e=>setEditRow({...editRow,seatClean:e.target.value})} style={inputSt}/></div>
        <div><label style={labelSt}>ガラスコーティング</label><input type="date" value={editRow.glassCoat||""} onChange={e=>setEditRow({...editRow,glassCoat:e.target.value})} style={inputSt}/></div>
        <div><label style={labelSt}>ボディコーティング</label><input type="date" value={editRow.bodyCoat||""} onChange={e=>setEditRow({...editRow,bodyCoat:e.target.value})} style={inputSt}/></div>
      </div>
      <div style={{fontSize:13,fontWeight:700,marginBottom:8,color:"#ea580c"}}>外装自社修復</div>
      {[0,1,2].map(i=><div key={i} style={{display:"grid",gridTemplateColumns:"2fr 1fr",gap:10,marginBottom:6}}>
        <div><label style={labelSt}>修復箇所{i+1}</label><input value={(editRow.repairs||[])[i]?.place||""} onChange={e=>{const rp=[...(editRow.repairs||[{place:"",date:""},{place:"",date:""},{place:"",date:""}])];rp[i]={...rp[i],place:e.target.value};setEditRow({...editRow,repairs:rp});}} style={inputSt} placeholder="例: 塗装割れ"/></div>
        <div><label style={labelSt}>実施日{i+1}</label><input type="date" value={(editRow.repairs||[])[i]?.date||""} onChange={e=>{const rp=[...(editRow.repairs||[{place:"",date:""},{place:"",date:""},{place:"",date:""}])];rp[i]={...rp[i],date:e.target.value};setEditRow({...editRow,repairs:rp});}} style={inputSt}/></div>
      </div>)}
      <div style={{display:"flex",gap:8,justifyContent:"flex-end",marginTop:16}}>
        <button onClick={()=>{setEditPlate(null);setEditRow(null);}} style={{padding:"8px 16px",fontSize:12,border:"1px solid #d1d5db",borderRadius:6,background:"#fff",cursor:"pointer"}}>キャンセル</button>
        <button onClick={saveRow} style={{padding:"8px 16px",fontSize:12,border:"none",borderRadius:6,background:"#2563eb",color:"#fff",fontWeight:700,cursor:"pointer"}}>保存</button>
      </div>
    </div>
  </div>;

  const odoModal=odoPlate&&<div style={{position:"fixed",top:0,left:0,right:0,bottom:0,background:"rgba(0,0,0,.5)",zIndex:9999,display:"flex",alignItems:"center",justifyContent:"center",padding:12}} onClick={()=>setOdoPlate(null)}>
    <div style={{background:"#fff",borderRadius:12,maxWidth:360,width:"100%",padding:20}} onClick={e=>e.stopPropagation()}>
      <div style={{fontSize:14,fontWeight:800,marginBottom:12}}>月末ODO入力</div>
      <div style={{marginBottom:8}}><label style={labelSt}>対象月</label><input type="month" value={odoMonth} onChange={e=>setOdoMonth(e.target.value)} style={inputSt}/></div>
      <div style={{marginBottom:12}}><label style={labelSt}>ODO値(km)</label><input type="number" value={odoInput} onChange={e=>setOdoInput(e.target.value)} style={inputSt} placeholder="例: 125000"/></div>
      <div style={{display:"flex",gap:8,justifyContent:"flex-end"}}>
        <button onClick={()=>setOdoPlate(null)} style={{padding:"6px 14px",fontSize:12,border:"1px solid #d1d5db",borderRadius:6,background:"#fff",cursor:"pointer"}}>閉じる</button>
        <button onClick={saveOdo} style={{padding:"6px 14px",fontSize:12,border:"none",borderRadius:6,background:"#2563eb",color:"#fff",fontWeight:700,cursor:"pointer"}}>保存</button>
      </div>
    </div>
  </div>;

  const allAlerts=filtered.flatMap(r=>getAlert(r).map(a=>({...a,vehicle:(r.name||r.code||"")+" "+r.no})));
  const dangerCount=allAlerts.filter(a=>a.type==="danger").length;
  const warnCount=allAlerts.filter(a=>a.type==="warning").length;

  return <div>
    {editModal}{odoModal}
    <div style={{display:"flex",gap:8,flexWrap:"wrap",marginBottom:12}}>
      <div style={{flex:"1 1 130px",background:"linear-gradient(135deg,#2563eb,#1d4ed8)",borderRadius:10,padding:"12px 16px",color:"#fff"}}>
        <div style={{fontSize:10,opacity:0.8}}>管理台数（マスター連動）</div>
        <div style={{fontSize:24,fontWeight:800}}>{rows.length}<span style={{fontSize:11,fontWeight:400,marginLeft:4}}>台</span></div>
      </div>
      {dangerCount>0&&<div style={{flex:"1 1 130px",background:"linear-gradient(135deg,#ef4444,#dc2626)",borderRadius:10,padding:"12px 16px",color:"#fff"}}>
        <div style={{fontSize:10,opacity:0.8}}>要対応</div>
        <div style={{fontSize:24,fontWeight:800}}>{dangerCount}<span style={{fontSize:11,fontWeight:400,marginLeft:4}}>件</span></div>
      </div>}
      {warnCount>0&&<div style={{flex:"1 1 130px",background:"linear-gradient(135deg,#f59e0b,#d97706)",borderRadius:10,padding:"12px 16px",color:"#fff"}}>
        <div style={{fontSize:10,opacity:0.8}}>注意</div>
        <div style={{fontSize:24,fontWeight:800}}>{warnCount}<span style={{fontSize:11,fontWeight:400,marginLeft:4}}>件</span></div>
      </div>}
    </div>
    {allAlerts.length>0&&<div style={{background:"#fef2f2",border:"1px solid #fecaca",borderRadius:8,padding:10,marginBottom:12}}>
      <div style={{fontSize:12,fontWeight:700,color:"#991b1b",marginBottom:6}}>⚠️ アラート</div>
      {allAlerts.slice(0,10).map((a,i)=><div key={i} style={{fontSize:11,color:a.type==="danger"?"#dc2626":"#d97706",padding:"2px 0"}}><span style={{fontWeight:700}}>{a.vehicle}</span>: {a.msg}</div>)}
    </div>}
    <div style={{display:"flex",gap:6,marginBottom:10,alignItems:"center",flexWrap:"wrap"}}>
      <input value={search} onChange={e=>setSearch(e.target.value)} placeholder="車両名・ナンバーで検索" style={{flex:1,minWidth:140,padding:"6px 10px",border:"1px solid #d1d5db",borderRadius:6,fontSize:11}}/>
      <select value={filterClass} onChange={e=>setFilterClass(e.target.value)} style={{padding:"6px 8px",border:"1px solid #d1d5db",borderRadius:6,fontSize:11}}>
        {classTypes.map(c=><option key={c} value={c}>{c==="all"?"全クラス":c+"クラス"}</option>)}
      </select>
      <span style={{fontSize:10,color:"#64748b"}}>{filtered.length}台</span>
    </div>
    <div style={{overflowX:"auto"}}>
      <table style={{width:"100%",fontSize:10,borderCollapse:"collapse",minWidth:900}}>
        <thead><tr style={{background:"#f1f5f9"}}>
          {["クラス","車両","No.","車検","オイル交換","ODO","アラート","消耗パーツ","メンテ","修復",""].map((h,i)=>
            <th key={i} style={{padding:"6px 6px",textAlign:"left",fontWeight:600,fontSize:9,borderBottom:"2px solid #e2e8f0",whiteSpace:"nowrap"}}>{h}</th>
          )}
        </tr></thead>
        <tbody>{filtered.map(r=>{
          const alerts=getAlert(r);
          const hasRepairs=(r.repairs||[]).some(rp=>rp.place);
          const rowBg=alerts.some(a=>a.type==="danger")?"#fef2f2":alerts.some(a=>a.type==="warning")?"#fffbeb":"#fff";
          return <tr key={r.no} style={{background:rowBg,borderBottom:"1px solid #f1f5f9"}}>
            <td style={{padding:"5px 6px",fontWeight:700,color:"#1e40af"}}>{r.type}</td>
            <td style={{padding:"5px 6px",fontWeight:700,fontSize:9}}>{r.name||r.code}</td>
            <td style={{padding:"5px 6px"}}>{r.no}</td>
            <td style={{padding:"5px 6px",fontSize:9}}>{r.inspectionDate||"-"}</td>
            <td style={{padding:"5px 6px",fontSize:9}}>
              <div>{r.oilChangeDate||"-"}</div>
              {r.oilChangeKm>0&&<div style={{color:"#64748b"}}>{r.oilChangeKm.toLocaleString()}km</div>}
            </td>
            <td style={{padding:"5px 6px"}}>
              <div style={{fontWeight:600}}>{r.currentOdo?r.currentOdo.toLocaleString():"-"}</div>
              <button onClick={()=>{setOdoPlate(r.no);setOdoInput("");}} style={{fontSize:8,padding:"1px 4px",border:"1px solid #d1d5db",borderRadius:3,background:"#fff",cursor:"pointer",marginTop:2}}>入力</button>
            </td>
            <td style={{padding:"5px 6px"}}>
              {alerts.map((a,i)=><div key={i} style={{fontSize:8,color:a.type==="danger"?"#dc2626":"#d97706",fontWeight:600}}>{a.msg}</div>)}
              {alerts.length===0&&<span style={{color:"#86efac",fontSize:9}}>✓</span>}
            </td>
            <td style={{padding:"5px 6px",fontSize:8}}>
              {r.oilExchange&&<div>油:{r.oilExchange.slice(5)}</div>}
              {r.batteryExchange&&<div>電:{(r.batteryExchange||"").slice(0,10)}</div>}
              {r.tireExchange&&<div>タ:{r.tireExchange.slice(5)}{r.tireCost>0?" ¥"+r.tireCost.toLocaleString():""}</div>}
              {r.coolant&&<div>冷:{r.coolant.slice(5)}</div>}
              {!r.oilExchange&&!r.batteryExchange&&!r.tireExchange&&!r.coolant&&"-"}
            </td>
            <td style={{padding:"5px 6px",fontSize:8}}>
              {r.seatClean&&<div>席:{r.seatClean.slice(5)}</div>}
              {r.glassCoat&&<div>硝:{r.glassCoat.slice(5)}</div>}
              {r.bodyCoat&&<div>体:{r.bodyCoat.slice(5)}</div>}
              {!r.seatClean&&!r.glassCoat&&!r.bodyCoat&&"-"}
            </td>
            <td style={{padding:"5px 6px",fontSize:8}}>
              {hasRepairs?(r.repairs||[]).filter(rp=>rp.place).map((rp,i)=><div key={i}>{rp.place}{rp.date?" "+rp.date.slice(5):""}</div>):"-"}
            </td>
            <td style={{padding:"5px 6px"}}>
              <button onClick={()=>{setEditRow({...r});setEditPlate(r.no);}} style={{fontSize:9,padding:"3px 8px",border:"1px solid #93c5fd",borderRadius:4,background:"#eff6ff",color:"#1d4ed8",cursor:"pointer"}}>編集</button>
            </td>
          </tr>;
        })}
        </tbody>
      </table>
      {filtered.length===0&&<div style={{textAlign:"center",padding:24,color:"#94a3b8",fontSize:12}}>車両マスターにデータがありません</div>}
    </div>
  </div>;
}

/* ==========================================
   車両稼働管理 — 配車表メンテ＋整備管理＋保守台帳 を統合
   ========================================== */
function VehicleFleetStatus({vehicles,vehicleClasses,maintenance,data,fleet,hmCars,hmCarData}){
  var E=React.createElement;
  var today=new Date().toISOString().slice(0,10);
  var _dt=useState(today);var viewDate=_dt[0];var setViewDate=_dt[1];
  var _sel=useState(null);var selCode=_sel[0];var setSelCode=_sel[1];
  var _filter=useState("all");var statusFilter=_filter[0];var setStatusFilter=_filter[1];
  // norm() はグローバル定義(L1060)を使用

  // ★ 定期ポーリング: localStorageの変更を2秒ごとに検出（配車表⇔整備管理の連動用）
  var _tick=useState(0);var tick=_tick[0];var setTick=_tick[1];
  useEffect(function(){
    var id=setInterval(function(){setTick(function(t){return t+1;});},2000);
    return function(){clearInterval(id);};
  },[]);

  // ★ メンテナンスデータ: localStorage（権威）+ props をマージ
  var mergedMaint=useMemo(function(){
    var propM=maintenance||[];
    var lsM=[];try{lsM=JSON.parse(localStorage.getItem("tkm_maintenance")||"[]");}catch(e){}
    if(!propM.length&&!lsM.length)return[];
    if(!lsM.length)return propM;
    if(!propM.length)return lsM;
    // props(Supabase経由)優先 — LSはpropsにないIDのフォールバック
    var idSet=new Set();var result=[];
    propM.forEach(function(m){if(m&&m.id&&!idSet.has(m.id)){idSet.add(m.id);result.push(m);}});
    lsM.forEach(function(m){if(m&&m.id&&!idSet.has(m.id)){idSet.add(m.id);result.push(m);}});
    return result;
  },[maintenance,tick]);

  // ★ HM車両データ: localStorage（権威）+ props をマージ
  var mergedHmCars=useMemo(function(){
    var propC=hmCars||[];
    var lsC=[];try{lsC=JSON.parse(localStorage.getItem("tkm_hm_cars")||"[]");}catch(e){}
    if(!propC.length&&!lsC.length)return[];
    if(!lsC.length)return propC;
    if(!propC.length)return lsC;
    // props(Supabase経由)優先 — LSはpropsにないIDのフォールバック
    var idSet=new Set();var result=[];
    propC.forEach(function(c){if(c&&c.id&&!idSet.has(c.id)){idSet.add(c.id);result.push(c);}});
    lsC.forEach(function(c){if(c&&c.id&&!idSet.has(c.id)){idSet.add(c.id);result.push(c);}});
    return result;
  },[hmCars,tick]);

  // 保守台帳データ（localStorageから直接読み込み）
  var vmtData=useMemo(function(){
    try{var s=localStorage.getItem("tkm_vmt_maint");return s?JSON.parse(s):{};}catch(e){return{};}
  },[tick]);

  // 各車両のステータスを計算
  var vehicleStatuses=useMemo(function(){
    var result=[];
    var vd=viewDate;
    var maints=mergedMaint;
    var resData=data||[];
    var fl=fleet||{};
    var hCars=mergedHmCars;
    var hData=hmCarData||[];

    (vehicles||[]).forEach(function(v){
      if(!v||!v.code)return;

      // ① 配車表メンテナンスブロック（終了日が基準日以降なら未稼働扱い＝予定含む）
      var activeMaint=null;
      var allMaints=[];
      maints.forEach(function(m){
        if(m.vehicleCode!==v.code)return;
        allMaints.push(m);
        if(norm(m.endDate)>=vd)activeMaint=m;
      });

      // ② HM整備管理のステータス
      var hmCar=null;
      hCars.forEach(function(c){if(c&&(c.id===v.code||(c.plate||"")===v.no||(c.name||"")===v.name))hmCar=c;});
      var hmStatus=hmCar?(hmCar.status||"active"):"active";

      // ③ 保守台帳データ
      var vmt=vmtData[v.no]||null;

      // ④ 本日の予約
      var todayRes=[];
      resData.forEach(function(r){if(r.status==="cancelled")return;if(fl[r.id]===v.code&&norm(r.lendDate)<=vd&&norm(r.returnDate)>=vd)todayRes.push(r);});

      // ⑤ 保険・走行距離（HM carData）
      var insVal=0,odo=0;
      if(hmCar){
        hData.forEach(function(d){
          if(!d||d.car_id!==hmCar.id)return;
          if(d.type==="insurance")insVal=Number(d.value||0);
          if(d.type==="mileage"){var km=Number(d.value||0);if(km>odo)odo=km;}
        });
      }
      // 保守台帳の走行距離フォールバック
      if(!odo&&vmt&&vmt.currentOdo)odo=Number(vmt.currentOdo||0);

      // ⑥ ステータス判定（整備管理 tkm_cars.status が権威）
      var status="active",statusLabel="稼働可";
      var statusColor="#15803d",statusBg="#f0fdf4",statusBorder="#86efac";
      // 整備管理のステータスを最優先
      if(hmStatus==="repair"){
        status="repair";statusLabel="修理中";
        statusColor="#991b1b";statusBg="#fee2e2";statusBorder="#fca5a5";
      }else if(hmStatus==="waiting"){
        status="waiting";statusLabel="修理待機";
        statusColor="#92400e";statusBg="#fef3c7";statusBorder="#fde68a";
      }else if(hmStatus==="estimating"){
        status="estimating";statusLabel="見積中";
        statusColor="#1e40af";statusBg="#dbeafe";statusBorder="#93c5fd";
      }
      // ※ tkm_maintenanceのメンテブロックはステータス判定に使用しない（tkm_cars.statusが権威）
      var isRented=todayRes.length>0;
      result.push({v:v,status:status,sl:statusLabel,sc:statusColor,sb:statusBg,sbo:statusBorder,am:activeMaint,aml:allMaints,tr:todayRes,rent:isRented,hc:hmCar,hs:hmStatus,ins:insVal,odo:odo,vmt:vmt});
    });
    return result;
  },[vehicles,mergedMaint,data,fleet,mergedHmCars,hmCarData,viewDate,vmtData]);

  // 集計
  var total=vehicleStatuses.length;
  var activeN=0,maintN=0,repairN=0,rentN=0;
  vehicleStatuses.forEach(function(s){
    if(s.status==="active")activeN++;
    else if(s.status==="maintenance")maintN++;
    else repairN++;
    if(s.rent)rentN++;
  });
  var inactiveN=maintN+repairN;
  var idleN=activeN-rentN;if(idleN<0)idleN=0;

  // クラス別
  var clsMap={};
  (vehicleClasses||[]).forEach(function(vc){clsMap[vc.type]={l:vc.label,t:0,a:0,m:0,r:0};});
  vehicleStatuses.forEach(function(s){
    var tp=s.v.type;if(!clsMap[tp])clsMap[tp]={l:tp,t:0,a:0,m:0,r:0};
    clsMap[tp].t++;
    if(s.status==="active")clsMap[tp].a++;else clsMap[tp].m++;
    if(s.rent)clsMap[tp].r++;
  });
  var clsArr=Object.keys(clsMap).filter(function(k){return clsMap[k].t>0}).map(function(k){return{type:k,l:clsMap[k].l,t:clsMap[k].t,a:clsMap[k].a,m:clsMap[k].m,r:clsMap[k].r};});

  // フィルタリング
  var filtered=vehicleStatuses.filter(function(s){
    if(statusFilter==="all")return true;
    if(statusFilter==="inactive")return s.status!=="active";
    if(statusFilter==="rented")return s.rent;
    if(statusFilter==="idle")return s.status==="active"&&!s.rent;
    return s.status===statusFilter;
  });

  // カード
  var card=function(bg,border,fg,val,label,fid,isA){
    return E("div",{onClick:function(){setStatusFilter(fid)},style:{background:isA?fg:bg,border:"1px solid "+border,borderRadius:8,padding:"10px 14px",textAlign:"center",cursor:"pointer",minWidth:80}},
      E("div",{style:{fontSize:24,fontWeight:800,color:isA?"#fff":fg}},val),
      E("div",{style:{fontSize:10,color:isA?"#ffffffcc":fg,marginTop:2,fontWeight:600}},label)
    );
  };

  // デバッグ（hooksは条件分岐returnの前に配置する必要あり）
  var _showDbg=useState(false);var showDbg=_showDbg[0];var setShowDbg=_showDbg[1];
  var dbgInfo=useMemo(function(){
    var propM=maintenance||[];
    var lsRaw="";try{lsRaw=localStorage.getItem("tkm_maintenance")||"";}catch(e){}
    var lsM=[];try{lsM=lsRaw?JSON.parse(lsRaw):[];}catch(e){}
    var vcodes=(vehicles||[]).slice(0,5).map(function(v){return v.code});
    var hmActive=mergedHmCars.filter(function(c){return c&&c.status&&c.status!=="active"}).map(function(c){return c.id+":"+c.status});
    return{propLen:propM.length,lsLen:lsM.length,mergedLen:mergedMaint.length,
      propSample:propM.slice(0,3).map(function(m){return(m.vehicleCode||"?")+"("+norm(m.startDate)+"~"+norm(m.endDate)+")"}).join(", "),
      lsSample:lsM.slice(0,3).map(function(m){return(m.vehicleCode||"?")+"("+norm(m.startDate)+"~"+norm(m.endDate)+")"}).join(", "),
      vcodes:vcodes.join(","),vd:viewDate,hmProp:(hmCars||[]).length,hmMerged:mergedHmCars.length,hmNonActive:hmActive.join(", ")||"なし",
      activeCount:vehicleStatuses.filter(function(s){return s.status!=="active"}).length};
  },[maintenance,mergedMaint,mergedHmCars,vehicles,viewDate,vehicleStatuses]);

  // 詳細ビュー
  if(selCode){
    var sv=vehicleStatuses.find(function(s){return s.v.code===selCode});
    if(!sv){setSelCode(null);return null;}
    return E("div",{style:{maxWidth:700,margin:"0 auto"}},
      E("div",{style:{display:"flex",alignItems:"center",gap:10,marginBottom:14,flexWrap:"wrap"}},
        E("button",{onClick:function(){setSelCode(null)},style:{padding:"6px 14px",fontSize:12,background:"#f1f5f9",border:"none",borderRadius:6,cursor:"pointer",fontWeight:600,color:"#475569"}},"← 一覧"),
        E("span",{style:{fontSize:18,fontWeight:800}},sv.v.name),
        E("span",{style:{fontSize:13,color:"#64748b"}},sv.v.no),
        E("span",{style:{fontSize:11,padding:"3px 10px",borderRadius:6,background:sv.sb,color:sv.sc,fontWeight:700,border:"1px solid "+sv.sbo}},sv.sl)
      ),
      E("div",{style:{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(120px,1fr))",gap:8,marginBottom:14}},
        E("div",{style:{background:"#f8fafc",border:"1px solid #e2e8f0",borderRadius:8,padding:10,textAlign:"center"}},E("div",{style:{fontSize:10,color:"#64748b"}},"クラス"),E("div",{style:{fontSize:14,fontWeight:700}},sv.v.type)),
        E("div",{style:{background:"#f8fafc",border:"1px solid #e2e8f0",borderRadius:8,padding:10,textAlign:"center"}},E("div",{style:{fontSize:10,color:"#64748b"}},"走行距離"),E("div",{style:{fontSize:14,fontWeight:700}},sv.odo?sv.odo.toLocaleString()+"km":"未記録")),
        E("div",{style:{background:"#f8fafc",border:"1px solid #e2e8f0",borderRadius:8,padding:10,textAlign:"center"}},E("div",{style:{fontSize:10,color:"#64748b"}},"保険(月額)"),E("div",{style:{fontSize:14,fontWeight:700}},sv.ins?"¥"+sv.ins.toLocaleString():"未設定")),
        E("div",{style:{background:"#f8fafc",border:"1px solid #e2e8f0",borderRadius:8,padding:10,textAlign:"center"}},E("div",{style:{fontSize:10,color:"#64748b"}},"HMステータス"),E("div",{style:{fontSize:14,fontWeight:700}},sv.hs==="repair"?"修理中":sv.hs==="waiting"?"待機":sv.hs==="estimating"?"見積":"稼働"))
      ),
      sv.am?E("div",{style:{background:"#fee2e2",border:"1px solid #fca5a5",borderRadius:8,padding:12,marginBottom:10}},
        E("div",{style:{fontSize:13,fontWeight:700,color:"#991b1b"}},"🔧 配車表メンテナンス"),
        E("div",{style:{fontSize:12,color:"#991b1b"}},(sv.am.label||"")+" "+norm(sv.am.startDate)+"〜"+norm(sv.am.endDate))
      ):null,
      sv.aml.length>0?E("div",{style:{background:"#fef3c7",border:"1px solid #fde68a",borderRadius:8,padding:12,marginBottom:10}},
        E("div",{style:{fontSize:13,fontWeight:700,color:"#92400e",marginBottom:4}},"📅 メンテナンス予定 ("+sv.aml.length+"件)"),
        sv.aml.map(function(m,i){return E("div",{key:i,style:{fontSize:11,padding:"3px 0"}},(m.label||"")+" "+norm(m.startDate)+"〜"+norm(m.endDate));})
      ):null,
      sv.tr.length>0?E("div",{style:{background:"#eff6ff",border:"1px solid #93c5fd",borderRadius:8,padding:12,marginBottom:10}},
        E("div",{style:{fontSize:13,fontWeight:700,color:"#1e40af",marginBottom:4}},"📋 当日予約 ("+sv.tr.length+"件)"),
        sv.tr.map(function(r,i){return E("div",{key:i,style:{fontSize:11,padding:"3px 0"}},(r.name||"不明")+" "+norm(r.lendDate)+"〜"+norm(r.returnDate));})
      ):null,
      sv.vmt?E("div",{style:{background:"#f0fdf4",border:"1px solid #86efac",borderRadius:8,padding:12}},
        E("div",{style:{fontSize:13,fontWeight:700,color:"#15803d",marginBottom:4}},"📋 保守台帳"),
        E("div",{style:{fontSize:11,color:"#475569",display:"grid",gridTemplateColumns:"1fr 1fr",gap:4}},
          sv.vmt.inspectionDate?E("span",null,"車検: "+sv.vmt.inspectionDate):null,
          sv.vmt.oilChangeDate?E("span",null,"オイル交換: "+sv.vmt.oilChangeDate):null,
          sv.vmt.oilExchange?E("span",null,"オイル: "+sv.vmt.oilExchange):null,
          sv.vmt.batteryExchange?E("span",null,"バッテリー: "+sv.vmt.batteryExchange):null,
          sv.vmt.tireExchange?E("span",null,"タイヤ: "+sv.vmt.tireExchange):null,
          sv.vmt.coolant?E("span",null,"クーラント: "+sv.vmt.coolant):null
        )
      ):null
    );
  }

  // メインビュー
  return E("div",{style:{maxWidth:1100,margin:"0 auto"}},
    E("div",{style:{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14,flexWrap:"wrap",gap:8}},
      E("div",{style:{fontSize:16,fontWeight:800}},"車両稼働管理"),
      E("div",{style:{display:"flex",alignItems:"center",gap:8}},
        E("span",{style:{fontSize:11,color:"#64748b"}},"基準日:"),
        E("input",{type:"date",value:viewDate,onChange:function(e){setViewDate(e.target.value)},style:{fontSize:12,padding:"4px 8px",border:"1px solid #cbd5e1",borderRadius:6}}),
        viewDate!==today?E("button",{onClick:function(){setViewDate(today)},style:{fontSize:11,padding:"4px 10px",background:"#2563eb",color:"#fff",border:"none",borderRadius:6,cursor:"pointer"}},"今日"):null,
        E("button",{onClick:function(){setShowDbg(!showDbg)},style:{fontSize:9,padding:"3px 8px",background:showDbg?"#fbbf24":"#e2e8f0",border:"none",borderRadius:4,cursor:"pointer",color:"#475569"}},showDbg?"診断OFF":"診断")
      )
    ),
    showDbg?E("div",{style:{background:"#fef3c7",border:"1px solid #fde68a",borderRadius:8,padding:10,marginBottom:10,fontSize:10,color:"#92400e",lineHeight:1.6}},
      E("div",null,"📊 props.maint: "+dbgInfo.propLen+"件 → "+dbgInfo.propSample),
      E("div",null,"📦 localStorage: "+dbgInfo.lsLen+"件 → "+dbgInfo.lsSample),
      E("div",null,"🔀 merged: "+dbgInfo.mergedLen+"件 | 基準日: "+dbgInfo.vd),
      E("div",null,"🚗 vehicles codes(先頭5): "+dbgInfo.vcodes),
      E("div",null,"🔧 HM車両: props="+dbgInfo.hmProp+"台 merged="+dbgInfo.hmMerged+"台 | 非稼働: "+dbgInfo.hmNonActive),
      E("div",null,"❌ 未稼働判定: "+dbgInfo.activeCount+"台")
    ):null,
    E("div",{style:{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(100px,1fr))",gap:8,marginBottom:14}},
      card("#f8fafc","#e2e8f0","#1e293b",total,"運用総台数","all",statusFilter==="all"),
      card("#f0fdf4","#86efac","#15803d",activeN,"稼働可","active",statusFilter==="active"),
      card("#eff6ff","#93c5fd","#1e40af",rentN,"貸出中","rented",statusFilter==="rented"),
      card("#f8fafc","#e2e8f0","#64748b",idleN,"空車","idle",statusFilter==="idle"),
      card("#fee2e2","#fca5a5","#991b1b",inactiveN,"未稼働","inactive",statusFilter==="inactive")
    ),
    E("div",{style:{background:"#f8fafc",border:"1px solid #e2e8f0",borderRadius:8,padding:12,marginBottom:14}},
      E("div",{style:{fontSize:12,fontWeight:700,marginBottom:8}},"クラス別台数"),
      E("div",{style:{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(170px,1fr))",gap:6}},
        clsArr.map(function(c){return E("div",{key:c.type,style:{background:"#fff",border:"1px solid #e2e8f0",borderRadius:6,padding:8,fontSize:11}},
          E("div",{style:{fontWeight:700,marginBottom:4}},c.type+"クラス"),
          E("div",{style:{display:"flex",gap:8,color:"#475569"}},
            E("span",null,"計:"+c.t),E("span",{style:{color:"#15803d"}},"稼働:"+c.a),
            c.m>0?E("span",{style:{color:"#991b1b"}},"停止:"+c.m):null,
            E("span",{style:{color:"#1e40af"}},"貸出:"+c.r)
          )
        );})
      )
    ),
    E("div",{style:{fontSize:12,fontWeight:600,color:"#475569",marginBottom:6}},"表示: "+filtered.length+"台"+(statusFilter!=="all"?" (フィルタ中)":"")),
    E("div",{style:{display:"grid",gap:6}},
      filtered.map(function(s){
        return E("div",{key:s.v.id,onClick:function(){setSelCode(s.v.code)},style:{
          background:"#fff",border:"1px solid "+(s.status!=="active"?s.sbo:"#e2e8f0"),
          borderRadius:8,padding:"10px 14px",cursor:"pointer",display:"flex",alignItems:"center",gap:12,
          borderLeft:"4px solid "+s.sc
        }},
          E("div",{style:{minWidth:150}},E("div",{style:{fontWeight:700,fontSize:13}},s.v.name),E("div",{style:{fontSize:11,color:"#64748b"}},s.v.no+" / "+s.v.type+"クラス")),
          E("div",{style:{minWidth:90}},E("span",{style:{fontSize:10,padding:"3px 10px",borderRadius:6,background:s.sb,color:s.sc,fontWeight:700,border:"1px solid "+s.sbo}},s.sl)),
          E("div",{style:{flex:1,fontSize:11,color:"#475569"}},
            s.rent?E("span",{style:{color:"#1e40af",fontWeight:600}},"📋 貸出中"):s.status==="active"?E("span",{style:{color:"#15803d"}},"空車"):null,
            s.am?E("span",{style:{color:"#991b1b",marginLeft:8,fontWeight:600}},"🔧 "+(s.am.label||"メンテ")+"〜"+norm(s.am.endDate)):null,
            s.aml.length>0&&!s.am?E("span",{style:{color:"#92400e",marginLeft:8}},"📅 予定"+s.aml.length+"件"):null
          ),
          E("div",{style:{fontSize:11,color:"#64748b",minWidth:70,textAlign:"right"}},s.odo?s.odo.toLocaleString()+"km":""),
          E("div",{style:{fontSize:12,color:"#cbd5e1"}},"›")
        );
      }),
      filtered.length===0?E("div",{style:{textAlign:"center",color:"#94a3b8",padding:40,fontSize:13}},"該当車両なし"):null
    )
  );
}

// エラーバウンダリ for VehicleFleetStatus
class VFSErrorBoundary extends React.Component{
  constructor(p){super(p);this.state={hasError:false,error:null};}
  static getDerivedStateFromError(e){return{hasError:true,error:e};}
  componentDidCatch(e,info){console.error("[VehicleFleetStatus ERROR]",e,info);}
  render(){if(this.state.hasError){return React.createElement("div",{style:{padding:20,background:"#fee2e2",border:"2px solid #dc2626",borderRadius:8,margin:10}},
    React.createElement("div",{style:{fontSize:14,fontWeight:700,color:"#991b1b"}},"⚠️ 稼働管理コンポーネントでエラーが発生"),
    React.createElement("pre",{style:{fontSize:11,color:"#991b1b",whiteSpace:"pre-wrap",marginTop:8}},String(this.state.error))
  );}return this.props.children;}
}

function VehicleTab(props){
  var _subTab=useState("status");
  var subTab=_subTab[0];
  var setSubTab=_subTab[1];
  var tabBtn=function(id,label,badge){return React.createElement("button",{onClick:function(){setSubTab(id);},style:{padding:"8px 12px",fontSize:13,fontWeight:subTab===id?700:500,color:subTab===id?"#2563eb":"#64748b",background:"none",border:"none",cursor:"pointer",borderBottom:subTab===id?"2px solid #2563eb":"none",position:"relative"}},label,badge?React.createElement("span",{style:{fontSize:9,marginLeft:4,padding:"1px 5px",borderRadius:8,background:"#dc2626",color:"#fff",fontWeight:700}},badge):null)};

  var maintCount=(props.maintenance||[]).length;

  return React.createElement("div",null,
    React.createElement("div",{style:{display:"flex",gap:8,marginBottom:12,borderBottom:"1px solid #e2e8f0",paddingBottom:8}},
      tabBtn("status","稼働管理",maintCount>0?maintCount:null),
      tabBtn("master","マスター"),
      tabBtn("fleet","整備管理"),
      tabBtn("maintenance","保守台帳")
    ),
    subTab==="status"&&React.createElement(VFSErrorBoundary,null,React.createElement(VehicleFleetStatus,{vehicles:props.vehicles||[],vehicleClasses:props.vehicleClasses||[],maintenance:props.maintenance||[],data:props.data||[],fleet:props.fleet||{},hmCars:props.hmCars||[],hmCarData:props.hmCarData||[]})),
    subTab==="master"&&React.createElement(VehicleManager,{vehicles:props.vehicles||[],onVehiclesChange:props.onVehiclesChange,vehicleClasses:props.vehicleClasses||[],onDeleteVehicle:props.onDeleteVehicle}),
    subTab==="fleet"&&React.createElement(FleetManager,{cars:props.hmCars||[],carData:props.hmCarData||[],logs:props.hmLogs||[],classes:props.hmClasses||[],hmReload:props.hmReload,maintenance:props.maintenance||[],onMaintenanceChange:props.onMaintenanceChange}),
    subTab==="maintenance"&&React.createElement(VehicleMaintenanceBook,{vehicles:props.vehicles||[]})
  );
}

/* ==========================================
   BUDDICA 整備管理（5機能＋コスト集計）
   ========================================== */
function FleetManager(p){
  var E=React.createElement;
  var _v=useState("list");var view=_v[0];var setView=_v[1];
  var _sel=useState(null);var selCar=_sel[0];var setSelCar=_sel[1];
  var _mi=useState("");var miIn=_mi[0];var setMiIn=_mi[1];
  var _oi=useState("");var oiIn=_oi[0];var setOiIn=_oi[1];
  var _iv=useState("");var ivIn=_iv[0];var setIvIn=_iv[1];
  var _ins=useState(null);var insIn=_ins[0];var setInsIn=_ins[1];
  var _sav=useState(false);var busy=_sav[0];var setBusy=_sav[1];
  // 整備記録入力用
  var _ld=useState(new Date().toISOString().slice(0,10));var logDate=_ld[0];var setLogDate=_ld[1];
  var _lc=useState("");var logCost=_lc[0];var setLogCost=_lc[1];
  var _ldesc=useState("");var logDesc=_ldesc[0];var setLogDesc=_ldesc[1];
  var _lcat=useState("oil");var logCat=_lcat[0];var setLogCat=_lcat[1];
  var _ledit=useState(null);var editLogId=_ledit[0];var setEditLogId=_ledit[1];
  var COST_CATS=[{v:"inspection",l:"車検"},{v:"semi_annual",l:"半年点検"},{v:"repair",l:"修理"},{v:"oil",l:"オイル交換"},{v:"other",l:"その他"}];
  var catLabel=function(v){var f=COST_CATS.filter(function(c){return c.v===v});return f.length?f[0].l:v||""}
  // 集計期間選択
  var _yr=useState(new Date().getFullYear());var filterYear=_yr[0];var setFilterYear=_yr[1];

  var cars=p.cars||[];var carData=p.carData||[];var logs=p.logs||[];
  var today=new Date().toISOString().slice(0,10);
  // メンテナンスブロックから車両ステータスを取得（稼働管理と連動）
  var maintBlocks=p.maintenance||[];
  var getMaintStatus=function(carId){
    var active=null;
    maintBlocks.forEach(function(m){if(m&&(m.vehicleCode===carId)&&norm(m.endDate)>=today)active=m;});
    return active;
  };
  var getEffectiveStatus=function(c){
    // tkm_cars.statusのみが権威（メンテブロック参照しない）
    var st=c.status||"active";
    if(st==="repair")return "修理中";
    if(st==="waiting")return "修理待機中";
    if(st==="estimating")return "見積中";
    return "稼働中";
  };
  var getEffectiveStatusKey=function(c){
    // tkm_cars.statusのみが権威（メンテブロック参照しない）
    return c.status||"active";
  };

  // ★ マウント時にhmReloadして最新データを取得（配車表からの変更を反映）
  useEffect(function(){if(p.hmReload)p.hmReload().catch(function(){});},[]);

  // 保存通知用（画面中央にポップアップ）
  var _msg=useState("");var saveMsg=_msg[0];var setSaveMsg=_msg[1];
  var showMsg=function(text,isErr){setSaveMsg(text);setTimeout(function(){setSaveMsg("")},isErr?6000:2500)};
  var save=function(fn){setBusy(true);return Promise.resolve().then(function(){return fn()}).then(function(){if(p.hmReload)return p.hmReload()}).then(function(){showMsg("登録完了",false)}).catch(function(e){console.error("HM save:",e);showMsg("保存エラー: "+String(e&&e.message||e),true)}).finally(function(){setBusy(false)})};

  // --- ヘルパー ---
  var sortDesc=function(arr){return arr.slice().sort(function(a,b){var d=(b.date||"").localeCompare(a.date||"");if(d!==0)return d;return(b.created_at||"").localeCompare(a.created_at||"")})};
  var cdFilter=function(carId,type){return(carData).filter(function(d){return d&&d.car_id===carId&&d.type===type})};
  var latestCD=function(carId,type){var items=sortDesc(cdFilter(carId,type));return items.length?items[0]:null};
  var getMileage=function(cid){var items=cdFilter(cid,"mileage");if(!items.length)return 0;var max=0;items.forEach(function(d){var km=Number(d.value||0);if(km>max)max=km;});return max};
  // オイル交換間隔は全車両共通（car_id="__global__"に保存）
  var getOilInterval=function(){var items=(carData).filter(function(d){return d&&d.car_id==="__global__"&&d.type==="oil_interval"});if(!items.length)return 5000;var sorted=sortDesc(items);return Number(sorted[0].value||0)||5000};
  var getLastOil=function(cid){return latestCD(cid,"oil_change")};
  var getNextOil=function(cid){var last=getLastOil(cid);var iv=getOilInterval();return last?Number(last.value||0)+iv:iv};
  var getInsurance=function(cid){var m=latestCD(cid,"insurance");return m?Number(m.value||0):0};
  var totalInsurance=function(){var t=0;cars.forEach(function(c){t+=getInsurance(c.id)});return t};
  var carLogs=function(cid){return(logs).filter(function(l){return l&&l.car_id===cid})};

  // 月別集計: {YYYY-MM: amount}
  var monthlyCost=function(logArr){var m={};(logArr||[]).forEach(function(l){var ym=(l.date||"").slice(0,7);if(ym){m[ym]=(m[ym]||0)+Number(l.cost||0)}});return m};
  // 年間集計
  var yearlyCost=function(logArr,yr){var t=0;(logArr||[]).forEach(function(l){if((l.date||"").slice(0,4)===String(yr)){t+=Number(l.cost||0)}});return t};

  // --- 保存処理 ---
  var saveMileage=function(){if(!selCar){showMsg("車両を選択してください",true);return;}if(!miIn){showMsg("走行距離を入力してください",true);return;}var km=Number(miIn);if(km<=0){showMsg("走行距離は1以上を入力してください",true);return;}if(!window.confirm("走行距離を"+km.toLocaleString()+"kmで記録しますか？"))return;save(function(){return DB.hm.saveCarData({id:crypto.randomUUID(),store_id:"takamatsu",car_id:selCar.id,type:"mileage",date:today,value:km,memo:""})}).then(function(){setMiIn("")})};
  var saveOil=function(){if(!selCar){showMsg("車両を選択してください",true);return;}if(!oiIn){showMsg("走行距離を入力してください",true);return;}var km=Number(oiIn);if(km<=0){showMsg("走行距離は1以上を入力してください",true);return;}if(!window.confirm("オイル交換を"+km.toLocaleString()+"kmで記録しますか？"))return;save(function(){return DB.hm.saveCarData({id:crypto.randomUUID(),store_id:"takamatsu",car_id:selCar.id,type:"oil_change",date:today,value:km,memo:""})}).then(function(){setOiIn("")})};
  var saveIv=function(){if(!ivIn){showMsg("交換間隔を入力してください",true);return;}var km=Number(ivIn);if(km<=0){showMsg("交換間隔は1以上を入力してください",true);return;}if(!window.confirm("オイル交換間隔を"+km.toLocaleString()+"kmに変更しますか？"))return;save(function(){return DB.hm.saveCarData({id:crypto.randomUUID(),store_id:"takamatsu",car_id:"__global__",type:"oil_interval",date:today,value:km,memo:""})}).then(function(){setIvIn("")})};
  var saveSt=function(st){if(!selCar)return;
    var labelMap2={active:"稼働中",repair:"修理中",waiting:"修理待機中",estimating:"見積中"};
    if(!window.confirm((selCar.name||"")+"のステータスを「"+(labelMap2[st]||st)+"」に変更しますか？"))return;
    var u={id:selCar.id,store_id:selCar.store_id||"takamatsu",name:selCar.name||"",plate:selCar.plate||"",class_id:selCar.class_id||"",status:st,notes:selCar.notes||""};
    setBusy(true);
    DB.hm.saveCar(u).then(async function(){
      setSelCar(u);
      showMsg("ステータス変更: "+(labelMap2[st]||st),false);
      // saveCar完了後にhmReloadでpropsのcars配列も更新（awaitで完了を待つ）
      if(p.hmReload){await p.hmReload();}
    }).catch(function(e){console.error("saveSt:",e);showMsg("保存エラー: "+String(e&&e.message||e),true);}).finally(function(){setBusy(false);});
  };
  var saveIns=function(){if(!selCar)return;var v=Number(insIn!=null?insIn:getInsurance(selCar.id));if(isNaN(v)||v<0)return;if(!window.confirm("保険料を¥"+v.toLocaleString()+"/月で保存しますか？"))return;var existing=sortDesc(cdFilter(selCar.id,"insurance"));var keepId=existing.length?existing[0].id:crypto.randomUUID();var delIds=existing.slice(1).map(function(d){return d.id});save(function(){var chain=Promise.resolve();delIds.forEach(function(did){chain=chain.then(function(){return DB.hm.deleteCarData(did)})});return chain.then(function(){return DB.hm.saveCarData({id:keepId,store_id:"takamatsu",car_id:selCar.id,type:"insurance",date:today,value:v,memo:""})})}).then(function(){setInsIn(null)});};
  var saveLog=function(){if(!selCar){showMsg("車両を選択してください",true);return;}if(!logDate){showMsg("日付を入力してください",true);return;}if(!logCost||Number(logCost)<=0){showMsg("金額を入力してください",true);return;}if(!logDesc||!logDesc.trim()){showMsg("詳細を入力してください（必須）",true);return;}var c=Number(logCost);var isEdit=!!editLogId;if(!window.confirm(isEdit?"整備記録を更新しますか？\n"+logDate+" ¥"+c.toLocaleString()+" "+logDesc:"整備記録を保存しますか？\n"+logDate+" ¥"+c.toLocaleString()+" "+logDesc))return;save(function(){return DB.hm.saveLog({id:isEdit?editLogId:crypto.randomUUID(),store_id:"takamatsu",car_id:selCar.id,date:logDate,type:logCat||"other",detail:logDesc||"",description:logDesc||"",cost:c,mileage:getMileage(selCar.id)})}).then(function(){setLogCost("");setLogDesc("");setEditLogId(null)})};
  var startEditLog=function(log){setEditLogId(log.id);setLogDate(log.date||"");setLogCost(String(log.cost||""));setLogDesc(log.detail||log.description||"");setLogCat(log.type||"other")};
  var cancelEditLog=function(){setEditLogId(null);setLogCost("");setLogDesc("");setLogDate(new Date().toISOString().slice(0,10));setLogCat("oil")};
  var delLog=function(id){if(!window.confirm("削除しますか？"))return;save(function(){return DB.hm.deleteLog(id)})};

  // --- 共通パーツ ---
  var navBtn=function(id,label){return E("button",{key:id,onClick:function(){setView(id)},style:{padding:"6px 14px",fontSize:12,fontWeight:view===id?700:500,background:view===id?"#2563eb":"#f1f5f9",color:view===id?"#fff":"#64748b",border:"none",borderRadius:6,cursor:"pointer"}},label)};
  // 通知ポップアップ（画面中央に大きく表示、全画面で常に見える）
  var isErr=saveMsg&&saveMsg.indexOf("エラー")>=0;
  var msgPopup=saveMsg?E("div",{style:{position:"fixed",top:0,left:0,right:0,bottom:0,display:"flex",alignItems:"center",justifyContent:"center",zIndex:99999,pointerEvents:"none"}},
    E("div",{style:{background:isErr?"#fee2e2":"#dcfce7",color:isErr?"#991b1b":"#15803d",border:"2px solid "+(isErr?"#f87171":"#4ade80"),borderRadius:12,padding:"20px 40px",fontSize:18,fontWeight:800,boxShadow:"0 8px 30px rgba(0,0,0,0.2)",textAlign:"center",pointerEvents:"auto"}},
      E("div",{style:{fontSize:28,marginBottom:4}},isErr?"❌":"✅"),
      saveMsg
    )
  ):null;
  var nav=E("div",{style:{display:"flex",gap:6,marginBottom:14,flexWrap:"wrap"}},navBtn("list","車両一覧"),navBtn("summary","コスト集計"));
  var statusBadge=function(s){var bg=s==="active"?"#f0fdf4":s==="repair"?"#fee2e2":s==="waiting"?"#fef3c7":"#dbeafe";var fg=s==="active"?"#15803d":s==="repair"?"#991b1b":s==="waiting"?"#92400e":"#1e40af";var lb=s==="active"?"稼働中":s==="repair"?"修理中":s==="waiting"?"修理待機中":"見積中";return E("span",{style:{fontSize:10,padding:"2px 8px",borderRadius:4,background:bg,color:fg,fontWeight:600}},lb)};
  var section=function(bg,border,title,children){return E("div",{style:{background:bg,border:"1px solid "+border,borderRadius:8,padding:12,marginBottom:10}},E("div",{style:{fontSize:13,fontWeight:700,marginBottom:8}},title),children)};
  var card=function(bg,border,fg,val,label){return E("div",{style:{background:bg,border:"1px solid "+border,borderRadius:8,padding:14,textAlign:"center",minWidth:120}},E("div",{style:{fontSize:22,fontWeight:700,color:fg}},val),E("div",{style:{fontSize:11,color:fg,marginTop:4}},label))};

  // ========== 車両一覧 ==========
  if(view==="list"){
    var tIns=totalInsurance();
    var allYearlyList=yearlyCost(logs,filterYear);
    return E("div",{style:{maxWidth:1000,margin:"0 auto"}},msgPopup,nav,

      // 全車両サマリー（保険合計＋整備費合計）
      E("div",{style:{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(150px,1fr))",gap:8,marginBottom:12}},
        E("div",{style:{background:"#f0fdf4",border:"1px solid #86efac",borderRadius:8,padding:12,textAlign:"center"}},
          E("div",{style:{fontSize:10,color:"#15803d",fontWeight:600}},"保険 月額合計"),
          E("div",{style:{fontSize:20,fontWeight:800,color:"#15803d"}},"¥"+tIns.toLocaleString())
        ),
        E("div",{style:{background:"#fefce8",border:"1px solid #fde68a",borderRadius:8,padding:12,textAlign:"center"}},
          E("div",{style:{fontSize:10,color:"#92400e",fontWeight:600}},"保険 年間合計"),
          E("div",{style:{fontSize:20,fontWeight:800,color:"#92400e"}},"¥"+(tIns*12).toLocaleString())
        ),
        E("div",{style:{background:"#fee2e2",border:"1px solid #fca5a5",borderRadius:8,padding:12,textAlign:"center"}},
          E("div",{style:{fontSize:10,color:"#991b1b",fontWeight:600}},"整備費 年間合計("+filterYear+")"),
          E("div",{style:{fontSize:20,fontWeight:800,color:"#991b1b"}},"¥"+allYearlyList.toLocaleString())
        ),
        E("div",{style:{background:"#dbeafe",border:"1px solid #93c5fd",borderRadius:8,padding:12,textAlign:"center"}},
          E("div",{style:{fontSize:10,color:"#1e40af",fontWeight:600}},"管理車両数"),
          E("div",{style:{fontSize:20,fontWeight:800,color:"#1e40af"}},cars.length+"台")
        )
      ),

      // オイル交換間隔（全車共通）
      E("div",{style:{background:"#fff7ed",border:"1px solid #fed7aa",borderRadius:8,padding:10,marginBottom:12,display:"flex",alignItems:"center",gap:8,flexWrap:"wrap"}},
        E("span",{style:{fontSize:12,fontWeight:600,color:"#9a3412"}},"オイル交換間隔（全車共通）: "+getOilInterval().toLocaleString()+"km"),
        E("input",{type:"number",value:ivIn,onChange:function(e){setIvIn(e.target.value)},placeholder:"新しい間隔(km)",className:"input-s",style:{maxWidth:140,fontSize:11}}),
        E("button",{onClick:saveIv,className:"btn-ghost",style:{fontSize:11,padding:"4px 10px"},disabled:busy},"変更")
      ),

      // 車両リスト
      E("div",{style:{display:"grid",gap:8}},
        cars.map(function(c){
          if(!c||!c.id)return null;
          var mil=getMileage(c.id);var ins=getInsurance(c.id);var cost=yearlyCost(carLogs(c.id),filterYear);
          return E("div",{key:c.id,style:{background:"white",border:"1px solid #e2e8f0",borderRadius:8,padding:12,cursor:"pointer"},onClick:function(){setSelCar(c);setInsIn(null);setView("detail")}},
            E("div",{style:{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6}},
              E("div",null,E("span",{style:{fontWeight:700,fontSize:14}},c.name||""),E("span",{style:{fontSize:11,color:"#64748b",marginLeft:8}},c.plate||"")),
              statusBadge(getEffectiveStatusKey(c))
            ),
            E("div",{style:{display:"flex",gap:16,fontSize:11,color:"#475569"}},
              E("span",null,"走行: "+(mil?mil.toLocaleString()+"km":"未記録")),
              E("span",null,"保険: "+(ins?"¥"+ins.toLocaleString()+"/月":"未設定")),
              E("span",null,"整備("+filterYear+"): ¥"+cost.toLocaleString())
            )
          );
        }),
        cars.length===0&&E("div",{style:{textAlign:"center",color:"#94a3b8",padding:40,fontSize:13}},"BUDDICAのcarsテーブルに車両を登録してください")
      ),
    );
  }

  // ========== 車両詳細 ==========
  if(view==="detail"&&selCar){
    var cid=selCar.id;
    var milHist=sortDesc(cdFilter(cid,"mileage"));
    var oilHist=sortDesc(cdFilter(cid,"oil_change"));
    var insHist=sortDesc(cdFilter(cid,"insurance"));
    var myLogs=sortDesc(carLogs(cid));
    var myMonthly=monthlyCost(carLogs(cid));
    var myYearly=yearlyCost(carLogs(cid),filterYear);
    var monthKeys=Object.keys(myMonthly).sort().reverse();
    var curMileage=getMileage(cid);
    var curIns=getInsurance(cid);
    var lastOil=getLastOil(cid);

    // 種別ごとの小計
    var catTotals={};COST_CATS.forEach(function(c){catTotals[c.v]=0});
    myLogs.forEach(function(l){if((l.date||"").slice(0,4)===String(filterYear)){catTotals[l.type||"other"]=(catTotals[l.type||"other"]||0)+Number(l.cost||0)}});

    // セクションヘッダー共通
    var secHead=function(emoji,title,badge){return E("div",{style:{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}},E("div",{style:{fontSize:13,fontWeight:700}},emoji+" "+title),badge||null)};
    // 小テーブルヘッダー
    var tblHead=function(cols){return E("thead",null,E("tr",{style:{background:"#f1f5f9",borderBottom:"2px solid #cbd5e1"}},cols.map(function(c,i){return E("th",{key:i,style:{padding:"5px 8px",fontSize:11,fontWeight:600,textAlign:c.align||"left",color:"#475569"}},c.label)})))};

    return E("div",{style:{maxWidth:800,margin:"0 auto"}},msgPopup,
      // ヘッダー
      E("div",{style:{background:"white",border:"1px solid #e2e8f0",borderRadius:10,padding:14,marginBottom:14,display:"flex",alignItems:"center",gap:10,flexWrap:"wrap"}},
        E("button",{onClick:function(){setView("list")},className:"btn-ghost",style:{padding:"5px 12px",fontSize:12}},"← 一覧へ"),
        E("div",{style:{flex:1}},
          E("div",{style:{display:"flex",alignItems:"center",gap:8}},
            E("span",{style:{fontSize:18,fontWeight:800}},selCar.name||""),
            E("span",{style:{fontSize:13,color:"#64748b"}},selCar.plate||""),
            statusBadge(selCar.status||"active")
          ),
          E("div",{style:{display:"flex",gap:16,fontSize:11,color:"#64748b",marginTop:4}},
            E("span",null,"走行: "+(curMileage?curMileage.toLocaleString()+"km":"未記録")),
            E("span",null,"保険: "+(curIns?"¥"+curIns.toLocaleString()+"/月":"未設定")),
            E("span",null,"整備("+filterYear+"): ¥"+myYearly.toLocaleString())
          )
        )
      ),

      // ③ ステータス
      section("#f8f4ff","#d8b4fe","③ 車両ステータス",
        E("div",{style:{display:"flex",gap:8,alignItems:"center"}},
          E("select",{value:getEffectiveStatusKey(selCar),onChange:function(e){saveSt(e.target.value)},className:"input-s",style:{maxWidth:200},disabled:busy},
            E("option",{value:"active"},"稼働中"),E("option",{value:"repair"},"修理中"),E("option",{value:"waiting"},"修理待機中"),E("option",{value:"estimating"},"見積中")
          ),
          busy&&E("span",{style:{fontSize:11,color:"#94a3b8"}},"保存中...")
        )
      ),

      // ① 走行距離
      E("div",{style:{background:"#eff6ff",border:"1px solid #93c5fd",borderRadius:8,padding:12,marginBottom:10}},
        secHead("①","走行距離管理",curMileage?E("span",{style:{fontSize:14,fontWeight:800,color:"#1e40af"}},curMileage.toLocaleString()+"km"):null),
        E("div",{style:{display:"flex",gap:8,alignItems:"center",marginBottom:10}},
          E("input",{type:"number",value:miIn,onChange:function(e){setMiIn(e.target.value)},placeholder:"現在の走行距離（km）",className:"input-s",style:{maxWidth:200}}),
          E("button",{onClick:saveMileage,className:"btn-primary",disabled:busy},"記録")
        ),
        milHist.length>0?E("div",null,
          E("div",{style:{fontSize:11,fontWeight:600,color:"#1e40af",marginBottom:4}},"記録履歴（"+milHist.length+"件）"),
          E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:11,background:"#fff",borderRadius:4}},
            tblHead([{label:"日付"},{label:"走行距離",align:"right"}]),
            E("tbody",null,milHist.map(function(m,i){return E("tr",{key:m.id||i,style:{borderBottom:"1px solid #e2e8f0"}},
              E("td",{style:{padding:"5px 8px"}},m.date||""),
              E("td",{style:{padding:"5px 8px",textAlign:"right",fontWeight:600}},Number(m.value||0).toLocaleString()+"km")
            )}))
          )
        ):E("div",{style:{fontSize:11,color:"#94a3b8",padding:8,textAlign:"center"}},"まだ記録がありません")
      ),

      // ② オイル交換
      E("div",{style:{background:"#fff7ed",border:"1px solid #fed7aa",borderRadius:8,padding:12,marginBottom:10}},
        secHead("②","オイル交換管理",null),
        // ステータスボックス
        E("div",{style:{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:8,marginBottom:10}},
          E("div",{style:{background:"#fefce8",borderRadius:6,padding:8,textAlign:"center"}},
            E("div",{style:{fontSize:10,color:"#92400e"}},"最終交換"),
            E("div",{style:{fontSize:13,fontWeight:700}},lastOil?Number(lastOil.value||0).toLocaleString()+"km":"未記録"),
            lastOil?E("div",{style:{fontSize:10,color:"#78716c"}},lastOil.date||""):null
          ),
          E("div",{style:{background:"#fff7ed",borderRadius:6,padding:8,textAlign:"center"}},
            E("div",{style:{fontSize:10,color:"#92400e"}},"次回交換目安"),
            E("div",{style:{fontSize:13,fontWeight:700,color:"#ea580c"}},getNextOil(cid).toLocaleString()+"km")
          ),
          E("div",{style:{background:"#f0fdf4",borderRadius:6,padding:8,textAlign:"center"}},
            E("div",{style:{fontSize:10,color:"#15803d"}},"交換間隔（全車共通）"),
            E("div",{style:{fontSize:13,fontWeight:700}},getOilInterval().toLocaleString()+"km")
          )
        ),
        // 入力欄
        E("div",{style:{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:8}},
          E("div",null,
            E("div",{style:{fontSize:11,color:"#78716c",marginBottom:4}},"交換時の走行距離を記録"),
            E("div",{style:{display:"flex",gap:4}},
              E("input",{type:"number",value:oiIn,onChange:function(e){setOiIn(e.target.value)},placeholder:"km",className:"input-s"}),
              E("button",{onClick:saveOil,className:"btn-primary",disabled:busy},"記録")
            )
          ),
          E("div",null,
            E("div",{style:{fontSize:11,color:"#78716c",marginBottom:4}},"交換間隔を変更"),
            E("div",{style:{display:"flex",gap:4}},
              E("input",{type:"number",value:ivIn,onChange:function(e){setIvIn(e.target.value)},placeholder:"例:5000",className:"input-s"}),
              E("button",{onClick:saveIv,className:"btn-ghost",disabled:busy},"変更")
            )
          )
        ),
        // 履歴
        oilHist.length>0?E("div",null,
          E("div",{style:{fontSize:11,fontWeight:600,color:"#9a3412",marginBottom:4}},"交換履歴（"+oilHist.length+"件）"),
          E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:11,background:"#fff",borderRadius:4}},
            tblHead([{label:"日付"},{label:"交換時走行距離",align:"right"}]),
            E("tbody",null,oilHist.map(function(o,i){return E("tr",{key:o.id||i,style:{borderBottom:"1px solid #e2e8f0"}},
              E("td",{style:{padding:"5px 8px"}},o.date||""),
              E("td",{style:{padding:"5px 8px",textAlign:"right",fontWeight:600}},Number(o.value||0).toLocaleString()+"km")
            )}))
          )
        ):E("div",{style:{fontSize:11,color:"#94a3b8",padding:8,textAlign:"center"}},"まだ交換記録がありません")
      ),

      // ④ 保険金額
      E("div",{style:{background:"#f0fdf4",border:"1px solid #86efac",borderRadius:8,padding:12,marginBottom:10}},
        secHead("④","保険金額（月額）",null),
        E("div",{style:{display:"flex",gap:8,alignItems:"center",marginBottom:10}},
          E("span",{style:{fontSize:13,fontWeight:600,color:"#15803d"}},"¥"),
          E("input",{type:"number",value:insIn!=null?insIn:curIns||"",onChange:function(e){setInsIn(e.target.value)},placeholder:"月額（円）",className:"input-s",style:{maxWidth:180,fontSize:16,fontWeight:700}}),
          E("span",{style:{fontSize:12,color:"#64748b"}},"/月"),
          E("button",{onClick:saveIns,className:"btn-primary",disabled:busy},"更新")
        ),
        // 現在の保険情報（年額換算表示）
        (function(){var dispIns=insIn!=null?Number(insIn):curIns;return dispIns?E("div",{style:{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginBottom:8}},
          E("div",{style:{background:"#dcfce7",borderRadius:6,padding:10,textAlign:"center"}},
            E("div",{style:{fontSize:10,color:"#15803d"}},"月額"),
            E("div",{style:{fontSize:16,fontWeight:800,color:"#15803d"}},"¥"+Number(dispIns||0).toLocaleString())
          ),
          E("div",{style:{background:"#fefce8",borderRadius:6,padding:10,textAlign:"center"}},
            E("div",{style:{fontSize:10,color:"#92400e"}},"年額"),
            E("div",{style:{fontSize:16,fontWeight:800,color:"#92400e"}},"¥"+(Number(dispIns||0)*12).toLocaleString())
          )
        ):E("div",{style:{fontSize:11,color:"#94a3b8",padding:8,textAlign:"center"}},"保険金額が未設定です")})(),
        // 最終更新日
        insHist.length>0?E("div",{style:{fontSize:10,color:"#64748b",textAlign:"right",marginTop:4}},"最終更新: "+(insHist[0].date||"")):null
      ),

      // ⑤ 整備記録
      E("div",{style:{background:"#fef2f2",border:"1px solid #fecaca",borderRadius:8,padding:12,marginBottom:10}},
        secHead("⑤","整備記録",E("span",{style:{fontSize:14,fontWeight:800,color:"#991b1b"}},"年間("+filterYear+"): ¥"+myYearly.toLocaleString())),
        E("div",{style:{fontSize:11,color:"#991b1b",marginBottom:6}},"1項目ごとに 種別・日付・金額・詳細 を入力（複数回登録可）"),
        E("div",{style:{display:"grid",gridTemplateColumns:"110px 120px 110px 1fr",gap:6,marginBottom:8}},
          E("select",{value:logCat,onChange:function(e){setLogCat(e.target.value)},className:"input-s"},
            COST_CATS.map(function(c){return E("option",{key:c.v,value:c.v},c.l)})
          ),
          E("input",{type:"date",value:logDate,onChange:function(e){setLogDate(e.target.value)},className:"input-s"}),
          E("input",{type:"number",value:logCost,onChange:function(e){setLogCost(e.target.value)},placeholder:"金額（円）",className:"input-s"}),
          E("input",{value:logDesc,onChange:function(e){setLogDesc(e.target.value)},placeholder:"詳細（必須）",className:"input-s"})
        ),
        E("button",{onClick:saveLog,className:"btn-primary",disabled:busy||!logDesc.trim(),style:{background:editLogId?"#e65100":"#2563eb"}},editLogId?"整備記録を更新":"整備記録を追加"),
        editLogId&&E("button",{onClick:cancelEditLog,style:{padding:"6px 14px",fontSize:12,background:"#78909c",color:"#fff",border:"none",borderRadius:6,cursor:"pointer",marginLeft:4}},"キャンセル"),

        // 種別ごとの年間小計
        E("div",{style:{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(90px,1fr))",gap:4,marginTop:12,marginBottom:8}},
          COST_CATS.map(function(c){return E("div",{key:c.v,style:{background:"#fff",border:"1px solid #fecaca",borderRadius:4,padding:6,textAlign:"center"}},
            E("div",{style:{fontSize:10,color:"#64748b"}},c.l),
            E("div",{style:{fontSize:12,fontWeight:700,color:catTotals[c.v]>0?"#991b1b":"#cbd5e1"}},"¥"+(catTotals[c.v]||0).toLocaleString())
          )})
        ),

        // 月別集計
        monthKeys.length>0?E("div",{style:{marginTop:8,marginBottom:12}},
          E("div",{style:{fontSize:11,fontWeight:600,color:"#991b1b",marginBottom:4}},"月別集計"),
          E("div",{style:{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(90px,1fr))",gap:4}},
            monthKeys.map(function(ym){return E("div",{key:ym,style:{background:"#fff",border:"1px solid #e2e8f0",borderRadius:4,padding:6,textAlign:"center",fontSize:11}},
              E("div",{style:{color:"#64748b"}},ym),E("div",{style:{fontWeight:700}},"¥"+myMonthly[ym].toLocaleString())
            )})
          )
        ):null,

        // 履歴一覧
        myLogs.length>0?E("div",{style:{marginTop:8}},
          E("div",{style:{fontSize:11,fontWeight:600,color:"#991b1b",marginBottom:4}},"整備履歴（"+myLogs.length+"件）"),
          E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:11,background:"#fff",borderRadius:4}},
            tblHead([{label:"日付"},{label:"種別"},{label:"金額",align:"right"},{label:"詳細"},{label:"",align:"right"}]),
            E("tbody",null,myLogs.map(function(l,i){return E("tr",{key:l.id||i,style:{borderBottom:"1px solid #f1f5f9"}},
              E("td",{style:{padding:"5px 8px"}},l.date||""),
              E("td",{style:{padding:"5px 8px"}},E("span",{style:{fontSize:10,padding:"2px 8px",borderRadius:4,background:l.type==="inspection"?"#dbeafe":l.type==="repair"?"#fee2e2":l.type==="semi_annual"?"#fef3c7":l.type==="oil"?"#fff7ed":"#f1f5f9",color:l.type==="inspection"?"#1e40af":l.type==="repair"?"#991b1b":l.type==="semi_annual"?"#92400e":l.type==="oil"?"#9a3412":"#475569",fontWeight:600}},catLabel(l.type))),
              E("td",{style:{padding:"5px 8px",textAlign:"right",fontWeight:700}},"¥"+Number(l.cost||0).toLocaleString()),
              E("td",{style:{padding:"5px 8px",color:"#475569",maxWidth:200,overflow:"hidden",textOverflow:"ellipsis"}},l.detail||l.description||""),
              E("td",{style:{padding:"5px 8px",textAlign:"right",whiteSpace:"nowrap"}},
                E("button",{onClick:function(){startEditLog(l)},style:{fontSize:10,color:"#2563eb",background:"none",border:"none",cursor:"pointer",marginRight:6}},"編集"),
                E("button",{onClick:function(){delLog(l.id)},style:{fontSize:10,color:"#dc2626",background:"none",border:"none",cursor:"pointer"}},"削除")
              )
            )}))
          )
        ):E("div",{style:{fontSize:11,color:"#94a3b8",padding:12,textAlign:"center"}},"まだ整備記録がありません。上のフォームから追加してください。")
      )
    );
  }

  // ========== コスト集計 ==========
  if(view==="summary"){
    var tIns=totalInsurance();
    var yearOpts=[];for(var yi=2024;yi<=2027;yi++){yearOpts.push(yi)}
    var allLogsYear=(logs||[]).filter(function(l){return(l.date||"").slice(0,4)===String(filterYear)});
    var allYearly=yearlyCost(logs,filterYear);

    // カテゴリ別年間集計
    var yearCatTotals={};COST_CATS.forEach(function(c){yearCatTotals[c.v]=0});
    allLogsYear.forEach(function(l){yearCatTotals[l.type||"other"]=(yearCatTotals[l.type||"other"]||0)+Number(l.cost||0)});

    // 月別＋カテゴリ別集計 {YYYY-MM: {total:N, inspection:N, repair:N, ...}}
    var monthCatData={};
    allLogsYear.forEach(function(l){
      var ym=(l.date||"").slice(0,7);if(!ym)return;
      if(!monthCatData[ym]){monthCatData[ym]={total:0};COST_CATS.forEach(function(c){monthCatData[ym][c.v]=0})}
      monthCatData[ym].total+=Number(l.cost||0);
      monthCatData[ym][l.type||"other"]=(monthCatData[ym][l.type||"other"]||0)+Number(l.cost||0);
    });
    var allMonthKeys=Object.keys(monthCatData).sort();

    // カテゴリ色
    var catColor=function(v){return v==="inspection"?"#1e40af":v==="semi_annual"?"#92400e":v==="repair"?"#991b1b":v==="oil"?"#9a3412":"#475569"};
    var catBg=function(v){return v==="inspection"?"#dbeafe":v==="semi_annual"?"#fef3c7":v==="repair"?"#fee2e2":v==="oil"?"#fff7ed":"#f1f5f9"};

    return E("div",{style:{maxWidth:1100,margin:"0 auto"}},msgPopup,nav,

      // 年度切替
      E("div",{style:{display:"flex",gap:8,alignItems:"center",marginBottom:14}},
        E("span",{style:{fontSize:12,fontWeight:600}},"年度:"),
        yearOpts.map(function(y){return E("button",{key:y,onClick:function(){setFilterYear(y)},style:{padding:"5px 14px",fontSize:12,fontWeight:filterYear===y?700:400,background:filterYear===y?"#2563eb":"#f1f5f9",color:filterYear===y?"#fff":"#64748b",border:"none",borderRadius:6,cursor:"pointer"}},String(y))})
      ),

      // サマリーカード（上段）
      E("div",{style:{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(140px,1fr))",gap:10,marginBottom:10}},
        card("#f0fdf4","#86efac","#15803d","¥"+tIns.toLocaleString(),"保険 月額合計"),
        card("#fefce8","#fde68a","#92400e","¥"+(tIns*12).toLocaleString(),"保険 年間合計"),
        card("#fee2e2","#fca5a5","#991b1b","¥"+allYearly.toLocaleString(),"整備 年間合計("+filterYear+")"),
        card("#dbeafe","#93c5fd","#1e40af",cars.length+"台","管理車両数")
      ),

      // カテゴリ別年間サマリー
      E("div",{style:{display:"grid",gridTemplateColumns:"repeat("+COST_CATS.length+",1fr)",gap:6,marginBottom:14}},
        COST_CATS.map(function(c){return E("div",{key:c.v,style:{background:catBg(c.v),border:"1px solid #e2e8f0",borderRadius:6,padding:8,textAlign:"center"}},
          E("div",{style:{fontSize:10,color:catColor(c.v),fontWeight:600}},c.l),
          E("div",{style:{fontSize:15,fontWeight:800,color:catColor(c.v)}},"¥"+(yearCatTotals[c.v]||0).toLocaleString())
        )})
      ),

      // 保険内訳（車両別）
      E("div",{style:{background:"#f0fdf4",border:"1px solid #86efac",borderRadius:8,padding:12,marginBottom:12}},
        E("div",{style:{fontSize:13,fontWeight:700,marginBottom:8}},"保険内訳（車両別）"),
        E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:12}},
          E("thead",null,E("tr",{style:{borderBottom:"2px solid #86efac",background:"#f0fdf4"}},
            E("th",{style:{padding:"6px 8px",textAlign:"left"}},"車両"),E("th",{style:{padding:"6px 8px",textAlign:"right"}},"月額"),E("th",{style:{padding:"6px 8px",textAlign:"right"}},"年額"))),
          E("tbody",null,
            cars.map(function(c){var iv=getInsurance(c.id);return E("tr",{key:c.id,style:{borderBottom:"1px solid #e2e8f0"}},
              E("td",{style:{padding:"6px 8px",fontWeight:600}},(c.name||"")+" "+(c.plate||"")),
              E("td",{style:{padding:"6px 8px",textAlign:"right"}},iv?"¥"+iv.toLocaleString():"未設定"),
              E("td",{style:{padding:"6px 8px",textAlign:"right"}},iv?"¥"+(iv*12).toLocaleString():"-")
            )}),
            E("tr",{style:{borderTop:"2px solid #15803d",fontWeight:700,background:"#dcfce7"}},
              E("td",{style:{padding:"8px"}},"合計"),
              E("td",{style:{padding:"8px",textAlign:"right",fontSize:14}},"¥"+tIns.toLocaleString()),
              E("td",{style:{padding:"8px",textAlign:"right",fontSize:14}},"¥"+(tIns*12).toLocaleString())
            )
          )
        )
      ),

      // 整備費内訳（車両別 × カテゴリ別）
      E("div",{style:{background:"#fef2f2",border:"1px solid #fecaca",borderRadius:8,padding:12,marginBottom:12}},
        E("div",{style:{fontSize:13,fontWeight:700,marginBottom:8}},"整備費内訳（車両別 / "+filterYear+"年）"),
        E("div",{style:{overflowX:"auto"}},
          E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:11,minWidth:600}},
            E("thead",null,E("tr",{style:{borderBottom:"2px solid #fca5a5",background:"#fef2f2"}},
              E("th",{style:{padding:"6px 8px",textAlign:"left",fontSize:12}},"車両"),
              COST_CATS.map(function(c){return E("th",{key:c.v,style:{padding:"6px 8px",textAlign:"right",color:catColor(c.v),fontSize:11}},c.l)}),
              E("th",{style:{padding:"6px 8px",textAlign:"right",fontSize:12,fontWeight:800}},"合計"),
              E("th",{style:{padding:"6px 8px",textAlign:"right"}},"件数")
            )),
            E("tbody",null,
              cars.map(function(c){
                var cl=carLogs(c.id).filter(function(l){return(l.date||"").slice(0,4)===String(filterYear)});
                var ct={};COST_CATS.forEach(function(cat){ct[cat.v]=0});
                var total=0;
                cl.forEach(function(l){ct[l.type||"other"]=(ct[l.type||"other"]||0)+Number(l.cost||0);total+=Number(l.cost||0)});
                return E("tr",{key:c.id,style:{borderBottom:"1px solid #e2e8f0"}},
                  E("td",{style:{padding:"6px 8px",fontWeight:600}},(c.name||"")),
                  COST_CATS.map(function(cat){return E("td",{key:cat.v,style:{padding:"6px 8px",textAlign:"right",color:ct[cat.v]>0?catColor(cat.v):"#cbd5e1"}},ct[cat.v]>0?"¥"+ct[cat.v].toLocaleString():"-")}),
                  E("td",{style:{padding:"6px 8px",textAlign:"right",fontWeight:700,fontSize:12}},total>0?"¥"+total.toLocaleString():"-"),
                  E("td",{style:{padding:"6px 8px",textAlign:"right",color:"#64748b"}},cl.length+"件")
                );
              }),
              E("tr",{style:{borderTop:"2px solid #991b1b",fontWeight:700,background:"#fee2e2"}},
                E("td",{style:{padding:"8px"}},"全車両合計"),
                COST_CATS.map(function(c){return E("td",{key:c.v,style:{padding:"8px",textAlign:"right",color:catColor(c.v),fontWeight:700}},"¥"+(yearCatTotals[c.v]||0).toLocaleString())}),
                E("td",{style:{padding:"8px",textAlign:"right",fontSize:14,fontWeight:800}},"¥"+allYearly.toLocaleString()),
                E("td",{style:{padding:"8px",textAlign:"right"}},allLogsYear.length+"件")
              )
            )
          )
        )
      ),

      // 月別推移（カテゴリ内訳付き）
      E("div",{style:{background:"#f8fafc",border:"1px solid #e2e8f0",borderRadius:8,padding:12}},
        E("div",{style:{fontSize:13,fontWeight:700,marginBottom:10}},"月別整備費（"+filterYear+"年）"),
        allMonthKeys.length>0?E("div",{style:{overflowX:"auto"}},
          E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:11,minWidth:500}},
            E("thead",null,E("tr",{style:{borderBottom:"2px solid #cbd5e1",background:"#f1f5f9"}},
              E("th",{style:{padding:"6px 8px",textAlign:"left",fontSize:12}},"月"),
              COST_CATS.map(function(c){return E("th",{key:c.v,style:{padding:"6px 8px",textAlign:"right",color:catColor(c.v),fontSize:11}},c.l)}),
              E("th",{style:{padding:"6px 8px",textAlign:"right",fontSize:12,fontWeight:800}},"月合計")
            )),
            E("tbody",null,
              allMonthKeys.map(function(ym){
                var md=monthCatData[ym];
                return E("tr",{key:ym,style:{borderBottom:"1px solid #e2e8f0"}},
                  E("td",{style:{padding:"6px 8px",fontWeight:600,fontSize:12}},ym),
                  COST_CATS.map(function(c){return E("td",{key:c.v,style:{padding:"6px 8px",textAlign:"right",color:(md[c.v]||0)>0?catColor(c.v):"#cbd5e1"}},(md[c.v]||0)>0?"¥"+(md[c.v]).toLocaleString():"-")}),
                  E("td",{style:{padding:"6px 8px",textAlign:"right",fontWeight:700,fontSize:13,color:"#991b1b"}},"¥"+(md.total||0).toLocaleString())
                );
              }),
              E("tr",{style:{borderTop:"2px solid #475569",fontWeight:700,background:"#e2e8f0"}},
                E("td",{style:{padding:"8px",fontSize:12}},"年間合計"),
                COST_CATS.map(function(c){return E("td",{key:c.v,style:{padding:"8px",textAlign:"right",color:catColor(c.v),fontWeight:700}},"¥"+(yearCatTotals[c.v]||0).toLocaleString())}),
                E("td",{style:{padding:"8px",textAlign:"right",fontSize:14,fontWeight:800,color:"#991b1b"}},"¥"+allYearly.toLocaleString())
              )
            )
          )
        ):E("div",{style:{textAlign:"center",color:"#94a3b8",padding:20,fontSize:12}},"まだ整備記録がありません")
      )
    );
  }

  // デフォルト（fallback）
  return E("div",{style:{maxWidth:1000,margin:"0 auto"}},msgPopup,nav,E("div",{style:{textAlign:"center",padding:40,color:"#94a3b8"}},"ビューを選択してください"));
}

/* ==========================================
   経営管理タブ (2026-04-17 追加)
   売上入力 / PL / CF / ダッシュボード / コスト入力
   - sales_entries を Excel「売上入力」の代わりに直接編集
   - PL/CF は reservations から直接計算（入金サイクルは設定タブ参照）
   ========================================== */
function ManagementTab({store}){
  const[sub,setSub]=useState("dashboard");
  const[loading,setLoading]=useState(false);
  const[msg,setMsg]=useState("");
  const[channels,setChannels]=useState([]);
  // 売上入力用
  const[salesRows,setSalesRows]=useState([]);
  const[salesFilter,setSalesFilter]=useState({ym:"",channel:"",vt:""});
  const[editing,setEditing]=useState(null); // {id,...}
  const[newEntry,setNewEntry]=useState(null);
  // PL/CF (computed from dbResvs + costAllMonths in plPivot/cfPivot)
  // コスト入力
  const[costRows,setCostRows]=useState([]);
  const[costYm,setCostYm]=useState("");
  // 全月コスト（PL/CF連動用）: {ym: [{account_code, amount, note}]}
  const[costAllMonths,setCostAllMonths]=useState({});
  // パトロール（SS↔APP比較）
  const[patrolResult,setPatrolResult]=useState(null);
  const[patrolLoading,setPatrolLoading]=useState(false);
  // 当月ダッシュボード
  const[dashYm,setDashYm]=useState(()=>{const d=new Date();return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0");});

  // ===== 経営DB (Excel再現ダッシュボード) =====
  const[dbStore,setDbStore]=useState(store||"tkm");
  const[dbResvs,setDbResvs]=useState([]);
  const[dbFleet,setDbFleet]=useState([]);
  const[dbVehs,setDbVehs]=useState([]);
  const[dbKpi,setDbKpi]=useState([]);
  const[dbTasks,setDbTasks]=useState([]);
  const[dbLoading2,setDbLoading2]=useState(false);
  const[dbTargets,setDbTargets]=useState({});  // {ym: {rev:目標売上, cnt:目標件数, perV:台/売上目標}}
  // 解析セクション開閉
  const[secOpen,setSecOpen]=useState({A:true,B:true,C:true,D:true});
  const toggleSec=(k)=>setSecOpen(p=>({...p,[k]:!p[k]}));
  // 投資回転率コスト仮定
  const[roiCost,setRoiCost]=useState({insurance:12000,parking:17600,inspection:5000,maintenance:5000});
  // 売上入力フィルタ
  const[salesYmF,setSalesYmF]=useState("");
  const[salesChF,setSalesChF]=useState("");
  // 予算CF
  const[bcfStore,setBcfStore]=useState("tkm");
  const[bcfData,setBcfData]=useState({nha:{},spk:{}});
  // 予実比較
  const[yjData,setYjData]=useState({nha:{},spk:{}});
  const[yjCf,setYjCf]=useState({nha:{},spk:{}});
  // 設定（マスターデータ）
  const[mgSettings,setMgSettings]=useState({
    channels:[
      {name:"オフィシャル",cycle:0,note:"入金日を手入力（予約当日）"},
      {name:"じゃらん",cycle:0,note:"当月末入金"},
      {name:"楽天",cycle:3,note:"3ヶ月後末入金"},
      {name:"エアトリ",cycle:1,note:"翌月末入金"},
      {name:"レンタカードットコム",cycle:1,note:"翌月末入金"},
      {name:"スカイチケット",cycle:1,note:"翌月末入金"},
      {name:"その他売上",cycle:0,note:"当月末"},
    ],
    initCash:10000000,minCash:0,runrateMonths:3,
  });

  const storeLabel=store==="spk"?"札幌店":(store==="tkm"?"高松店":store);

  // チャネル一覧（固定定義 — DB不使用）

  // 売上ロード
  const loadSales=useCallback(async(opts={})=>{
    if(!sb)return;
    setLoading(true);
    let q=sb.from("sales_entries").select("*").eq("store",store).order("return_date",{ascending:false}).limit(2000);
    if(opts.ym)q=q.eq("fiscal_month",opts.ym);
    if(opts.channel)q=q.eq("channel",opts.channel);
    if(opts.vt)q=q.eq("vehicle_type",opts.vt);
    const{data,error}=await q;
    if(error){setMsg("ERROR: "+error.message);}
    else{setSalesRows(data||[]);setMsg("");}
    setLoading(false);
  },[store]);

  // コストロード（app_settingsベース）
  const loadCost=useCallback(async(ym)=>{
    if(!sb||!ym)return;
    const key="cost_"+dbStore+"_"+ym;
    const{data}=await sb.from("app_settings").select("*").eq("key",key).single();
    if(data&&data.value)try{setCostRows(JSON.parse(data.value));}catch(e){setCostRows([]);}
    else setCostRows([]);
  },[dbStore]);
  // 全月コストロード（PL/CF連動用）
  const loadCostAll=useCallback(async(st)=>{
    if(!sb)return;
    const{data}=await sb.from("app_settings").select("*").like("key","cost_"+st+"_%");
    const mp={};
    (data||[]).forEach(d=>{
      const ym=d.key.replace("cost_"+st+"_","");
      try{mp[ym]=JSON.parse(d.value);}catch(e){}
    });
    setCostAllMonths(mp);
  },[]);
  // コスト保存
  const saveCostEntry=useCallback(async(ym,acctCode,amount,note)=>{
    const updated=[...costRows.filter(r=>r.account_code!==acctCode),{account_code:acctCode,amount:parseInt(amount)||0,note:note||""}].filter(r=>r.amount>0||r.note);
    setCostRows(updated);
    if(!sb)return;
    const key="cost_"+dbStore+"_"+ym;
    await sb.from("app_settings").upsert({key,value:JSON.stringify(updated)},{onConflict:"key"});
    // 全月キャッシュも更新
    setCostAllMonths(prev=>({...prev,[ym]:updated}));
  },[dbStore,costRows]);

  // 経営DB: データロード（ページネーション付き）
  const loadDbAll=useCallback(async(table)=>{
    if(!sb)return[];
    let all=[],offset=0;
    while(true){
      const{data}=await sb.from(table).select("*").range(offset,offset+999);
      if(!data||data.length===0)break;
      all=all.concat(data);
      if(data.length<1000)break;
      offset+=1000;
    }
    return all;
  },[]);

  useEffect(()=>{
    if(!["exceldash","pl","cf","dashboard","hpcv","budgetcf","roi","cfsim","costsum","analytics"].includes(sub)||!sb)return;
    setDbLoading2(true);
    const isSpk=dbStore==="spk";
    const tasksTable=isSpk?"tasks":"tkm_tasks";
    Promise.all([
      loadDbAll(isSpk?"reservations":"tkm_reservations"),
      loadDbAll(isSpk?"fleet":"tkm_fleet"),
      loadDbAll(isSpk?"vehicles":"tkm_vehicles"),
      loadDbAll(isSpk?"vehicle_monthly_kpi":"tkm_vehicle_monthly_kpi"),
      sub==="analytics"?loadDbAll(tasksTable):Promise.resolve([]),
    ]).then(([r,f,v,k,t])=>{
      setDbResvs(r);setDbFleet(f);setDbVehs(v);setDbKpi(k);
      if(sub==="analytics")setDbTasks(t.filter(tk=>tk.type==="DEL"||tk.type==="COL"));
      setDbLoading2(false);
    }).catch(()=>setDbLoading2(false));
    // 目標値をロード
    sb.from("app_settings").select("*").eq("key","budget_targets_"+(isSpk?"spk":"tkm")).single()
      .then(({data})=>{if(data&&data.value)try{setDbTargets(JSON.parse(data.value));}catch(e){}});
    // 全月コストをロード（PL/CF連動用）
    loadCostAll(isSpk?"spk":"tkm");
  },[sub,dbStore]);

  // 予算CFデータロード
  useEffect(()=>{
    if(sub!=="budgetcf"||!sb)return;
    Promise.all([
      sb.from("app_settings").select("*").eq("key","budgetcf_nha").single(),
      sb.from("app_settings").select("*").eq("key","budgetcf_spk").single(),
    ]).then(([{data:d1},{data:d2}])=>{
      const nha=d1?.value?JSON.parse(d1.value):{};
      const spk=d2?.value?JSON.parse(d2.value):{};
      setBcfData({nha,spk});
    });
  },[sub]);

  const saveDbTarget=useCallback(async(ym,field,val)=>{
    const nv=parseInt(val)||0;
    const next={...dbTargets,[ym]:{...(dbTargets[ym]||{}), [field]:nv}};
    setDbTargets(next);
    if(!sb)return;
    const key="budget_targets_"+dbStore;
    const json=JSON.stringify(next);
    const{error}=await sb.from("app_settings").upsert({key,value:json},{onConflict:"key"});
    if(error)console.error("target save error",error);
  },[dbTargets,dbStore]);

  // 予実比較: データロード
  useEffect(()=>{
    if(sub!=="yojitsu"||!sb)return;
    Promise.all([
      sb.from("app_settings").select("*").eq("key","yojitsu_nha").single(),
      sb.from("app_settings").select("*").eq("key","yojitsu_spk").single(),
    ]).then(([{data:d1},{data:d2}])=>{
      const nha=d1?.value?JSON.parse(d1.value):{};
      const spk=d2?.value?JSON.parse(d2.value):{};
      setYjData({nha,spk});
    });
    // 入金実績: tkm_accountingとaccountingから月別入金額を集計
    Promise.all([
      loadDbAll("tkm_reservations"),
      loadDbAll("reservations"),
    ]).then(([nhaR,spkR])=>{
      // CF入金=売上計上ベースで代用（入金タイミングずれは将来対応）
      const calc=(rows,rdKey)=>{
        const byYm={};
        rows.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel").forEach(r=>{
          const rd=r[rdKey];if(!rd)return;
          const ym=rd.slice(0,7);
          const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
          const rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
          byYm[ym]=(byYm[ym]||0)+rev;
        });
        return byYm;
      };
      setYjCf({nha:calc(nhaR,"end_date"),spk:calc(spkR,"return_date")});
    });
  },[sub]);

  const saveYjField=useCallback(async(st,ym,field,val)=>{
    const nv=parseInt(val)||0;
    const next={...yjData,[st]:{...(yjData[st]||{}),[ym]:{...((yjData[st]||{})[ym]||{}),[field]:nv}}};
    setYjData(next);
    if(!sb)return;
    const{error}=await sb.from("app_settings").upsert({key:"yojitsu_"+st,value:JSON.stringify(next[st])},{onConflict:"key"});
    if(error)console.error("yojitsu save error",error);
  },[yjData]);

  // 設定ロード
  useEffect(()=>{
    if(sub!=="settings"||!sb)return;
    sb.from("app_settings").select("*").eq("key","mg_settings").single()
      .then(({data})=>{if(data?.value)try{setMgSettings(p=>({...p,...JSON.parse(data.value)}));}catch(e){}});
  },[sub]);

  const saveMgSettings=useCallback(async(next)=>{
    setMgSettings(next);
    if(!sb)return;
    await sb.from("app_settings").upsert({key:"mg_settings",value:JSON.stringify(next)},{onConflict:"key"});
  },[]);

  // 経営DB: メトリクス計算
  const DB_CHANNELS=["オフィシャル","じゃらん","楽天","エアトリ","レンタカードットコム","スカイチケット","その他売上"];
  const DB_OTA_MAP={"HP":"オフィシャル","J":"じゃらん","R":"楽天","O":"エアトリ","A":"エアトリ","S":"スカイチケット","RC":"レンタカードットコム","G":"その他売上","direct":"その他売上"};
  const DB_VEH_TYPES=["A","B","C","D","E","H","S","F"];

  const dbMetrics=useMemo(()=>{
    const isSpk=dbStore==="spk";
    const rdKey=isSpk?"return_date":"end_date";
    const ldKey=isSpk?"lend_date":"start_date";

    // Fleet map: reservation_id -> vehicle_code
    const fMap={};
    dbFleet.forEach(f=>{fMap[f.reservation_id]=f.vehicle_code;});
    // Vehicle map: code -> obj
    const vMap={};
    dbVehs.forEach(v=>{vMap[v.code]=v;});
    // KPI flags: {ym: {code: active}}
    const kpiF={};
    dbKpi.forEach(k=>{
      if(!kpiF[k.year_month])kpiF[k.year_month]={};
      kpiF[k.year_month][k.vehicle_code]=k.active;
    });

    const months={};
    const active=dbResvs.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");

    active.forEach(r=>{
      const rd=r[rdKey];
      if(!rd)return;
      const ym=rd.slice(0,7);
      if(!months[ym])months[ym]={
        chRev:{},chCnt:{},vtRev:{},vtCnt:{},
        delOta:0,delHp:0,
        totalRev:0,totalCnt:0,
        totalBase:0,totalOpt:0,totalDisc:0,
      };
      const m=months[ym];
      const ch=DB_OTA_MAP[r.ota]||"その他売上";
      // ★ 売上計上 = base_price + option_price - discount（割引差引後の最終金額）
      // base_price/option_price が未設定(0)の場合は price をフォールバック
      const bp=Number(r.base_price)||0;
      const op=Number(r.option_price)||0;
      const dc=Number(r.discount)||0;
      const hasBreakdown=bp>0||op>0;
      const revenue=hasBreakdown?(bp+op-dc):(Number(r.price)||0);

      m.chRev[ch]=(m.chRev[ch]||0)+revenue;
      m.chCnt[ch]=(m.chCnt[ch]||0)+1;
      m.totalRev+=revenue;
      m.totalCnt+=1;
      m.totalBase+=bp;
      m.totalOpt+=op;
      m.totalDisc+=dc;

      // デリバリー（札幌=デリバリー専門→全件DEL、高松=visit_typeから判定）
      const isDel=isSpk?true:(()=>{const vt_raw=(r.visit_type||"").toUpperCase();return vt_raw.includes("DEL")||vt_raw==="L"||vt_raw.includes("配達");})();
      if(isDel){if(ch==="オフィシャル")m.delHp++;else m.delOta++;}

      // 車両タイプ別（fleet経由でvehiclesのtypeを取得）
      const vc=fMap[r.id];
      const vObj=vc?vMap[vc]:null;
      let vType="?";
      if(vObj){vType=vObj.type||"?";}
      else if(isSpk&&r.vehicle){vType=r.vehicle;}
      else if(!isSpk&&r.vehicle_class){vType=r.vehicle_class;}
      if(vType&&vType!=="?"){
        m.vtRev[vType]=(m.vtRev[vType]||0)+revenue;
        m.vtCnt[vType]=(m.vtCnt[vType]||0)+1;
      }
    });

    // 稼働率計算（月ごと）
    const ymList=Object.keys(months).sort();
    ymList.forEach(ym=>{
      const m=months[ym];
      const y=parseInt(ym.split("-")[0]),mo=parseInt(ym.split("-")[1]);
      const dim=new Date(y,mo,0).getDate();
      // isKpiActive
      const kf=kpiF[ym]||{};
      const activeVehs=dbVehs.filter(v=>{
        const c=v.code;
        if(kf[c]!==undefined)return kf[c];
        return v.active!==false;
      });
      m.activeCount=activeVehs.length;
      m.totalVehs=dbVehs.length;
      m.dim=dim;
      // 稼働日数（車両別日Set）
      const vehDays={};
      active.forEach(r=>{
        const ld=r[ldKey],rd2=r[rdKey];
        if(!ld||!rd2)return;
        const vc=fMap[r.id];
        if(!vc)return;
        if(!activeVehs.find(v=>v.code===vc))return;
        const ms=new Date(y,mo-1,1),me=new Date(y,mo-1,dim);
        let s=new Date(ld.slice(0,10)),e=new Date(rd2.slice(0,10));
        if(s<ms)s=ms;if(e>me)e=me;
        if(s>e)return;
        if(!vehDays[vc])vehDays[vc]=new Set();
        for(let d=new Date(s);d<=e;d.setDate(d.getDate()+1)){
          vehDays[vc].add(d.toISOString().slice(0,10));
        }
      });
      let totalDays=0;
      Object.values(vehDays).forEach(s=>{totalDays+=s.size;});
      m.rentalDays=totalDays;
      m.maxDays=m.activeCount*dim;
      m.utilPct=m.maxDays>0?Math.round(totalDays/m.maxDays*100):0;
      // 車両タイプ別稼働率
      m.vtUtil={};
      DB_VEH_TYPES.forEach(t=>{
        const typeVehs=activeVehs.filter(v=>(v.type||"")==t);
        if(typeVehs.length===0)return;
        let tDays=0;
        typeVehs.forEach(v=>{if(vehDays[v.code])tDays+=vehDays[v.code].size;});
        m.vtUtil[t]=typeVehs.length*dim>0?Math.round(tDays/(typeVehs.length*dim)*1000)/10:0;
      });
    });

    return{months,ymList};
  },[dbResvs,dbFleet,dbVehs,dbKpi,dbStore]);

  // サブタブ切替時にロード
  useEffect(()=>{
    if(sub==="cost"){loadCost(costYm||dashYm);if(!costYm)setCostYm(dashYm);}
  },[sub]);

  // 売上追加
  const addSalesRow=async()=>{
    if(!newEntry||!newEntry.channel||!newEntry.return_date){setMsg("チャネルと返却日は必須");return;}
    setLoading(true);
    const payload={
      channel:newEntry.channel,
      return_date:newEntry.return_date,
      booking_date:newEntry.booking_date||null,
      base_amount:parseInt(newEntry.base_amount||0)||0,
      option_amount:parseInt(newEntry.option_amount||0)||0,
      discount:parseInt(newEntry.discount||0)||0,
      store:store,
      rental_days:newEntry.rental_days?parseFloat(newEntry.rental_days):null,
      vehicle_type:newEntry.vehicle_type||null,
      delivery:newEntry.delivery||null,
      resv_no:newEntry.resv_no||null,
      payment_date:newEntry.payment_date||null,
      note:newEntry.note||null,
      source:"app",
    };
    const{error}=await sb.from("sales_entries").insert(payload);
    if(error){setMsg("追加失敗: "+error.message);}
    else{setMsg("追加OK");setNewEntry(null);loadSales(salesFilter);}
    setLoading(false);
  };

  // 売上更新
  const updateSalesRow=async(row)=>{
    if(!row||!row.id)return;
    setLoading(true);
    const payload={
      channel:row.channel,
      return_date:row.return_date,
      booking_date:row.booking_date||null,
      base_amount:parseInt(row.base_amount||0)||0,
      option_amount:parseInt(row.option_amount||0)||0,
      discount:parseInt(row.discount||0)||0,
      rental_days:row.rental_days?parseFloat(row.rental_days):null,
      vehicle_type:row.vehicle_type||null,
      delivery:row.delivery||null,
      resv_no:row.resv_no||null,
      payment_date:row.payment_date||null,
      note:row.note||null,
    };
    const{error}=await sb.from("sales_entries").update(payload).eq("id",row.id);
    if(error){setMsg("更新失敗: "+error.message);}
    else{setMsg("更新OK");setEditing(null);loadSales(salesFilter);}
    setLoading(false);
  };

  // 売上削除
  const deleteSalesRow=async(id)=>{
    if(!confirm("この売上行を削除しますか？ PL/CFから自動的に消えます。"))return;
    setLoading(true);
    const{error}=await sb.from("sales_entries").delete().eq("id",id);
    if(error){setMsg("削除失敗: "+error.message);}
    else{setMsg("削除OK");loadSales(salesFilter);}
    setLoading(false);
  };

  // コスト保存
  const fmt=(n)=>n==null?"-":Number(n).toLocaleString();
  const fmtM=(n)=>n==null?"-":"¥"+Math.round(n/10000).toLocaleString()+"万";

  // PLをピボット化（year_month × channel）
  // PLピボット（reservationsから直接計算）
  const plPivot=useMemo(()=>{
    const isSpk=dbStore==="spk";
    const rdKey=isSpk?"return_date":"end_date";
    const ldKey=isSpk?"lend_date":"start_date";
    const ymSet=new Set(),chSet=new Set();
    const map={};
    const daysByYm={};
    const active=dbResvs.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");
    active.forEach(r=>{
      const rd=r[rdKey];if(!rd)return;
      const ym=rd.slice(0,7);
      const ch=DB_OTA_MAP[r.ota]||"その他売上";
      const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
      const revenue=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
      ymSet.add(ym);chSet.add(ch);
      const key=ym+"|"+ch;
      if(!map[key])map[key]={revenue:0,count:0};
      map[key].revenue+=revenue;
      map[key].count+=1;
      // 泊数
      const ld=r[ldKey];
      if(ld&&rd){
        const d0=new Date(ld.slice(0,10)),d1=new Date(rd.slice(0,10));
        const nights=Math.max(1,Math.round((d1-d0)/(86400000)));
        if(!daysByYm[ym])daysByYm[ym]={sum:0,cnt:0};
        daysByYm[ym].sum+=nights;daysByYm[ym].cnt+=1;
      }
    });
    const yms=Array.from(ymSet).sort();
    const chOrder=["オフィシャル","じゃらん","楽天","エアトリ","スカイチケット","レンタカードットコム","その他売上"];
    const chs=chOrder.filter(c=>chSet.has(c)).concat(Array.from(chSet).filter(c=>!chOrder.includes(c)));
    return{yms,chs,map,daysByYm};
  },[dbResvs,dbStore]);

  // CFピボット（reservations + 入金サイクルから計算）
  const cfPivot=useMemo(()=>{
    const isSpk=dbStore==="spk";
    const rdKey=isSpk?"return_date":"end_date";
    // チャネル入金サイクルマップ
    const cycleMap={};
    (mgSettings.channels||[]).forEach(c=>{cycleMap[c.name]=c.cycle||0;});
    const ymSet=new Set(),chSet=new Set();
    const map={};
    const active=dbResvs.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");
    active.forEach(r=>{
      const rd=r[rdKey];if(!rd)return;
      const ch=DB_OTA_MAP[r.ota]||"その他売上";
      const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
      const revenue=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
      // 入金月 = 売上月 + cycle月
      const cycle=cycleMap[ch]||0;
      const [sy,sm]=rd.slice(0,7).split("-").map(Number);
      let ny=sy,nm=sm+cycle;
      while(nm>12){nm-=12;ny++;}
      const cashYm=ny+"-"+String(nm).padStart(2,"0");
      ymSet.add(cashYm);chSet.add(ch);
      const key=cashYm+"|"+ch;
      if(!map[key])map[key]={cash_in:0,count:0};
      map[key].cash_in+=revenue;
      map[key].count+=1;
    });
    const yms=Array.from(ymSet).sort();
    const chOrder=["オフィシャル","じゃらん","楽天","エアトリ","スカイチケット","レンタカードットコム","その他売上"];
    const chs=chOrder.filter(c=>chSet.has(c)).concat(Array.from(chSet).filter(c=>!chOrder.includes(c)));
    // 支出予算（costAllMonthsから取得）
    const expByYm={};
    Object.entries(costAllMonths).forEach(([ym,rows])=>{
      if(!rows)return;
      let repay=0,sga=0,cogs=0,vehicle=0;
      rows.forEach(r=>{
        const c=r.account_code||"";const a=r.amount||0;
        if(c.startsWith("repay_"))repay+=a;
        else if(c.startsWith("sga_"))sga+=a;
        else if(c.startsWith("cogs_"))cogs+=a;
        else if(c==="vehicle_purchase")vehicle+=a;
      });
      expByYm[ym]={repay,sga,cogs,vehicle,total:repay+sga+cogs+vehicle};
      ymSet.add(ym);
    });
    const allYms=Array.from(ymSet).sort();
    return{yms:allYms,chs,map,expByYm};
  },[dbResvs,dbStore,mgSettings,costAllMonths]);

  // 当月ダッシュボード集計（reservationsベース / PLピボットから取得）
  const dashSummary=useMemo(()=>{
    const isSpk=dbStore==="spk";
    const rdKey=isSpk?"return_date":"end_date";
    const ldKey=isSpk?"lend_date":"start_date";
    const active=dbResvs.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");
    const ym=dashYm;
    let plRev=0,plCnt=0,daysSum=0,daysCnt=0;
    const byCh={};
    active.forEach(r=>{
      const rd=r[rdKey];if(!rd||rd.slice(0,7)!==ym)return;
      const ch=DB_OTA_MAP[r.ota]||"その他売上";
      const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
      const rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
      plRev+=rev;plCnt+=1;
      byCh[ch]=(byCh[ch]||0)+rev;
      const ld=r[ldKey];
      if(ld&&rd){const d0=new Date(ld.slice(0,10)),d1=new Date(rd.slice(0,10));const n=Math.max(1,Math.round((d1-d0)/86400000));daysSum+=n;daysCnt++;}
    });
    const avgNights=daysCnt>0?(daysSum/daysCnt):0;
    const unitPrice=plCnt>0?(plRev/plCnt):0;
    const dailyRate=daysSum>0?(plRev/daysSum):0;
    // CF入金（当月入金分）
    const cfIn=cfPivot.chs.reduce((a,ch)=>a+((cfPivot.map[ym+"|"+ch]||{}).cash_in||0),0);
    return{plRev,plCnt,cfIn,byCh,avgNights,daysSum,unitPrice,dailyRate};
  },[dbResvs,dbStore,dashYm,cfPivot]);

  const subTabs=[
    {id:"exceldash",l:"📊 経営DB"},
    {id:"yojitsu",l:"📈 予実比較"},
    {id:"settings",l:"���️ 設定"},
    {id:"dashboard",l:"📊 ダッシュボード"},
    {id:"sales",l:"📝 売上入力"},
    {id:"pl",l:"📘 PL(月次)"},
    {id:"cf",l:"💰 CF(月次)"},
    {id:"cost",l:"🧾 コスト入力"},
    {id:"costsum",l:"📋 コスト一覧"},
    {id:"hpcv",l:"🔵 HP-CV"},
    {id:"budgetcf",l:"📊 予算CF"},
    {id:"roi",l:"📈 投資回転率"},
    {id:"cfsim",l:"🔮 CFシミュ"},
    {id:"analytics",l:"🔬 解析"},
    {id:"patrol",l:"🔍 パトロール"},
  ];

  const card={padding:12,borderRadius:10,background:"#fff",border:"1px solid #e2e8f0"};
  const h={fontSize:16,fontWeight:900,marginBottom:10};
  const lbl={fontSize:10,color:"#64748b",marginBottom:2};
  const val={fontSize:18,fontWeight:800,color:"#0f172a"};
  const inp={width:"100%",padding:"4px 6px",fontSize:11,border:"1px solid #cbd5e1",borderRadius:4};
  const th={padding:"6px 8px",fontSize:10,color:"#64748b",textAlign:"left",borderBottom:"1px solid #e2e8f0",fontWeight:700,background:"#f8fafc"};
  const td={padding:"4px 8px",fontSize:11,borderBottom:"1px solid #f1f5f9"};
  const btn=(c)=>({padding:"4px 10px",fontSize:11,fontWeight:700,borderRadius:6,border:"none",cursor:"pointer",background:c||"#1e40af",color:"#fff"});

  return <div>
    <h2 style={{fontSize:18,fontWeight:900,marginBottom:6}}>💼 {storeLabel} 経営管理</h2>
    <p style={{fontSize:11,color:"#64748b",marginBottom:12}}>Excel「売上入力」タブの代替。売上入力→PL/CF/ダッシュボードが自動連動。</p>

    {/* サブタブ */}
    <div style={{display:"flex",gap:6,flexWrap:"wrap",marginBottom:12,borderBottom:"1px solid #e2e8f0",paddingBottom:8}}>
      {subTabs.map(t=>{
        const sel=sub===t.id;
        return <button key={t.id} onClick={()=>setSub(t.id)} style={{padding:"6px 12px",fontSize:12,fontWeight:700,borderRadius:8,border:"none",cursor:"pointer",background:sel?"#1e40af":"#f1f5f9",color:sel?"#fff":"#334155"}}>{t.l}</button>;
      })}
      <div style={{flex:1}}/>
      {loading&&<span style={{fontSize:11,color:"#64748b"}}>読込中...</span>}
      {msg&&<span style={{fontSize:11,color:msg.startsWith("ERROR")||msg.includes("失敗")?"#dc2626":"#059669",fontWeight:700}}>{msg}</span>}
    </div>

    {/* === 経営DB (Excel再現ダッシュボード) === */}
    {sub==="exceldash"&&<div>
      {/* 店舗切替 */}
      <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:12}}>
        {["tkm","spk"].map(s=>{
          const sel2=dbStore===s;
          const lb=s==="tkm"?"高松店":"札幌店";
          return <button key={s} onClick={()=>setDbStore(s)} style={{padding:"6px 16px",fontSize:13,fontWeight:800,borderRadius:8,border:sel2?"2px solid #1e40af":"2px solid #e2e8f0",cursor:"pointer",background:sel2?"#1e40af":"#fff",color:sel2?"#fff":"#334155"}}>{lb}</button>;
        })}
        {dbLoading2&&<span style={{fontSize:11,color:"#64748b",marginLeft:8}}>読込中...</span>}
        <span style={{fontSize:10,color:"#94a3b8",marginLeft:8}}>※ reservationsから自動集計 | 売上計上 = 基本料金 + 付帯売上 - 割引（最終金額）</span>
      </div>

      {(()=>{
        const{months,ymList}=dbMetrics;
        if(ymList.length===0)return <div style={{padding:20,textAlign:"center",color:"#94a3b8"}}>データなし</div>;
        const sLabel=dbStore==="tkm"?"高松":"札幌";
        const thS={padding:"4px 6px",fontSize:9,color:"#64748b",textAlign:"right",borderBottom:"2px solid #e2e8f0",fontWeight:700,background:"#f8fafc",whiteSpace:"nowrap",position:"sticky",top:0,zIndex:1};
        const tdS={padding:"3px 6px",fontSize:10,textAlign:"right",borderBottom:"1px solid #f1f5f9",whiteSpace:"nowrap"};
        const tdL={padding:"3px 6px",fontSize:10,textAlign:"left",borderBottom:"1px solid #f1f5f9",whiteSpace:"nowrap",position:"sticky",left:0,background:"#fff",zIndex:1};
        const secH=(text)=><tr><td colSpan={ymList.length+1} style={{padding:"8px 6px 4px",fontSize:12,fontWeight:900,background:"#f0f9ff",color:"#0369a1",borderBottom:"2px solid #0ea5e9"}}>{text}</td></tr>;
        const fmtK=(n)=>n==null||n===0?"-":"¥"+(n>=10000?Math.round(n/10000).toLocaleString()+"万":n.toLocaleString());
        const fmtN=(n)=>n==null||n===0?"-":n.toLocaleString();
        const fmtP=(n)=>n==null||n===0?"-":(n*100).toFixed(1)+"%";
        const chg=(cur,prev)=>{
          if(!prev||prev===0)return null;
          const d=cur-prev;
          const p=Math.round(d/prev*100);
          const color=d>0?"#059669":d<0?"#dc2626":"#64748b";
          const arrow=d>0?"▲":d<0?"▼":"→";
          return <span style={{fontSize:8,color,marginLeft:2}}>{arrow}{Math.abs(p)}%</span>;
        };

        return <div style={{overflow:"auto",maxHeight:"75vh",border:"1px solid #e2e8f0",borderRadius:8}}>
          <table style={{width:"100%",borderCollapse:"collapse",minWidth:ymList.length*90}}>
            <thead>
              <tr>
                <th style={{...thS,textAlign:"left",position:"sticky",left:0,zIndex:2,minWidth:160}}>項目</th>
                {ymList.map(ym=><th key={ym} style={thS}>{ym.replace("20","").replace("-","/")}</th>)}
              </tr>
            </thead>
            <tbody>
              {/* ▼ セクション1: チャネル別売上金額 */}
              {secH("▼ チャネル別売上金額（計上ベース）— "+sLabel)}
              {DB_CHANNELS.map(ch=>{
                return <tr key={"rev_"+ch}>
                  <td style={{...tdL,paddingLeft:16}}>{ch}</td>
                  {ymList.map((ym,i)=>{
                    const v=(months[ym]?.chRev[ch])||0;
                    const prev=i>0?((months[ymList[i-1]]?.chRev[ch])||0):0;
                    return <td key={ym} style={tdS}>{fmtK(v)} {i>0&&chg(v,prev)}</td>;
                  })}
                </tr>;
              })}
              <tr style={{fontWeight:800,background:"#f0fdf4"}}>
                <td style={{...tdL,fontWeight:800}}>売上合計</td>
                {ymList.map((ym,i)=>{
                  const v=months[ym]?.totalRev||0;
                  const prev=i>0?(months[ymList[i-1]]?.totalRev||0):0;
                  return <td key={ym} style={{...tdS,fontWeight:800}}>{fmtK(v)} {i>0&&chg(v,prev)}</td>;
                })}
              </tr>
              {/* 構成比率 */}
              <tr><td style={{...tdL,paddingLeft:16,fontSize:9,color:"#94a3b8"}} colSpan={ymList.length+1}>↳ 売上金額 構成比率</td></tr>
              {DB_CHANNELS.map(ch=>{
                return <tr key={"revp_"+ch}>
                  <td style={{...tdL,paddingLeft:24,fontSize:9,color:"#64748b"}}>{ch}</td>
                  {ymList.map(ym=>{
                    const v=(months[ym]?.chRev[ch])||0;
                    const total=months[ym]?.totalRev||1;
                    return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{fmtP(v/total)}</td>;
                  })}
                </tr>;
              })}

              {/* ▼ セクション2: 売上件数 */}
              {secH("▼ 売上件数（チャネル別）— "+sLabel)}
              {DB_CHANNELS.map(ch=>{
                return <tr key={"cnt_"+ch}>
                  <td style={{...tdL,paddingLeft:16}}>{ch}</td>
                  {ymList.map((ym,i)=>{
                    const v=(months[ym]?.chCnt[ch])||0;
                    const prev=i>0?((months[ymList[i-1]]?.chCnt[ch])||0):0;
                    return <td key={ym} style={tdS}>{fmtN(v)} {i>0&&chg(v,prev)}</td>;
                  })}
                </tr>;
              })}
              <tr style={{fontWeight:800,background:"#f0fdf4"}}>
                <td style={{...tdL,fontWeight:800}}>合計件数</td>
                {ymList.map((ym,i)=>{
                  const v=months[ym]?.totalCnt||0;
                  const prev=i>0?(months[ymList[i-1]]?.totalCnt||0):0;
                  return <td key={ym} style={{...tdS,fontWeight:800}}>{fmtN(v)} {i>0&&chg(v,prev)}</td>;
                })}
              </tr>
              {/* 件数構成比率 */}
              <tr><td style={{...tdL,paddingLeft:16,fontSize:9,color:"#94a3b8"}} colSpan={ymList.length+1}>↳ 件数 構成比率</td></tr>
              {DB_CHANNELS.map(ch=>{
                return <tr key={"cntp_"+ch}>
                  <td style={{...tdL,paddingLeft:24,fontSize:9,color:"#64748b"}}>{ch}</td>
                  {ymList.map(ym=>{
                    const v=(months[ym]?.chCnt[ch])||0;
                    const total=months[ym]?.totalCnt||1;
                    return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{fmtP(v/total)}</td>;
                  })}
                </tr>;
              })}

              {/* ▼ セクション3: デリバリー利用状況 */}
              {secH("▼ デリバリー利用状況 — "+sLabel)}
              <tr><td style={{...tdL,paddingLeft:16}}>OTA DEL利用数</td>
                {ymList.map(ym=><td key={ym} style={tdS}>{fmtN(months[ym]?.delOta||0)}</td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>↳ OTA DEL構成比</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const otaCnt=DB_CHANNELS.filter(c=>c!=="オフィシャル").reduce((s,c)=>(s+(m?.chCnt[c]||0)),0);
                  return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{otaCnt>0?fmtP((m?.delOta||0)/otaCnt):"-"}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>オフィシャル DEL利用数</td>
                {ymList.map(ym=><td key={ym} style={tdS}>{fmtN(months[ym]?.delHp||0)}</td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>↳ HP DEL構成比</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const hpCnt=m?.chCnt["オフィシャル"]||0;
                  return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{hpCnt>0?fmtP((m?.delHp||0)/hpCnt):"-"}</td>;
                })}</tr>
              <tr style={{fontWeight:700}}><td style={{...tdL,paddingLeft:16}}>合算DEL件数</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  return <td key={ym} style={{...tdS,fontWeight:700}}>{fmtN((m?.delOta||0)+(m?.delHp||0))}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>合算DEL利用率</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const total=m?.totalCnt||0;
                  return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{total>0?fmtP(((m?.delOta||0)+(m?.delHp||0))/total):"-"}</td>;
                })}</tr>

              {/* ▼ セクション4: 売上目標・実績管理（金額） */}
              {secH("▼ 売上目標・実績管理（金額）— "+sLabel)}
              <tr style={{background:"#fffbeb"}}><td style={{...tdL,paddingLeft:16,fontWeight:700}}>目標総売上（入力可）</td>
                {ymList.map(ym=><td key={ym} style={{...tdS,padding:0}}><input type="number" value={dbTargets[ym]?.rev||""} onChange={e=>saveDbTarget(ym,"rev",e.target.value)} style={{width:"100%",border:"none",background:"#fffbeb",textAlign:"right",fontSize:10,padding:"3px 4px"}} placeholder="0"/></td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>実績総売上（計上）</td>
                {ymList.map(ym=><td key={ym} style={tdS}>{fmtK(months[ym]?.totalRev||0)}</td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>差分（実績−目標）</td>
                {ymList.map(ym=>{
                  const tgt=dbTargets[ym]?.rev||0;
                  const act=months[ym]?.totalRev||0;
                  const diff=act-tgt;
                  const color=tgt===0?"#64748b":diff>=0?"#059669":"#dc2626";
                  return <td key={ym} style={{...tdS,color,fontWeight:tgt?700:400}}>{tgt?fmtK(diff):"-"}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>達成率</td>
                {ymList.map(ym=>{
                  const tgt=dbTargets[ym]?.rev||0;
                  const act=months[ym]?.totalRev||0;
                  const pct=tgt>0?act/tgt:0;
                  const bg=pct>=1?"#dcfce7":pct>=0.7?"#fef9c3":pct>0?"#fef2f2":"transparent";
                  return <td key={ym} style={{...tdS,background:bg,fontWeight:700}}>{tgt>0?(pct*100).toFixed(1)+"%":"-"}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>OTA売上合計</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const otaRev=DB_CHANNELS.filter(c=>c!=="オフィシャル").reduce((s,c)=>(s+(m?.chRev[c]||0)),0);
                  return <td key={ym} style={tdS}>{fmtK(otaRev)}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:24,fontSize:9,color:"#64748b"}}>↳ OTA 売上構成比率</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const otaRev=DB_CHANNELS.filter(c=>c!=="オフィシャル").reduce((s,c)=>(s+(m?.chRev[c]||0)),0);
                  return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{m?.totalRev>0?fmtP(otaRev/m.totalRev):"-"}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>オフィシャル売上</td>
                {ymList.map(ym=><td key={ym} style={tdS}>{fmtK(months[ym]?.chRev["オフィシャル"]||0)}</td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:24,fontSize:9,color:"#64748b"}}>↳ オフィシャル 売上構成比率</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{m?.totalRev>0?fmtP((m?.chRev["オフィシャル"]||0)/m.totalRev):"-"}</td>;
                })}</tr>

              {/* ▼ セクション5: 売上区分（基本料金 / 付帯売上 / 割引） */}
              {secH("▼ 売上区分（基本料金 / 付帯売上 / 割引）— "+sLabel)}
              <tr><td style={{...tdL,paddingLeft:16}}>基本料金</td>
                {ymList.map((ym,i)=>{
                  const v=months[ym]?.totalBase||0;
                  const prev=i>0?(months[ymList[i-1]]?.totalBase||0):0;
                  return <td key={ym} style={tdS}>{fmtK(v)} {i>0&&chg(v,prev)}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:24,fontSize:9,color:"#64748b"}}>↳ 基本料金 構成比</td>
                {ymList.map(ym=>{
                  const bp=months[ym]?.totalBase||0;
                  const gross=(months[ym]?.totalBase||0)+(months[ym]?.totalOpt||0);
                  return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{gross>0?fmtP(bp/gross):"-"}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>付帯売上</td>
                {ymList.map((ym,i)=>{
                  const v=months[ym]?.totalOpt||0;
                  const prev=i>0?(months[ymList[i-1]]?.totalOpt||0):0;
                  return <td key={ym} style={tdS}>{fmtK(v)} {i>0&&chg(v,prev)}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:24,fontSize:9,color:"#64748b"}}>↳ 付帯売上 構成比</td>
                {ymList.map(ym=>{
                  const op=months[ym]?.totalOpt||0;
                  const gross=(months[ym]?.totalBase||0)+(months[ym]?.totalOpt||0);
                  return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{gross>0?fmtP(op/gross):"-"}</td>;
                })}</tr>
              <tr style={{color:"#dc2626"}}><td style={{...tdL,paddingLeft:16,color:"#dc2626"}}>割引・クーポン</td>
                {ymList.map((ym,i)=>{
                  const v=months[ym]?.totalDisc||0;
                  const prev=i>0?(months[ymList[i-1]]?.totalDisc||0):0;
                  return <td key={ym} style={{...tdS,color:"#dc2626"}}>{v>0?"-"+fmtK(v):"-"} {i>0&&v>0&&prev>0?chg(v,prev):null}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:24,fontSize:9,color:"#64748b"}}>↳ 割引率（グロス対比）</td>
                {ymList.map(ym=>{
                  const dc=months[ym]?.totalDisc||0;
                  const gross=(months[ym]?.totalBase||0)+(months[ym]?.totalOpt||0);
                  return <td key={ym} style={{...tdS,fontSize:9,color:dc>0?"#dc2626":"#64748b"}}>{gross>0?fmtP(dc/gross):"-"}</td>;
                })}</tr>
              <tr style={{fontWeight:800,background:"#f0fdf4"}}>
                <td style={{...tdL,fontWeight:800}}>売上計上額（= 基本+付帯-割引）</td>
                {ymList.map((ym,i)=>{
                  const v=months[ym]?.totalRev||0;
                  const prev=i>0?(months[ymList[i-1]]?.totalRev||0):0;
                  return <td key={ym} style={{...tdS,fontWeight:800}}>{fmtK(v)} {i>0&&chg(v,prev)}</td>;
                })}</tr>

              {/* ▼ セクション6: 売上件数 目標・実績管理 */}
              {secH("▼ 売上件数 目標・実績管理 — "+sLabel)}
              <tr style={{background:"#fffbeb"}}><td style={{...tdL,paddingLeft:16,fontWeight:700}}>目標売上件数（入力可）</td>
                {ymList.map(ym=><td key={ym} style={{...tdS,padding:0}}><input type="number" value={dbTargets[ym]?.cnt||""} onChange={e=>saveDbTarget(ym,"cnt",e.target.value)} style={{width:"100%",border:"none",background:"#fffbeb",textAlign:"right",fontSize:10,padding:"3px 4px"}} placeholder="0"/></td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>OTA件数</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const otaCnt=DB_CHANNELS.filter(c=>c!=="オフィシャル").reduce((s,c)=>(s+(m?.chCnt[c]||0)),0);
                  return <td key={ym} style={tdS}>{fmtN(otaCnt)}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>オフィシャル件数</td>
                {ymList.map(ym=><td key={ym} style={tdS}>{fmtN(months[ym]?.chCnt["オフィシャル"]||0)}</td>)}</tr>
              <tr style={{fontWeight:700}}><td style={{...tdL,fontWeight:700}}>実績件数合計</td>
                {ymList.map(ym=><td key={ym} style={{...tdS,fontWeight:700}}>{fmtN(months[ym]?.totalCnt||0)}</td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>差分（実績−目標）</td>
                {ymList.map(ym=>{
                  const tgt=dbTargets[ym]?.cnt||0;
                  const act=months[ym]?.totalCnt||0;
                  const diff=act-tgt;
                  const color=tgt===0?"#64748b":diff>=0?"#059669":"#dc2626";
                  return <td key={ym} style={{...tdS,color,fontWeight:tgt?700:400}}>{tgt?fmtN(diff):"-"}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>達成率</td>
                {ymList.map(ym=>{
                  const tgt=dbTargets[ym]?.cnt||0;
                  const act=months[ym]?.totalCnt||0;
                  const pct=tgt>0?act/tgt:0;
                  const bg=pct>=1?"#dcfce7":pct>=0.7?"#fef9c3":pct>0?"#fef2f2":"transparent";
                  return <td key={ym} style={{...tdS,background:bg,fontWeight:700}}>{tgt>0?(pct*100).toFixed(1)+"%":"-"}</td>;
                })}</tr>

              {/* ▼ セクション7: 運用・稼働・単価分析 */}
              {secH("▼ 運用・稼働・単価分析 — "+sLabel)}
              <tr><td style={{...tdL,paddingLeft:16}}>稼働台数(KPI active)</td>
                {ymList.map(ym=><td key={ym} style={tdS}>{months[ym]?.activeCount||0}台</td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>稼働率</td>
                {ymList.map((ym,i)=>{
                  const v=months[ym]?.utilPct||0;
                  const prev=i>0?(months[ymList[i-1]]?.utilPct||0):0;
                  const bg=v>=50?"#dcfce7":v>=30?"#fef9c3":"#fef2f2";
                  return <td key={ym} style={{...tdS,background:bg,fontWeight:700}}>{v}% {i>0&&chg(v,prev)}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>稼働日数</td>
                {ymList.map(ym=><td key={ym} style={tdS}>{months[ym]?.rentalDays||0}日</td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>最大稼働日数</td>
                {ymList.map(ym=><td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{months[ym]?.maxDays||0}日</td>)}</tr>
              <tr style={{background:"#fffbeb"}}><td style={{...tdL,paddingLeft:16,fontWeight:700}}>台/売上目標（入力可）</td>
                {ymList.map(ym=><td key={ym} style={{...tdS,padding:0}}><input type="number" value={dbTargets[ym]?.perV||""} onChange={e=>saveDbTarget(ym,"perV",e.target.value)} style={{width:"100%",border:"none",background:"#fffbeb",textAlign:"right",fontSize:10,padding:"3px 4px"}} placeholder="0"/></td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>台/売上実績</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const perV=m?.activeCount>0?Math.round(m.totalRev/m.activeCount):0;
                  return <td key={ym} style={tdS}>{fmtK(perV)}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>台/売上 達成率</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const tgt=dbTargets[ym]?.perV||0;
                  const perV=m?.activeCount>0?Math.round(m.totalRev/m.activeCount):0;
                  const pct=tgt>0?perV/tgt:0;
                  const bg=pct>=1?"#dcfce7":pct>=0.7?"#fef9c3":pct>0?"#fef2f2":"transparent";
                  return <td key={ym} style={{...tdS,background:bg}}>{tgt>0?(pct*100).toFixed(1)+"%":"-"}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>OTA 予約単価</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const otaRev=DB_CHANNELS.filter(c=>c!=="オフィシャル").reduce((s,c)=>(s+(m?.chRev[c]||0)),0);
                  const otaCnt=DB_CHANNELS.filter(c=>c!=="オフィシャル").reduce((s,c)=>(s+(m?.chCnt[c]||0)),0);
                  return <td key={ym} style={tdS}>{otaCnt>0?fmtK(Math.round(otaRev/otaCnt)):"-"}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>HP 予約単価</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const hpR=m?.chRev["オフィシャル"]||0;
                  const hpC=m?.chCnt["オフィシャル"]||0;
                  return <td key={ym} style={tdS}>{hpC>0?fmtK(Math.round(hpR/hpC)):"-"}</td>;
                })}</tr>
              <tr style={{fontWeight:700}}><td style={{...tdL,paddingLeft:16}}>全体 予約単価</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  return <td key={ym} style={{...tdS,fontWeight:700}}>{m?.totalCnt>0?fmtK(Math.round(m.totalRev/m.totalCnt)):"-"}</td>;
                })}</tr>

              {/* ▼ セクション8: 車両タイプ別稼働率 */}
              {secH("▼ 車両タイプ別 稼働率 — "+sLabel)}
              {DB_VEH_TYPES.map(t=>{
                const hasData=ymList.some(ym=>months[ym]?.vtUtil[t]>0);
                if(!hasData)return null;
                return <tr key={"vtu_"+t}><td style={{...tdL,paddingLeft:16}}>タイプ {t}</td>
                  {ymList.map(ym=>{
                    const v=months[ym]?.vtUtil[t]||0;
                    const bg=v>=50?"#dcfce7":v>=30?"#fef9c3":v>0?"#fef2f2":"transparent";
                    return <td key={ym} style={{...tdS,background:bg}}>{v>0?v.toFixed(1)+"%":"-"}</td>;
                  })}
                </tr>;
              })}

              {/* ▼ セクション9: 車両タイプ別売上 */}
              {secH("▼ 車両タイプ別 売上金額（計上ベース）— "+sLabel)}
              {DB_VEH_TYPES.map(t=>{
                const hasData=ymList.some(ym=>(months[ym]?.vtRev[t]||0)>0);
                if(!hasData)return null;
                return <tr key={"vtrev_"+t}><td style={{...tdL,paddingLeft:16}}>タイプ {t}</td>
                  {ymList.map(ym=><td key={ym} style={tdS}>{fmtK(months[ym]?.vtRev[t]||0)}</td>)}
                </tr>;
              })}
              <tr style={{fontWeight:800,background:"#f0fdf4"}}>
                <td style={{...tdL,fontWeight:800}}>合計</td>
                {ymList.map(ym=>{
                  const total=DB_VEH_TYPES.reduce((s,t)=>s+(months[ym]?.vtRev[t]||0),0);
                  return <td key={ym} style={{...tdS,fontWeight:800}}>{fmtK(total)}</td>;
                })}
              </tr>
              {/* 構成比率 */}
              <tr><td style={{...tdL,paddingLeft:16,fontSize:9,color:"#94a3b8"}} colSpan={ymList.length+1}>↳ 車両タイプ別 売上構成比率</td></tr>
              {DB_VEH_TYPES.map(t=>{
                const hasData=ymList.some(ym=>(months[ym]?.vtRev[t]||0)>0);
                if(!hasData)return null;
                return <tr key={"vtrevp_"+t}><td style={{...tdL,paddingLeft:24,fontSize:9,color:"#64748b"}}>タイプ {t}</td>
                  {ymList.map(ym=>{
                    const v=months[ym]?.vtRev[t]||0;
                    const total=DB_VEH_TYPES.reduce((s,tt)=>s+(months[ym]?.vtRev[tt]||0),0);
                    return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{total>0?fmtP(v/total):"-"}</td>;
                  })}
                </tr>;
              })}

              {/* ▼ セクション10: コスト・粗利サマリー */}
              {secH("▼ コスト・粗利サマリー — "+sLabel+"（月次コストより）")}
              <tr style={{background:"#fffbeb"}}><td style={{...tdL,paddingLeft:16,fontWeight:700}}>支出合計（入力可）</td>
                {ymList.map(ym=><td key={ym} style={{...tdS,padding:0}}><input type="number" value={dbTargets[ym]?.cost||""} onChange={e=>saveDbTarget(ym,"cost",e.target.value)} style={{width:"100%",border:"none",background:"#fffbeb",textAlign:"right",fontSize:10,padding:"3px 4px"}} placeholder="0"/></td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>売上合計（計上ベース）</td>
                {ymList.map(ym=><td key={ym} style={tdS}>{fmtK(months[ym]?.totalRev||0)}</td>)}</tr>
              <tr style={{fontWeight:800}}><td style={{...tdL,fontWeight:800}}>粗利（売上−支出）</td>
                {ymList.map(ym=>{
                  const cost=dbTargets[ym]?.cost||0;
                  const rev=months[ym]?.totalRev||0;
                  const gross=rev-cost;
                  const color=cost===0?"#334155":gross>=0?"#059669":"#dc2626";
                  return <td key={ym} style={{...tdS,fontWeight:800,color}}>{cost>0?fmtK(gross):fmtK(rev)}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>粗利率（粗利÷売上）</td>
                {ymList.map(ym=>{
                  const cost=dbTargets[ym]?.cost||0;
                  const rev=months[ym]?.totalRev||0;
                  const pct=rev>0?(rev-cost)/rev:0;
                  const bg=cost===0?"transparent":pct>=0.3?"#dcfce7":pct>=0?"#fef9c3":"#fef2f2";
                  return <td key={ym} style={{...tdS,background:bg,fontWeight:700}}>{cost>0?(pct*100).toFixed(1)+"%":"100%"}</td>;
                })}</tr>
            </tbody>
          </table>
        </div>;
      })()}
    </div>}

    {/* --- 予実比較 --- */}
    {sub==="yojitsu"&&(()=>{
      // 月列生成（2026-01 ~ 2027-12）
      const yjMonths=[];
      for(let y=2026;y<=2027;y++)for(let m=1;m<=12;m++)yjMonths.push(y+"-"+String(m).padStart(2,"0"));
      const thS2={padding:"4px 6px",fontSize:9,color:"#64748b",textAlign:"right",borderBottom:"2px solid #e2e8f0",fontWeight:700,background:"#f8fafc",whiteSpace:"nowrap",position:"sticky",top:0,zIndex:1};
      const tdS2={padding:"3px 6px",fontSize:10,textAlign:"right",borderBottom:"1px solid #f1f5f9",whiteSpace:"nowrap"};
      const tdL2={padding:"3px 6px",fontSize:10,textAlign:"left",borderBottom:"1px solid #f1f5f9",whiteSpace:"nowrap",position:"sticky",left:0,background:"#fff",zIndex:1};
      const secH2=(text)=><tr><td colSpan={yjMonths.length+1} style={{padding:"8px 6px 4px",fontSize:12,fontWeight:900,background:"#f0f9ff",color:"#0369a1",borderBottom:"2px solid #0ea5e9"}}>{text}</td></tr>;
      const fmtK2=(n)=>n==null||n===0?"-":"¥"+(Math.abs(n)>=10000?((n<0?"-":"")+(Math.round(Math.abs(n)/10000).toLocaleString()+"万")):(n<0?"-¥"+Math.abs(n).toLocaleString():"¥"+n.toLocaleString()));
      const inpS={width:"100%",border:"none",background:"#fffbeb",textAlign:"right",fontSize:10,padding:"3px 4px"};

      const renderStore=(st,label)=>{
        const d=yjData[st]||{};
        const cf=yjCf[st]||{};
        return <React.Fragment key={st}>
          {secH2("▼ "+label+" — 入金合計")}
          <tr><td style={{...tdL2,paddingLeft:16}}>実績（入金/計上）</td>
            {yjMonths.map(ym=>{
              const v=cf[ym]||0;
              return <td key={ym} style={{...tdS2,fontWeight:v>0?700:400}}>{fmtK2(v)}</td>;
            })}</tr>
          <tr style={{background:"#fffbeb"}}><td style={{...tdL2,paddingLeft:16,fontWeight:700}}>予算（入力可）</td>
            {yjMonths.map(ym=><td key={ym} style={{...tdS2,padding:0}}><input type="number" value={d[ym]?.budget||""} onChange={e=>saveYjField(st,ym,"budget",e.target.value)} style={inpS} placeholder="0"/></td>)}</tr>
          <tr><td style={{...tdL2,paddingLeft:16}}>差額（実績−予算）</td>
            {yjMonths.map(ym=>{
              const act=cf[ym]||0,bgt=d[ym]?.budget||0;
              const diff=act-bgt;
              const color=bgt===0?"#64748b":diff>=0?"#059669":"#dc2626";
              return <td key={ym} style={{...tdS2,color,fontWeight:bgt?700:400}}>{bgt?fmtK2(diff):"-"}</td>;
            })}</tr>
          <tr><td style={{...tdL2,paddingLeft:16}}>達成率</td>
            {yjMonths.map(ym=>{
              const act=cf[ym]||0,bgt=d[ym]?.budget||0;
              const pct=bgt>0?act/bgt:0;
              const bg=bgt===0?"transparent":pct>=1?"#dcfce7":pct>=0.7?"#fef9c3":"#fef2f2";
              return <td key={ym} style={{...tdS2,background:bg,fontWeight:700}}>{bgt>0?(pct*100).toFixed(1)+"%":"-"}</td>;
            })}</tr>
          <tr><td style={{...tdL2,paddingLeft:16,fontSize:9,color:"#94a3b8"}} colSpan={yjMonths.length+1}>↳ 調整欄（予算内訳メモ）</td></tr>
          {[1,2,3,4,5].map(n=>{const ak="_adj"+n+"t",fk="adj"+n;return <tr key={fk} style={{background:"#fffbeb"}}>
            <td style={{...tdL2,paddingLeft:24,padding:0}}><input type="text" value={d[ak]||""} onChange={e=>{const sd={...(yjData[st]||{})};sd[ak]=e.target.value;setYjData({...yjData,[st]:sd});}} onBlur={()=>{if(sb)sb.from("app_settings").upsert({key:"yojitsu_"+st,value:JSON.stringify(yjData[st]||{})},{onConflict:"key"});}} style={{...inpS,textAlign:"left",fontSize:9}} placeholder={"調整"+n+"（タイトル入力）"}/></td>
            {yjMonths.map(ym=><td key={ym} style={{...tdS2,padding:0}}><input type="number" value={(d[ym]||{})[fk]||""} onChange={e=>saveYjField(st,ym,fk,e.target.value)} style={inpS} placeholder="0"/></td>)}
          </tr>;})}
          <tr style={{fontWeight:700}}><td style={{...tdL2,paddingLeft:24,fontWeight:700}}>調整合計</td>
            {yjMonths.map(ym=>{
              const dd=d[ym]||{};
              const total=(dd.adj1||0)+(dd.adj2||0)+(dd.adj3||0)+(dd.adj4||0)+(dd.adj5||0);
              return <td key={ym} style={{...tdS2,fontWeight:700}}>{total?fmtK2(total):"-"}</td>;
            })}</tr>
        </React.Fragment>;
      };

      // 全体計算
      const renderTotal=()=>{
        const nD=yjData.nha||{},sD=yjData.spk||{},nCf=yjCf.nha||{},sCf=yjCf.spk||{};
        return <React.Fragment>
          {secH2("▼ 全体 — 入金合計")}
          <tr><td style={{...tdL2,paddingLeft:16}}>実績（入金/計上）</td>
            {yjMonths.map(ym=>{
              const v=(nCf[ym]||0)+(sCf[ym]||0);
              return <td key={ym} style={{...tdS2,fontWeight:v>0?700:400}}>{fmtK2(v)}</td>;
            })}</tr>
          <tr><td style={{...tdL2,paddingLeft:16}}>予算</td>
            {yjMonths.map(ym=>{
              const v=(nD[ym]?.budget||0)+(sD[ym]?.budget||0);
              return <td key={ym} style={tdS2}>{v?fmtK2(v):"-"}</td>;
            })}</tr>
          <tr><td style={{...tdL2,paddingLeft:16}}>差額</td>
            {yjMonths.map(ym=>{
              const act=(nCf[ym]||0)+(sCf[ym]||0);
              const bgt=(nD[ym]?.budget||0)+(sD[ym]?.budget||0);
              const diff=act-bgt;
              const color=bgt===0?"#64748b":diff>=0?"#059669":"#dc2626";
              return <td key={ym} style={{...tdS2,color,fontWeight:bgt?700:400}}>{bgt?fmtK2(diff):"-"}</td>;
            })}</tr>
          <tr><td style={{...tdL2,paddingLeft:16}}>達成率</td>
            {yjMonths.map(ym=>{
              const act=(nCf[ym]||0)+(sCf[ym]||0);
              const bgt=(nD[ym]?.budget||0)+(sD[ym]?.budget||0);
              const pct=bgt>0?act/bgt:0;
              const bg=bgt===0?"transparent":pct>=1?"#dcfce7":pct>=0.7?"#fef9c3":"#fef2f2";
              return <td key={ym} style={{...tdS2,background:bg,fontWeight:700}}>{bgt>0?(pct*100).toFixed(1)+"%":"-"}</td>;
            })}</tr>
        </React.Fragment>;
      };

      return <div>
        <div style={{fontSize:14,fontWeight:900,marginBottom:4}}>予実比較ダッシュボード — 入金予算 vs 実績</div>
        <div style={{fontSize:10,color:"#64748b",marginBottom:12}}>差額＝実績−予算　■ <span style={{color:"#059669"}}>緑＝実績が予算超過（有利）</span>　■ <span style={{color:"#dc2626"}}>赤＝実績が予算未達（不利）</span>　※実績は現在 売上計上ベース（入金タイミング反映は将来対応）</div>
        <div style={{overflow:"auto",maxHeight:"75vh",border:"1px solid #e2e8f0",borderRadius:8}}>
          <table style={{width:"100%",borderCollapse:"collapse",minWidth:yjMonths.length*80}}>
            <thead><tr>
              <th style={{...thS2,textAlign:"left",position:"sticky",left:0,zIndex:2,minWidth:180}}>店舗 / 指標</th>
              {yjMonths.map(ym=><th key={ym} style={thS2}>{ym.replace("20","").replace("-","/")}</th>)}
            </tr></thead>
            <tbody>
              {renderStore("tkm","高松")}
              {renderStore("spk","札幌")}
              {renderTotal()}
            </tbody>
          </table>
        </div>
      </div>;
    })()}

    {/* --- 設定 --- */}
    {sub==="settings"&&<div>
      <div style={{fontSize:14,fontWeight:900,marginBottom:12}}>設定・マスターデータ</div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16}}>
        {/* チャネルマスター */}
        <div style={{background:"#fff",border:"1px solid #e2e8f0",borderRadius:8,padding:12}}>
          <div style={{fontSize:12,fontWeight:800,marginBottom:8}}>チャネルマスター（入金サイクル）</div>
          <table style={{width:"100%",borderCollapse:"collapse"}}>
            <thead><tr>
              <th style={{fontSize:9,textAlign:"left",padding:"3px 6px",borderBottom:"2px solid #e2e8f0"}}>チャネル名</th>
              <th style={{fontSize:9,textAlign:"center",padding:"3px 6px",borderBottom:"2px solid #e2e8f0",width:80}}>入金サイクル(月後)</th>
              <th style={{fontSize:9,textAlign:"left",padding:"3px 6px",borderBottom:"2px solid #e2e8f0"}}>備考</th>
            </tr></thead>
            <tbody>
              {(mgSettings.channels||[]).map((ch,i)=><tr key={i}>
                <td style={{fontSize:10,padding:"3px 6px",borderBottom:"1px solid #f1f5f9"}}>{ch.name}</td>
                <td style={{padding:0,borderBottom:"1px solid #f1f5f9"}}><input type="number" value={ch.cycle} onChange={e=>{const chs=[...(mgSettings.channels||[])];chs[i]={...chs[i],cycle:parseInt(e.target.value)||0};saveMgSettings({...mgSettings,channels:chs});}} style={{width:"100%",textAlign:"center",border:"none",background:"#fffbeb",fontSize:10,padding:"3px 4px"}}/></td>
                <td style={{fontSize:9,padding:"3px 6px",borderBottom:"1px solid #f1f5f9",color:"#64748b"}}>{ch.note}</td>
              </tr>)}
            </tbody>
          </table>
        </div>
        {/* 主要前提 */}
        <div style={{background:"#fff",border:"1px solid #e2e8f0",borderRadius:8,padding:12}}>
          <div style={{fontSize:12,fontWeight:800,marginBottom:8}}>主要前提</div>
          {[
            {k:"initCash",l:"期初現金残高（円）",note:"銀行残高の期初値"},
            {k:"minCash",l:"最低必要残高（円）",note:"アラート基準"},
            {k:"runrateMonths",l:"ランレート基準月数",note:"直近N月平均でショート予測"},
          ].map(f=><div key={f.k} style={{display:"flex",alignItems:"center",gap:8,marginBottom:8}}>
            <span style={{fontSize:10,width:160,flexShrink:0}}>{f.l}</span>
            <input type="number" value={mgSettings[f.k]||0} onChange={e=>saveMgSettings({...mgSettings,[f.k]:parseInt(e.target.value)||0})} style={{width:120,border:"1px solid #e2e8f0",borderRadius:4,padding:"4px 8px",fontSize:11,background:"#fffbeb"}}/>
            <span style={{fontSize:9,color:"#64748b"}}>{f.note}</span>
          </div>)}
          <div style={{fontSize:12,fontWeight:800,marginTop:16,marginBottom:8}}>店舗マスター</div>
          <div style={{fontSize:10,color:"#334155"}}>1. 高松　2. 札幌</div>
          <div style={{fontSize:9,color:"#94a3b8",marginTop:4}}>※ 店舗の追加はAPPの管理者設定で行います</div>
        </div>
      </div>
      {/* 車両タイプ別台数（APPはSupabase vehiclesから自動取得） */}
      <div style={{background:"#fff",border:"1px solid #e2e8f0",borderRadius:8,padding:12,marginTop:16}}>
        <div style={{fontSize:12,fontWeight:800,marginBottom:4}}>車両タイプ別台数（自動 — Supabase vehicles / vehicle_monthly_kpi）</div>
        <div style={{fontSize:9,color:"#94a3b8",marginBottom:8}}>※ APPでは配車表の「稼働除外」フラグで月別台数を管理。Excelのような手入力不要。</div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
          {["tkm","spk"].map(st=>{
            const vehs=st==="spk"?dbVehs:[];
            const label=st==="tkm"?"高松":"札幌";
            return <div key={st}>
              <div style={{fontSize:11,fontWeight:700,marginBottom:4}}>{label}</div>
              <div style={{fontSize:9,color:"#64748b"}}>
                {st==="spk"&&dbVehs.length>0?
                  DB_VEH_TYPES.map(t=>{const c=dbVehs.filter(v=>(v.type||"")==t&&v.active!==false).length;return c>0?<span key={t} style={{marginRight:8}}>タイプ{t}: {c}台</span>:null;}):
                  <span>経営DBタブで店舗を選択するとロードされます</span>
                }
              </div>
            </div>;
          })}
        </div>
      </div>
    </div>}

    {/* --- ダッシュボード --- */}
    {sub==="dashboard"&&<div>
      <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:12}}>
        <span style={{fontSize:12,color:"#64748b"}}>対象月:</span>
        <input type="month" value={dashYm} onChange={e=>setDashYm(e.target.value)} style={{padding:"4px 8px",fontSize:12,border:"1px solid #cbd5e1",borderRadius:6}}/>
        <button onClick={()=>setSub("dashboard")} style={btn("#0891b2")}>↻ 再読込</button>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(160px,1fr))",gap:10,marginBottom:16}}>
        <div style={card}><div style={lbl}>当月売上 (計上)</div><div style={val}>{fmtM(dashSummary.plRev)}</div><div style={{fontSize:10,color:"#64748b"}}>{dashSummary.plCnt}件</div></div>
        <div style={card}><div style={lbl}>当月入金 (CF)</div><div style={val}>{fmtM(dashSummary.cfIn)}</div></div>
        <div style={card}><div style={lbl}>売上件数</div><div style={val}>{dashSummary.plCnt}件</div></div>
        <div style={card}><div style={lbl}>客単価 (1予約)</div><div style={val}>{dashSummary.plCnt>0?"¥"+Math.round(dashSummary.unitPrice).toLocaleString():"-"}</div></div>
        <div style={{...card,background:"#eef2ff",border:"1px solid #c7d2fe"}}><div style={lbl}>★ 平均泊数 (1予約あたり)</div><div style={{...val,color:"#4338ca"}}>{dashSummary.avgNights>0?dashSummary.avgNights.toFixed(2)+"泊":"-"}</div><div style={{fontSize:10,color:"#64748b"}}>総稼働 {dashSummary.daysSum.toFixed(1)}日</div></div>
        <div style={card}><div style={lbl}>1日あたり単価</div><div style={val}>{dashSummary.dailyRate>0?"¥"+Math.round(dashSummary.dailyRate).toLocaleString():"-"}</div></div>
      </div>
      <div style={{...card,marginBottom:12}}>
        <div style={{...h,fontSize:14}}>チャネル別構成 ({dashYm})</div>
        {Object.keys(dashSummary.byCh).length===0?<div style={{fontSize:11,color:"#94a3b8"}}>データなし</div>:
          <table style={{width:"100%",borderCollapse:"collapse"}}><tbody>
            {Object.entries(dashSummary.byCh).sort((a,b)=>b[1]-a[1]).map(([ch,rev])=>{
              const pct=dashSummary.plRev>0?(rev/dashSummary.plRev*100):0;
              return <tr key={ch}><td style={{...td,width:120}}>{ch}</td><td style={td}><div style={{width:"100%",height:14,background:"#f1f5f9",borderRadius:4,overflow:"hidden"}}><div style={{width:pct+"%",height:"100%",background:"#3b82f6"}}/></div></td><td style={{...td,textAlign:"right",width:100}}>{fmtM(rev)}</td><td style={{...td,textAlign:"right",width:60,fontWeight:700}}>{pct.toFixed(1)}%</td></tr>;
            })}
          </tbody></table>
        }
      </div>
    </div>}

    {/* --- 売上入力 --- */}
    {sub==="sales"&&(()=>{
      // 売上入力（Excel再現）— reservationsから自動表示
      const isSpkS=dbStore==="spk";
      const rdKeyS=isSpkS?"return_date":"end_date";
      const otaMapS={"HP":"オフィシャル","J":"じゃらん","R":"楽天","O":"エアトリ","A":"エアトリ","S":"スカイチケット","RC":"レンタカードットコム","G":"その他売上","direct":"その他売上"};
      const cycleMap={};(mgSettings.channels||[]).forEach(c=>{cycleMap[c.name]=c.cycle||0;});
      const salesList=dbResvs.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel").map(r=>{
        const rd=r[rdKeyS]||"";
        const ym=rd.slice(0,7);
        const ch=otaMapS[r.ota]||"その他売上";
        const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
        const rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
        const cycle=cycleMap[ch]||0;
        let payYm="-";
        if(rd){
          const dt=new Date(rd.slice(0,10));
          dt.setMonth(dt.getMonth()+cycle);
          payYm=dt.getFullYear()+"-"+String(dt.getMonth()+1).padStart(2,"0");
        }
        const ldS=isSpkS?r.lend_date:r.start_date;
        let days=0;
        if(ldS&&rd){const d1=new Date(ldS.slice(0,10)),d2=new Date(rd.slice(0,10));days=Math.max(1,Math.round((d2-d1)/86400000));}
        return{id:r.id,resv:r.resv_no||r.id,ch,rd:rd.slice(0,10),bp,op,dc,rev,ym,payYm,days,vt:r.vehicle||r.vehicle_class||"-",del:isSpkS?"DEL":(r.visit_type||"-")};
      }).sort((a,b)=>b.rd.localeCompare(a.rd));
      const filtered=salesList.filter(r=>{
        if(salesYmF&&r.ym!==salesYmF)return false;
        if(salesChF&&r.ch!==salesChF)return false;
        return true;
      });
      const totalRev=filtered.reduce((s,r)=>s+r.rev,0);
      return <div>
      <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:8}}>
        {["tkm","spk"].map(s=>{
          const sel2=dbStore===s;
          return <button key={s} onClick={()=>setDbStore(s)} style={{padding:"6px 16px",fontSize:13,fontWeight:800,borderRadius:8,border:sel2?"2px solid #1e40af":"2px solid #e2e8f0",cursor:"pointer",background:sel2?"#1e40af":"#fff",color:sel2?"#fff":"#334155"}}>{s==="tkm"?"高松店":"札幌店"}</button>;
        })}
        <span style={{fontSize:10,color:"#94a3b8"}}>※ reservationsから全自動表示（Excel売上入力シートと同等）</span>
      </div>
      <div style={{display:"flex",gap:6,marginBottom:10,flexWrap:"wrap",alignItems:"center"}}>
        <span style={{fontSize:11,color:"#64748b"}}>フィルタ:</span>
        <input type="month" value={salesYmF} onChange={e=>setSalesYmF(e.target.value)} style={{padding:"4px 8px",fontSize:11,border:"1px solid #cbd5e1",borderRadius:6}}/>
        <select value={salesChF} onChange={e=>setSalesChF(e.target.value)} style={{padding:"4px 8px",fontSize:11,border:"1px solid #cbd5e1",borderRadius:6}}>
          <option value="">全チャネル</option>
          {DB_CHANNELS.map(c=><option key={c} value={c}>{c}</option>)}
        </select>
        <button onClick={()=>{setSalesYmF("");setSalesChF("");}} style={{...btn("#f1f5f9"),color:"#334155"}}>クリア</button>
        <div style={{flex:1}}/>
        <span style={{fontSize:11,fontWeight:700}}>{filtered.length}件 / 合計 ¥{totalRev.toLocaleString()}</span>
      </div>

      <div style={{overflow:"auto",maxHeight:"65vh",border:"1px solid #e2e8f0",borderRadius:8}}>
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
          <thead style={{position:"sticky",top:0,zIndex:1}}>
            <tr>
              <th style={th}>予約番号</th>
              <th style={th}>チャネル</th>
              <th style={th}>計上日(返却)</th>
              <th style={{...th,textAlign:"right"}}>基本料金</th>
              <th style={{...th,textAlign:"right"}}>付帯売上</th>
              <th style={{...th,textAlign:"right"}}>割引</th>
              <th style={{...th,textAlign:"right"}}>合計売上</th>
              <th style={th}>車両</th>
              <th style={th}>日数</th>
              <th style={th}>DEL</th>
              <th style={th}>計上月</th>
              <th style={th}>入金月</th>
            </tr>
          </thead>
          <tbody>
            {filtered.slice(0,500).map(r=><tr key={r.id}>
              <td style={{...td,fontFamily:"monospace",fontSize:9}}>{r.resv}</td>
              <td style={td}>{r.ch}</td>
              <td style={td}>{r.rd}</td>
              <td style={{...td,textAlign:"right"}}>¥{r.bp.toLocaleString()}</td>
              <td style={{...td,textAlign:"right"}}>¥{r.op.toLocaleString()}</td>
              <td style={{...td,textAlign:"right",color:r.dc?"#dc2626":"#94a3b8"}}>{r.dc?"-¥"+r.dc.toLocaleString():"0"}</td>
              <td style={{...td,textAlign:"right",fontWeight:700}}>¥{r.rev.toLocaleString()}</td>
              <td style={td}>{r.vt}</td>
              <td style={td}>{r.days||"-"}</td>
              <td style={td}>{r.del}</td>
              <td style={{...td,fontSize:9,color:"#64748b"}}>{r.ym}</td>
              <td style={{...td,fontSize:9,color:"#64748b"}}>{r.payYm}</td>
            </tr>)}
            {filtered.length===0&&<tr><td colSpan={12} style={{padding:24,textAlign:"center",color:"#94a3b8",fontSize:12}}>データなし（経営DBタブでデータをロードしてください）</td></tr>}
            {filtered.length>500&&<tr><td colSpan={12} style={{padding:8,textAlign:"center",color:"#94a3b8",fontSize:10}}>表示上限500件（全{filtered.length}件）</td></tr>}
          </tbody>
        </table>
      </div>
    </div>;})()}

    {/* --- PL --- */}
    {sub==="pl"&&<div>
      <div style={{marginBottom:10,fontSize:11,color:"#64748b"}}>📘 月次PL = 計上月（返却日ベース）のチャネル別売上集計 + 平均泊数 + 客単価</div>
      <div style={{display:"flex",gap:6,marginBottom:10}}>
        {["tkm","spk"].map(s=><button key={s} onClick={()=>setDbStore(s)} style={{padding:"4px 12px",fontSize:11,fontWeight:700,borderRadius:6,border:"none",cursor:"pointer",background:dbStore===s?"#1e40af":"#e2e8f0",color:dbStore===s?"#fff":"#334155"}}>{s==="tkm"?"高松":"札幌"}</button>)}
      </div>
      {dbLoading2?<div style={{padding:24,textAlign:"center",color:"#94a3b8"}}>読込中...</div>:
      <div style={{overflow:"auto",maxHeight:"70vh",border:"1px solid #e2e8f0",borderRadius:8}}>
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
          <thead><tr>
            <th style={th}>年月</th>
            {plPivot.chs.map(ch=><th key={ch} style={{...th,textAlign:"right"}}>{ch}</th>)}
            <th style={{...th,textAlign:"right",background:"#dbeafe"}}>売上合計</th>
            <th style={{...th,textAlign:"right"}}>件数</th>
            <th style={{...th,textAlign:"right",background:"#eef2ff"}}>平均泊数</th>
            <th style={{...th,textAlign:"right"}}>客単価</th>
            <th style={{...th,textAlign:"right"}}>日単価</th>
          </tr></thead>
          <tbody>
            {plPivot.yms.map(ym=>{
              const total=plPivot.chs.reduce((a,ch)=>a+((plPivot.map[ym+"|"+ch]||{}).revenue||0),0);
              const cnt=plPivot.chs.reduce((a,ch)=>a+((plPivot.map[ym+"|"+ch]||{}).count||0),0);
              const d=(plPivot.daysByYm||{})[ym]||{sum:0,cnt:0};
              const avgN=d.cnt>0?(d.sum/d.cnt):0;
              const unit=cnt>0?(total/cnt):0;
              const daily=d.sum>0?(total/d.sum):0;
              const otaTotal=plPivot.chs.filter(c=>c!=="オフィシャル"&&c!=="その他売上").reduce((a,ch)=>a+((plPivot.map[ym+"|"+ch]||{}).revenue||0),0);
              return <tr key={ym}>
                <td style={{...td,fontWeight:700}}>{ym}</td>
                {plPivot.chs.map(ch=>{
                  const v=(plPivot.map[ym+"|"+ch]||{}).revenue||0;
                  return <td key={ch} style={{...td,textAlign:"right",color:v>0?"#0f172a":"#cbd5e1"}}>{v>0?"¥"+fmt(v):"-"}</td>;
                })}
                <td style={{...td,textAlign:"right",fontWeight:800,background:"#eff6ff"}}>¥{fmt(total)}</td>
                <td style={{...td,textAlign:"right"}}>{cnt}</td>
                <td style={{...td,textAlign:"right",background:"#eef2ff",fontWeight:700,color:"#4338ca"}}>{avgN>0?avgN.toFixed(1):"-"}</td>
                <td style={{...td,textAlign:"right"}}>{unit>0?"¥"+fmt(Math.round(unit)):"-"}</td>
                <td style={{...td,textAlign:"right",color:"#059669"}}>{daily>0?"¥"+fmt(Math.round(daily)):"-"}</td>
              </tr>;
            })}
            {plPivot.yms.length>0&&(()=>{
              const grandTotal=plPivot.yms.reduce((a,ym)=>a+plPivot.chs.reduce((b,ch)=>b+((plPivot.map[ym+"|"+ch]||{}).revenue||0),0),0);
              const grandCnt=plPivot.yms.reduce((a,ym)=>a+plPivot.chs.reduce((b,ch)=>b+((plPivot.map[ym+"|"+ch]||{}).count||0),0),0);
              return <tr style={{background:"#f0f9ff",fontWeight:800}}>
                <td style={{...td,fontWeight:900}}>累計</td>
                {plPivot.chs.map(ch=>{
                  const v=plPivot.yms.reduce((a,ym)=>a+((plPivot.map[ym+"|"+ch]||{}).revenue||0),0);
                  return <td key={ch} style={{...td,textAlign:"right"}}>{v>0?"¥"+fmt(v):"-"}</td>;
                })}
                <td style={{...td,textAlign:"right",background:"#dbeafe"}}>¥{fmt(grandTotal)}</td>
                <td style={{...td,textAlign:"right"}}>{grandCnt}</td>
                <td style={td}>-</td>
                <td style={{...td,textAlign:"right"}}>{grandCnt>0?"¥"+fmt(Math.round(grandTotal/grandCnt)):"-"}</td>
                <td style={td}>-</td>
              </tr>;
            })()}
            {plPivot.yms.length===0&&<tr><td colSpan={plPivot.chs.length+6} style={{padding:24,textAlign:"center",color:"#94a3b8",fontSize:12}}>データなし — 上の店舗ボタンで切り替えてください</td></tr>}
          </tbody>
        </table>
      </div>}
    </div>}

    {/* --- CF --- */}
    {sub==="cf"&&(()=>{
      const expByYm=cfPivot.expByYm||{};
      let cumBal=mgSettings.initCash||0;
      return <div>
      <div style={{marginBottom:10,fontSize:11,color:"#64748b"}}>💰 月次CF = 入金（チャネル別入金サイクル自動計算）− 支出予算（コスト入力から自動取得）→ 純収支・残高推移</div>
      <div style={{display:"flex",gap:6,marginBottom:10}}>
        {["tkm","spk"].map(s=><button key={s} onClick={()=>setDbStore(s)} style={{padding:"4px 12px",fontSize:11,fontWeight:700,borderRadius:6,border:"none",cursor:"pointer",background:dbStore===s?"#059669":"#e2e8f0",color:dbStore===s?"#fff":"#334155"}}>{s==="tkm"?"高松":"札幌"}</button>)}
      </div>
      <div style={{marginBottom:8,fontSize:10,color:"#94a3b8"}}>入金サイクル: {(mgSettings.channels||[]).map(c=>c.name+"="+c.cycle+"ヶ月").join(" / ")} | 期初残高: ¥{fmt(mgSettings.initCash||0)}</div>
      {dbLoading2?<div style={{padding:24,textAlign:"center",color:"#94a3b8"}}>読込中...</div>:
      <div style={{overflow:"auto",maxHeight:"70vh",border:"1px solid #e2e8f0",borderRadius:8}}>
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
          <thead><tr>
            <th style={th}>月</th>
            {cfPivot.chs.map(ch=><th key={ch} style={{...th,textAlign:"right",fontSize:9}}>{ch.slice(0,4)}</th>)}
            <th style={{...th,textAlign:"right",background:"#dcfce7"}}>入金計</th>
            <th style={{...th,textAlign:"right",background:"#fef2f2"}}>返済</th>
            <th style={{...th,textAlign:"right",background:"#fef2f2"}}>販管費</th>
            <th style={{...th,textAlign:"right",background:"#fef2f2"}}>売上原価</th>
            <th style={{...th,textAlign:"right",background:"#fee2e2"}}>支出計</th>
            <th style={{...th,textAlign:"right",background:"#fef9c3"}}>純収支</th>
            <th style={{...th,textAlign:"right",background:"#fef9c3"}}>残高</th>
          </tr></thead>
          <tbody>
            {cfPivot.yms.map(ym=>{
              const cashIn=cfPivot.chs.reduce((a,ch)=>a+((cfPivot.map[ym+"|"+ch]||{}).cash_in||0),0);
              const exp=expByYm[ym]||{repay:0,sga:0,cogs:0,total:0};
              const net=cashIn-exp.total;
              cumBal+=net;
              return <tr key={ym}>
                <td style={{...td,fontWeight:700}}>{ym}</td>
                {cfPivot.chs.map(ch=>{
                  const v=(cfPivot.map[ym+"|"+ch]||{}).cash_in||0;
                  return <td key={ch} style={{...td,textAlign:"right",color:v>0?"#0f172a":"#cbd5e1",fontSize:9}}>{v>0?"¥"+fmt(v):"-"}</td>;
                })}
                <td style={{...td,textAlign:"right",fontWeight:800,background:"#f0fdf4",color:"#059669"}}>¥{fmt(cashIn)}</td>
                <td style={{...td,textAlign:"right",background:"#fef2f2",color:exp.repay>0?"#dc2626":"#cbd5e1"}}>{exp.repay>0?"¥"+fmt(exp.repay):"-"}</td>
                <td style={{...td,textAlign:"right",background:"#fef2f2",color:exp.sga>0?"#dc2626":"#cbd5e1"}}>{exp.sga>0?"¥"+fmt(exp.sga):"-"}</td>
                <td style={{...td,textAlign:"right",background:"#fef2f2",color:exp.cogs>0?"#dc2626":"#cbd5e1"}}>{exp.cogs>0?"¥"+fmt(exp.cogs):"-"}</td>
                <td style={{...td,textAlign:"right",fontWeight:800,background:"#fee2e2",color:"#dc2626"}}>{exp.total>0?"¥"+fmt(exp.total):"-"}</td>
                <td style={{...td,textAlign:"right",fontWeight:800,color:net>=0?"#059669":"#dc2626"}}>¥{fmt(net)}</td>
                <td style={{...td,textAlign:"right",fontWeight:800,background:cumBal<0?"#fecaca":"#fef9c3",color:cumBal>=0?"#92400e":"#dc2626"}}>¥{fmt(Math.round(cumBal))}</td>
              </tr>;
            })}
            {cfPivot.yms.length===0&&<tr><td colSpan={cfPivot.chs.length+8} style={{padding:24,textAlign:"center",color:"#94a3b8",fontSize:12}}>データなし</td></tr>}
          </tbody>
        </table>
      </div>}
      {Object.keys(expByYm).length===0&&<div style={{marginTop:8,padding:8,background:"#fffbeb",borderRadius:6,fontSize:11,color:"#92400e"}}>⚠️ 支出予算が未入力です。「コスト入力」タブから月別に返済・販管費・売上原価を入力すると、CFに自動反映されます。</div>}
    </div>;
    })()}

    {/* --- コスト入力 --- */}
    {sub==="cost"&&(()=>{
      const COST_ACCOUNTS=[
        {cat:"返済（CFのみ反映）",items:[
          {code:"repay_1",name:"返済①（道銀/北洋）"},
          {code:"repay_2",name:"返済②（沖銀）"},
          {code:"repay_3",name:"返済③（IUR）"},
          {code:"repay_4",name:"返済④"},
          {code:"repay_5",name:"返済⑤（LAB）"},
        ]},
        {cat:"販管費",items:[
          {code:"sga_social_ins",name:"社会保険"},
          {code:"sga_salary",name:"給与���計"},
          {code:"sga_ota_fee",name:"手数料合計（OTA等）"},
          {code:"sga_telecom",name:"通信費"},
          {code:"sga_fuel",name:"ガソリン代"},
          {code:"sga_travel",name:"出張費"},
          {code:"sga_office",name:"消耗品"},
          {code:"sga_ad",name:"広告費"},
          {code:"sga_transport",name:"移動費"},
          {code:"sga_utility",name:"光熱費"},
          {code:"sga_tax",name:"税金"},
          {code:"sga_repair",name:"車両修理"},
          {code:"sga_construction",name:"工事"},
          {code:"sga_other",name:"その他販管費"},
        ]},
        {cat:"売上原価",items:[
          {code:"cogs_lease",name:"リース/ローン合計"},
          {code:"cogs_insurance",name:"保険"},
          {code:"cogs_inspection",name:"車���費（車検）"},
          {code:"cogs_maintenance",name:"車両費（点検/整備）"},
          {code:"cogs_repair",name:"修理"},
          {code:"cogs_rent",name:"賃料合計（ヤード等）"},
          {code:"cogs_other",name:"その他原価"},
        ]},
      ];
      return <div>
        <div style={{marginBottom:8,fontSize:11,color:"#64748b"}}>🧾 支出予算の入力（コスト内訳）。ここに入力した内容は CF(月次) の支出欄に自動反映されます。</div>
        <div style={{display:"flex",gap:8,alignItems:"center",marginBottom:10,flexWrap:"wrap"}}>
          <div style={{display:"flex",gap:6}}>
            {["tkm","spk"].map(s=><button key={s} onClick={()=>{setDbStore(s);if(costYm)setTimeout(()=>loadCost(costYm),100);}} style={{padding:"4px 12px",fontSize:11,fontWeight:700,borderRadius:6,border:"none",cursor:"pointer",background:dbStore===s?"#dc2626":"#e2e8f0",color:dbStore===s?"#fff":"#334155"}}>{s==="tkm"?"高松":"札幌"}</button>)}
          </div>
          <span style={{fontSize:12,color:"#64748b"}}>対象月:</span>
          <input type="month" value={costYm} onChange={e=>{setCostYm(e.target.value);loadCost(e.target.value);}} style={{padding:"4px 8px",fontSize:12,border:"1px solid #cbd5e1",borderRadius:6}}/>
        </div>
        {COST_ACCOUNTS.map(({cat,items})=>{
          const catTotal=items.reduce((s,a)=>s+((costRows.find(r=>r.account_code===a.code)||{}).amount||0),0);
          return <div key={cat} style={{...card,marginBottom:12}}>
            <div style={{...h,fontSize:14,display:"flex",justifyContent:"space-between",alignItems:"center"}}>
              <span>{cat}</span>
              <span style={{fontSize:12,color:"#1e40af"}}>合計 ¥{fmt(catTotal)}</span>
            </div>
            <table style={{width:"100%",borderCollapse:"collapse"}}>
              <tbody>
                {items.map(a=>{
                  const cur=costRows.find(r=>r.account_code===a.code)||{amount:0,note:""};
                  return <tr key={a.code}>
                    <td style={{...td,paddingLeft:8,width:"40%"}}>{a.name}</td>
                    <td style={{...td,textAlign:"right",width:140}}>
                      <input type="number" style={{...inp,textAlign:"right"}} defaultValue={cur.amount||0} onBlur={e=>{const v=parseInt(e.target.value||0)||0;if(v!==(cur.amount||0))saveCostEntry(costYm,a.code,v,cur.note);}}/>
                    </td>
                    <td style={{...td,width:200}}>
                      <input style={inp} defaultValue={cur.note||""} placeholder="メモ" onBlur={e=>{if(e.target.value!==(cur.note||""))saveCostEntry(costYm,a.code,cur.amount||0,e.target.value);}}/>
                    </td>
                  </tr>;
                })}
              </tbody>
            </table>
          </div>;
        })}
        {!costYm&&<div style={{padding:24,textAlign:"center",color:"#94a3b8",fontSize:12}}>対象月を選択してください</div>}
      </div>;
    })()}

    {/* --- コスト一覧（月次サマリー） --- */}
    {sub==="costsum"&&(()=>{
      const COST_ITEMS=[
        {cat:"返済",items:[{name:"返済①",code:"repay_1"},{name:"返済②",code:"repay_2"},{name:"返済③",code:"repay_3"},{name:"返済④",code:"repay_4"},{name:"返済⑤",code:"repay_5"}]},
        {cat:"販管費",items:[{name:"社会保険",code:"sga_social_ins"},{name:"給与合計",code:"sga_salary"},{name:"手数料合計",code:"sga_ota_fee"},{name:"通信費",code:"sga_telecom"},{name:"ガソリン代",code:"sga_fuel"},{name:"出張費",code:"sga_travel"},{name:"消耗品",code:"sga_office"},{name:"広告費",code:"sga_ad"},{name:"移動費",code:"sga_transport"},{name:"光熱費",code:"sga_utility"},{name:"税金",code:"sga_tax"},{name:"車両修理",code:"sga_repair"},{name:"工事",code:"sga_construction"},{name:"その他",code:"sga_other"}]},
        {cat:"売上原価",items:[{name:"リース/ローン",code:"cogs_lease"},{name:"保険",code:"cogs_insurance"},{name:"車検",code:"cogs_inspection"},{name:"点検/整備",code:"cogs_maintenance"},{name:"修理",code:"cogs_repair"},{name:"賃料合計",code:"cogs_rent"},{name:"その他",code:"cogs_other"}]},
      ];
      // 月別コストは costAllMonths を使用
      const costMonthly=costAllMonths;
      const csLoading=false;
      const _stLabel=dbStore==="spk"?"札幌":"高松";
      const yms_inner=Object.keys(costMonthly).sort();
      // Compatibility block
      const setCostMonthly_=()=>{};
      const setCsLoading_=()=>{};
      const yms=yms_inner;
      const store_=dbStore;
      // render below uses old var names, map COST_ITEMS
      return <div>
        <div style={{display:"flex",gap:6,marginBottom:10}}>
          {["tkm","spk"].map(s=><button key={s} onClick={()=>setDbStore(s)} style={{padding:"4px 12px",fontSize:11,fontWeight:700,borderRadius:6,border:"none",cursor:"pointer",background:dbStore===s?"#7c3aed":"#e2e8f0",color:dbStore===s?"#fff":"#334155"}}>{s==="tkm"?"高松":"札幌"}</button>)}
        </div>
        <div style={{...h,fontSize:14}}>📋 月次コスト一覧（{_stLabel}）</div>
        {yms.length===0?<div style={{padding:24,textAlign:"center",color:"#94a3b8",fontSize:12}}>コストデータなし。「コスト入力」タブから月別に入力してください。</div>:
        <div style={{overflow:"auto",maxHeight:"70vh",border:"1px solid #e2e8f0",borderRadius:8}}>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
            <thead><tr>
              <th style={th}>科目</th>
              {yms.map(ym=><th key={ym} style={{...th,textAlign:"right"}}>{ym}</th>)}
            </tr></thead>
            <tbody>
              {COST_ITEMS.map(({cat,items})=><React.Fragment key={cat}>
                <tr style={{background:"#f0f9ff"}}><td colSpan={yms.length+1} style={{...td,fontWeight:900,fontSize:11}}>{cat}</td></tr>
                {items.map(({name,code})=>{
                  return <tr key={code}>
                    <td style={{...td,paddingLeft:16}}>{name}</td>
                    {yms.map(ym=>{
                      const rows=costMonthly[ym]||[];
                      const v=(rows.find(r=>r.account_code===code)||{}).amount||0;
                      return <td key={ym} style={{...td,textAlign:"right",color:v>0?"#0f172a":"#cbd5e1"}}>{v>0?"¥"+fmt(v):"-"}</td>;
                    })}
                  </tr>;
                })}
                <tr style={{background:"#f8fafc",fontWeight:700}}>
                  <td style={td}>{cat}計</td>
                  {yms.map(ym=>{
                    const rows=costMonthly[ym]||[];
                    const total=items.reduce((s,{code})=>s+((rows.find(r=>r.account_code===code)||{}).amount||0),0);
                    return <td key={ym} style={{...td,textAlign:"right",color:"#1e40af"}}>¥{fmt(total)}</td>;
                  })}
                </tr>
              </React.Fragment>)}
            </tbody>
          </table>
        </div>}
      </div>;
    })()}

    {/* --- HP-CV（オフィシャル予約件数） --- */}
    {sub==="hpcv"&&(()=>{
      const isSpk=dbStore==="spk";
      const rdKey=isSpk?"return_date":"end_date";
      const hpResvs=dbResvs.filter(r=>r.ota==="HP"&&r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel").sort((a,b)=>(a[rdKey]||"").localeCompare(b[rdKey]||""));
      const byMonth={};
      hpResvs.forEach(r=>{
        const ym=(r[rdKey]||"").slice(0,7);if(!ym)return;
        if(!byMonth[ym])byMonth[ym]=[];
        byMonth[ym].push(r);
      });
      const months=Object.keys(byMonth).sort();
      return <div>
        <div style={{display:"flex",gap:6,marginBottom:10}}>
          {["tkm","spk"].map(s=><button key={s} onClick={()=>setDbStore(s)} style={{padding:"4px 12px",fontSize:11,fontWeight:700,borderRadius:6,border:"none",cursor:"pointer",background:dbStore===s?"#2563eb":"#e2e8f0",color:dbStore===s?"#fff":"#334155"}}>{s==="tkm"?"高松":"札幌"}</button>)}
        </div>
        {dbLoading2?<div style={{padding:24,textAlign:"center",color:"#94a3b8"}}>読込中...</div>:
        months.length===0?<div style={{padding:24,textAlign:"center",color:"#94a3b8",fontSize:12}}>HP予約なし</div>:
        months.map(ym=>{
          const rows=byMonth[ym];
          const total=rows.reduce((s,r)=>{const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;return s+((bp>0||op>0)?(bp+op-dc):(Number(r.price)||0));},0);
          return <div key={ym} style={{...card,marginBottom:12}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
              <span style={{fontSize:14,fontWeight:900}}>{ym}</span>
              <span style={{fontSize:12,fontWeight:700,color:"#1e40af"}}>{rows.length}件 / ¥{fmt(total)}</span>
            </div>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
              <thead><tr>
                <th style={th}>#</th><th style={th}>予約番号</th><th style={{...th,textAlign:"right"}}>金額</th><th style={th}>店舗</th><th style={th}>返却日</th>
              </tr></thead>
              <tbody>
                {rows.map((r,i)=>{
                  const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
                  const rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
                  return <tr key={r.id}><td style={td}>{i+1}</td><td style={td}>{r.reservation_id||r.id}</td><td style={{...td,textAlign:"right"}}>¥{fmt(rev)}</td><td style={td}>{isSpk?"札幌":"高松"}</td><td style={td}>{(r[rdKey]||"").slice(0,10)}</td></tr>;
                })}
              </tbody>
            </table>
          </div>;
        })}
      </div>;
    })()}

    {/* --- 予算CF --- */}
    {sub==="budgetcf"&&(()=>{
      const saveBcf=async(st,ym,field,val)=>{
        const nv=parseFloat(val)||0;
        const next={...bcfData,[st]:{...(bcfData[st]||{}),[ym]:{...((bcfData[st]||{})[ym]||{}),[field]:nv}}};
        setBcfData(next);
        const key="budgetcf_"+st;
        await sb.from("app_settings").upsert({key,value:JSON.stringify(next[st])},{onConflict:"key"});
      };
      const chNames=["オフィシャル","じゃらん","楽天","エアトリ","レンタカードットコム","スカイチケット","その他売上"];
      const cycles={};(mgSettings.channels||[]).forEach(c=>{cycles[c.name]=c.cycle||0;});
      // Generate 24 months
      const yms24=[];
      for(let i=0;i<24;i++){const d=new Date(2026,i,1);yms24.push(d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0"));}
      const stData=bcfData[bcfStore]||{};
      // 予算売上→OTA構成比→入金月計算
      const cashByYm={};
      yms24.forEach(ym=>{
        const d=stData[ym]||{};
        const budgetRev=d.budgetRev||0;
        chNames.forEach(ch=>{
          const ratio=d["r_"+ch]||(ch==="オフィシャル"?0.3:ch==="じゃらん"?0.15:ch==="楽天"?0.35:ch==="エアトリ"?0.1:ch==="スカイチケット"?0.1:0);
          const rev=budgetRev*ratio;
          const cycle=cycles[ch]||0;
          const[sy,sm]=ym.split("-").map(Number);
          let ny=sy,nm=sm+cycle;while(nm>12){nm-=12;ny++;}
          const cashYm=ny+"-"+String(nm).padStart(2,"0");
          if(!cashByYm[cashYm])cashByYm[cashYm]={};
          cashByYm[cashYm][ch]=(cashByYm[cashYm][ch]||0)+rev;
        });
      });
      return <div>
        <div style={{display:"flex",gap:6,marginBottom:10}}>
          {["tkm","spk","all"].map(s=><button key={s} onClick={()=>setBcfStore(s)} style={{padding:"4px 12px",fontSize:11,fontWeight:700,borderRadius:6,border:"none",cursor:"pointer",background:bcfStore===s?"#7c3aed":"#e2e8f0",color:bcfStore===s?"#fff":"#334155"}}>{s==="tkm"?"高松":s==="spk"?"札幌":"全体"}</button>)}
        </div>
        <div style={{fontSize:11,color:"#64748b",marginBottom:8}}>月別予算売上とOTA構成比を入力 → 入金月を自動シミュレーション</div>
        <div style={{overflow:"auto",maxHeight:"70vh",border:"1px solid #e2e8f0",borderRadius:8}}>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
            <thead><tr>
              <th style={th}>年月</th>
              <th style={{...th,textAlign:"right",background:"#fffbeb"}}>予算売上</th>
              {chNames.map(ch=><th key={ch} style={{...th,textAlign:"right",fontSize:9}}>{ch.slice(0,4)}</th>)}
              <th style={{...th,textAlign:"right",background:"#dcfce7"}}>入金合計</th>
            </tr></thead>
            <tbody>
              {yms24.map(ym=>{
                const d=stData[ym]||{};
                const cashRow=cashByYm[ym]||{};
                const cashTotal=Object.values(cashRow).reduce((a,b)=>a+b,0);
                return <tr key={ym}>
                  <td style={{...td,fontWeight:700}}>{ym}</td>
                  <td style={{...td,textAlign:"right",background:"#fffbeb"}}>
                    {bcfStore!=="all"?<input type="number" style={{...inp,textAlign:"right",width:100}} defaultValue={d.budgetRev||0} onBlur={e=>saveBcf(bcfStore,ym,"budgetRev",e.target.value)}/>:
                    <span>¥{fmt((((bcfData.nha||{})[ym]||{}).budgetRev||0)+(((bcfData.spk||{})[ym]||{}).budgetRev||0))}</span>}
                  </td>
                  {chNames.map(ch=>{
                    const ratio=d["r_"+ch];
                    return <td key={ch} style={{...td,textAlign:"right",fontSize:9}}>
                      {bcfStore!=="all"?<input type="number" step="0.01" style={{...inp,textAlign:"right",width:50,fontSize:9}} defaultValue={ratio!=null?ratio:(ch==="オフィシャル"?0.3:ch==="じゃらん"?0.15:ch==="楽天"?0.35:ch==="エアトリ"?0.1:ch==="スカイチケット"?0.1:0)} onBlur={e=>saveBcf(bcfStore,ym,"r_"+ch,e.target.value)}/>:
                      <span>{((ratio||0)*100).toFixed(0)}%</span>}
                    </td>;
                  })}
                  <td style={{...td,textAlign:"right",fontWeight:800,background:"#f0fdf4",color:"#059669"}}>¥{fmt(Math.round(cashTotal))}</td>
                </tr>;
              })}
            </tbody>
          </table>
        </div>
      </div>;
    })()}

    {/* --- 投資回転率 --- */}
    {sub==="roi"&&(()=>{
      const isSpk=dbStore==="spk";
      const rdKey=isSpk?"return_date":"end_date";
      const fMap={};dbFleet.forEach(f=>{fMap[f.reservation_id]=f.vehicle_code;});
      const vMap={};dbVehs.forEach(v=>{vMap[v.code]=v;});
      const active=dbResvs.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");
      // クラス別集計
      const types=isSpk?["A","B","C","S","F","H"]:["A","A2","B","B2","C","D","S","F","H"];
      const typeStat={};
      types.forEach(t=>{typeStat[t]={rev:0,cnt:0,vehs:dbVehs.filter(v=>(v.type||"")==t&&v.active!==false).length};});
      active.forEach(r=>{
        const rd=r[rdKey];if(!rd)return;
        const vc=fMap[r.id];const vObj=vc?vMap[vc]:null;
        let vType="?";
        if(vObj)vType=vObj.type||"?";
        else if(isSpk&&r.vehicle)vType=r.vehicle;
        else if(!isSpk&&r.vehicle_class)vType=r.vehicle_class;
        if(!typeStat[vType])return;
        const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
        const rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
        typeStat[vType].rev+=rev;typeStat[vType].cnt+=1;
      });
      // 月数（データ期間）
      const ymSet=new Set();
      active.forEach(r=>{const rd=r[rdKey];if(rd)ymSet.add(rd.slice(0,7));});
      const monthCount=ymSet.size||1;
      return <div>
        <div style={{display:"flex",gap:6,marginBottom:10}}>
          {["tkm","spk"].map(s=><button key={s} onClick={()=>setDbStore(s)} style={{padding:"4px 12px",fontSize:11,fontWeight:700,borderRadius:6,border:"none",cursor:"pointer",background:dbStore===s?"#d97706":"#e2e8f0",color:dbStore===s?"#fff":"#334155"}}>{s==="tkm"?"高松":"札幌"}</button>)}
        </div>
        <div style={{fontSize:11,color:"#64748b",marginBottom:8}}>クラス別 1台あたり月間収益分析（データ期間: {monthCount}ヶ月）</div>
        {dbLoading2?<div style={{padding:24,textAlign:"center",color:"#94a3b8"}}>読込中...</div>:
        <div style={{overflow:"auto",border:"1px solid #e2e8f0",borderRadius:8}}>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
            <thead><tr>
              <th style={th}>項目</th>
              {types.filter(t=>typeStat[t].vehs>0).map(t=><th key={t} style={{...th,textAlign:"right"}}>クラス {t}</th>)}
              <th style={{...th,textAlign:"right",background:"#dbeafe"}}>合計</th>
            </tr></thead>
            <tbody>
              <tr><td style={{...td,fontWeight:700}}>保有台数</td>
                {types.filter(t=>typeStat[t].vehs>0).map(t=><td key={t} style={{...td,textAlign:"right"}}>{typeStat[t].vehs}台</td>)}
                <td style={{...td,textAlign:"right",background:"#eff6ff",fontWeight:700}}>{types.reduce((s,t)=>s+typeStat[t].vehs,0)}台</td>
              </tr>
              <tr><td style={{...td,fontWeight:700}}>売上合計</td>
                {types.filter(t=>typeStat[t].vehs>0).map(t=><td key={t} style={{...td,textAlign:"right"}}>¥{fmt(typeStat[t].rev)}</td>)}
                <td style={{...td,textAlign:"right",background:"#eff6ff",fontWeight:700}}>¥{fmt(types.reduce((s,t)=>s+typeStat[t].rev,0))}</td>
              </tr>
              <tr><td style={{...td,fontWeight:700}}>月平均売上/台</td>
                {types.filter(t=>typeStat[t].vehs>0).map(t=>{
                  const perV=typeStat[t].vehs>0?Math.round(typeStat[t].rev/typeStat[t].vehs/monthCount):0;
                  return <td key={t} style={{...td,textAlign:"right",fontWeight:700,color:"#059669"}}>¥{fmt(perV)}</td>;
                })}
                <td style={{...td,textAlign:"right",background:"#eff6ff"}}>-</td>
              </tr>
              <tr style={{background:"#fefce8"}}><td style={{...td,fontWeight:700}}>原価/台/月</td>
                {types.filter(t=>typeStat[t].vehs>0).map(t=>{
                  const cost=roiCost.insurance+roiCost.parking+roiCost.inspection+roiCost.maintenance;
                  return <td key={t} style={{...td,textAlign:"right"}}>¥{fmt(cost)}</td>;
                })}
                <td style={{...td,textAlign:"right",background:"#eff6ff"}}>-</td>
              </tr>
              <tr style={{fontWeight:800}}><td style={{...td,fontWeight:900,color:"#dc2626"}}>粗利/台/月</td>
                {types.filter(t=>typeStat[t].vehs>0).map(t=>{
                  const perV=typeStat[t].vehs>0?Math.round(typeStat[t].rev/typeStat[t].vehs/monthCount):0;
                  const cost=roiCost.insurance+roiCost.parking+roiCost.inspection+roiCost.maintenance;
                  const profit=perV-cost;
                  return <td key={t} style={{...td,textAlign:"right",fontWeight:800,color:profit>0?"#059669":"#dc2626"}}>¥{fmt(profit)}</td>;
                })}
                <td style={{...td,textAlign:"right",background:"#eff6ff"}}>-</td>
              </tr>
              <tr><td style={{...td,fontWeight:700}}>件数合計</td>
                {types.filter(t=>typeStat[t].vehs>0).map(t=><td key={t} style={{...td,textAlign:"right"}}>{typeStat[t].cnt}件</td>)}
                <td style={{...td,textAlign:"right",background:"#eff6ff",fontWeight:700}}>{types.reduce((s,t)=>s+typeStat[t].cnt,0)}件</td>
              </tr>
            </tbody>
          </table>
          <div style={{padding:8,fontSize:10,color:"#94a3b8"}}>
            原価仮定（1台/月）: 保険¥{fmt(roiCost.insurance)} + 駐車場¥{fmt(roiCost.parking)} + 車検月割¥{fmt(roiCost.inspection)} + 点検月割¥{fmt(roiCost.maintenance)} = ¥{fmt(roiCost.insurance+roiCost.parking+roiCost.inspection+roiCost.maintenance)}
          </div>
        </div>}
      </div>;
    })()}

    {/* --- CFシミュレーター --- */}
    {sub==="patrol"&&(()=>{
      // === パトロール: SS(Google Sheets) ↔ APP(Supabase) 自動比較 ===
      const SS_PUB_BASE="https://docs.google.com/spreadsheets/d/e/2PACX-1vQVK2mRkYMKG3cPtr5HSi9TWSS1JevKOvTmOusvXjoOZOEtW_KTX9oYXQld3FeK3Q/pub";
      const SS_GIDS={
        pl_nha:"1117507661",pl_spk:"609433931",
        cf_nha:"1575364807",cf_spk:"1260007687",
        cost_nha:"1740899330",cost_spk:"658706807",
      };
      const parseSSNum=(s)=>{if(!s||s==="-"||s==="")return 0;return parseInt(String(s).replace(/[",¥\s]/g,""))||0;};
      const parseSSYm=(s)=>{if(!s)return null;const m=String(s).match(/(\d{4})\D+(\d{1,2})/);return m?(m[1]+"-"+m[2].padStart(2,"0")):null;};
      const fetchSSCsv=async(gid)=>{
        const url=SS_PUB_BASE+"?gid="+gid+"&single=true&output=csv";
        const resp=await fetch(url);
        const text=await resp.text();
        // CSV parse (handle quoted fields with commas)
        return text.split("\n").map(line=>{
          const row=[];let inQ=false,cur="";
          for(let i=0;i<line.length;i++){
            const c=line[i];
            if(c==='"'){inQ=!inQ;}
            else if(c===","&&!inQ){row.push(cur);cur="";}
            else{cur+=c;}
          }
          row.push(cur);
          return row;
        });
      };

      const runPatrol=async()=>{
        setPatrolLoading(true);setPatrolResult(null);
        try{
          // 1) PL比較
          const plNhaCsv=await fetchSSCsv(SS_GIDS.pl_nha);
          const plSpkCsv=await fetchSSCsv(SS_GIDS.pl_spk);
          // 2) CF比較
          const cfNhaCsv=await fetchSSCsv(SS_GIDS.cf_nha);
          const cfSpkCsv=await fetchSSCsv(SS_GIDS.cf_spk);
          // 3) コスト比較
          const costNhaCsv=await fetchSSCsv(SS_GIDS.cost_nha);
          const costSpkCsv=await fetchSSCsv(SS_GIDS.cost_spk);

          const results=[];
          const chMap={"オフィシャル":"オフィシャル","じゃらん":"じゃらん","楽天":"楽天","エアトリ":"エアトリ","レンタカードットコム":"レンタカードットコム","スカイチケット":"スカイチケット","その他売上":"その他売上"};

          // --- PL比較 ---
          const comparePL=(csv,storeKey,storeName)=>{
            const hdr=csv[1]||[];
            const ymCols=[];
            for(let c=1;c<hdr.length;c++){const ym=parseSSYm(hdr[c]);if(ym)ymCols.push({c,ym});}
            // SS channels
            for(let r=2;r<csv.length;r++){
              const label=(csv[r][0]||"").trim();
              if(label==="売上合計"||label===""||label.startsWith("▼")||label==="OTA")continue;
              const ch=Object.keys(chMap).find(k=>label.includes(k));
              if(!ch)continue;
              ymCols.forEach(({c,ym})=>{
                const ssVal=parseSSNum(csv[r][c]);
                // APP value from plPivot
                const appKey=ym+"|"+ch;
                const pivot=storeKey==="tkm"?plPivotNha:plPivotSpk;
                const appVal=Math.round((pivot.map[appKey]||{}).rev||0);
                if(ssVal===0&&appVal===0)return;
                const diff=appVal-ssVal;
                if(Math.abs(diff)>1){
                  results.push({section:"PL",store:storeName,month:ym,item:ch,ss:ssVal,app:appVal,diff});
                }
              });
            }
          };

          // --- CF入金比較 ---
          const compareCF=(csv,storeKey,storeName)=>{
            const hdr=csv[1]||[];
            const ymCols=[];
            for(let c=1;c<hdr.length;c++){const ym=parseSSYm(hdr[c]);if(ym)ymCols.push({c,ym});}
            let section="入金";
            for(let r=2;r<csv.length;r++){
              const label=(csv[r][0]||"").trim();
              if(label.includes("▼ 入金"))section="入金";
              if(label.includes("▼ 支出"))section="支出";
              if(label==="入金合計"){
                ymCols.forEach(({c,ym})=>{
                  const ssVal=parseSSNum(csv[r][c]);
                  const pivot=storeKey==="tkm"?cfPivotNha:cfPivotSpk;
                  const appVal=Math.round(pivot.chs.reduce((a,ch)=>a+((pivot.map[ym+"|"+ch]||{}).cash_in||0),0));
                  if(ssVal===0&&appVal===0)return;
                  const diff=appVal-ssVal;
                  if(Math.abs(diff)>1)results.push({section:"CF入金",store:storeName,month:ym,item:"入金合計",ss:ssVal,app:appVal,diff});
                });
                continue;
              }
              if(label==="支出合計"){
                ymCols.forEach(({c,ym})=>{
                  const ssVal=parseSSNum(csv[r][c]);
                  const pivot=storeKey==="tkm"?cfPivotNha:cfPivotSpk;
                  const exp=(pivot.expByYm[ym]||{}).total||0;
                  const appVal=Math.round(exp);
                  if(ssVal===0&&appVal===0)return;
                  const diff=appVal-ssVal;
                  if(Math.abs(diff)>1)results.push({section:"CF支出",store:storeName,month:ym,item:"支出合計",ss:ssVal,app:appVal,diff});
                });
                continue;
              }
              // CF入金チャネル別
              if(section==="入金"){
                const ch=Object.keys(chMap).find(k=>label.includes(k));
                if(!ch)continue;
                ymCols.forEach(({c,ym})=>{
                  const ssVal=parseSSNum(csv[r][c]);
                  const pivot=storeKey==="tkm"?cfPivotNha:cfPivotSpk;
                  const appVal=Math.round((pivot.map[ym+"|"+ch]||{}).cash_in||0);
                  if(ssVal===0&&appVal===0)return;
                  const diff=appVal-ssVal;
                  if(Math.abs(diff)>1)results.push({section:"CF入金",store:storeName,month:ym,item:ch,ss:ssVal,app:appVal,diff});
                });
              }
              // CF支出内訳
              if(section==="支出"){
                const costItem=label.replace(/\s+/g,"");
                const costMap={"返済①":"repay","返済②":"repay","返済③":"repay","返済④":"repay","返済⑤":"repay","販管費":"sga","売上原価":"cogs","車両仕入":"vehicle"};
                const cat=Object.keys(costMap).find(k=>costItem.includes(k));
                if(!cat)continue;
                ymCols.forEach(({c,ym})=>{
                  const ssVal=parseSSNum(csv[r][c]);
                  if(ssVal===0)return;
                  results.push({section:"CF支出明細",store:storeName,month:ym,item:costItem,ss:ssVal,app:null,diff:null,note:"SSのみ（APPコスト入力で入力要）"});
                });
              }
            }
          };

          // --- コスト比較 ---
          const compareCost=(csv,storeKey,storeName)=>{
            const hdr=csv[1]||[];
            const ymCols=[];
            for(let c=1;c<hdr.length;c++){const ym=parseSSYm(hdr[c]);if(ym)ymCols.push({c,ym});}
            // row 2+ = data
            for(let r=2;r<csv.length;r++){
              const label=(csv[r][0]||"").trim();
              if(!label||label.startsWith("月次"))continue;
              const costKey={"道銀/北洋":"repay_1","沖銀":"repay_2","IUR":"repay_3","返済④":"repay_4","LAB":"repay_5","販管費":"sga","売上原価":"cogs","車両仕入":"vehicle_purchase","支出合計（自動）":"total"};
              const k=costKey[label];
              if(!k)continue;
              ymCols.forEach(({c,ym})=>{
                const ssVal=parseSSNum(csv[r][c]);
                // APP value
                const pivot=storeKey==="tkm"?cfPivotNha:cfPivotSpk;
                const exp=pivot.expByYm[ym]||{};
                let appVal=0;
                if(k==="total")appVal=Math.round(exp.total||0);
                else if(k==="sga")appVal=Math.round(exp.sga||0);
                else if(k==="cogs")appVal=Math.round(exp.cogs||0);
                else if(k==="vehicle_purchase")appVal=Math.round(exp.vehicle||0);
                else if(k.startsWith("repay_")){
                  // 個別返済は合算でしか持っていないのでスキップ（合計で比較）
                  return;
                }
                if(ssVal===0&&appVal===0)return;
                const diff=appVal-ssVal;
                if(Math.abs(diff)>1)results.push({section:"コスト",store:storeName,month:ym,item:label,ss:ssVal,app:appVal,diff});
              });
            }
          };

          // Both storesのPL/CFピボットを計算
          // 高松用ピボット
          const buildPivots=(resvs,isSpk,costAll)=>{
            const rdKey=isSpk?"return_date":"end_date";
            const cycleMap={};
            (mgSettings.channels||[]).forEach(c=>{cycleMap[c.name]=c.cycle||0;});
            // PL pivot
            const plMap={};
            const active=resvs.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");
            active.forEach(r=>{
              const rd=r[rdKey];if(!rd)return;
              const ym=rd.slice(0,7);
              const ch=DB_OTA_MAP[r.ota]||"その他売上";
              const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
              const rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
              const key=ym+"|"+ch;
              if(!plMap[key])plMap[key]={rev:0};
              plMap[key].rev+=rev;
            });
            // CF pivot
            const cfMap={};const cfChSet=new Set();const cfYmSet=new Set();
            active.forEach(r=>{
              const rd=r[rdKey];if(!rd)return;
              const ch=DB_OTA_MAP[r.ota]||"その他売上";
              const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
              const rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
              const cycle=cycleMap[ch]||0;
              const[sy,sm]=rd.slice(0,7).split("-").map(Number);
              let ny=sy,nm=sm+cycle;while(nm>12){nm-=12;ny++;}
              const cashYm=ny+"-"+String(nm).padStart(2,"0");
              cfYmSet.add(cashYm);cfChSet.add(ch);
              const key=cashYm+"|"+ch;
              if(!cfMap[key])cfMap[key]={cash_in:0};
              cfMap[key].cash_in+=rev;
            });
            const expByYm={};
            Object.entries(costAll).forEach(([ym,rows])=>{
              if(!rows)return;
              let repay=0,sga=0,cogs=0,vehicle=0;
              rows.forEach(r=>{
                const c=r.account_code||"";const a=r.amount||0;
                if(c.startsWith("repay_"))repay+=a;
                else if(c.startsWith("sga_"))sga+=a;
                else if(c.startsWith("cogs_"))cogs+=a;
                else if(c==="vehicle_purchase")vehicle+=a;
              });
              expByYm[ym]={repay,sga,cogs,vehicle,total:repay+sga+cogs+vehicle};
            });
            const chs=["オフィシャル","じゃらん","楽天","エアトリ","スカイチケット","レンタカードットコム","その他売上"];
            return{plPivot:{map:plMap},cfPivot:{map:cfMap,chs,expByYm}};
          };

          // Load TKM data
          const nhaResvs=await loadDbAll("tkm_reservations");
          // Load TKM costs
          const{data:nhaCostData}=await sb.from("app_settings").select("*").like("key","cost_tkm_%");
          const nhaCosts={};(nhaCostData||[]).forEach(d=>{const ym=d.key.replace("cost_tkm_","");try{nhaCosts[ym]=JSON.parse(d.value);}catch(e){}});
          // Load SPK data
          const spkResvs=await loadDbAll("reservations");
          const{data:spkCostData}=await sb.from("app_settings").select("*").like("key","cost_spk_%");
          const spkCosts={};(spkCostData||[]).forEach(d=>{const ym=d.key.replace("cost_spk_","");try{spkCosts[ym]=JSON.parse(d.value);}catch(e){}});

          const nhaPivots=buildPivots(nhaResvs,false,nhaCosts);
          const spkPivots=buildPivots(spkResvs,true,spkCosts);
          const plPivotNha=nhaPivots.plPivot;
          const plPivotSpk=spkPivots.plPivot;
          const cfPivotNha=nhaPivots.cfPivot;
          const cfPivotSpk=spkPivots.cfPivot;

          comparePL(plNhaCsv,"tkm","高松");
          comparePL(plSpkCsv,"spk","札幌");
          compareCF(cfNhaCsv,"tkm","高松");
          compareCF(cfSpkCsv,"spk","札幌");
          compareCost(costNhaCsv,"tkm","高松");
          compareCost(costSpkCsv,"spk","札幌");

          // Summary
          const matchCount=results.length===0;
          const totalChecks=results.length;
          setPatrolResult({results,ts:new Date().toLocaleString("ja-JP"),nhaCnt:nhaResvs.length,spkCnt:spkResvs.length,nhaCostMonths:Object.keys(nhaCosts).length,spkCostMonths:Object.keys(spkCosts).length});
        }catch(e){
          setPatrolResult({error:e.message,ts:new Date().toLocaleString("ja-JP")});
        }
        setPatrolLoading(false);
      };

      const pr=patrolResult;
      return <div>
        <div style={{fontSize:14,fontWeight:900,marginBottom:8}}>🔍 SS↔APP パトロール</div>
        <div style={{fontSize:10,color:"#64748b",marginBottom:12}}>Google Sheets（手動更新）とAPP計算値を自動比較。差異があればセル単位で表示。</div>
        <div style={{display:"flex",gap:8,alignItems:"center",marginBottom:12}}>
          <button onClick={runPatrol} disabled={patrolLoading} style={{...btn("#059669"),padding:"8px 20px",fontSize:12,opacity:patrolLoading?0.5:1}}>
            {patrolLoading?"🔄 チェック中...":"▶ パトロール実行"}
          </button>
          {pr&&!pr.error&&<span style={{fontSize:11,color:"#64748b"}}>最終実行: {pr.ts} | 高松{pr.nhaCnt}件・札幌{pr.spkCnt}件 | コスト: 高松{pr.nhaCostMonths}ヶ月・札幌{pr.spkCostMonths}ヶ月</span>}
        </div>
        {pr&&pr.error&&<div style={{padding:12,background:"#fef2f2",borderRadius:8,color:"#dc2626",fontSize:11}}>❌ エラー: {pr.error}</div>}
        {pr&&!pr.error&&(()=>{
          const r=pr.results;
          if(r.length===0)return <div style={{padding:24,textAlign:"center",background:"#f0fdf4",borderRadius:12,border:"2px solid #86efac"}}>
            <div style={{fontSize:48,marginBottom:8}}>✅</div>
            <div style={{fontSize:16,fontWeight:900,color:"#059669"}}>完全一致</div>
            <div style={{fontSize:11,color:"#64748b",marginTop:4}}>SS(スプレッドシート)とAPP(Supabase)の全数値が一致しています</div>
          </div>;
          // Group by section
          const sections=["PL","CF入金","CF支出","CF支出明細","コスト"];
          const grouped={};r.forEach(x=>{if(!grouped[x.section])grouped[x.section]=[];grouped[x.section].push(x);});
          const sectionColors={"PL":"#1e40af","CF入金":"#059669","CF支出":"#dc2626","CF支出明細":"#d97706","コスト":"#7c3aed"};
          return <div>
            <div style={{padding:12,background:"#fef3c7",borderRadius:8,marginBottom:12,border:"1px solid #fbbf24"}}>
              <span style={{fontSize:14,fontWeight:900,color:"#92400e"}}>⚠️ {r.length}件の差異を検出</span>
              <span style={{fontSize:10,color:"#92400e",marginLeft:8}}>— SSを正としてAPPを修正するか、SSの入力ミスか確認してください</span>
            </div>
            {sections.map(sec=>{
              const items=grouped[sec];if(!items||items.length===0)return null;
              return <div key={sec} style={{marginBottom:16}}>
                <div style={{fontSize:12,fontWeight:900,color:sectionColors[sec]||"#334155",marginBottom:6,padding:"4px 8px",background:"#f8fafc",borderRadius:4,borderLeft:"3px solid "+(sectionColors[sec]||"#334155")}}>{sec}（{items.length}件）</div>
                <div style={{overflow:"auto",border:"1px solid #e2e8f0",borderRadius:8}}>
                  <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
                    <thead><tr>
                      <th style={th}>店舗</th><th style={th}>月</th><th style={th}>項目</th>
                      <th style={{...th,textAlign:"right",background:"#dbeafe"}}>SS値</th>
                      <th style={{...th,textAlign:"right",background:"#dcfce7"}}>APP値</th>
                      <th style={{...th,textAlign:"right",background:"#fef3c7"}}>差額</th>
                      <th style={th}>備考</th>
                    </tr></thead>
                    <tbody>{items.sort((a,b)=>(b.month||"").localeCompare(a.month||"")||a.item.localeCompare(b.item)).map((x,i)=>{
                      const diffPct=x.ss>0?Math.round(Math.abs(x.diff||0)/x.ss*100):0;
                      return <tr key={i} style={{background:i%2===0?"#fff":"#f8fafc"}}>
                        <td style={{...td,fontWeight:700}}>{x.store}</td>
                        <td style={td}>{x.month}</td>
                        <td style={td}>{x.item}</td>
                        <td style={{...td,textAlign:"right",color:"#1e40af"}}>¥{fmt(x.ss)}</td>
                        <td style={{...td,textAlign:"right",color:x.app!==null?"#059669":"#94a3b8"}}>{x.app!==null?"¥"+fmt(x.app):"-"}</td>
                        <td style={{...td,textAlign:"right",fontWeight:700,color:(x.diff||0)>0?"#059669":"#dc2626"}}>{x.diff!==null?(x.diff>0?"+":"")+fmt(x.diff):"-"}{diffPct>0?" ("+diffPct+"%)":""}</td>
                        <td style={{...td,fontSize:9,color:"#64748b"}}>{x.note||""}</td>
                      </tr>;
                    })}</tbody>
                  </table>
                </div>
              </div>;
            })}
          </div>;
        })()}
      </div>;
    })()}

    {sub==="analytics"&&(()=>{
      const RELIABLE_FROM="2026-04";
      const isSpk=dbStore==="spk";
      const rdKey=isSpk?"return_date":"end_date";
      const ldKey=isSpk?"lend_date":"start_date";

      // --- Shared maps ---
      const fMap={};dbFleet.forEach(f=>{fMap[f.reservation_id]=f.vehicle_code;});
      const vMap={};dbVehs.forEach(v=>{vMap[v.code]=v;});
      const kpiF={};dbKpi.forEach(k=>{if(!kpiF[k.year_month])kpiF[k.year_month]={};kpiF[k.year_month][k.vehicle_code]=k.active;});

      const active=dbResvs.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");
      const reliable=active.filter(r=>{const rd=r[rdKey];return rd&&rd.slice(0,7)>=RELIABLE_FROM;});

      const revCalc=(r)=>{const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;return(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);};

      // --- Month aggregation ---
      const mAgg={};
      reliable.forEach(r=>{
        const rd=r[rdKey];if(!rd)return;
        const ym=rd.slice(0,7);
        if(!mAgg[ym])mAgg[ym]={resvs:[],rev:0,cnt:0,daySum:0,otaRev:{},otaCnt:{},vtRev:{},vtCnt:{},createdInMonth:0,createdBeforeMonth:0,oneDay:0,prefCnt:{}};
        const m=mAgg[ym];
        const rev=revCalc(r);
        m.resvs.push(r);m.rev+=rev;m.cnt+=1;
        // days
        const ld=r[ldKey],rd2=r[rdKey];
        if(ld&&rd2){const days=Math.max(1,Math.round((new Date(rd2.slice(0,10))-new Date(ld.slice(0,10)))/(86400000)));m.daySum+=days;
          if(ld.slice(0,10)===rd2.slice(0,10))m.oneDay+=1;
        }
        // ota
        const ch=DB_OTA_MAP[r.ota]||"その他売上";
        m.otaRev[ch]=(m.otaRev[ch]||0)+rev;m.otaCnt[ch]=(m.otaCnt[ch]||0)+1;
        // veh type
        const vc=fMap[r.id];const vObj=vc?vMap[vc]:null;
        let vType="?";
        if(vObj)vType=vObj.type||"?";
        else if(isSpk&&r.vehicle)vType=r.vehicle;
        else if(!isSpk&&r.vehicle_class)vType=r.vehicle_class;
        if(vType&&vType!=="?"){m.vtRev[vType]=(m.vtRev[vType]||0)+rev;m.vtCnt[vType]=(m.vtCnt[vType]||0)+1;}
        // lead time & created-in-month
        if(r.created_at){
          const caYm=r.created_at.slice(0,7);
          if(caYm===ym)m.createdInMonth+=1;
          const monthFirst=ym+"-01";
          if(r.created_at.slice(0,10)<monthFirst)m.createdBeforeMonth+=1;
        }
        // prefecture
        if(r.prefecture){const p=r.prefecture;m.prefCnt[p]=(m.prefCnt[p]||0)+1;}
      });

      // lead time by month
      const leadByM={};
      reliable.forEach(r=>{
        const rd=r[rdKey],ld=r[ldKey];if(!rd||!ld||!r.created_at)return;
        const ym=rd.slice(0,7);
        const lt=Math.max(0,Math.round((new Date(ld.slice(0,10))-new Date(r.created_at.slice(0,10)))/(86400000)));
        if(!leadByM[ym])leadByM[ym]=[];
        leadByM[ym].push(lt);
      });
      const median=(arr)=>{if(!arr||arr.length===0)return 0;const s=[...arr].sort((a,b)=>a-b);const mid=Math.floor(s.length/2);return s.length%2?s[mid]:Math.round((s[mid-1]+s[mid])/2);};

      // utilization per month (same logic as dbMetrics)
      const utilByM={};
      const ymList=Object.keys(mAgg).sort();
      ymList.forEach(ym=>{
        const[y,mo]=[parseInt(ym.split("-")[0]),parseInt(ym.split("-")[1])];
        const dim=new Date(y,mo,0).getDate();
        const kf=kpiF[ym]||{};
        const activeVehs=dbVehs.filter(v=>{const c=v.code;if(kf[c]!==undefined)return kf[c];return v.active!==false;});
        const vehDays={};
        reliable.forEach(r=>{
          const ld=r[ldKey],rd2=r[rdKey];if(!ld||!rd2)return;
          const vc=fMap[r.id];if(!vc)return;
          if(!activeVehs.find(v=>v.code===vc))return;
          const ms2=new Date(y,mo-1,1),me2=new Date(y,mo-1,dim);
          let s=new Date(ld.slice(0,10)),e=new Date(rd2.slice(0,10));
          if(s<ms2)s=ms2;if(e>me2)e=me2;if(s>e)return;
          if(!vehDays[vc])vehDays[vc]=new Set();
          for(let d=new Date(s);d<=e;d.setDate(d.getDate()+1))vehDays[vc].add(d.toISOString().slice(0,10));
        });
        let totalDays=0;Object.values(vehDays).forEach(s2=>{totalDays+=s2.size;});
        const vtUtil={};
        DB_VEH_TYPES.forEach(t=>{
          const tv=activeVehs.filter(v=>(v.type||"")==t);if(tv.length===0)return;
          let tD=0;tv.forEach(v=>{if(vehDays[v.code])tD+=vehDays[v.code].size;});
          vtUtil[t]=tv.length*dim>0?Math.round(tD/(tv.length*dim)*1000)/10:0;
        });
        // per-vehicle util
        const perVeh={};
        activeVehs.forEach(v=>{
          const ds=vehDays[v.code]?vehDays[v.code].size:0;
          perVeh[v.code]={days:ds,pct:dim>0?Math.round(ds/dim*1000)/10:0,name:v.name||v.code,type:v.type||"?"};
        });
        utilByM[ym]={activeCount:activeVehs.length,dim,totalDays,maxDays:activeVehs.length*dim,pct:activeVehs.length*dim>0?Math.round(totalDays/(activeVehs.length*dim)*100):0,vtUtil,perVeh,vehDays};
      });

      // year aggregation
      const yearAgg={};
      ymList.forEach(ym=>{
        const yr=ym.slice(0,4);
        if(!yearAgg[yr])yearAgg[yr]={rev:0,cnt:0,daySum:0,leadTimes:[],createdInMonth:0,createdBeforeMonth:0,oneDay:0,totalDays:0,maxDays:0};
        const ya=yearAgg[yr],m=mAgg[ym],u=utilByM[ym]||{};
        ya.rev+=m.rev;ya.cnt+=m.cnt;ya.daySum+=m.daySum;ya.oneDay+=m.oneDay;
        ya.createdInMonth+=m.createdInMonth;ya.createdBeforeMonth+=m.createdBeforeMonth;
        ya.totalDays+=(u.totalDays||0);ya.maxDays+=(u.maxDays||0);
        if(leadByM[ym])ya.leadTimes=ya.leadTimes.concat(leadByM[ym]);
      });
      const yrList=Object.keys(yearAgg).sort();

      // current month tasks for time analysis
      const taskTimeBuckets={DEL:{},COL:{}};
      dbTasks.forEach(tk=>{
        if(!tk.time||!tk.type)return;
        const hh=tk.time.slice(0,2);
        const bucket=hh+":00";
        if(tk.type==="DEL"){taskTimeBuckets.DEL[bucket]=(taskTimeBuckets.DEL[bucket]||0)+1;}
        if(tk.type==="COL"){taskTimeBuckets.COL[bucket]=(taskTimeBuckets.COL[bucket]||0)+1;}
      });

      // delivery place ranking
      const delPlaces={},colPlaces={};
      reliable.forEach(r=>{
        if(r.del_place){const p=r.del_place.trim();if(p)delPlaces[p]=(delPlaces[p]||0)+1;}
        if(r.col_place){const p=r.col_place.trim();if(p)colPlaces[p]=(colPlaces[p]||0)+1;}
      });
      const delRank=Object.entries(delPlaces).sort((a,b)=>b[1]-a[1]).slice(0,20);
      const colRank=Object.entries(colPlaces).sort((a,b)=>b[1]-a[1]).slice(0,20);

      // prefecture ranking
      const allPrefCnt={};
      reliable.forEach(r=>{if(r.prefecture){const p=r.prefecture;allPrefCnt[p]=(allPrefCnt[p]||0)+1;}});
      const prefRank=Object.entries(allPrefCnt).sort((a,b)=>b[1]-a[1]).slice(0,20);

      // current month
      const nowYm=(()=>{const d=new Date();return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0");})();

      // Collapsible section header (redesigned with colored left border)
      const secColors={A:"#3b82f6",B:"#059669",C:"#d97706",D:"#8b5cf6"};
      const secHeader=(key,label)=>React.createElement("div",{onClick:()=>toggleSec(key),style:{cursor:"pointer",display:"flex",alignItems:"center",gap:10,padding:"10px 14px",marginBottom:10,marginTop:key==="A"?0:20,background:"#fff",borderRadius:10,borderLeft:"4px solid "+(secColors[key]||"#3b82f6"),boxShadow:"0 1px 3px rgba(0,0,0,0.06)"}},
        React.createElement("span",{style:{fontSize:14,color:secColors[key]||"#3b82f6",fontWeight:900,width:20}},secOpen[key]?"\u25BC":"\u25B6"),
        React.createElement("span",{style:{fontSize:15,fontWeight:900,color:"#0f172a",flex:1}},label),
        React.createElement("span",{style:{fontSize:10,color:"#94a3b8",fontWeight:600}},secOpen[key]?"閉じる":"開く")
      );

      // bar helper (inline horizontal bar, wider)
      const bar=(pct,color)=>React.createElement("div",{style:{display:"flex",alignItems:"center",gap:6}},
        React.createElement("div",{style:{width:100,height:12,background:"#f1f5f9",borderRadius:6,overflow:"hidden"}},
